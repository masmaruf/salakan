---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import PageSection from '../components/PageSection.astro';
import InfoCard from '../components/ui/InfoCard.astro';
import ActionLinkButton from '../components/ui/ActionLinkButton.astro';
import { getProfil, getPengaturan } from '../lib/content';

const profil = await getProfil();
const pengaturan = await getPengaturan();
const heroImg = profil?.hero?.gambar;
const lokasi = profil?.lokasi;
const potensi = profil?.potensiDesa ?? [];

import Icon from '../components/ui/Icon.tsx';
---

<MainLayout title="Profil | Padukuhan Salakan" description="Profil, visi misi, potensi desa, dan data wilayah Padukuhan Salakan.">

  <PageHero
    eyebrow={profil?.hero?.badge}
    icon="diamond"
    title={profil?.hero?.judul || profil?.namaPadukuhan || 'Padukuhan Salakan'}
    sectionClass="bg-slate-900"
    containerClass="container-premium relative z-10 flex min-h-[280px] flex-col justify-end px-5 pb-8 pt-20 sm:min-h-[340px] sm:px-8 md:min-h-[400px]"
    contentClass="max-w-lg"
    titleClass="max-w-lg text-2xl font-bold leading-[1.15] tracking-tight text-white sm:text-3xl md:text-4xl"
    badgeClass="mb-3 inline-flex items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-white/90 backdrop-blur-sm"
    badgeTextClass="text-[11px] font-bold uppercase tracking-[0.12em] text-white/90"
    badgeIconClass="text-[14px]"
    backgroundImage={heroImg}
    overlayClass="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-slate-900/20"
    orbs={[]}
  />

  <PageSection eyebrow={profil?.sejarahLabel || 'Kisah Kami'} title={profil?.sejarahJudul || 'Sejarah & Filosofi'} sectionClass="relative overflow-hidden py-10 sm:py-14">
    <div class="prose-profil max-w-none whitespace-pre-line text-[15px] leading-[1.8] text-on-surface-variant lg:max-w-3xl">
      {profil?.sejarahSingkat}
    </div>

    <div class="mt-8 rounded-xl border-l-4 border-m3-primary bg-surface-container-low/60 p-5 sm:p-6">
      <div class="mb-2 flex items-center gap-2">
        <Icon name="visibility" class="text-[20px] text-m3-primary" />
        <h3 class="text-base font-bold text-on-surface">Visi</h3>
      </div>
      <p class="text-[15px] italic leading-relaxed text-on-surface-variant">
        "{profil?.visi}"
      </p>
    </div>

    <div class="mt-6">
      <h3 class="mb-4 text-base font-bold text-on-surface">Misi</h3>
      <ul class="space-y-3">
        {profil?.misi?.map((item) => (
          <li class="flex items-start gap-3">
            <Icon name="check_circle" class="mt-0.5 shrink-0 text-[20px] text-m3-primary" />
            <span class="text-[15px] leading-relaxed text-on-surface-variant">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </PageSection>

  {potensi.length > 0 && (
    <PageSection eyebrow="Keunggulan Lokal" title="Potensi Desa" sectionClass="bg-surface-container-low/40 py-10 sm:py-14">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {potensi.map((item, i) => (
          <div class:list={[
            'rounded-xl border p-6 transition-all hover:-translate-y-0.5 hover:shadow-md',
            i === 0
              ? 'border-m3-primary bg-m3-primary text-white sm:col-span-2 lg:col-span-1'
              : 'border-outline-variant bg-surface-container-lowest',
          ]}>
            <div class:list={[
              'mb-4 grid h-12 w-12 place-items-center rounded-xl',
              i === 0 ? 'bg-white/20' : 'bg-primary-container/30',
            ]}>
              <Icon name={item.ikon} class={['text-[24px]', i === 0 ? 'text-white' : 'text-m3-primary'].join(' ')} />
            </div>
            <h3 class:list={['mb-2 text-lg font-bold', i === 0 ? 'text-white' : 'text-on-surface']}>{item.judul}</h3>
            <p class:list={['text-sm leading-relaxed', i === 0 ? 'text-white/80' : 'text-on-surface-variant']}>{item.deskripsi}</p>
          </div>
        ))}
      </div>
    </PageSection>
  )}

  {profil?.dataWilayah && profil.dataWilayah.length > 0 && (
    <PageSection eyebrow="Statistik" title="Data Wilayah">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
        {profil.dataWilayah.map((item) => (
          <InfoCard class="rounded-xl border border-outline-variant bg-surface-container-lowest p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)]">
            <p class="text-xl font-bold leading-tight text-m3-primary sm:text-2xl">{item.value}</p>
            <p class="mt-1.5 text-[12px] font-medium text-on-surface-variant">{item.label}</p>
          </InfoCard>
        ))}
      </div>
    </PageSection>
  )}

  {(lokasi?.alamat || lokasi?.gambarPeta) && (
    <PageSection eyebrow="Lokasi" title="Temukan Kami" sectionClass="bg-surface-container-low/40 py-10 sm:py-14">
      <div class="relative overflow-hidden rounded-xl border border-outline-variant">
        {lokasi?.gambarPeta ? (
          <img
            src={lokasi.gambarPeta}
            alt="Peta lokasi Padukuhan Salakan"
            class="h-[240px] w-full object-cover sm:h-[300px] md:h-[360px]"
          />
        ) : (
          <div class="flex h-[240px] w-full items-center justify-center bg-surface-container-high sm:h-[300px] md:h-[360px]">
            <Icon name="map" class="text-[48px] text-outline" />
          </div>
        )}

        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-900/80 to-transparent p-5 sm:p-6">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div class="text-white">
              <div class="mb-1 flex items-center gap-1.5">
                <Icon name="location_on" class="text-[16px]" />
                <span class="text-xs font-bold uppercase tracking-wider text-white/80">Alamat</span>
              </div>
              <p class="max-w-md text-sm leading-relaxed">{lokasi?.alamat}</p>
            </div>
            {lokasi?.linkPeta && (
              <ActionLinkButton href={lokasi.linkPeta} label="Buka Peta" icon="open_in_new" target="_blank" rel="noopener noreferrer" class="w-full justify-center bg-white text-slate-900 shadow-lg sm:w-auto sm:justify-start" />
            )}
          </div>
        </div>
      </div>
    </PageSection>
  )}

</MainLayout>
