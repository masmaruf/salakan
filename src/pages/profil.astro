---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getProfil } from '../lib/keystatic';

const profil = await getProfil();
---

<MainLayout title="Profil | Padukuhan Salakan" description="Profil, visi misi, dan data wilayah Padukuhan Salakan.">
  <section class="section relative overflow-hidden bg-slate-50 min-h-screen">
    {/* Ornamen Grafis (Glowing Orbs) */}
    <div class="absolute -top-32 left-32 h-[500px] w-[500px] rounded-full bg-blue-300/20 blur-[100px] pointer-events-none"></div>
    <div class="absolute top-1/2 right-10 h-[600px] w-[600px] -translate-y-1/2 rounded-full bg-emerald-200/20 blur-[120px] pointer-events-none"></div>

    <div class="container relative z-10 py-12 md:py-20">
      <div class="text-center mb-16">
      <SectionHeading
        center
        title={profil?.namaPadukuhan ?? 'Padukuhan Salakan'}
        description={profil?.tagline ?? 'Profil padukuhan dan arah pengembangan wilayah.'}
      />
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <article class="group relative flex flex-col gap-5 rounded-[2.5rem] bg-white/70 backdrop-blur-2xl p-8 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all hover:shadow-[0_20px_40px_rgb(0,0,0,0.06)] hover:-translate-y-1">
          <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-8xl">history_edu</span>
          </div>
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-100 to-white text-blue-600 shadow-sm transition group-hover:bg-blue-600 group-hover:text-white">
            <span class="material-symbols-outlined text-[28px]">history_edu</span>
          </div>
          <div class="relative z-10 mt-2 space-y-3">
            <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Sejarah Singkat</h2>
            <p class="text-base leading-relaxed text-slate-600 md:text-lg">{profil?.sejarahSingkat}</p>
          </div>
        </article>

        <article class="group relative flex flex-col gap-5 rounded-[2.5rem] bg-white/70 backdrop-blur-2xl p-8 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all hover:shadow-[0_20px_40px_rgb(0,0,0,0.06)] hover:-translate-y-1">
          <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-8xl">visibility</span>
          </div>
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-100 to-white text-emerald-600 shadow-sm transition group-hover:bg-emerald-600 group-hover:text-white">
            <span class="material-symbols-outlined text-[28px]">visibility</span>
          </div>
          <div class="relative z-10 mt-2 space-y-3">
            <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Visi</h2>
            <p class="text-base leading-relaxed text-slate-600 md:text-lg">{profil?.visi}</p>
          </div>
        </article>
      </div>

      <div class="mt-6 grid gap-6 lg:grid-cols-2">
        <article class="group relative flex flex-col gap-5 rounded-[2.5rem] bg-white/70 backdrop-blur-2xl p-8 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all hover:shadow-[0_20px_40px_rgb(0,0,0,0.06)] hover:-translate-y-1">
          <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-8xl">explore</span>
          </div>
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-100 to-white text-amber-600 shadow-sm transition group-hover:bg-amber-600 group-hover:text-white">
            <span class="material-symbols-outlined text-[28px]">explore</span>
          </div>
          <div class="relative z-10 mt-2 space-y-3">
            <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Misi</h2>
            <ul class="list-none space-y-4 text-base leading-relaxed text-slate-600 md:text-lg">
              {profil?.misi?.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="material-symbols-outlined mt-1 text-amber-500 text-[20px]">check_circle</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>

        <article class="group relative flex flex-col gap-5 rounded-[2.5rem] bg-white/70 backdrop-blur-2xl p-8 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all hover:shadow-[0_20px_40px_rgb(0,0,0,0.06)] hover:-translate-y-1">
          <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-8xl">analytics</span>
          </div>
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-100 to-white text-indigo-600 shadow-sm transition group-hover:bg-indigo-600 group-hover:text-white">
            <span class="material-symbols-outlined text-[28px]">analytics</span>
          </div>
          <div class="relative z-10 mt-2 space-y-4">
            <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Data Wilayah</h2>
            <div class="grid gap-4 sm:grid-cols-2">
              {profil?.dataWilayah?.map((item) => (
                <div class="rounded-2xl bg-white p-5 shadow-[0_2px_15px_rgb(0,0,0,0.02)] transition hover:shadow-md">
                  <strong class="block text-3xl font-black tracking-tight text-indigo-600">{item.value}</strong>
                  <span class="mt-2 block text-sm font-bold text-slate-400 uppercase tracking-widest">{item.label}</span>
                </div>
              ))}
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</MainLayout>
