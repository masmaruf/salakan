---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PageSection from '../components/PageSection.astro';
import InfoCard from '../components/ui/InfoCard.astro';
import ActionLinkButton from '../components/ui/ActionLinkButton.astro';
import { getHalamanCopy, getMonografi, getPengaturan, getProfil } from '../lib/content';
import { getMonografiSummary } from '../lib/monografi-summary';
import { resolveMapEmbedSrc } from '../lib/maps';
import { renderMarkdown } from '../lib/rich-text';

const profil = await getProfil();
const pengaturan = await getPengaturan();
const halaman = await getHalamanCopy();
const monografi = await getMonografi();
const heroImg = profil?.hero?.gambar;
const lokasi = profil?.lokasi;
const potensi = profil?.potensiDesa ?? [];
const monografiSummary = getMonografiSummary(monografi);
const dataWilayah = profil?.dataWilayah?.length
  ? profil.dataWilayah
  : [
      { label: 'Total Jiwa', value: String(monografiSummary.totalJiwa) },
      { label: 'Total KK', value: String(monografiSummary.totalKK) },
      { label: 'Jumlah RT', value: String(monografiSummary.jumlahRT) },
    ];
const mapEmbedSrc = resolveMapEmbedSrc({
  embedHtml: pengaturan?.embedPetaHtml,
  fallbackUrl: pengaturan?.linkPeta,
});

import Icon from '../components/ui/Icon.tsx';
---

<MainLayout title={halaman.profil.layoutTitle} description={halaman.profil.layoutDescription}>

  <PageHero
    eyebrow={profil?.hero?.badge}
    icon="diamond"
    title={profil?.hero?.judul || profil?.namaPadukuhan || 'Padukuhan Salakan'}
    sectionClass="bg-slate-900"
    containerClass="container-premium relative z-10 flex min-h-[280px] flex-col justify-end px-5 pb-8 pt-20 sm:min-h-[340px] sm:px-8 md:min-h-[400px]"
    contentClass="max-w-lg"
    titleClass="max-w-lg text-2xl font-bold leading-[1.15] tracking-tight text-white sm:text-3xl md:text-4xl"
    badgeClass="mb-3 inline-flex items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-white/90 backdrop-blur-sm"
    badgeTextClass="text-[11px] font-bold uppercase tracking-[0.12em] text-white/90"
    badgeIconClass="text-[14px]"
    backgroundImage={heroImg}
    overlayClass="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-slate-900/20"
    orbs={[]}
  />

  <section class="container-premium pt-4 pb-2">
    <Breadcrumb items={[
      { name: 'Beranda', href: '/' },
      { name: 'Profil' },
    ]} />
  </section>

  <PageSection eyebrow={profil?.sejarahLabel || halaman.profil.storyEyebrow} title={profil?.sejarahJudul || halaman.profil.storyTitle} sectionClass="relative overflow-hidden py-10 sm:py-14">
    <div class="article-rich prose-profil max-w-none text-[15px] leading-[1.8] text-on-surface-variant lg:max-w-3xl" set:html={renderMarkdown(profil?.sejarahSingkat)} />

    <div class="callout-panel mt-8">
      <div class="mb-2 flex items-center gap-2">
        <Icon name="visibility" class="text-[20px] text-m3-primary" />
        <h3 class="text-base font-bold text-on-surface">{halaman.profil.visionTitle}</h3>
      </div>
      <div class="article-rich text-[15px] italic leading-relaxed text-on-surface-variant" set:html={renderMarkdown(profil?.visi)} />
    </div>

    <div class="mt-6">
      <h3 class="mb-4 text-base font-bold text-on-surface">{halaman.profil.missionTitle}</h3>
      <ul class="space-y-3">
        {profil?.misi?.map((item) => (
          <li class="flex items-start gap-3">
            <Icon name="check_circle" class="mt-0.5 shrink-0 text-[20px] text-m3-primary" />
            <span class="text-[15px] leading-relaxed text-on-surface-variant">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </PageSection>

  {potensi.length > 0 && (
    <PageSection eyebrow={halaman.profil.potentialEyebrow} title={halaman.profil.potentialTitle} sectionClass="bg-surface-container-low/40 py-10 sm:py-14">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {potensi.map((item, i) => (
          <div class:list={[
            'rounded-xl border p-6 transition-all hover:-translate-y-0.5 hover:shadow-md',
            i === 0
              ? 'border-m3-primary bg-m3-primary text-white sm:col-span-2 lg:col-span-1'
              : 'border-outline-variant bg-surface-container-lowest',
          ]}>
            <div class:list={[
              'mb-4 grid h-12 w-12 place-items-center rounded-xl',
              i === 0 ? 'bg-white/20' : 'bg-primary-container/30',
            ]}>
              <Icon name={item.ikon} class={['text-[24px]', i === 0 ? 'text-white' : 'text-m3-primary'].join(' ')} />
            </div>
            <h3 class:list={['mb-2 text-lg font-bold', i === 0 ? 'text-white' : 'text-on-surface']}>{item.judul}</h3>
            <p class:list={['text-sm leading-relaxed', i === 0 ? 'text-white/80' : 'text-on-surface-variant']}>{item.deskripsi}</p>
          </div>
        ))}
      </div>
    </PageSection>
  )}

  {dataWilayah.length > 0 && (
    <PageSection eyebrow={halaman.profil.statsEyebrow} title={halaman.profil.statsTitle}>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
        {dataWilayah.map((item) => (
          <InfoCard>
            <p class="text-xl font-bold leading-tight text-m3-primary sm:text-2xl">{item.value}</p>
            <p class="mt-1.5 text-[12px] font-medium text-on-surface-variant">{item.label}</p>
          </InfoCard>
        ))}
      </div>
    </PageSection>
  )}

  {(mapEmbedSrc || lokasi?.alamat || lokasi?.linkPeta) && (
    <PageSection eyebrow={halaman.profil.locationEyebrow} title={halaman.profil.locationTitle} sectionClass="bg-surface-container-low/40 py-10 sm:py-14">
      <div class="space-y-5">
        {(lokasi?.alamat || lokasi?.linkPeta) && (
          <div class="section-card flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="min-w-0">
              <div class="mb-1 flex items-center gap-1.5">
                <Icon name="location_on" class="text-[16px] text-m3-primary" />
                <span class="section-kicker-muted">{halaman.profil.addressLabel}</span>
              </div>
              <p class="text-sm leading-relaxed text-on-surface">{lokasi?.alamat}</p>
            </div>
            {lokasi?.linkPeta && (
              <ActionLinkButton href={lokasi.linkPeta} label={halaman.profil.openMapLabel} icon="open_in_new" target="_blank" rel="noopener noreferrer" class="w-full justify-center sm:w-auto sm:justify-start" />
            )}
          </div>
        )}

        <div class="media-frame">
          {mapEmbedSrc ? (
            <iframe
              title="Peta Padukuhan Salakan"
              src={mapEmbedSrc}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="h-full w-full min-h-[360px] border-none md:min-h-[460px]"
            />
          ) : (
            <div class="flex min-h-[360px] flex-col items-center justify-center p-8 text-center">
              <Icon name="wrong_location" class="mb-4 text-[48px] text-outline" />
              <p class="text-base font-bold text-on-surface">{halaman.profil.mapEmptyTitle}</p>
              <p class="mt-2 max-w-xs text-sm text-on-surface-variant">
                {halaman.profil.mapEmptyDescription}
              </p>
            </div>
          )}
        </div>
      </div>
    </PageSection>
  )}

</MainLayout>
