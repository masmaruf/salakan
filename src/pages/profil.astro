---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getProfil } from '../lib/keystatic';

const profil = await getProfil();
---

<MainLayout title="Profil | Padukuhan Salakan" description="Profil, visi misi, dan data wilayah Padukuhan Salakan.">
  <section class="section-premium bg-slate-50">
    <div class="container-premium relative z-10">
      <div class="text-center mb-16">
        <SectionHeading
          center
          title={profil?.namaPadukuhan ?? 'Padukuhan Salakan'}
          description={profil?.tagline ?? 'Profil padukuhan dan arah pengembangan wilayah.'}
        />
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <article class="group card-premium flex flex-col gap-6">
          <div class="absolute top-6 right-6 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-[100px] text-blue-600">history_edu</span>
          </div>
          <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-50 text-blue-600 shadow-inner group-hover:bg-blue-600 group-hover:text-white transition-all border border-blue-100">
            <span class="material-symbols-outlined text-[32px]">history_edu</span>
          </div>
          <div class="relative z-10 space-y-4">
            <h2 class="text-3xl font-black tracking-tight text-slate-900">Sejarah Singkat</h2>
            <p class="text-lg font-medium leading-relaxed text-slate-500">{profil?.sejarahSingkat}</p>
          </div>
        </article>

        <article class="group card-premium flex flex-col gap-6">
          <div class="absolute top-6 right-6 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-[100px] text-emerald-600">visibility</span>
          </div>
          <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600 shadow-inner group-hover:bg-emerald-600 group-hover:text-white transition-all border border-emerald-100">
            <span class="material-symbols-outlined text-[32px]">visibility</span>
          </div>
          <div class="relative z-10 space-y-4">
            <h2 class="text-3xl font-black tracking-tight text-slate-900">Visi</h2>
            <p class="text-lg font-medium leading-relaxed text-slate-500">{profil?.visi}</p>
          </div>
        </article>
      </div>

      <div class="mt-8 grid gap-8 lg:grid-cols-2">
        <article class="group card-premium flex flex-col gap-6">
          <div class="absolute top-6 right-6 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-[100px] text-amber-600">explore</span>
          </div>
          <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-2xl bg-amber-50 text-amber-600 shadow-inner group-hover:bg-amber-600 group-hover:text-white transition-all border border-amber-100">
            <span class="material-symbols-outlined text-[32px]">explore</span>
          </div>
          <div class="relative z-10 space-y-4">
            <h2 class="text-3xl font-black tracking-tight text-slate-900">Misi</h2>
            <ul class="list-none space-y-5 text-lg font-medium text-slate-500">
              {profil?.misi?.map((item) => (
                <li class="flex items-start gap-4">
                  <span class="material-symbols-outlined mt-1 text-amber-500 text-[24px]">check_circle</span>
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>

        <article class="group card-premium flex flex-col gap-6">
          <div class="absolute top-6 right-6 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-[100px] text-indigo-600">analytics</span>
          </div>
          <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600 shadow-inner group-hover:bg-indigo-600 group-hover:text-white transition-all border border-indigo-100">
            <span class="material-symbols-outlined text-[32px]">analytics</span>
          </div>
          <div class="relative z-10 space-y-6">
            <h2 class="text-3xl font-black tracking-tight text-slate-900">Data Wilayah</h2>
            <div class="grid gap-5 sm:grid-cols-2">
              {profil?.dataWilayah?.map((item) => (
                <div class="rounded-2xl bg-slate-50/50 p-6 border border-slate-100 transition hover:bg-white hover:shadow-xl hover:-translate-y-1">
                  <strong class="block text-4xl font-black tracking-tighter text-indigo-600">{item.value}</strong>
                  <span class="mt-2 block text-label">{item.label}</span>
                </div>
              ))}
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</MainLayout>
