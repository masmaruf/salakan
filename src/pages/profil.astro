---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getProfil } from '../lib/keystatic';

const profil = await getProfil();
---

<MainLayout title="Profil | Padukuhan Salakan" description="Profil, visi misi, dan data wilayah Padukuhan Salakan.">
  <section class="section">
    <div class="container">
      <SectionHeading
        title={profil?.namaPadukuhan ?? 'Padukuhan Salakan'}
        description={profil?.tagline ?? 'Profil padukuhan dan arah pengembangan wilayah.'}
      />

      <div class="grid gap-4 lg:grid-cols-2">
        <article class="surface-card flex flex-col gap-4 p-5 md:p-6">
          <span class="badge badge-primary badge-outline w-fit">Sejarah</span>
          <h2 class="text-2xl font-bold tracking-tight text-slate-950">Sejarah singkat</h2>
          <p class="text-sm leading-8 text-slate-600 md:text-base">{profil?.sejarahSingkat}</p>
        </article>
        <article class="surface-card flex flex-col gap-4 p-5 md:p-6">
          <span class="badge badge-primary badge-outline w-fit">Visi</span>
          <h2 class="text-2xl font-bold tracking-tight text-slate-950">Visi</h2>
          <p class="text-sm leading-8 text-slate-600 md:text-base">{profil?.visi}</p>
        </article>
      </div>

      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <article class="surface-card flex flex-col gap-4 p-5 md:p-6">
          <span class="badge badge-primary badge-outline w-fit">Misi</span>
          <h2 class="text-2xl font-bold tracking-tight text-slate-950">Misi</h2>
          <ul class="list-disc space-y-2 pl-5 text-sm leading-8 text-slate-600 md:text-base">
            {profil?.misi?.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="surface-card flex flex-col gap-4 p-5 md:p-6">
          <span class="badge badge-primary badge-outline w-fit">Data wilayah</span>
          <h2 class="text-2xl font-bold tracking-tight text-slate-950">Data wilayah</h2>
          <div class="grid gap-3">
            {profil?.dataWilayah?.map((item) => (
              <div class="rounded-[20px] border border-slate-200 bg-white px-4 py-4 shadow-sm">
                <strong class="block text-lg font-extrabold tracking-tight text-slate-950">{item.value}</strong>
                <span class="mt-1 block text-sm text-slate-500">{item.label}</span>
              </div>
            ))}
          </div>
        </article>
      </div>
    </div>
  </section>
</MainLayout>
