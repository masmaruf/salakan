---
import MainLayout from '../layouts/MainLayout.astro';
import { getProfil, getPengaturan } from '../lib/keystatic';

const profil = await getProfil();
const pengaturan = await getPengaturan();
const heroImg = profil?.hero?.gambar;
const lokasi = profil?.lokasi;
const potensi = profil?.potensiDesa ?? [];
---

<MainLayout title="Profil | Padukuhan Salakan" description="Profil, visi misi, potensi desa, dan data wilayah Padukuhan Salakan.">

  <!-- ===== HERO ===== -->
  <section class="relative isolate overflow-hidden bg-slate-900">
    {heroImg ? (
      <img
        src={heroImg}
        alt={profil?.namaPadukuhan ?? 'Padukuhan Salakan'}
        class="absolute inset-0 h-full w-full object-cover"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900"></div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-slate-900/20"></div>

    <div class="relative z-10 flex min-h-[280px] flex-col justify-end px-5 pb-8 pt-20 sm:min-h-[340px] sm:px-8 md:min-h-[400px]">
      <div class="container-premium">
        {profil?.hero?.badge && (
          <span class="mb-3 inline-flex items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-white/90 backdrop-blur-sm">
            <span class="material-symbols-outlined text-[14px]">diamond</span>
            {profil.hero.badge}
          </span>
        )}
        <h1 class="max-w-lg text-2xl font-bold leading-[1.15] tracking-tight text-white sm:text-3xl md:text-4xl">
          {profil?.hero?.judul || profil?.namaPadukuhan || 'Padukuhan Salakan'}
        </h1>
      </div>
    </div>
  </section>

  <!-- ===== SEJARAH & FILOSOFI ===== -->
  <section class="relative overflow-hidden py-10 sm:py-14">
    <div class="pointer-events-none absolute right-0 top-0 h-full w-1/2 opacity-[0.03]"
         style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23000' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);">
    </div>

    <div class="container-premium relative z-10">
      <div class="mb-6 flex items-center gap-3">
        <div class="h-px w-8 bg-m3-primary"></div>
        <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-m3-primary">
          {profil?.sejarahLabel || 'Kisah Kami'}
        </span>
      </div>

      <h2 class="text-[24px] font-bold leading-[32px] text-on-surface mb-5 sm:text-[28px] sm:leading-[36px]">
        {profil?.sejarahJudul || 'Sejarah & Filosofi'}
      </h2>

      <div class="prose-profil text-[15px] leading-[1.8] text-on-surface-variant whitespace-pre-line max-w-none lg:max-w-3xl">
        {profil?.sejarahSingkat}
      </div>

      <!-- Visi -->
      <div class="mt-8 rounded-xl border-l-4 border-m3-primary bg-surface-container-low/60 p-5 sm:p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="material-symbols-outlined text-m3-primary text-[20px]">visibility</span>
          <h3 class="text-base font-bold text-on-surface">Visi</h3>
        </div>
        <p class="text-[15px] italic leading-relaxed text-on-surface-variant">
          "{profil?.visi}"
        </p>
      </div>

      <!-- Misi -->
      <div class="mt-6">
        <h3 class="text-base font-bold text-on-surface mb-4">Misi</h3>
        <ul class="space-y-3">
          {profil?.misi?.map((item) => (
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-m3-primary text-[20px] mt-0.5 shrink-0">check_circle</span>
              <span class="text-[15px] leading-relaxed text-on-surface-variant">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== POTENSI DESA ===== -->
  {potensi.length > 0 && (
    <section class="py-10 sm:py-14 bg-surface-container-low/40">
      <div class="container-premium">
        <div class="mb-6 flex items-center gap-3">
          <div class="h-px w-8 bg-m3-primary"></div>
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-m3-primary">Keunggulan Lokal</span>
        </div>
        <h2 class="text-[24px] font-bold leading-[32px] text-on-surface mb-6 sm:text-[28px] sm:leading-[36px]">
          Potensi Desa
        </h2>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {potensi.map((item, i) => (
            <div class:list={[
              'rounded-xl border p-6 transition-all hover:-translate-y-0.5 hover:shadow-md',
              i === 0
                ? 'bg-m3-primary text-white border-m3-primary sm:col-span-2 lg:col-span-1'
                : 'bg-surface-container-lowest border-outline-variant',
            ]}>
              <div class:list={[
                'grid h-12 w-12 place-items-center rounded-xl mb-4',
                i === 0 ? 'bg-white/20' : 'bg-primary-container/30',
              ]}>
                <span class:list={[
                  'material-symbols-outlined text-[24px]',
                  i === 0 ? 'text-white' : 'text-m3-primary',
                ]}>{item.ikon}</span>
              </div>
              <h3 class:list={[
                'text-lg font-bold mb-2',
                i === 0 ? 'text-white' : 'text-on-surface',
              ]}>{item.judul}</h3>
              <p class:list={[
                'text-sm leading-relaxed',
                i === 0 ? 'text-white/80' : 'text-on-surface-variant',
              ]}>{item.deskripsi}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== DATA WILAYAH ===== -->
  {profil?.dataWilayah && profil.dataWilayah.length > 0 && (
    <section class="py-10 sm:py-14">
      <div class="container-premium">
        <div class="mb-6 flex items-center gap-3">
          <div class="h-px w-8 bg-m3-primary"></div>
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-m3-primary">Statistik</span>
        </div>
        <h2 class="text-[24px] font-bold leading-[32px] text-on-surface mb-6 sm:text-[28px] sm:leading-[36px]">
          Data Wilayah
        </h2>

        <div class="grid gap-4 grid-cols-2 sm:grid-cols-3">
          {profil.dataWilayah.map((item) => (
            <div class="rounded-xl bg-surface-container-lowest border border-outline-variant p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)]">
              <p class="text-xl font-bold text-m3-primary leading-tight sm:text-2xl">{item.value}</p>
              <p class="text-[12px] text-on-surface-variant mt-1.5 font-medium">{item.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== LOKASI ===== -->
  {(lokasi?.alamat || lokasi?.gambarPeta) && (
    <section class="py-10 sm:py-14 bg-surface-container-low/40">
      <div class="container-premium">
        <div class="mb-6 flex items-center gap-3">
          <div class="h-px w-8 bg-m3-primary"></div>
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-m3-primary">Lokasi</span>
        </div>
        <h2 class="text-[24px] font-bold leading-[32px] text-on-surface mb-6 sm:text-[28px] sm:leading-[36px]">
          Temukan Kami
        </h2>

        <div class="relative overflow-hidden rounded-xl border border-outline-variant">
          {lokasi?.gambarPeta ? (
            <img
              src={lokasi.gambarPeta}
              alt="Peta lokasi Padukuhan Salakan"
              class="h-[240px] w-full object-cover sm:h-[300px] md:h-[360px]"
            />
          ) : (
            <div class="h-[240px] w-full bg-surface-container-high sm:h-[300px] md:h-[360px] flex items-center justify-center">
              <span class="material-symbols-outlined text-[48px] text-outline">map</span>
            </div>
          )}

          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-900/80 to-transparent p-5 sm:p-6">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div class="text-white">
                <div class="flex items-center gap-1.5 mb-1">
                  <span class="material-symbols-outlined text-[16px]">location_on</span>
                  <span class="text-xs font-bold uppercase tracking-wider text-white/80">Alamat</span>
                </div>
                <p class="text-sm leading-relaxed max-w-md">{lokasi?.alamat}</p>
              </div>
              {lokasi?.linkPeta && (
                <a
                  href={lokasi.linkPeta}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-bold text-slate-900 shadow-lg transition-all hover:-translate-y-0.5 hover:shadow-xl shrink-0"
                >
                  <span class="material-symbols-outlined text-[18px]">open_in_new</span>
                  Buka Peta
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

</MainLayout>
