---
import GalleryGrid from '../components/GalleryGrid.astro';
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getGaleri, sortByDateDesc } from '../lib/keystatic';

const galeri = sortByDateDesc(
  (await getGaleri()).map((item) => ({
    slug: item.slug,
    entry: item.entry!,
  }))
);
---

<MainLayout title="Galeri | Padukuhan Salakan" description="Galeri kegiatan dan dokumentasi visual Padukuhan Salakan.">
  <section class="section-premium bg-slate-50">
    <div class="container-premium relative z-10">
      <div class="text-center mb-16">
        <SectionHeading
          center
          title="Galeri Dokumentasi"
          description="Kumpulan dokumentasi visual suasana padukuhan, kerja bersama, dan kegiatan warga dari waktu ke waktu."
        />
      </div>
      
      <div class="card-premium !bg-white/40 !backdrop-blur-3xl p-8 md:p-12 border border-white/50">
        <div class="absolute top-0 right-0 p-12 opacity-5 pointer-events-none">
           <span class="material-symbols-outlined text-[140px] text-blue-600">photo_library</span>
        </div>
        <GalleryGrid items={galeri} />
      </div>
    </div>
  </section>
</MainLayout>
