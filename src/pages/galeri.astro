---
import GalleryGrid from '../components/GalleryGrid.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { getGaleri, sortByDateDesc } from '../lib/keystatic';

const galeri = sortByDateDesc(
  (await getGaleri()).map((item) => ({
    slug: item.slug,
    entry: item.entry!,
  }))
);
---

<MainLayout title="Galeri | Padukuhan Salakan" description="Galeri kegiatan dan dokumentasi visual Padukuhan Salakan.">

  <div class="container-premium pt-8 pb-4">
    <h1 class="text-[28px] font-bold leading-[36px] text-on-surface">Galeri Dokumentasi</h1>
    <p class="text-base text-on-surface-variant mt-1">Dokumentasi visual suasana padukuhan, kerja bersama, dan kegiatan warga.</p>
  </div>

  <section class="container-premium py-8">
    <GalleryGrid items={galeri} />
  </section>

</MainLayout>
