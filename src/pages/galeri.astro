---
import GalleryGrid from '../components/GalleryGrid.astro';
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { formatTanggal, getGaleri, sortByDateDesc } from '../lib/content';

const galeri = sortByDateDesc(
  (await getGaleri()).map((item) => ({
    slug: item.slug,
    entry: item.entry!,
  }))
);

const terbaru = galeri[0]?.entry?.tanggal;
---

<MainLayout title="Galeri | Padukuhan Salakan" description="Galeri kegiatan dan dokumentasi visual Padukuhan Salakan.">

  <PageHero
    eyebrow="Dokumentasi"
    icon="photo_library"
    title="Galeri Dokumentasi"
    description="Kumpulan momen visual dari kegiatan warga, suasana kampung, dan kerja bersama yang membentuk cerita Salakan."
    orbs={[
      { class: 'absolute -top-16 right-[10%] h-[260px] w-[260px] rounded-full bg-blue-400/20 blur-3xl sm:h-[340px] sm:w-[340px]' },
      { class: 'absolute bottom-[-3rem] left-[12%] h-[220px] w-[220px] rounded-full bg-emerald-400/10 blur-3xl sm:h-[300px] sm:w-[300px]' },
    ]}
  />

  <section class="container-premium pt-4 pb-2">
    <Breadcrumb items={[
      { name: 'Beranda', href: '/' },
      { name: 'Galeri' },
    ]} />
  </section>

  <section class="container-premium py-6 pb-3">
    <div class="grid gap-4 sm:grid-cols-3">
      <div class="card border border-base-300/70 bg-base-100 shadow-sm">
        <div class="card-body p-5">
          <p class="section-kicker">Total Dokumentasi</p>
          <p class="mt-2 text-3xl font-black tracking-tight text-base-content">{galeri.length}</p>
          <p class="mt-1 text-sm text-base-content/65">Foto dan dokumentasi kegiatan yang sudah tampil di galeri publik.</p>
        </div>
      </div>
      <div class="card border border-base-300/70 bg-base-100 shadow-sm">
        <div class="card-body p-5">
          <p class="section-kicker">Pembaruan Terbaru</p>
          <p class="mt-2 text-base font-bold text-base-content">{terbaru ? formatTanggal(terbaru) : 'Belum ada data'}</p>
          <p class="mt-1 text-sm text-base-content/65">Tanggal dokumentasi terbaru yang sudah dipublikasikan.</p>
        </div>
      </div>
      <div class="card border border-primary/15 bg-primary/5 shadow-sm">
        <div class="card-body p-5">
          <p class="section-kicker">Ritme Visual</p>
          <p class="mt-2 text-base font-bold text-base-content">Dokumentasi warga</p>
          <p class="mt-1 text-sm text-base-content/65">Kartu galeri dibuat seragam dengan pola arsip berita dan agenda.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-premium py-8 sm:py-12">
    <GalleryGrid items={galeri} />
  </section>

</MainLayout>
