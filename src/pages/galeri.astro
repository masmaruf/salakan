---
import GalleryGrid from '../components/GalleryGrid.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { getGaleri, sortByDateDesc } from '../lib/keystatic';

const galeri = sortByDateDesc(
  (await getGaleri()).map((item) => ({
    slug: item.slug,
    entry: item.entry!,
  }))
);
---

<MainLayout title="Galeri | Padukuhan Salakan" description="Galeri kegiatan dan dokumentasi visual Padukuhan Salakan.">

  <section class="relative isolate overflow-hidden bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-14 sm:py-20">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-20 right-1/4 h-[320px] w-[320px] rounded-full bg-blue-500/15 blur-3xl"></div>
    </div>
    <div class="container-premium relative z-10 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 backdrop-blur mb-4">
        <span class="material-symbols-outlined text-blue-300 text-[16px]">photo_library</span>
        <span class="text-xs font-bold uppercase tracking-[0.15em] text-blue-200">Dokumentasi</span>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-white sm:text-3xl md:text-4xl">Galeri Dokumentasi</h1>
      <p class="mt-3 text-base font-medium text-blue-100/70 max-w-xl mx-auto">Dokumentasi visual suasana padukuhan, kerja bersama, dan kegiatan warga.</p>
    </div>
  </section>

  <section class="container-premium py-10 sm:py-14">
    <GalleryGrid items={galeri} />
  </section>

</MainLayout>
