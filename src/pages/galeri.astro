---
import GalleryGrid from '../components/GalleryGrid.astro';
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getGaleri, sortByDateDesc } from '../lib/keystatic';

const galeri = sortByDateDesc(
  (await getGaleri()).map((item) => ({
    slug: item.slug,
    entry: item.entry!,
  }))
);
---

<MainLayout title="Galeri | Padukuhan Salakan" description="Galeri kegiatan dan dokumentasi visual Padukuhan Salakan.">
  <section class="section">
    <div class="container">
      <SectionHeading
        title="Galeri kegiatan"
        description="Kumpulan dokumentasi visual untuk menunjukkan suasana padukuhan, kerja bersama, dan kegiatan warga yang berlangsung dari waktu ke waktu."
      />
      <GalleryGrid items={galeri} />
    </div>
  </section>
</MainLayout>
