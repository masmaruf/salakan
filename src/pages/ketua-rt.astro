---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Badge from '../components/ui/Badge.astro';
import CopyButton from '../components/ui/CopyButton.astro';
import Icon from '../components/ui/Icon.tsx';
import { normalizeWhatsapp } from '../lib/content';
import { withSiteTitle } from '../lib/site';

const rtItems = (await getCollection('rt'))
  .filter((item) => item.data.aktif)
  .sort((a, b) => a.data.nomor_rt.localeCompare(b.data.nomor_rt));

function toWhatsappNumber(value?: string) {
  if (!value) return '';
  const normalized = normalizeWhatsapp(value);
  if (normalized.startsWith('0')) return `62${normalized.slice(1)}`;
  return normalized;
}

function displayPhone(value?: string) {
  if (!value) return '';
  const normalized = normalizeWhatsapp(value);
  if (normalized.startsWith('62')) return `0${normalized.slice(2)}`;
  return value;
}

function whatsappHref(rt: (typeof rtItems)[number]) {
  const number = toWhatsappNumber(rt.data.no_hp_ketua);
  if (!number) return '';

  const message = [
    `Halo Ketua RT ${rt.data.nomor_rt}, saya warga RT ${rt.data.nomor_rt}.`,
    'Saya ingin konsultasi terkait pelayanan warga/koordinasi lingkungan.',
  ].join(' ');

  return `https://wa.me/${number}?text=${encodeURIComponent(message)}`;
}
---

<MainLayout
  title={withSiteTitle('Hubungi Ketua RT')}
  description="Pilih RT sesuai tempat tinggal Anda untuk melanjutkan konsultasi pelayanan warga melalui WhatsApp."
>
  <PageHero
    eyebrow="Layanan cepat warga"
    icon="contact_phone"
    title="Hubungi Ketua RT"
    description="Hubungi ketua RT wilayah Anda untuk konsultasi pelayanan warga, koordinasi lingkungan, atau hal yang perlu ditindaklanjuti di tingkat RT."
  />

  <section class="container-premium pt-4 pb-2">
    <Breadcrumb items={[
      { name: 'Beranda', href: '/' },
      { name: 'Kontak', href: '/kontak' },
      { name: 'Ketua RT' },
    ]} />
  </section>

  <section class="container-premium py-8 sm:py-10">
    <div class="mb-6 rounded-xl border border-outline-variant bg-surface-container-lowest p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)] sm:p-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <Badge
            label="Langkah 1 dari 2 · Pilih RT"
            tone="primary"
            class="px-3 py-3 text-[11px] font-bold uppercase tracking-[0.14em]"
          />
          <h2 class="mt-4 text-2xl font-bold tracking-tight text-on-surface">Pemetaan kontak RT aktif</h2>
          <p class="mt-3 max-w-3xl text-base leading-relaxed text-on-surface-variant">
            Pilih RT sesuai tempat tinggal Anda, lalu lanjut ke WhatsApp atau salin nomor ketuanya. Pola ini dibuat agar warga bisa bergerak cepat tanpa mencari kontak satu per satu.
          </p>
        </div>
        <a href="/kontak" class="btn btn-outline btn-sm">
          Jalur kontak umum <Icon name="arrow_forward" class="text-[16px]" />
        </a>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        {rtItems.map((rt) => (
          <a href={`#rt-${rt.data.nomor_rt}`} class="group flex items-center justify-between gap-3 rounded-xl border border-outline-variant bg-surface-container-lowest p-4 shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md">
            <div>
              <p class="section-kicker-muted">Wilayah</p>
              <p class="mt-1 text-lg font-bold tracking-tight text-on-surface">RT {rt.data.nomor_rt}</p>
            </div>
            <div class:list={[
              'grid h-11 w-11 place-items-center rounded-2xl transition-colors',
              rt.data.no_hp_ketua ? 'bg-success/10 text-success group-hover:bg-m3-primary group-hover:text-on-primary' : 'bg-surface-container-low text-on-surface-variant',
            ]}>
              <Icon name={rt.data.no_hp_ketua ? 'chat' : 'info'} class="text-[20px]" />
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {rtItems.map((rt) => {
        const href = whatsappHref(rt);
        const hasContact = Boolean(href);
        const phoneDisplay = displayPhone(rt.data.no_hp_ketua);

        return (
          <article id={`rt-${rt.data.nomor_rt}`} class="flex h-full scroll-mt-28 flex-col rounded-xl border border-outline-variant bg-surface-container-lowest p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="section-kicker">Wilayah</p>
                <h3 class="mt-1 text-3xl font-bold tracking-tight text-on-surface">RT {rt.data.nomor_rt}</h3>
              </div>
              <div class:list={[
                'grid h-11 w-11 place-items-center rounded-2xl',
                hasContact ? 'bg-primary-container/40 text-m3-primary' : 'bg-surface-container-low text-on-surface-variant',
              ]}>
                <Icon name={hasContact ? 'groups' : 'warning'} class="text-[22px]" />
              </div>
            </div>

            <div class="mt-4 flex items-center gap-2">
              <Badge label={hasContact ? 'Siap dihubungi' : 'Kontak belum tersedia'} tone={hasContact ? 'success' : 'surface'} />
            </div>

            <div class="mt-5 flex-1 rounded-xl bg-surface-container-low px-4 py-4">
              <p class="section-kicker-muted">Ketua RT</p>
              <p class="mt-1 text-base font-bold text-on-surface">{rt.data.nama_ketua}</p>
              <p class="mt-1 text-sm text-on-surface-variant">
                {phoneDisplay || 'Nomor WhatsApp belum tersedia'}
              </p>
            </div>

            {hasContact ? (
              <div class="mt-5 grid gap-2">
                <a
                  class="btn border-[#25D366] bg-[#25D366] text-neutral hover:bg-[#1DA851] hover:border-[#1DA851]"
                  href={href}
                  target="_blank"
                  rel="noreferrer"
                >
                  <Icon name="chat" class="text-[18px]" /> Chat WhatsApp
                </a>
                <CopyButton value={phoneDisplay || rt.data.no_hp_ketua || ''} label="Salin nomor" class="btn btn-outline w-full" />
              </div>
            ) : (
              <span class="alert alert-warning mt-5 inline-flex min-h-[44px] items-center justify-center gap-2 px-5 py-3 text-sm font-bold">
                <Icon name="warning" class="text-[18px]" /> Kontak belum tersedia
              </span>
            )}
          </article>
        );
      })}
    </div>
  </section>
</MainLayout>
