---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import Badge from '../components/ui/Badge.astro';
import Icon from '../components/ui/Icon.tsx';
import { normalizeWhatsapp } from '../lib/content';
import { withSiteTitle } from '../lib/site';

const rtItems = (await getCollection('rt'))
  .filter((item) => item.data.aktif)
  .sort((a, b) => a.data.nomor_rt.localeCompare(b.data.nomor_rt));

function toWhatsappNumber(value?: string) {
  if (!value) return '';
  const normalized = normalizeWhatsapp(value);
  if (normalized.startsWith('0')) return `62${normalized.slice(1)}`;
  return normalized;
}

function whatsappHref(rt: (typeof rtItems)[number]) {
  const number = toWhatsappNumber(rt.data.no_hp_ketua);
  if (!number) return '';

  const message = [
    `Halo Ketua RT ${rt.data.nomor_rt}, saya warga RT ${rt.data.nomor_rt}.`,
    'Saya ingin konsultasi terkait pelayanan warga/koordinasi lingkungan.',
  ].join(' ');

  return `https://wa.me/${number}?text=${encodeURIComponent(message)}`;
}
---

<MainLayout
  title={withSiteTitle('Hubungi Ketua RT')}
  description="Pilih RT sesuai tempat tinggal Anda untuk melanjutkan konsultasi pelayanan warga melalui WhatsApp."
>
  <PageHero
    eyebrow="Layanan cepat warga"
    icon="contact_phone"
    title="Hubungi Ketua RT"
    description="Hubungi ketua RT wilayah Anda untuk konsultasi pelayanan warga, koordinasi lingkungan, atau hal yang perlu ditindaklanjuti di tingkat RT."
  />

  <section class="container-premium py-8 sm:py-10">
    <div class="section-card mb-6">
      <Badge label="Langkah 1 dari 2 · Pilih RT" tone="primary" class="px-3 py-1" />
      <h2 class="mt-4 text-2xl font-bold tracking-tight text-on-surface">Untuk urusan apa?</h2>
      <p class="mt-3 max-w-3xl text-base leading-relaxed text-on-surface-variant">
        Hubungi ketua RT wilayah Anda untuk konsultasi pelayanan warga — misalnya surat keterangan,
        koordinasi lingkungan, atau hal yang perlu ditindaklanjuti di tingkat RT. Pilih RT sesuai
        tempat tinggal Anda, lalu lanjut chat WhatsApp.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {rtItems.map((rt) => {
        const href = whatsappHref(rt);
        const hasContact = Boolean(href);

        return (
          <article class="section-card flex h-full flex-col rounded-[1.5rem] p-5 sm:p-5">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="section-kicker">Wilayah</p>
                <h3 class="mt-1 text-3xl font-black tracking-tight text-on-surface">RT {rt.data.nomor_rt}</h3>
              </div>
              <div class="grid h-11 w-11 place-items-center rounded-2xl bg-primary-container/40 text-m3-primary">
                <Icon name="groups" class="text-[22px]" />
              </div>
            </div>

            <div class="mt-5 flex-1 rounded-2xl bg-surface-container-low px-4 py-4">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-on-surface-variant">Ketua RT</p>
              <p class="mt-1 text-base font-bold text-on-surface">{rt.data.nama_ketua}</p>
              <p class="mt-1 text-sm text-on-surface-variant">
                {rt.data.no_hp_ketua || 'Nomor WhatsApp belum tersedia'}
              </p>
            </div>

            {hasContact ? (
              <a
                class="action-pill-success mt-5"
                href={href}
                target="_blank"
                rel="noreferrer"
              >
                <Icon name="chat" class="text-[18px]" /> Chat WhatsApp
              </a>
            ) : (
              <span class="mt-5 inline-flex min-h-[44px] items-center justify-center gap-2 rounded-full bg-surface-container px-5 py-3 text-sm font-bold text-on-surface-variant">
                <Icon name="warning" class="text-[18px]" /> Kontak belum tersedia
              </span>
            )}
          </article>
        );
      })}
    </div>
  </section>
</MainLayout>
