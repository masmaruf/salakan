---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import EmptyStateCard from '../components/ui/EmptyStateCard.astro';
import FilterToolbar from '../components/ui/FilterToolbar.astro';
import ArchiveCard from '../components/ui/ArchiveCard.astro';
import Icon from '../components/ui/Icon.tsx';
import {
  KATEGORI_LOG_KEGIATAN,
  kategoriLogLabels,
  formatTanggalLog,
  formatWaktuLog,
  isValidKategoriLog,
  isValidPeriodeLog,
  matchesPeriodeLog,
} from '../lib/log-kegiatan';
import { getLogKegiatan } from '../lib/content';
import { excerptMarkdown, markdownToText } from '../lib/rich-text';
import { withSiteTitle } from '../lib/site';

const allLogs = (await getLogKegiatan())
  .filter((item) => item.entry.statusPublikasi === 'publish')
  .sort((a, b) => {
    const orderDiff = (b.entry.urutanTampil ?? 0) - (a.entry.urutanTampil ?? 0);
    if (orderDiff !== 0) return orderDiff;
    return new Date(b.entry.tanggal).getTime() - new Date(a.entry.tanggal).getTime();
  })
  .map((item) => ({
    slug: item.slug,
    judul: item.entry.judul,
    tanggal: item.entry.tanggal,
    kategori: item.entry.kategori,
    waktu_mulai: item.entry.waktuMulai,
    waktu_selesai: item.entry.waktuSelesai,
    lokasi: item.entry.lokasi,
    ringkasan: item.entry.ringkasan,
    hasil_tindak_lanjut: item.entry.hasilTindakLanjut,
    pihak_terlibat: item.entry.pihakTerlibat,
    foto_dokumentasi: item.entry.fotoDokumentasi,
    kontenTerkait: item.entry.kontenTerkait,
  }));

const kategoriParam = Astro.url.searchParams.get('kategori') ?? 'semua';
const periodeParam = Astro.url.searchParams.get('periode') ?? 'semua';
const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const normalizedQuery = query.toLowerCase();

const activeKategori = isValidKategoriLog(kategoriParam) ? kategoriParam : 'semua';
const activePeriode = isValidPeriodeLog(periodeParam) ? periodeParam : 'semua';

const logs = allLogs.filter((item) => {
  if (activeKategori !== 'semua' && item.kategori !== activeKategori) return false;
  if (!matchesPeriodeLog(item.tanggal, activePeriode)) return false;

  if (normalizedQuery) {
    const haystack = [
      item.judul,
      markdownToText(item.ringkasan),
      item.lokasi,
      item.pihak_terlibat,
      markdownToText(item.hasil_tindak_lanjut),
      kategoriLogLabels[item.kategori],
    ]
      .filter(Boolean)
      .join(' ')
      .toLowerCase();

    if (!haystack.includes(normalizedQuery)) return false;
  }

  return true;
});
---

<MainLayout
  title={withSiteTitle('Log Kegiatan Dukuh')}
  description="Arsip ringkas kegiatan dukuh Padukuhan Salakan yang sudah dipublikasikan, mencakup pelayanan, administrasi, rapat, dan kegiatan undangan."
>
  <PageHero
    eyebrow="Arsip Operasional"
    icon="pending_actions"
    title="Log kegiatan dukuh yang sudah dipublikasikan bisa dipantau dari satu halaman"
    description="Halaman ini merangkum kegiatan operasional dukuh secara ringkas agar warga dapat melihat layanan, administrasi, rapat, dan kehadiran kegiatan yang sudah dipublikasikan."
  />

  <section class="container-premium pt-4 pb-2">
    <Breadcrumb items={[
      { name: 'Beranda', href: '/' },
      { name: 'Log Kegiatan' },
    ]} />
  </section>

  <section class="container-premium py-8 sm:py-10">
    <FilterToolbar
      eyebrow="Filter Arsip"
      title="Temukan log kegiatan yang dibutuhkan"
      description="Filter log kegiatan dibuat seirama dengan agenda dan berita agar pola pencarian warga tetap konsisten di seluruh arsip publik."
      resultText={query || activeKategori !== 'semua' || activePeriode !== 'semua' ? `Menampilkan ${logs.length} log${query ? ` untuk "${query}"` : ''}${activeKategori !== 'semua' ? ` pada kategori ${kategoriLogLabels[activeKategori]}` : ''}${activePeriode !== 'semua' ? ` dengan periode ${activePeriode.replace('-', ' ')}` : ''}.` : 'Semua log kegiatan yang sudah dipublikasikan ditampilkan dari yang terbaru.'}
    >
      <div slot="active" class="flex flex-wrap items-center gap-2">
        {(query || activeKategori !== 'semua' || activePeriode !== 'semua') && (
          <a class="btn btn-outline btn-sm rounded-full" href="/log-kegiatan">
            <Icon name="restart_alt" class="text-[16px]" />
            Reset filter
          </a>
        )}
      </div>

      <form slot="filters" class="grid gap-4 md:grid-cols-[1.1fr_0.8fr_0.8fr_auto] md:items-end">
        <label class="grid gap-2">
          <span class="detail-label">Cari judul, lokasi, atau pihak terlibat</span>
          <div class="input input-bordered flex h-auto min-h-12 items-center gap-3 rounded-2xl bg-base-100 px-4 py-3 focus-within:outline focus-within:outline-2 focus-within:outline-primary/35">
            <Icon name="search" class="text-[20px] text-primary" />
            <input
              name="q"
              type="search"
              value={query}
              placeholder="Contoh: pelayanan surat, rapat, posyandu"
              class="w-full border-0 bg-transparent p-0 text-sm text-base-content outline-none placeholder:text-base-content/50"
            />
          </div>
        </label>

        <label class="grid gap-2">
          <span class="detail-label">Kategori</span>
          <select name="kategori" class="select select-bordered min-h-12 rounded-2xl bg-base-100 text-sm text-base-content">
            <option value="semua" selected={activeKategori === 'semua'}>Semua kategori</option>
            {KATEGORI_LOG_KEGIATAN.map((item) => (
              <option value={item} selected={activeKategori === item}>{kategoriLogLabels[item]}</option>
            ))}
          </select>
        </label>

        <label class="grid gap-2">
          <span class="detail-label">Periode</span>
          <select name="periode" class="select select-bordered min-h-12 rounded-2xl bg-base-100 text-sm text-base-content">
            <option value="semua" selected={activePeriode === 'semua'}>Semua waktu</option>
            <option value="bulan-ini" selected={activePeriode === 'bulan-ini'}>Bulan ini</option>
            <option value="tahun-ini" selected={activePeriode === 'tahun-ini'}>Tahun ini</option>
          </select>
        </label>

        <button
          type="submit"
          class="btn btn-primary w-full rounded-full md:w-auto"
        >
          <Icon name="search" class="text-[16px]" />
          Terapkan
        </button>
      </form>
    </FilterToolbar>
  </section>

  <section class="container-premium py-0 pb-10 sm:pb-12">
    {logs.length > 0 ? (
      <ol class="timeline timeline-vertical timeline-snap-icon">
        {logs.map((item, index) => {
          const waktuLabel = formatWaktuLog(item.waktu_mulai, item.waktu_selesai);
          const isLast = index === logs.length - 1;
          return (
            <li>
              {index > 0 && <hr class="bg-base-300" />}
              <div class="timeline-start hidden w-28 text-right sm:block">
                <time datetime={item.tanggal} class="badge badge-ghost rounded-full px-3 py-3 text-[11px] font-bold uppercase tracking-[0.08em]">
                  {formatTanggalLog(item.tanggal)}
                </time>
              </div>
              <div class="timeline-middle">
                <span class="status status-primary status-lg shadow-sm" aria-label="Log kegiatan dipublikasikan"></span>
              </div>
              <div class="timeline-end w-full pb-5 ps-3 sm:ps-5">
                <ArchiveCard
                  href={`/log-kegiatan/${item.slug}`}
                  title={item.judul}
                  summary={excerptMarkdown(item.ringkasan, 220)}
                  image={item.foto_dokumentasi}
                  imageAlt={`Dokumentasi ${item.judul}`}
                  badges={[
                    { label: kategoriLogLabels[item.kategori], tone: 'surface' },
                    { label: 'Dipublikasikan', tone: 'success' },
                  ]}
                  meta={[
                    { icon: 'calendar_today', text: formatTanggalLog(item.tanggal), datetime: item.tanggal },
                    ...(waktuLabel ? [{ icon: 'schedule', text: waktuLabel }] : []),
                    ...(item.lokasi ? [{ icon: 'location_on', text: item.lokasi }] : []),
                    ...(item.pihak_terlibat ? [{ icon: 'group', text: item.pihak_terlibat }] : []),
                  ]}
                  class="w-full"
                >
                  {item.hasil_tindak_lanjut && (
                    <div class="alert border-success/20 bg-success/10 items-start rounded-2xl p-3 text-base-content">
                      <Icon name="check_circle" class="mt-0.5 text-[18px] text-success" />
                      <div>
                        <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-success">Tindak lanjut</p>
                        <p class="mt-1 text-sm leading-relaxed text-base-content">{excerptMarkdown(item.hasil_tindak_lanjut, 180)}</p>
                      </div>
                    </div>
                  )}
                </ArchiveCard>
              </div>
              {!isLast && <hr class="bg-base-300" />}
            </li>
          );
        })}
      </ol>
    ) : (
      <EmptyStateCard message="Belum ada log kegiatan yang cocok dengan filter saat ini." />
    )}
  </section>
</MainLayout>
