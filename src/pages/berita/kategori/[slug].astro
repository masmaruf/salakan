---
import MainLayout from '../../../layouts/MainLayout.astro';
import PageIntro from '../../../components/ui/PageIntro.astro';
import NewsGrid from '../../../components/NewsGrid.astro';
import EmptyStateCard from '../../../components/ui/EmptyStateCard.astro';
import { getKegiatan, getKategoriBerita, sortByDateDesc } from '../../../lib/content';

const { slug } = Astro.params;
const categories = await getKategoriBerita();
const category = categories.find((item) => item.slug === slug && item.entry.status === 'tampil');

if (!category) {
  return Astro.redirect('/404');
}

const allKegiatan = sortByDateDesc(
  (await getKegiatan())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const kegiatan = allKegiatan.filter(({ entry }) => entry.kategori === category.slug);
const title = `Kategori: ${category.entry.labelTampil} | Padukuhan Salakan`;
const description = category.entry.deskripsi || `Arsip berita kategori ${category.entry.labelTampil}.`;
---

<MainLayout title={title} description={description}>

  <PageIntro
    title={category.entry.labelTampil}
    description={description}
    breadcrumbs={[
      { label: 'Beranda', href: '/' },
      { label: 'Berita', href: '/berita' },
      { label: category.entry.labelTampil, active: true },
    ]}
  >
    <div class="mt-4 flex items-center gap-3">
      <span class="text-sm text-on-surface-variant">{kegiatan.length} artikel</span>
      <a class="text-sm font-semibold text-m3-primary hover:underline" href="/berita">Semua berita</a>
    </div>
  </PageIntro>

  <section class="container-premium py-8">
    {kegiatan.length > 0 ? (
      <NewsGrid items={kegiatan} />
    ) : (
      <EmptyStateCard message="Belum ada berita yang tayang pada kategori ini." />
    )}
  </section>

</MainLayout>
