---
import MainLayout from '../../../layouts/MainLayout.astro';
import NewsGrid from '../../../components/NewsGrid.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import { getKegiatan, getKategoriBerita, sortByDateDesc } from '../../../lib/keystatic';

export async function getStaticPaths() {
  const categories = await getKategoriBerita();

  return categories
    .filter((item) => item.entry.status === 'tampil')
    .map((item) => ({
      params: { slug: item.slug },
      props: { category: item },
    }));
}

const { category } = Astro.props;
const allKegiatan = sortByDateDesc(
  (await getKegiatan())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({
      slug: item.slug,
      entry: item.entry!,
    }))
);

const kegiatan = allKegiatan.filter(({ entry }) => entry.kategori === category.slug);
const title = `Kategori: ${category.entry.labelTampil} | Padukuhan Salakan`;
const description =
  category.entry.deskripsi ||
  `Arsip berita dan artikel untuk kategori ${category.entry.labelTampil}.`;
---

<MainLayout title={title} description={description}>
  <section class="section">
    <div class="container space-y-6">
      <nav class="breadcrumbs text-sm text-slate-500">
        <ul>
          <li><a href="/">Beranda</a></li>
          <li><a href="/berita">Berita</a></li>
          <li class="text-slate-700">{category.entry.labelTampil}</li>
        </ul>
      </nav>

      <div class="rounded-[var(--radius-xl)] border border-slate-200 bg-gradient-to-br from-white via-white to-violet-50/60 p-6 shadow-sm md:p-8">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div class="space-y-3">
            <span class="badge badge-primary badge-outline">Kategori berita</span>
            <SectionHeading
              title={category.entry.labelTampil}
              description={description}
            />
          </div>
          <div class="stats border border-slate-200 bg-white shadow-sm">
            <div class="stat px-5 py-4">
              <div class="stat-title text-slate-500">Jumlah artikel</div>
              <div class="stat-value text-3xl text-violet-700">{kegiatan.length}</div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <a class="btn btn-sm rounded-[var(--radius-md)] border border-slate-200 bg-white text-slate-700 shadow-none hover:bg-slate-50" href="/berita">
          Kembali ke semua berita
        </a>
      </div>

      <NewsGrid items={kegiatan} />
    </div>
  </section>
</MainLayout>
