---
import MainLayout from '../../../layouts/MainLayout.astro';
import NewsGrid from '../../../components/NewsGrid.astro';
import { getKegiatan, getKategoriBerita, sortByDateDesc } from '../../../lib/keystatic';

export async function getStaticPaths() {
  const categories = await getKategoriBerita();

  return categories
    .filter((item) => item.entry.status === 'tampil')
    .map((item) => ({
      params: { slug: item.slug },
      props: { category: item },
    }));
}

const { category } = Astro.props;
const allKegiatan = sortByDateDesc(
  (await getKegiatan())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({
      slug: item.slug,
      entry: item.entry!,
    }))
);

const kegiatan = allKegiatan.filter(({ entry }) => entry.kategori === category.slug);
const title = `Kategori: ${category.entry.labelTampil} | Padukuhan Salakan`;
const description =
  category.entry.deskripsi ||
  `Arsip berita dan artikel untuk kategori ${category.entry.labelTampil}.`;
---

<MainLayout title={title} description={description}>
  <section class="section">
    <div class="container space-y-6">
      <div class="surface-card space-y-6 p-6 md:p-8">
        <nav class="breadcrumbs text-sm text-slate-500">
          <ul>
            <li><a href="/">Beranda</a></li>
            <li><a href="/berita">Berita</a></li>
            <li class="text-slate-700">{category.entry.labelTampil}</li>
          </ul>
        </nav>

        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_220px] lg:items-end">
          <div class="space-y-3">
            <h1 class="page-title font-extrabold text-slate-950">{category.entry.labelTampil}</h1>
            <p class="max-w-3xl text-body-lg text-slate-600">{description}</p>
          </div>
          <article class="rounded-[var(--radius-lg)] border border-slate-200 bg-white px-5 py-4 shadow-sm">
            <small class="block text-sm text-slate-500">Jumlah artikel</small>
            <strong class="mt-1 block text-3xl font-extrabold tracking-tight text-slate-950">{kegiatan.length}</strong>
          </article>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <a class="btn btn-sm btn-outline rounded-[var(--radius-md)]" href="/berita">
          Kembali ke semua berita
        </a>
      </div>

      <NewsGrid items={kegiatan} />
    </div>
  </section>
</MainLayout>
