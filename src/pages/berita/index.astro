---
import MainLayout from '../../layouts/MainLayout.astro';
import NewsGrid from '../../components/NewsGrid.astro';
import { getKegiatan, getKategoriBeritaMap, sortByDateDesc } from '../../lib/keystatic';

const selectedCategory = Astro.url.searchParams.get('kategori');
const selectedTag = Astro.url.searchParams.get('tag');
const categoryLabels = await getKategoriBeritaMap();

const allKegiatan = sortByDateDesc(
  (await getKegiatan())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({
      slug: item.slug,
      entry: item.entry!,
    }))
);

const kegiatan = allKegiatan.filter(({ entry }) => {
  const matchesCategory = selectedCategory ? entry.kategori === selectedCategory : true;
  const matchesTag = selectedTag ? entry.tag?.includes(selectedTag) : true;
  return matchesCategory && matchesTag;
});

const pageDescription = selectedCategory
  ? `Arsip berita dan artikel untuk kategori ${categoryLabels[selectedCategory] ?? selectedCategory}.`
  : selectedTag
    ? `Arsip berita dan artikel untuk tag ${selectedTag}.`
    : 'Arsip berita, artikel, dan dokumentasi warga Padukuhan Salakan.';

const allCategories = allKegiatan.map(({ entry }) => entry.kategori);
const activeCategories = Array.from(new Set(allCategories)).slice(0, 6);
---

<MainLayout title="Berita & Artikel | Padukuhan Salakan" description={pageDescription}>

  <section class="relative isolate overflow-hidden bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-14 sm:py-20">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-20 right-1/3 h-[320px] w-[320px] rounded-full bg-blue-500/15 blur-3xl"></div>
    </div>
    <div class="container-premium relative z-10 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 backdrop-blur mb-4">
        <span class="material-symbols-outlined text-blue-300 text-[16px]">newspaper</span>
        <span class="text-xs font-bold uppercase tracking-[0.15em] text-blue-200">Berita & Artikel</span>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-white sm:text-3xl md:text-4xl">Kabar Salakan</h1>
      <p class="mt-3 text-base font-medium text-blue-100/70 max-w-xl mx-auto">Informasi terbaru dan kegiatan seputar Padukuhan Salakan.</p>
    </div>
  </section>

  <div class="container-premium pt-8 pb-4">

    <!-- Category Filters -->
    <div class="flex gap-2 overflow-x-auto mt-5 pb-1 hide-scrollbar items-center">
      <a
        class:list={[
          'rounded-full px-4 py-2 text-sm font-semibold whitespace-nowrap min-h-[36px] inline-flex items-center transition-colors',
          !selectedCategory && !selectedTag
            ? 'bg-primary-container text-on-primary-container shadow-sm'
            : 'bg-white border border-outline-variant text-on-surface-variant hover:bg-surface-container-low',
        ]}
        href="/berita"
      >
        Semua
      </a>
      {activeCategories.map((category) => (
        <a
          class:list={[
            'rounded-full px-4 py-2 text-sm font-semibold whitespace-nowrap min-h-[36px] inline-flex items-center transition-colors',
            selectedCategory === category
              ? 'bg-primary-container text-on-primary-container shadow-sm'
              : 'bg-white border border-outline-variant text-on-surface-variant hover:bg-surface-container-low',
          ]}
          href={`/berita?kategori=${category}`}
        >
          {categoryLabels[category] ?? category}
        </a>
      ))}
    </div>

    <!-- Active filter tag -->
    {(selectedCategory || selectedTag) && (
      <div class="flex flex-wrap items-center gap-2 mt-3">
        {selectedCategory && (
          <span class="inline-flex items-center gap-1 rounded-full bg-primary-container text-on-primary-container px-3 py-1 text-xs font-bold">
            {categoryLabels[selectedCategory] ?? selectedCategory}
          </span>
        )}
        {selectedTag && (
          <span class="inline-flex items-center gap-1 rounded-full bg-surface-variant text-on-surface-variant px-3 py-1 text-xs font-bold">
            Tag: {selectedTag}
          </span>
        )}
        <a class="inline-flex items-center gap-1 text-xs font-semibold text-m3-primary hover:underline" href="/berita">
          <span class="material-symbols-outlined text-[16px]">close</span> Reset
        </a>
      </div>
    )}
  </div>

  <!-- News Feed -->
  <section class="container-premium py-4 pb-10">
    {kegiatan.length > 0 ? (
      <NewsGrid items={kegiatan} />
    ) : (
      <div class="rounded-xl bg-surface-container-lowest border border-outline-variant p-12 text-center text-on-surface-variant">
        Belum ada berita untuk filter ini.
      </div>
    )}
  </section>

</MainLayout>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
