---
import MainLayout from '../../layouts/MainLayout.astro';
import NewsGrid from '../../components/NewsGrid.astro';
import { getKegiatan, getKategoriBeritaMap, sortByDateDesc } from '../../lib/keystatic';

const selectedCategory = Astro.url.searchParams.get('kategori');
const selectedTag = Astro.url.searchParams.get('tag');
const categoryLabels = await getKategoriBeritaMap();

const allKegiatan = sortByDateDesc(
  (await getKegiatan())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({
      slug: item.slug,
      entry: item.entry!,
    }))
);

const kegiatan = allKegiatan.filter(({ entry }) => {
  const matchesCategory = selectedCategory ? entry.kategori === selectedCategory : true;
  const matchesTag = selectedTag ? entry.tag?.includes(selectedTag) : true;
  return matchesCategory && matchesTag;
});

const pageDescription = selectedCategory
  ? `Arsip berita dan artikel untuk kategori ${categoryLabels[selectedCategory] ?? selectedCategory}.`
  : selectedTag
    ? `Arsip berita dan artikel untuk tag ${selectedTag}.`
    : 'Arsip berita, artikel, dan dokumentasi warga Padukuhan Salakan.';

// Hanya ambil 6 kategori unik agar layout rapi
const allCategories = allKegiatan.map(({ entry }) => entry.kategori);
const activeCategories = Array.from(new Set(allCategories)).slice(0, 6);
---

<MainLayout title="Berita & Artikel | Padukuhan Salakan" description={pageDescription}>
  <section class="section-premium bg-slate-50/50">
    <div class="container-premium relative z-10">
      
      {/* Breadcrumb Premium */}
      <nav class="flex text-sm font-bold text-slate-400 uppercase tracking-[0.2em] mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center gap-3">
          <li><a href="/" class="hover:text-blue-600 transition">Beranda</a></li>
          <li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
          <li class="text-blue-700 bg-blue-50 px-3 py-1 rounded-full text-[0.7rem] ring-1 ring-blue-100">Berita & Kabar</li>
        </ol>
      </nav>

      {/* Header Info Card */}
      <div class="card-premium p-8 md:p-12 mb-16">
        <div class="grid gap-12 lg:grid-cols-[1.5fr_auto] lg:items-end">
          <div class="space-y-8">
            <h1 class="hero-title text-gradient !mb-4">
              {selectedCategory || selectedTag ? 'Telusuri Topik' : 'Kabar & Artikel Warga'}
            </h1>
            <p class="max-w-2xl text-xl font-bold text-slate-400 leading-relaxed">
              {selectedCategory
                ? `Pusat informasi yang menyaring langsung berita khusus di lingkup "${categoryLabels[selectedCategory] ?? selectedCategory}".`
                : selectedTag
                  ? `Artikel terpilih yang ditarik menggunakan topik kunci referensi "${selectedTag}".`
                  : 'Dokumentasi, liputan, dan kabar eksklusif dari aktivitas warga hingga wacana pembaharuan padukuhan yang disajikan secara transparan.'}
            </p>
            
            <div class="flex flex-wrap gap-3 pt-4">
              <span class="flex items-center gap-2 text-xs font-black text-slate-400 uppercase tracking-widest mr-2">
                 <span class="material-symbols-outlined text-[18px]">filter_list</span> Filter Topik:
              </span>
              {activeCategories.map((category) => (
                <a class="inline-flex items-center rounded-full bg-white px-5 py-2.5 text-sm font-bold text-slate-600 shadow-sm border border-slate-100 transition-all hover:bg-blue-600 hover:text-white hover:border-blue-600 hover:shadow-lg" href={`/berita?kategori=${category}`}>
                  {categoryLabels[category] ?? category}
                </a>
              ))}
            </div>

            {(selectedCategory || selectedTag) && (
              <div class="flex flex-wrap gap-4 pt-8 border-t border-slate-100">
                {selectedCategory && (
                  <span class="inline-flex items-center gap-2 rounded-full bg-blue-100 px-5 py-2 text-sm font-black text-blue-800 ring-1 ring-blue-200">
                    Kategori: {categoryLabels[selectedCategory] ?? selectedCategory}
                  </span>
                )}
                {selectedTag && (
                  <span class="inline-flex items-center gap-2 rounded-full bg-indigo-100 px-5 py-2 text-sm font-black text-indigo-800 ring-1 ring-indigo-200">
                    Tag: {selectedTag}
                  </span>
                )}
                <a class="inline-flex items-center gap-2 rounded-full bg-slate-900 px-7 py-2.5 text-sm font-black text-white shadow-lg transition-all hover:bg-blue-600 hover:-translate-y-0.5" href="/berita">
                  <span class="material-symbols-outlined text-[20px]">restart_alt</span> Reset Filter
                </a>
              </div>
            )}
          </div>

          <div class="flex gap-4 lg:flex-col xl:flex-row">
             <div class="flex flex-col items-center justify-center rounded-[2rem] bg-white p-8 shadow-sm border border-slate-100 min-w-[160px]">
               <strong class="text-5xl font-black text-slate-900 leading-none">{kegiatan.length}</strong>
               <span class="mt-3 text-[0.65rem] font-black text-blue-600 uppercase tracking-[0.2em]">Artikel Aktif</span>
             </div>
             <div class="flex flex-col items-center justify-center rounded-[2rem] bg-white p-8 shadow-sm border border-slate-100 min-w-[160px]">
               <strong class="text-5xl font-black text-slate-900 leading-none">{activeCategories.length}</strong>
               <span class="mt-3 text-[0.65rem] font-black text-emerald-600 uppercase tracking-[0.2em]">Kategori</span>
             </div>
          </div>
        </div>
      </div>

      <div class="mt-20">
        <NewsGrid items={kegiatan} />
      </div>
    </div>
  </section>
</MainLayout>
