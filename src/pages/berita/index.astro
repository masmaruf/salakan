---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import NewsGrid from '../../components/NewsGrid.astro';
import EmptyStateCard from '../../components/ui/EmptyStateCard.astro';
import PillFilterBar from '../../components/ui/PillFilterBar.astro';
import Badge from '../../components/ui/Badge.astro';
import FilterToolbar from '../../components/ui/FilterToolbar.astro';
import { getKegiatan, getKategoriBeritaMap, sortByDateDesc } from '../../lib/content';
import { getBeritaCategoryTone, getTagUmumLabel } from '../../lib/content-taxonomy';
import Icon from '../../components/ui/Icon.tsx';

const selectedCategory = Astro.url.searchParams.get('kategori');
const selectedTag = Astro.url.searchParams.get('tag');
const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const normalizedQuery = query.toLowerCase();
const categoryLabels = await getKategoriBeritaMap();

const allKegiatan = sortByDateDesc(
  (await getKegiatan())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({
      slug: item.slug,
      entry: item.entry!,
    }))
);

const kegiatan = allKegiatan.filter(({ entry }) => {
  const matchesCategory = selectedCategory ? entry.kategori === selectedCategory : true;
  const entryTags = (entry.tag ?? []) as string[];
  const matchesTag = selectedTag ? entryTags.includes(selectedTag) : true;
  const haystack = [
    entry.judul,
    entry.ringkasan,
    entry.kategori,
    ...(entry.tag ?? []),
    ...((entry.tag ?? []).map((tag) => getTagUmumLabel(tag))),
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
  const matchesQuery = normalizedQuery ? haystack.includes(normalizedQuery) : true;
  return matchesCategory && matchesTag && matchesQuery;
});

const pageDescription = selectedCategory
  ? `Arsip berita dan artikel untuk kategori ${categoryLabels[selectedCategory] ?? selectedCategory}.`
  : selectedTag
    ? `Arsip berita dan artikel untuk tag ${getTagUmumLabel(selectedTag)}.`
    : 'Arsip berita, artikel, dan dokumentasi warga Padukuhan Salakan.';

const allCategories = allKegiatan.map(({ entry }) => entry.kategori).filter(Boolean);
const activeCategories = Array.from(new Set(allCategories)).slice(0, 6);
const filterItems = [
  { href: query ? `/berita?q=${encodeURIComponent(query)}` : '/berita', label: 'Semua', active: !selectedCategory && !selectedTag },
  ...activeCategories.map((category) => ({
    href: `/berita?kategori=${category}${query ? `&q=${encodeURIComponent(query)}` : ''}`,
    label: categoryLabels[category] ?? category,
    active: selectedCategory === category,
  })),
];

const featured = kegiatan[0] ?? null;
const shouldShowFeatured = Boolean(featured && !selectedTag && !query);
const displayItems = shouldShowFeatured ? kegiatan.slice(1) : kegiatan;
---

<MainLayout title="Berita & Artikel | Padukuhan Salakan" description={pageDescription}>
  <PageHero
    eyebrow="Berita & Artikel"
    icon="newspaper"
    title="Kabar Salakan"
    description="Informasi terbaru, catatan kegiatan, dan cerita warga Padukuhan Salakan dalam satu ruang baca yang lebih rapi."
  />

  <section class="container-premium pt-4 pb-2">
    <Breadcrumb items={[
      { name: 'Beranda', href: '/' },
      { name: 'Berita' },
    ]} />
  </section>

  <section class="container-premium pb-4 pt-6 sm:pt-8">
    <FilterToolbar
      eyebrow="Filter Arsip"
      title="Cari berita dan artikel warga"
      description="Pola arsip berita disamakan dengan agenda dan log kegiatan agar warga lebih cepat memahami cara memfilter dan membaca hasilnya."
      resultText={selectedCategory || selectedTag || query ? `Menampilkan ${kegiatan.length} hasil${query ? ` untuk "${query}"` : ''}${selectedCategory ? ` pada kategori ${categoryLabels[selectedCategory] ?? selectedCategory}` : ''}${selectedTag ? ` dengan tag ${getTagUmumLabel(selectedTag)}` : ''}.` : 'Semua berita dan artikel publik ditampilkan dari yang terbaru.'}
    >
      <div slot="active" class="flex flex-wrap items-center gap-2">
        {(selectedCategory || selectedTag || query) && (
          <a class="btn btn-outline btn-sm" href="/berita">
            <Icon name="restart_alt" class="text-[16px]" />
            Reset filter
          </a>
        )}
      </div>

      <div slot="filters" class="grid gap-4">
        <PillFilterBar items={filterItems} />

        <form action="/berita" method="get" class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
          <div class="grid gap-2">
            <label for="berita-search" class="detail-label text-on-surface-variant">Cari judul, ringkasan, kategori, atau tag</label>
            <div class="flex h-auto items-center gap-3 rounded-xl border border-outline-variant bg-surface-container-lowest px-4 py-3 transition-all focus-within:border-m3-primary focus-within:ring-2 focus-within:ring-m3-primary/20">
              <Icon name="search" class="text-[20px] text-on-surface-variant/70" />
              <input
                id="berita-search"
                name="q"
                type="search"
                value={query}
                placeholder="Contoh: posyandu, gotong royong, pelayanan"
                class="w-full border-0 bg-transparent p-0 text-sm text-on-surface outline-none placeholder:text-on-surface-variant/60"
              />
            </div>
            {selectedCategory && <input type="hidden" name="kategori" value={selectedCategory} />}
            {selectedTag && <input type="hidden" name="tag" value={selectedTag} />}
          </div>
          <button type="submit" class="btn btn-primary">
            <Icon name="search" class="text-[16px]" />
            Terapkan pencarian
          </button>
        </form>

        {(selectedCategory || selectedTag) && (
          <div class="flex flex-wrap items-center gap-2">
            {selectedCategory && (
              <Badge label={categoryLabels[selectedCategory] ?? selectedCategory} tone="primary" class="px-3 py-1" />
            )}
            {selectedTag && (
              <Badge label={`Tag: ${getTagUmumLabel(selectedTag)}`} tone="surface" class="px-3 py-1" />
            )}
          </div>
        )}
      </div>
    </FilterToolbar>
  </section>

  {shouldShowFeatured && (
    <section class="container-premium py-3 sm:py-4">
      <a class="group grid overflow-hidden rounded-xl border border-outline-variant bg-surface-container-lowest shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md lg:grid-cols-[0.95fr_1.05fr]" href={`/berita/${featured.slug}`}>
        {featured.entry.gambarUtama && (
          <div class="min-h-[220px] overflow-hidden bg-surface-container lg:min-h-full">
            <img
              src={featured.entry.gambarUtama}
              alt={featured.entry.judul}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
        <div class="flex flex-col gap-3 p-5 sm:p-7">
          <div class="flex flex-wrap items-center gap-2">
            <Badge label={categoryLabels[featured.entry.kategori] ?? featured.entry.kategori} tone={getBeritaCategoryTone(featured.entry.kategori)} />
            {featured.entry.unggulan && <Badge label="Unggulan" tone="info" icon="verified" />}
          </div>
          <h2 class="mt-1 text-2xl font-bold leading-tight tracking-tight text-on-surface transition-colors group-hover:text-m3-primary sm:text-3xl">{featured.entry.judul}</h2>
          <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">{new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(featured.entry.tanggal))}</p>
          <p class="mt-1 max-w-3xl text-base leading-relaxed text-on-surface-variant">{featured.entry.ringkasan}</p>
          <div class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-m3-primary transition-transform group-hover:translate-x-0.5">
            Baca selengkapnya <Icon name="arrow_forward" class="text-[16px]" />
          </div>
        </div>
      </a>
    </section>
  )}

  <section class="container-premium py-3 pb-10 sm:py-4">
    {kegiatan.length > 0 ? (
      displayItems.length > 0 ? <NewsGrid items={displayItems} /> : <EmptyStateCard message="Hanya satu konten yang cocok dan sudah ditampilkan sebagai sorotan." />
    ) : (
      <EmptyStateCard message="Belum ada berita untuk filter ini." />
    )}
  </section>
</MainLayout>
