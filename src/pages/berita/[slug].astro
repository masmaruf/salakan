---
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import ShareActions from '../../components/ShareActions.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { resolveSeoImage, resolveSeoText, toAbsoluteUrl, withSiteTitle } from '../../lib/site';
import { formatTanggal, getAgenda, getGaleri, getKegiatan, getKategoriBeritaMap, getLogKegiatan, getProgram, getStrukturOrganisasi } from '../../lib/content';
import { getBeritaCategoryTone } from '../../lib/content-taxonomy';
import RelatedContentSection from '../../components/ui/RelatedContentSection.astro';
import {
  createAgendaRelationItem,
  createBeritaRelationItem,
  createGaleriRelationItem,
  createLembagaRelationItem,
  createLogRelationItem,
  createProgramRelationItem,
} from '../../lib/content-relations';
import { findRelatedContent } from '../../lib/related-content';
import { renderMarkdown } from '../../lib/rich-text';

const { slug } = Astro.params;
const [categoryLabels, allKegiatan, agendaItems, programItems, logItems, lembagaItems, galeriItems] = await Promise.all([
  getKategoriBeritaMap(),
  getKegiatan(),
  getAgenda(),
  getProgram(),
  getLogKegiatan(),
  getStrukturOrganisasi(),
  getGaleri(),
]);

const item = allKegiatan.find((k) => k.slug === slug && k.entry?.statusPublikasi === 'publish');
if (!item) {
  return Astro.redirect('/404');
}

const { entry } = item;
const articleHtml = renderMarkdown(entry.isi || '');
const articleUrl = toAbsoluteUrl(`/berita/${item.slug}`);
const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.judul));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage, entry.gambarUtama);

const shareLinks = [
  { label: 'WhatsApp', href: `https://wa.me/?text=${encodeURIComponent(entry.judul)}%20${encodeURIComponent(articleUrl)}`, icon: 'chat' },
  { label: 'Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(articleUrl)}`, icon: 'share' },
  { label: 'Salin', href: articleUrl, icon: 'content_copy', copy: true },
];

const relatedItems = findRelatedContent(
  createBeritaRelationItem(item, categoryLabels),
  [
    ...allKegiatan
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => createBeritaRelationItem(candidate, categoryLabels)),
    ...agendaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createAgendaRelationItem),
    ...programItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createProgramRelationItem),
    ...logItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLogRelationItem),
    ...lembagaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLembagaRelationItem),
    ...galeriItems.map(createGaleriRelationItem),
  ],
  4,
);

import Icon from '../../components/ui/Icon.tsx';
---

<MainLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={entry.tanggal}
>

  <article class="container-premium max-w-4xl py-6 sm:py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Berita', href: '/berita' },
      { label: entry.judul, active: true },
    ]} />

    <header class="mb-6">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <a
          href={`/berita?kategori=${entry.kategori}`}
          class:list={[
            'rounded-md px-2.5 py-1 text-[12px] font-semibold transition-opacity hover:opacity-80',
            getBeritaCategoryTone(entry.kategori) === 'warning' && 'bg-amber-100 text-amber-800',
            getBeritaCategoryTone(entry.kategori) === 'info' && 'bg-blue-100 text-blue-800',
            getBeritaCategoryTone(entry.kategori) === 'success' && 'bg-emerald-100 text-emerald-800',
            getBeritaCategoryTone(entry.kategori) === 'surface' && 'border border-outline-variant bg-surface-variant text-on-surface-variant',
            getBeritaCategoryTone(entry.kategori) === 'primary' && 'bg-primary-container text-on-primary-container',
            getBeritaCategoryTone(entry.kategori) === 'error' && 'bg-error-container text-on-error-container',
          ]}
        >
          {categoryLabels[entry.kategori] ?? entry.kategori}
        </a>
        {entry.jenisKonten && (
          <span class="rounded-md border border-outline-variant bg-surface-variant px-2.5 py-1 text-[12px] font-semibold capitalize text-on-surface-variant">
            {entry.jenisKonten}
          </span>
        )}
        {entry.unggulan && (
          <span class="flex items-center gap-1 rounded-md bg-amber-100 px-2.5 py-1 text-[12px] font-semibold text-amber-800">
            <Icon name="star" class="text-[12px]" /> Unggulan
          </span>
        )}
      </div>

      <h1 class="text-2xl font-bold leading-tight tracking-tight text-on-surface sm:text-3xl md:text-4xl">
        {entry.judul}
      </h1>

      <p class="mt-3 text-base leading-relaxed text-on-surface-variant">
        {entry.ringkasan}
      </p>

      <ContentMeta
        class="mt-4 flex flex-wrap items-center gap-4 border-t border-outline-variant/40 pt-4"
        items={[
          { icon: 'calendar_today', text: formatTanggal(entry.tanggal), datetime: entry.tanggal, accentClass: 'text-on-surface-variant' },
          ...(entry.penulis ? [{ icon: 'person', text: entry.penulis, accentClass: 'text-on-surface-variant' }] : []),
        ]}
        iconClass="text-[16px]"
      />
    </header>

    {entry.gambarUtama && (
      <div class="mb-8 overflow-hidden rounded-xl border border-outline-variant">
        <Image
          src={entry.gambarUtama}
          alt={entry.altGambarUtama || entry.judul}
          width={1200}
          height={675}
          class="h-auto w-full object-cover"
          loading="eager"
        />
      </div>
    )}

    <div
      class="prose prose-slate prose-lg max-w-none
        prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-on-surface
        prose-p:text-on-surface-variant prose-p:leading-relaxed
        prose-a:text-m3-primary prose-a:no-underline hover:prose-a:underline
        prose-img:rounded-xl prose-img:border prose-img:border-outline-variant
        prose-blockquote:border-l-m3-primary prose-blockquote:bg-surface-container-low prose-blockquote:rounded-r-xl
        prose-code:text-m3-primary prose-code:bg-surface-container-low prose-code:rounded
        prose-pre:bg-inverse-surface prose-pre:rounded-xl"
      set:html={articleHtml}
    />

    {entry.tag && entry.tag.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2 border-t border-outline-variant/40 pt-6">
        {entry.tag.map((tag: string) => (
          <a
            href={`/berita?tag=${encodeURIComponent(tag)}`}
            class="rounded-full border border-outline-variant bg-surface-container-low px-3 py-1.5 text-[12px] font-semibold text-on-surface-variant transition-colors hover:bg-primary-container hover:text-on-primary-container"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <ShareActions title="Bagikan artikel ini" links={shareLinks} />
  </article>

  <RelatedContentSection
    title="Konten Terkait Berita Ini"
    actionHref="/berita"
    actionLabel="Lihat arsip berita"
    items={relatedItems}
    sectionClass="bg-surface-container-low/50 py-10"
  />

</MainLayout>
