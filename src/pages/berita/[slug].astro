---
import { Image } from 'astro:assets';
import { marked } from 'marked';
import MainLayout from '../../layouts/MainLayout.astro';
import { resolveSeoImage, resolveSeoText, toAbsoluteUrl, withSiteTitle } from '../../lib/site';
import { formatTanggal, getKegiatan, getKategoriBeritaMap } from '../../lib/keystatic';

export async function getStaticPaths() {
  const items = await getKegiatan();
  return items
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({
    params: { slug: item.slug },
    props: { item: { slug: item.slug, entry: item.entry! } },
  }));
}

const { item } = Astro.props;
const { entry } = item;
const [categoryLabels, allKegiatan] = await Promise.all([getKategoriBeritaMap(), getKegiatan()]);
const articleHtml = marked.parse(entry.isi, { breaks: true }) as string;
const articleUrl = toAbsoluteUrl(`/berita/${item.slug}`);
const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.judul));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage, entry.gambarUtama);
const shareText = `${entry.judul} | Padukuhan Salakan`;
const encodedUrl = encodeURIComponent(articleUrl);
const encodedText = encodeURIComponent(shareText);
const shareLinks = [
  {
    label: 'Facebook',
    icon: 'thumb_up',
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  },
  {
    label: 'WhatsApp',
    icon: 'chat',
    href: `https://wa.me/?text=${encodedText}%20${encodedUrl}`,
  },
  {
    label: 'Telegram',
    icon: 'send',
    href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedText}`,
  },
  {
    label: 'Email',
    icon: 'mail',
    href: `mailto:?subject=${encodedText}&body=${encodedText}%0A${encodedUrl}`,
  },
  {
    label: 'Salin link',
    icon: 'link',
    href: articleUrl,
    copy: true,
  },
];
const categoryHref = `/berita/kategori/${entry.kategori}`;
const relatedArticles = allKegiatan
  .filter((candidate) => candidate.slug !== item.slug && candidate.entry?.statusPublikasi === 'publish')
  .sort((a, b) => {
    const sameCategoryA = a.entry?.kategori === entry.kategori ? 1 : 0;
    const sameCategoryB = b.entry?.kategori === entry.kategori ? 1 : 0;
    if (sameCategoryA !== sameCategoryB) return sameCategoryB - sameCategoryA;

    const sharedTagsA = (a.entry?.tag ?? []).filter((tag) => entry.tag?.includes(tag)).length;
    const sharedTagsB = (b.entry?.tag ?? []).filter((tag) => entry.tag?.includes(tag)).length;
    return sharedTagsB - sharedTagsA;
  })
  .slice(0, 3);
---

<MainLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={entry.tanggal}
>
  <section class="section">
    <div class="container max-w-5xl">
      <article class="surface-card ui-radius-xl overflow-hidden">
        {entry.gambarUtama && (
          <Image
            src={entry.gambarUtama}
            alt={entry.altGambarUtama || entry.judul}
            width={1440}
            height={900}
            class="h-[18rem] w-full object-cover md:h-[26rem]"
            loading="eager"
            sizes="(max-width: 920px) 100vw, 920px"
          />
        )}
        <div class="px-5 py-6 md:px-10 md:py-10">
          <nav class="breadcrumbs mb-6 text-sm text-slate-500">
            <ul>
              <li><a href="/">Beranda</a></li>
              <li><a href="/berita">Berita</a></li>
              <li><a href={categoryHref}>{categoryLabels[entry.kategori] ?? entry.kategori}</a></li>
              <li class="text-slate-700">{entry.judul}</li>
            </ul>
          </nav>
          <div class="mb-6 flex flex-wrap items-center gap-2">
            <a class="badge badge-primary badge-outline" href={categoryHref}>{categoryLabels[entry.kategori] ?? entry.kategori}</a>
            {entry.jenisKonten && <span class="badge badge-ghost capitalize">{entry.jenisKonten}</span>}
          </div>
          <div class="space-y-5">
            <h1 class="max-w-4xl text-3xl font-extrabold tracking-tight text-slate-950 md:text-5xl">{entry.judul}</h1>
            <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
              <time class="ui-radius-md inline-flex items-center gap-2 border border-slate-200 bg-slate-50 px-3 py-1.5 font-medium" datetime={entry.tanggal}>
                <span class="material-symbols-outlined text-[18px]">calendar_today</span>
                {formatTanggal(entry.tanggal)}
              </time>
              {entry.penulis && (
                <p class="ui-radius-md inline-flex items-center gap-2 border border-slate-200 bg-white px-3 py-1.5 font-medium">
                  <span class="material-symbols-outlined text-[18px]">edit_square</span>
                  Ditulis oleh {entry.penulis}
                </p>
              )}
              {entry.unggulan && (
                <p class="ui-radius-md inline-flex items-center gap-2 border border-violet-200 bg-violet-50 px-3 py-1.5 font-semibold text-violet-700">
                  <span class="material-symbols-outlined text-[18px]">star</span>
                  Konten unggulan
                </p>
              )}
            </div>
          </div>
          <p class="mt-7 max-w-3xl text-lg leading-8 text-slate-600 md:text-xl">{entry.ringkasan}</p>

          <div class="ui-radius-lg mt-8 border border-slate-200 bg-slate-50/80 p-4 md:p-5">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-500">Bagikan artikel</p>
                <p class="mt-1 text-sm text-slate-600">Sebarkan informasi ini ke warga melalui kanal yang paling nyaman.</p>
              </div>
              <div class="flex flex-wrap gap-2">
                {shareLinks.map((link) => (
                  link.copy ? (
                    <button
                      class="btn btn-sm border-slate-200 bg-white text-slate-700 shadow-none hover:bg-slate-100"
                      type="button"
                      data-copy-link
                      data-copy-value={articleUrl}
                    >
                      <span class="material-symbols-outlined text-[18px]">{link.icon}</span>
                      <span data-copy-label>{link.label}</span>
                    </button>
                  ) : (
                    <a
                      class="btn btn-sm border-slate-200 bg-white text-slate-700 shadow-none hover:bg-slate-100"
                      href={link.href}
                      target="_blank"
                      rel="noreferrer"
                    >
                      <span class="material-symbols-outlined text-[18px]">{link.icon}</span>
                      {link.label}
                    </a>
                  )
                ))}
              </div>
            </div>
          </div>

          <div class="mt-10 border-t border-slate-200 pt-8">
            <div class="article-rich text-slate-700" set:html={articleHtml} />
          </div>

          <div class="mt-10 grid gap-4 border-t border-slate-200 pt-8 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
            <div class="space-y-4">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-500">Kategori artikel</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <a class="badge badge-primary badge-outline" href={categoryHref}>
                    {categoryLabels[entry.kategori] ?? entry.kategori}
                  </a>
                </div>
              </div>
              {entry.tag?.length ? (
                <div>
                  <p class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-500">Tags</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {entry.tag.map((tag: string) => (
                      <a class="badge badge-outline" href={`/berita?tag=${encodeURIComponent(tag)}`}>
                        {tag}
                      </a>
                    ))}
                  </div>
                </div>
              ) : null}
            </div>

            <div class="ui-radius-lg border border-slate-200 bg-slate-50/80 p-4 md:min-w-[280px]">
              <p class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-500">Bagikan lagi</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {shareLinks.map((link) => (
                  link.copy ? (
                    <button
                      class="btn btn-sm border-slate-200 bg-white text-slate-700 shadow-none hover:bg-slate-100"
                      type="button"
                      data-copy-link
                      data-copy-value={articleUrl}
                    >
                      <span class="material-symbols-outlined text-[18px]">{link.icon}</span>
                      <span data-copy-label>{link.label}</span>
                    </button>
                  ) : (
                    <a
                      class="btn btn-sm border-slate-200 bg-white text-slate-700 shadow-none hover:bg-slate-100"
                      href={link.href}
                      target="_blank"
                      rel="noreferrer"
                    >
                      <span class="material-symbols-outlined text-[18px]">{link.icon}</span>
                      {link.label}
                    </a>
                  )
                ))}
              </div>
            </div>
          </div>
        </div>
      </article>

      {relatedArticles.length > 0 && (
        <section class="mt-6">
          <div class="surface-card ui-radius-xl p-5 md:p-7">
            <div class="mb-5 flex flex-wrap items-end justify-between gap-4">
              <div>
                <span class="badge badge-outline">Artikel terkait</span>
                <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-950">Bacaan lain yang masih berkaitan</h2>
              </div>
              <a class="btn btn-outline" href="/berita">Lihat semua berita</a>
            </div>
            <div class="grid gap-4 lg:grid-cols-3">
              {relatedArticles.map(({ slug, entry: relatedEntry }) => (
                <article class="card ui-radius-lg border border-slate-200 bg-white shadow-sm">
                  {relatedEntry?.gambarUtama && (
                    <Image
                      src={relatedEntry.gambarUtama}
                      alt={relatedEntry.altGambarUtama || relatedEntry.judul}
                      width={960}
                      height={540}
                      class="h-48 w-full object-cover"
                      loading="lazy"
                    />
                  )}
                  <div class="flex h-full flex-col gap-3 p-5">
                    <h3 class="text-xl font-bold tracking-tight text-slate-950">
                      <a href={`/berita/${slug}`}>{relatedEntry.judul}</a>
                    </h3>
                    <time class="text-sm text-slate-500" datetime={relatedEntry.tanggal}>{formatTanggal(relatedEntry.tanggal)}</time>
                    <a class="btn btn-sm mt-auto w-fit border-slate-200 bg-slate-50 text-slate-700 shadow-none hover:bg-slate-100" href={`/berita/${slug}`}>
                      Baca artikel
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>
      )}
    </div>
  </section>
</MainLayout>

<script is:inline>
  document.querySelectorAll('[data-copy-link]').forEach((button) => {
    button.addEventListener('click', async () => {
      const value = button.getAttribute('data-copy-value') || '';
      const label = button.querySelector('[data-copy-label]');

      try {
        await navigator.clipboard.writeText(value);
        if (label) label.textContent = 'Tersalin';
        setTimeout(() => {
          if (label) label.textContent = 'Salin link';
        }, 1800);
      } catch {
        if (label) label.textContent = 'Gagal salin';
        setTimeout(() => {
          if (label) label.textContent = 'Salin link';
        }, 1800);
      }
    });
  });
</script>
