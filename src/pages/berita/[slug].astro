---
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import ShareActions from '../../components/ShareActions.astro';
import Badge from '../../components/ui/Badge.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { resolveSeoImage, resolveSeoText, toAbsoluteUrl, withSiteTitle } from '../../lib/site';
import { formatTanggal, getAgenda, getGaleri, getKegiatan, getKategoriBeritaMap, getLogKegiatan, getProgram, getStrukturOrganisasi } from '../../lib/content';
import { getTagUmumLabel, jenisKontenKegiatanLabels } from '../../lib/content-taxonomy';
import RelatedContentSection from '../../components/ui/RelatedContentSection.astro';
import {
  createAgendaRelationItem,
  createBeritaRelationItem,
  createGaleriRelationItem,
  createLembagaRelationItem,
  createLogRelationItem,
  createProgramRelationItem,
} from '../../lib/content-relations';
import { findRelatedContent } from '../../lib/related-content';
import { renderMarkdown } from '../../lib/rich-text';

const { slug } = Astro.params;
const [categoryLabels, allKegiatan, agendaItems, programItems, logItems, lembagaItems, galeriItems] = await Promise.all([
  getKategoriBeritaMap(),
  getKegiatan(),
  getAgenda(),
  getProgram(),
  getLogKegiatan(),
  getStrukturOrganisasi(),
  getGaleri(),
]);

const item = allKegiatan.find((k) => k.slug === slug && k.entry?.statusPublikasi === 'publish');
if (!item) {
  return Astro.redirect('/404');
}

const { entry } = item;
const articleHtml = renderMarkdown(entry.isi || '');
const articleUrl = toAbsoluteUrl(`/berita/${item.slug}`);
const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.judul));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage, entry.gambarUtama);

const shareLinks = [
  { label: 'WhatsApp', href: `https://wa.me/?text=${encodeURIComponent(entry.judul)}%20${encodeURIComponent(articleUrl)}`, icon: 'chat' },
  { label: 'Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(articleUrl)}`, icon: 'share' },
  { label: 'Salin', href: articleUrl, icon: 'content_copy', copy: true },
];

const relatedItems = findRelatedContent(
  createBeritaRelationItem(item, categoryLabels),
  [
    ...allKegiatan
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => createBeritaRelationItem(candidate, categoryLabels)),
    ...agendaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createAgendaRelationItem),
    ...programItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createProgramRelationItem),
    ...logItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLogRelationItem),
    ...lembagaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLembagaRelationItem),
    ...galeriItems.map(createGaleriRelationItem),
  ],
  4,
);

---

<MainLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={entry.tanggal}
  modifiedTime={entry.tanggal}
>

  <article class="container-premium max-w-4xl py-6 sm:py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Berita', href: '/berita' },
      { label: entry.judul, active: true },
    ]} />

    <header class="card mb-6 border border-base-300/70 bg-base-100 shadow-sm">
      <div class="card-body p-5 sm:p-6">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <Badge
          href={`/berita?kategori=${entry.kategori}`}
          label={categoryLabels[entry.kategori] ?? entry.kategori}
          tone="primary"
          variant="soft"
          class="hover:opacity-80"
        />
        {entry.jenisKonten && (
          <Badge
            label={jenisKontenKegiatanLabels[entry.jenisKonten] ?? entry.jenisKonten}
            tone="surface"
            variant="outline"
            class="capitalize"
          />
        )}
        {entry.unggulan && (
          <Badge label="Unggulan" tone="warning" variant="soft" icon="star" />
        )}
      </div>

      <h1 class="text-2xl font-bold leading-tight tracking-tight text-on-surface sm:text-3xl md:text-4xl">
        {entry.judul}
      </h1>

      <p class="mt-3 text-base leading-relaxed text-on-surface-variant">
        {entry.ringkasan}
      </p>

      <ContentMeta
        class="mt-4 flex flex-wrap items-center gap-4 border-t border-base-300/70 pt-4"
        items={[
          { icon: 'calendar_today', text: formatTanggal(entry.tanggal), datetime: entry.tanggal, accentClass: 'text-base-content/60' },
          ...(entry.penulis ? [{ icon: 'person', text: entry.penulis, accentClass: 'text-base-content/60' }] : []),
        ]}
        iconClass="text-[16px]"
      />
      </div>
    </header>

    {entry.gambarUtama && (
      <div class="card mb-8 overflow-hidden border border-base-300/70 bg-base-100 shadow-sm">
        <Image
          src={entry.gambarUtama}
          alt={entry.altGambarUtama || entry.judul}
          width={1200}
          height={675}
          class="h-auto w-full object-cover"
          loading="eager"
        />
      </div>
    )}

    <div
      class="article-rich berita-rich"
      set:html={articleHtml}
    />

    {entry.tag && entry.tag.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2 border-t border-outline-variant/40 pt-6">
        {entry.tag.map((tag: string) => (
          <Badge
            href={`/berita?tag=${encodeURIComponent(tag)}`}
            label={`#${getTagUmumLabel(tag)}`}
            tone="surface"
            variant="outline"
            class="transition-colors hover:border-primary hover:text-primary"
          />
        ))}
      </div>
    )}

    <ShareActions title="Bagikan artikel ini" links={shareLinks} />
  </article>

  <RelatedContentSection
    title="Konten Terkait Berita Ini"
    actionHref="/berita"
    actionLabel="Lihat arsip berita"
    items={relatedItems}
    sectionClass="bg-surface-container-low/50 py-10"
  />

</MainLayout>
