---
import { Image } from 'astro:assets';
import { marked } from 'marked';
import MainLayout from '../../layouts/MainLayout.astro';
import { resolveSeoImage, resolveSeoText, toAbsoluteUrl, withSiteTitle } from '../../lib/site';
import { formatTanggal, getKegiatan, getKategoriBeritaMap } from '../../lib/keystatic';
import NewsGrid from '../../components/NewsGrid.astro';

const { slug } = Astro.params;
const [categoryLabels, allKegiatan] = await Promise.all([getKategoriBeritaMap(), getKegiatan()]);

const item = allKegiatan.find((k) => k.slug === slug && k.entry?.statusPublikasi === 'publish');
if (!item) {
  return Astro.redirect('/404');
}

const { entry } = item;
const articleHtml = marked.parse(entry.isi || '', { breaks: true }) as string;
const articleUrl = toAbsoluteUrl(`/berita/${item.slug}`);
const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.judul));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage, entry.gambarUtama);

const shareLinks = [
  { label: 'WhatsApp', href: `https://wa.me/?text=${encodeURIComponent(entry.judul)}%20${encodeURIComponent(articleUrl)}`, icon: 'chat' },
  { label: 'Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(articleUrl)}`, icon: 'share' },
  { label: 'Salin', href: articleUrl, icon: 'content_copy', copy: true },
];

const relatedArticles = allKegiatan
  .filter((c) => c.slug !== item.slug && c.entry?.statusPublikasi === 'publish')
  .sort((a, b) => {
    const sameCatA = a.entry?.kategori === entry.kategori ? 1 : 0;
    const sameCatB = b.entry?.kategori === entry.kategori ? 1 : 0;
    if (sameCatA !== sameCatB) return sameCatB - sameCatA;
    const sharedA = (a.entry?.tag ?? []).filter((t) => entry.tag?.includes(t)).length;
    const sharedB = (b.entry?.tag ?? []).filter((t) => entry.tag?.includes(t)).length;
    return sharedB - sharedA;
  })
  .slice(0, 3);
---

<MainLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={entry.tanggal}
>

  <article class="container-premium max-w-4xl py-8">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-m3-primary transition-colors">Beranda</a>
      <span class="material-symbols-outlined text-[16px] text-outline-variant">chevron_right</span>
      <a href="/berita" class="hover:text-m3-primary transition-colors">Berita</a>
      <span class="material-symbols-outlined text-[16px] text-outline-variant">chevron_right</span>
      <span class="text-on-surface font-medium truncate max-w-[200px]">{entry.judul}</span>
    </nav>

    <!-- Article Header -->
    <header class="mb-6">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <a
          href={`/berita?kategori=${entry.kategori}`}
          class="text-[12px] font-semibold px-2.5 py-1 rounded-md bg-primary-container text-on-primary-container hover:opacity-80 transition-opacity"
        >
          {categoryLabels[entry.kategori] ?? entry.kategori}
        </a>
        {entry.jenisKonten && (
          <span class="text-[12px] font-semibold px-2.5 py-1 rounded-md bg-surface-variant text-on-surface-variant border border-outline-variant capitalize">
            {entry.jenisKonten}
          </span>
        )}
        {entry.unggulan && (
          <span class="text-[12px] font-semibold px-2.5 py-1 rounded-md bg-amber-100 text-amber-800 flex items-center gap-1">
            <span class="material-symbols-outlined text-[12px]">star</span> Unggulan
          </span>
        )}
      </div>

      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-on-surface leading-tight tracking-tight">
        {entry.judul}
      </h1>

      <p class="mt-3 text-base text-on-surface-variant leading-relaxed">
        {entry.ringkasan}
      </p>

      <div class="flex flex-wrap items-center gap-4 mt-4 pt-4 border-t border-outline-variant/40 text-sm text-on-surface-variant">
        <time class="flex items-center gap-1.5" datetime={entry.tanggal}>
          <span class="material-symbols-outlined text-[16px]">calendar_today</span>
          {formatTanggal(entry.tanggal)}
        </time>
        {entry.penulis && (
          <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-[16px]">person</span>
            {entry.penulis}
          </span>
        )}
      </div>
    </header>

    <!-- Hero Image -->
    {entry.gambarUtama && (
      <div class="rounded-xl overflow-hidden mb-8 border border-outline-variant">
        <Image
          src={entry.gambarUtama}
          alt={entry.altGambarUtama || entry.judul}
          width={1200}
          height={675}
          class="w-full h-auto object-cover"
          loading="eager"
        />
      </div>
    )}

    <!-- Article Body -->
    <div
      class="prose prose-slate prose-lg max-w-none
        prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-on-surface
        prose-p:text-on-surface-variant prose-p:leading-relaxed
        prose-a:text-m3-primary prose-a:no-underline hover:prose-a:underline
        prose-img:rounded-xl prose-img:border prose-img:border-outline-variant
        prose-blockquote:border-l-m3-primary prose-blockquote:bg-surface-container-low prose-blockquote:rounded-r-xl
        prose-code:text-m3-primary prose-code:bg-surface-container-low prose-code:rounded
        prose-pre:bg-inverse-surface prose-pre:rounded-xl"
      set:html={articleHtml}
    />

    <!-- Tags -->
    {entry.tag && entry.tag.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-outline-variant/40">
        {entry.tag.map((tag: string) => (
          <a
            href={`/berita?tag=${encodeURIComponent(tag)}`}
            class="text-[12px] font-semibold px-3 py-1.5 rounded-full bg-surface-container-low text-on-surface-variant border border-outline-variant hover:bg-primary-container hover:text-on-primary-container transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Share -->
    <div class="mt-8 pt-6 border-t border-outline-variant/40">
      <p class="text-sm font-semibold text-on-surface-variant mb-3">Bagikan artikel ini</p>
      <div class="flex gap-2">
        {shareLinks.map((link) => (
          <a
            href={link.href}
            class="grid h-10 w-10 place-items-center rounded-xl bg-surface-container-lowest border border-outline-variant text-on-surface-variant transition-colors hover:bg-primary-container hover:text-on-primary-container hover:border-transparent"
            target={link.copy ? undefined : '_blank'}
            rel={link.copy ? undefined : 'noreferrer'}
            title={link.label}
            data-copy-link={link.copy ? '' : undefined}
            data-copy-value={link.copy ? link.href : undefined}
          >
            <span class="material-symbols-outlined text-[20px]">{link.icon}</span>
          </a>
        ))}
      </div>
    </div>

  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="py-10 bg-surface-container-low/50">
      <div class="container-premium">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-[24px] font-bold leading-[32px] text-on-surface">Berita Terkait</h2>
          <a class="text-sm font-semibold text-m3-primary hover:underline" href="/berita">Lihat semua</a>
        </div>
        <NewsGrid items={relatedArticles.map((a) => ({ slug: a.slug, entry: a.entry as any }))} compact />
      </div>
    </section>
  )}

</MainLayout>

<script is:inline>
  document.querySelectorAll('[data-copy-link]').forEach((button) => {
    button.addEventListener('click', async (e) => {
      e.preventDefault();
      const value = button.getAttribute('data-copy-value') || '';
      try {
        await navigator.clipboard.writeText(value);
      } catch {}
    });
  });
</script>
