---
import MainLayout from '../../layouts/MainLayout.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import BadgeList from '../../components/ui/BadgeList.astro';
import StatCard from '../../components/ui/StatCard.astro';
import PageSection from '../../components/PageSection.astro';
import MetricGrid from '../../components/ui/MetricGrid.astro';
import { formatTanggal, getKasRt, getPengaturan } from '../../lib/content';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [items, pengaturan] = await Promise.all([getKasRt(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.kasRt;
const reports = items.filter(({ entry }) => entry.statusPublikasi === 'publish').sort((a, b) => new Date(b.entry.tanggalUpdate).getTime() - new Date(a.entry.tanggalUpdate).getTime());
const totalSaldo = reports.reduce((sum, item) => sum + item.entry.saldoAkhir, 0);
function formatRupiah(value: number) { return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(value); }
---

<MainLayout title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Transparansi Kas RT'))} description={resolveSeoText(seo?.seoDescription, 'Ringkasan pemasukan, pengeluaran, dan saldo kas RT warga Padukuhan Salakan.')} image={resolveSeoImage(seo?.ogImage)}>
  <PageIntro
    title="Transparansi Kas RT"
    description="Ringkasan kas disusun dalam format yang mudah dibaca warga: fokus pada periode, arus masuk-keluar, saldo, dan catatan penggunaan utama."
    breadcrumbs={[{ label: 'Beranda', href: '/' }, { label: 'Pusat Data', href: '/data' }, { label: 'Transparansi Kas RT', active: true }]}
  />

  <section class="container-premium py-4 sm:py-6">
    <div class="grid gap-4 md:grid-cols-3">
      <StatCard label="Periode Tayang" value={reports.length} icon="receipt_long" variant="blue" />
      <StatCard label="Saldo Tercatat" value={formatRupiah(totalSaldo)} icon="account_balance_wallet" variant="emerald" />
      <StatCard label="Pembaruan Terakhir" value={reports[0] ? formatTanggal(reports[0].entry.tanggalUpdate) : '-'} icon="calendar_today" variant="slate" />
    </div>
  </section>

  <PageSection sectionClass="pb-10 pt-4 sm:pb-14" title="Laporan Kas" eyebrow="Ringkasan Periode">
    <div class="grid gap-4 lg:grid-cols-2">
      {reports.map(({ slug, entry }) => (
        <article class="card border border-base-300/70 bg-base-100 shadow-sm" id={slug}>
          <div class="card-body p-5">
          <div class="mb-3 flex flex-wrap items-center gap-2">
            <BadgeList
              items={[
                { label: entry.periode, tone: 'primary' },
                { label: 'Sorotan', tone: 'warning', visible: entry.unggulan },
              ]}
            />
            <time class="badge badge-ghost rounded-full px-3 py-3 text-[12px] font-medium" datetime={entry.tanggalUpdate}>{formatTanggal(entry.tanggalUpdate)}</time>
          </div>
          <p class="text-sm leading-relaxed text-base-content/65">{entry.ringkasan}</p>
          <MetricGrid
            class="mt-4 grid gap-3 sm:grid-cols-3"
            items={[
              { label: 'Masuk', value: formatRupiah(entry.pemasukan), class: 'border-base-300/70 bg-base-200/50 px-4 py-3' },
              { label: 'Keluar', value: formatRupiah(entry.pengeluaran), class: 'border-base-300/70 bg-base-200/50 px-4 py-3' },
              { label: 'Saldo', value: formatRupiah(entry.saldoAkhir), class: 'border-base-300/70 bg-base-200/50 px-4 py-3' },
            ]}
          />
          <div class="mt-4 border-t border-base-300/70 pt-4"><p class="detail-label">Sumber Dana</p><BadgeList class="mt-2 flex flex-wrap gap-2" items={entry.sumberDana.map((source) => ({ label: source, tone: 'surface', class: 'px-2 py-1' }))} />{entry.catatan && <p class="mt-3 text-sm leading-relaxed text-base-content/65">{entry.catatan}</p>}</div>
          </div>
        </article>
      ))}
    </div>
  </PageSection>
</MainLayout>
