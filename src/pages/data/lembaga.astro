---
import MainLayout from '../../layouts/MainLayout.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import PillFilterBar from '../../components/ui/PillFilterBar.astro';
import StatCard from '../../components/ui/StatCard.astro';
import BadgeList from '../../components/ui/BadgeList.astro';
import ActionLinkButton from '../../components/ui/ActionLinkButton.astro';
import LabelValueList from '../../components/ui/LabelValueList.astro';
import InlineAction from '../../components/ui/InlineAction.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';
import DaisyCard from '../../components/ui/DaisyCard.astro';
import DaisyFactCard from '../../components/ui/DaisyFactCard.astro';
import Icon from '../../components/ui/Icon.tsx';
import {
  excerpt,
  formatTanggal,
  getAgenda,
  getGaleri,
  getKegiatan,
  getKategoriBeritaMap,
  getLogKegiatan,
  getPengaturan,
  getProgram,
  getStrukturOrganisasi,
} from '../../lib/content';
import { BIDANG_LEMBAGA, bidangLembagaIcons, bidangLembagaLabels, getFokusLembagaLabel } from '../../lib/content-taxonomy';
import {
  createAgendaRelationItem,
  createBeritaRelationItem,
  createGaleriRelationItem,
  createLembagaRelationItem,
  createLogRelationItem,
  createProgramRelationItem,
} from '../../lib/content-relations';
import { findRelatedContent } from '../../lib/related-content';
import { markdownToText, renderMarkdown } from '../../lib/rich-text';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [lembagaItems, pengaturan, agendaItems, beritaItems, programItems, logItems, galeriItems, categoryLabels] = await Promise.all([
  getStrukturOrganisasi(),
  getPengaturan(),
  getAgenda(),
  getKegiatan(),
  getProgram(),
  getLogKegiatan(),
  getGaleri(),
  getKategoriBeritaMap(),
]);
const seo = pengaturan?.seoHalamanData?.strukturOrganisasi;
const items = lembagaItems
  .filter(({ entry }) => entry.statusPublikasi === 'publish')
  .sort((a, b) => a.entry.urutanTampil - b.entry.urutanTampil)
  .map((item) => ({
    ...item,
    entry: {
      ...item.entry,
      fokusKegiatan: item.entry.fokusKegiatan ?? [],
      layananUtama: item.entry.layananUtama ?? [],
      dokumentasiTerkait: item.entry.dokumentasiTerkait ?? [],
    },
  }));

const bidangParam = Astro.url.searchParams.get('bidang') ?? 'semua';
const activeBidang = ['semua', ...BIDANG_LEMBAGA].includes(bidangParam) ? bidangParam : 'semua';
const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const normalizedQuery = query.toLowerCase();

const grouped = {
  pimpinan: items.filter(({ entry }) => entry.bidang === 'pimpinan'),
  kegiatan: items.filter(({ entry }) => entry.bidang === 'kegiatan'),
  wilayah: items.filter(({ entry }) => entry.bidang === 'wilayah'),
} as const;

function matchesSearch(value: typeof items[number]) {
  if (!normalizedQuery) return true;

  const haystack = [
    value.entry.jabatan,
    value.entry.namaPejabat,
    value.entry.ringkasan,
    markdownToText(value.entry.deskripsiTugas),
    value.entry.kontak,
    value.entry.jadwalRutin,
    value.entry.lokasiKegiatan,
    ...value.entry.fokusKegiatan,
    ...value.entry.layananUtama,
    ...value.entry.dokumentasiTerkait.map((item) => item.label),
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();

  return haystack.includes(normalizedQuery);
}

function formatFokusLabel(value: string) {
  return getFokusLembagaLabel(value);
}

const filteredByBidang = activeBidang === 'semua'
  ? items
  : items.filter(({ entry }) => entry.bidang === activeBidang);

const filteredItems = filteredByBidang.filter(matchesSearch);

const highlighted = filteredItems[0] ?? items[0] ?? null;
const rutinCount = items.filter(({ entry }) => entry.jadwalRutin).length;
const dokumentasiCount = items.reduce((sum, item) => sum + item.entry.dokumentasiTerkait.length, 0);
const activeBidangLabel = activeBidang === 'semua' ? 'Semua bidang' : bidangLembagaLabels[activeBidang as keyof typeof bidangLembagaLabels];

const relationCandidates = [
  ...agendaItems
    .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
    .map(createAgendaRelationItem),
  ...beritaItems
    .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
    .map((candidate) => createBeritaRelationItem(candidate, categoryLabels)),
  ...programItems
    .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
    .map(createProgramRelationItem),
  ...logItems
    .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
    .map(createLogRelationItem),
  ...galeriItems.map(createGaleriRelationItem),
];

const highlightedRelated = highlighted
  ? findRelatedContent(createLembagaRelationItem(highlighted), relationCandidates, 3)
  : [];

const filteredItemsWithRelations = filteredItems.map((item) => ({
  ...item,
  relatedItems: findRelatedContent(createLembagaRelationItem(item), relationCandidates, 3),
}));
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Lembaga Padukuhan'))}
  description={resolveSeoText(seo?.seoDescription, 'Informasi lembaga dan organisasi yang berada di wilayah Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <PageIntro
    title="Lembaga Padukuhan"
    description={`Direktori lembaga dan organisasi yang bergerak di wilayah Padukuhan Salakan. Saat ini ada ${items.length} lembaga aktif yang ditampilkan untuk membantu warga mengenali pengampu kegiatan, fokus kerja, dan jalur koordinasinya.`}
    breadcrumbs={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'Lembaga', active: true },
    ]}
  >
    <PillFilterBar
      items={[
        { href: query ? `/data/lembaga?q=${encodeURIComponent(query)}` : '/data/lembaga', label: 'Semua bidang', active: activeBidang === 'semua' },
        { href: `/data/lembaga?bidang=pimpinan${query ? `&q=${encodeURIComponent(query)}` : ''}`, label: bidangLembagaLabels.pimpinan, active: activeBidang === 'pimpinan' },
        { href: `/data/lembaga?bidang=kegiatan${query ? `&q=${encodeURIComponent(query)}` : ''}`, label: bidangLembagaLabels.kegiatan, active: activeBidang === 'kegiatan' },
        { href: `/data/lembaga?bidang=wilayah${query ? `&q=${encodeURIComponent(query)}` : ''}`, label: bidangLembagaLabels.wilayah, active: activeBidang === 'wilayah' },
      ]}
    />
  </PageIntro>

  <section class="container-premium py-3 sm:py-4">
    <DaisyCard as="form" action="/data/lembaga" method="get" bodyClass="card-body grid gap-3 p-5 sm:p-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
      <div class="grid gap-2">
        <label for="search-lembaga" class="detail-label">Cari lembaga, pengampu, fokus, atau layanan</label>
        <div class="input input-bordered flex h-auto min-h-12 items-center gap-3 rounded-2xl bg-base-100 px-4 py-3 focus-within:outline focus-within:outline-2 focus-within:outline-primary/35">
          <Icon name="search" class="text-[20px] text-primary" />
          <input
            id="search-lembaga"
            name="q"
            type="search"
            value={query}
            placeholder="Contoh: posyandu, keamanan, pembangunan"
            class="w-full border-0 bg-transparent p-0 text-sm text-base-content outline-none placeholder:text-base-content/50"
          />
        </div>
        <input type="hidden" name="bidang" value={activeBidang} />
      </div>
      <div class="flex flex-wrap gap-2">
        <button
          type="submit"
          class="btn btn-primary"
        >
          <Icon name="search" class="text-[18px]" />
          Cari
        </button>
        {(query || activeBidang !== 'semua') && (
          <a
            href="/data/lembaga"
            class="btn btn-outline"
          >
            <Icon name="restart_alt" class="text-[18px]" />
            Reset filter
          </a>
        )}
      </div>
    </DaisyCard>
  </section>

  <section class="container-premium py-4 sm:py-6">
    <div class="grid gap-4 md:grid-cols-3">
      <StatCard label="Lembaga Aktif" value={items.length} icon="account_balance" variant="blue" description="Direktori organisasi dan pengampu kegiatan warga yang sedang ditampilkan." />
      <StatCard label="Jadwal Tersedia" value={rutinCount} icon="event_note" variant="emerald" description="Lembaga yang sudah memiliki informasi ritme kegiatan atau pertemuan rutin." />
      <StatCard label="Dokumentasi Terkait" value={dokumentasiCount} icon="library_books" variant="amber" description="Tautan agenda, berita, atau arsip yang membantu warga menelusuri kegiatan lembaga." />
    </div>
  </section>

  <section class="container-premium py-8">
    <div class="grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
      {highlighted && (
        <DaisyCard as="article" bodyClass="card-body grid gap-5 p-5 sm:p-6 lg:grid-cols-[1.1fr_0.9fr]">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <BadgeList
                class="flex flex-wrap items-center gap-2"
                items={[
                  {
                    label: bidangLembagaLabels[highlighted.entry.bidang as keyof typeof bidangLembagaLabels],
                    tone: 'primary',
                  },
                  {
                    label: `${highlighted.entry.fokusKegiatan.length} fokus kerja`,
                    tone: 'surface',
                    variant: 'ghost',
                    visible: highlighted.entry.fokusKegiatan.length > 0,
                  },
                ]}
              />
            </div>
            <h2 class="mt-4 text-2xl font-bold tracking-tight text-base-content">{highlighted.entry.jabatan}</h2>
            <p class="mt-1 text-sm font-semibold text-base-content/70">Pengampu: {highlighted.entry.namaPejabat}</p>
            <p class="mt-3 text-base leading-relaxed text-base-content/70">
              {highlighted.entry.ringkasan || markdownToText(highlighted.entry.deskripsiTugas)}
            </p>
            {highlighted.entry.fokusKegiatan.length > 0 && (
              <BadgeList
                class="mt-4 flex flex-wrap gap-2"
                items={highlighted.entry.fokusKegiatan.map((item) => ({
                  label: formatFokusLabel(item),
                  tone: 'surface' as const,
                }))}
              />
            )}
            {highlighted.entry.layananUtama.length > 0 && (
              <div class="mt-5 border-t border-base-300/70 pt-4">
                <p class="detail-label">Layanan atau peran utama</p>
                <ul class="mt-3 grid gap-2 text-sm leading-relaxed text-base-content/70">
                  {highlighted.entry.layananUtama.map((item) => (
                    <li class="rounded-xl border border-base-300/70 bg-base-200 px-4 py-3">{item}</li>
                  ))}
                </ul>
              </div>
            )}
            {highlighted.entry.dokumentasiTerkait.length > 0 && (
              <div class="mt-5 border-t border-base-300/70 pt-4">
                <p class="detail-label">Dokumentasi terkait</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {highlighted.entry.dokumentasiTerkait.map((item) => (
                    <InlineAction href={item.href} label={item.label} icon="arrow_outward" />
                  ))}
                </div>
              </div>
            )}
            {highlightedRelated.length > 0 && (
              <div class="mt-5 border-t border-base-300/70 pt-4">
                <p class="detail-label">Konten terkait</p>
                <div class="mt-3 grid gap-3">
                  {highlightedRelated.map((related) => (
                    <ArchiveCard
                      href={related.href}
                      title={related.title}
                      summary={excerpt(related.summary || '', 120)}
                      badges={[{ label: related.typeLabel, tone: related.badgeTone ?? 'surface' }]}
                      meta={[
                        ...(related.date ? [{ icon: 'calendar_today', text: formatTanggal(related.date), datetime: related.date }] : []),
                      ]}
                      class="gap-3 p-4"
                    />
                  ))}
                </div>
              </div>
            )}
          </div>

          <div class="grid gap-3">
            <DaisyFactCard label="Bidang" value={bidangLembagaLabels[highlighted.entry.bidang as keyof typeof bidangLembagaLabels]} />
            <DaisyFactCard label="Jadwal rutin" value={highlighted.entry.jadwalRutin || 'Menyesuaikan kebutuhan dan agenda warga'} />
            <DaisyFactCard label="Lokasi kegiatan" value={highlighted.entry.lokasiKegiatan || 'Wilayah Padukuhan Salakan'} />
            <DaisyFactCard label="Kontak koordinasi" value={highlighted.entry.kontak} />
            <div class="pt-1">
              <ActionLinkButton href="/kontak" label="Butuh jalur kontak umum" icon="arrow_forward" variant="outline" />
            </div>
          </div>
        </DaisyCard>
      )}

      <DaisyCard>
        <div class="flex items-center gap-3">
          <div class="grid h-11 w-11 place-items-center rounded-xl bg-base-200 text-primary">
            <Icon name="groups" class="text-[22px]" />
          </div>
          <div>
            <p class="section-kicker">Ringkasan Direktori</p>
            <h2 class="mt-1 text-xl font-bold tracking-tight text-base-content">Pilih lembaga yang paling relevan</h2>
          </div>
        </div>
        <div class="mt-4 space-y-3">
          {Object.entries(grouped).map(([key, groupItems]) => (
            <DaisyFactCard
              label={bidangLembagaLabels[key as keyof typeof bidangLembagaLabels]}
              value={`${groupItems.length} lembaga aktif`}
              icon={bidangLembagaIcons[key as keyof typeof bidangLembagaIcons]}
              href={`/data/lembaga?bidang=${key}${query ? `&q=${encodeURIComponent(query)}` : ''}`}
            />
          ))}
        </div>
      </DaisyCard>
    </div>
  </section>

  <section class="container-premium pb-10 pt-2 sm:pb-14">
    <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="section-kicker">Daftar Lembaga</p>
        <h2 class="mt-1 text-2xl font-bold tracking-tight text-base-content">Direktori organisasi warga</h2>
      </div>
      <p class="max-w-xl text-sm leading-relaxed text-base-content/70">
        {query
          ? `Menampilkan ${filteredItems.length} hasil untuk pencarian "${query}" pada ${activeBidangLabel.toLowerCase()}.`
          : activeBidang === 'semua'
            ? 'Semua lembaga ditampilkan agar warga lebih mudah mengenali peran, ritme kegiatan, dan jalur koordinasinya.'
            : `Menampilkan lembaga pada bidang ${bidangLembagaLabels[activeBidang as keyof typeof bidangLembagaLabels].toLowerCase()}.`}
      </p>
    </div>

    {filteredItems.length > 0 ? (
      <div class="space-y-4">
        {filteredItemsWithRelations.map(({ slug, entry, relatedItems }, index) => (
          <details class="collapse collapse-arrow group border border-base-300/70 bg-base-100 shadow-sm transition-all open:shadow-md" id={slug} open={index === 0 && !query}>
            <summary class="collapse-title flex cursor-pointer list-none items-start gap-4 p-5 pr-14 sm:p-6 sm:pr-14">
              <div class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-primary text-primary-content">
                <Icon name={bidangLembagaIcons[entry.bidang as keyof typeof bidangLembagaIcons]} class="text-[20px]" />
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <BadgeList
                    class="flex flex-wrap items-center gap-2"
                    items={[
                      {
                        label: bidangLembagaLabels[entry.bidang as keyof typeof bidangLembagaLabels],
                        tone: 'primary',
                      },
                      {
                        label: `${entry.fokusKegiatan.length} fokus`,
                        tone: 'surface',
                        variant: 'ghost',
                        visible: entry.fokusKegiatan.length > 0,
                      },
                    ]}
                  />
                </div>
                <h3 class="mt-3 text-xl font-bold tracking-tight text-base-content transition-colors group-hover:text-primary">{entry.jabatan}</h3>
                <p class="mt-1 text-sm font-semibold text-base-content/70">Pengampu: {entry.namaPejabat}</p>
                <p class="mt-3 max-w-3xl text-sm leading-relaxed text-base-content/70">
                  {entry.ringkasan || markdownToText(entry.deskripsiTugas)}
                </p>
              </div>
            </summary>

            <div class="collapse-content border-t border-base-300/70 px-5 pb-5 pt-5 sm:px-6 sm:pb-6">
              {entry.fokusKegiatan.length > 0 && (
                <BadgeList
                  class="flex flex-wrap gap-2"
                  items={entry.fokusKegiatan.map((item) => ({
                    label: formatFokusLabel(item),
                    tone: 'surface' as const,
                  }))}
                />
              )}

              <div class="mt-4 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
                <DaisyCard surface="muted" shadow="none" bodyClass="card-body p-4">
                  <p class="detail-label">Deskripsi tugas</p>
                  <div class="article-rich mt-3 text-sm leading-relaxed text-base-content/70" set:html={renderMarkdown(entry.deskripsiTugas)} />
                  <LabelValueList
                    class="mt-4"
                    items={[
                      { label: 'Jadwal rutin', value: entry.jadwalRutin },
                      { label: 'Lokasi kegiatan', value: entry.lokasiKegiatan },
                      { label: 'Kontak koordinasi', value: entry.kontak },
                    ]}
                  />
                </DaisyCard>

                <DaisyCard surface="muted" shadow="none" bodyClass="card-body p-4">
                  <p class="detail-label">Peran utama</p>
                  {entry.layananUtama.length > 0 ? (
                    <ul class="mt-3 grid gap-2 text-sm leading-relaxed text-base-content/70">
                      {entry.layananUtama.map((item) => (
                        <li class="rounded-xl border border-base-300/70 bg-base-100 px-4 py-3">{item}</li>
                      ))}
                    </ul>
                  ) : (
                    <p class="mt-3 text-sm leading-relaxed text-base-content/70">Peran utama lembaga ini mengikuti kebutuhan koordinasi dan pelayanan warga.</p>
                  )}
                </DaisyCard>
              </div>

              {entry.dokumentasiTerkait.length > 0 && (
                <DaisyCard surface="muted" shadow="none" class="mt-4" bodyClass="card-body p-4">
                  <p class="detail-label">Dokumentasi terkait</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {entry.dokumentasiTerkait.map((item) => (
                      <InlineAction href={item.href} label={item.label} icon="arrow_outward" />
                    ))}
                  </div>
                </DaisyCard>
              )}

              {relatedItems.length > 0 && (
                <DaisyCard surface="muted" shadow="none" class="mt-4" bodyClass="card-body p-4">
                  <p class="detail-label">Konten terkait</p>
                  <div class="mt-3 grid gap-3 lg:grid-cols-2">
                    {relatedItems.map((related) => (
                      <ArchiveCard
                        href={related.href}
                        title={related.title}
                        summary={excerpt(related.summary || '', 110)}
                        badges={[{ label: related.typeLabel, tone: related.badgeTone ?? 'surface' }]}
                        meta={[
                          ...(related.date ? [{ icon: 'calendar_today', text: formatTanggal(related.date), datetime: related.date }] : []),
                        ]}
                        class="gap-3 p-4"
                      />
                    ))}
                  </div>
                </DaisyCard>
              )}
            </div>
          </details>
        ))}
      </div>
    ) : (
      <DaisyCard class="text-center" bodyClass="card-body p-6 sm:p-8">
        <div class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-base-200 text-primary">
          <Icon name="search_off" class="text-[28px]" />
        </div>
        <h3 class="mt-4 text-xl font-bold tracking-tight text-base-content">Belum ada lembaga yang cocok</h3>
        <p class="mx-auto mt-2 max-w-2xl text-sm leading-relaxed text-base-content/70">
          Coba gunakan kata kunci yang lebih umum, atau reset filter agar semua organisasi warga di Padukuhan Salakan ditampilkan kembali.
        </p>
        <div class="mt-5 flex flex-wrap justify-center gap-2">
          <ActionLinkButton href="/data/lembaga" label="Tampilkan semua lembaga" icon="restart_alt" variant="outline" />
          <ActionLinkButton href="/kontak" label="Hubungi padukuhan" icon="call" variant="outline" />
        </div>
      </DaisyCard>
    )}
  </section>
</MainLayout>
