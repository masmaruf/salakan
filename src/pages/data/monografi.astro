---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import StatCard from '../../components/ui/StatCard.astro';
import { getPengaturan, getMonografi } from '../../lib/content';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const pengaturan = await getPengaturan();
const monografi = await getMonografi();

if (!monografi) {
  return Astro.redirect('/404');
}

const { identitasDukuh, demografi, fasilitas, potensi } = monografi;
const seo = pengaturan?.seoHalamanData?.monografi;

const statsPendidikan = [
  { label: 'TK/PAUD', value: fasilitas.pendidikan.tkPaud, icon: 'child_care' },
  { label: 'SD', value: fasilitas.pendidikan.sd, icon: 'school' },
  { label: 'SMP', value: fasilitas.pendidikan.smp, icon: 'menu_book' },
  { label: 'SMK', value: fasilitas.pendidikan.smk, icon: 'construction' },
  { label: 'SLB', value: fasilitas.pendidikan.slb, icon: 'accessibility_new' },
  { label: 'PKBM', value: fasilitas.pendidikan.pkbm, icon: 'edit_note' },
  { label: 'PT/Univ', value: fasilitas.pendidikan.universitas, icon: 'account_balance' },
];

const statsKesehatan = [
  { label: 'Puskesmas', value: fasilitas.kesehatan.puskesmas, icon: 'local_hospital' },
  { label: 'Posyandu Balita', value: fasilitas.kesehatan.posyanduBalita, icon: 'baby_changing_station' },
  { label: 'Posyandu Lansia', value: fasilitas.kesehatan.posyanduLansia, icon: 'elderly' },
];

import Icon from '../../components/ui/Icon.tsx';
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Monografi & Data Wilayah'))}
  description={resolveSeoText(seo?.seoDescription, 'Data monografi, kependudukan, fasilitas, dan potensi Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>

  <div class="container-premium pt-8 pb-4">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'Monografi', active: true },
    ]} />
    <h1 class="text-[28px] font-bold leading-[36px] text-on-surface">Data Monografi</h1>
    <p class="text-base text-on-surface-variant mt-1 max-w-2xl">
      Profil kependudukan, sarana prasarana, dan potensi seni & ekonomi Padukuhan Salakan.
    </p>
  </div>

  <section class="container-premium py-8 space-y-10">

    <!-- Identitas Dukuh -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 sm:p-6">
      <div class="flex items-center gap-4">
        <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary-container/30 text-m3-primary">
          <Icon name="face_6" class="text-[22px]" />
        </div>
        <div>
          <span class="text-[12px] font-semibold text-m3-primary uppercase tracking-wider">Identitas Dukuh</span>
          <h2 class="text-lg font-bold text-on-surface">{identitasDukuh.namaDukuh}</h2>
        </div>
      </div>
      <div class="flex flex-wrap gap-4 mt-4 text-sm text-on-surface-variant">
        <span class="flex items-center gap-1.5">
          <Icon name="school" class="text-[16px]" /> {identitasDukuh.pendidikan}
        </span>
        <span class="flex items-center gap-1.5">
          <Icon name="location_on" class="text-[16px]" /> {identitasDukuh.alamat}
        </span>
      </div>
    </div>

    <!-- Demografi -->
    <div>
      <h2 class="text-[20px] font-bold text-on-surface mb-4">Kependudukan & Demografi</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <StatCard label="Total Jiwa" value={demografi.totalJiwa} icon="group" variant="blue" />
        <StatCard label="Laki-laki" value={demografi.totalLakiLaki} icon="male" variant="blue" description={`${Math.round((demografi.totalLakiLaki / demografi.totalJiwa) * 100)}% dari populasi`} />
        <StatCard label="Perempuan" value={demografi.totalPerempuan} icon="female" variant="amber" description={`${Math.round((demografi.totalPerempuan / demografi.totalJiwa) * 100)}% dari populasi`} />
        <StatCard label="Kepala Keluarga" value={demografi.totalKK} icon="home" variant="slate" description={`L: ${demografi.kkLakiLaki} | P: ${demografi.kkPerempuan}`} />
      </div>
      <div class="grid gap-3 sm:grid-cols-2 mt-3">
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-4 flex items-center gap-3">
          <div class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-surface-container-high text-on-surface-variant">
            <Icon name="straighten" class="text-[20px]" />
          </div>
          <div>
            <p class="text-[12px] text-on-surface-variant">Luas Wilayah</p>
            <p class="text-sm font-bold text-on-surface">{demografi.luasWilayah}</p>
          </div>
        </div>
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-4 flex items-center gap-3">
          <div class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-surface-container-high text-on-surface-variant">
            <Icon name="grid_view" class="text-[20px]" />
          </div>
          <div>
            <p class="text-[12px] text-on-surface-variant">Wilayah RT</p>
            <p class="text-sm font-bold text-on-surface">{demografi.jumlahRT} Unit RT</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Fasilitas -->
    <div class="grid gap-8 lg:grid-cols-2">
      <div>
        <h2 class="text-[20px] font-bold text-on-surface mb-4 flex items-center gap-2">
          <Icon name="school" class="text-[20px] text-m3-primary" /> Sarana Pendidikan
        </h2>
        <div class="grid gap-2 sm:grid-cols-2">
          {statsPendidikan.map((item) => (
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="grid h-8 w-8 place-items-center rounded-lg bg-surface-container-high text-on-surface-variant">
                  <Icon name={item.icon} class="text-[16px]" />
                </div>
                <span class="text-sm font-medium text-on-surface">{item.label}</span>
              </div>
              <span class="text-sm font-bold text-m3-primary">{item.value}</span>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-[20px] font-bold text-on-surface mb-4 flex items-center gap-2">
          <Icon name="health_and_safety" class="text-[20px] text-m3-error" /> Sarana Kesehatan
        </h2>
        <div class="grid gap-2">
          {statsKesehatan.map((item) => (
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="grid h-8 w-8 place-items-center rounded-lg bg-error-container/30 text-m3-error">
                  <Icon name={item.icon} class="text-[16px]" />
                </div>
                <span class="text-sm font-medium text-on-surface">{item.label}</span>
              </div>
              <span class="text-sm font-bold text-m3-error">{item.value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Potensi -->
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="bg-inverse-surface rounded-xl p-6">
        <h2 class="text-base font-bold text-inverse-on-surface flex items-center gap-2 mb-4">
          <Icon name="theater_comedy" class="text-[18px]" /> Seni & Budaya
        </h2>
        <div class="flex flex-wrap gap-2">
          {potensi.seniBudaya.map((item) => (
            <span class="text-[12px] font-semibold px-3 py-1.5 rounded-full bg-white/10 text-inverse-on-surface border border-white/10">
              {item}
            </span>
          ))}
        </div>
      </div>
      <div class="bg-m3-primary rounded-xl p-6">
        <h2 class="text-base font-bold text-on-primary flex items-center gap-2 mb-4">
          <Icon name="storefront" class="text-[18px]" /> UMKM & Industri
        </h2>
        <div class="flex flex-wrap gap-2">
          {potensi.umkmIndustri.map((item) => (
            <span class="text-[12px] font-semibold px-3 py-1.5 rounded-full bg-white/20 text-on-primary border border-white/20">
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>

  </section>

</MainLayout>
