---
import MainLayout from '../../layouts/MainLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import BadgeList from '../../components/ui/BadgeList.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import StatCard from '../../components/ui/StatCard.astro';
import { getPengaturan, getMonografi } from '../../lib/content';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const pengaturan = await getPengaturan();
const monografi = await getMonografi();

if (!monografi) {
  return Astro.redirect('/404');
}

const { identitasDukuh, demografi, fasilitas, potensi } = monografi;
const seo = pengaturan?.seoHalamanData?.monografi;

const statsPendidikan = [
  { label: 'TK/PAUD', value: fasilitas.pendidikan.tkPaud, icon: 'child_care' },
  { label: 'SD', value: fasilitas.pendidikan.sd, icon: 'school' },
  { label: 'SMP', value: fasilitas.pendidikan.smp, icon: 'menu_book' },
  { label: 'SMK', value: fasilitas.pendidikan.smk, icon: 'construction' },
  { label: 'SLB', value: fasilitas.pendidikan.slb, icon: 'accessibility_new' },
  { label: 'PKBM', value: fasilitas.pendidikan.pkbm, icon: 'edit_note' },
  { label: 'PT/Univ', value: fasilitas.pendidikan.universitas, icon: 'account_balance' },
];

const statsKesehatan = [
  { label: 'Puskesmas', value: fasilitas.kesehatan.puskesmas, icon: 'local_hospital' },
  { label: 'Posyandu Balita', value: fasilitas.kesehatan.posyanduBalita, icon: 'baby_changing_station' },
  { label: 'Posyandu Lansia', value: fasilitas.kesehatan.posyanduLansia, icon: 'elderly' },
];

import Icon from '../../components/ui/Icon.tsx';
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Monografi & Data Wilayah'))}
  description={resolveSeoText(seo?.seoDescription, 'Data monografi, kependudukan, fasilitas, dan potensi Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>

  <PageIntro
    title="Data Monografi"
    description="Profil kependudukan, sarana prasarana, dan potensi seni & ekonomi Padukuhan Salakan."
    breadcrumbs={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'Monografi', active: true },
    ]}
  />

  <section class="container-premium space-y-10 py-8">

    <!-- Identitas Dukuh -->
    <div class="card border border-base-300/70 bg-base-100 shadow-sm">
      <div class="card-body p-5 sm:p-6">
        <div class="flex items-center gap-4">
          <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary/10 text-primary">
            <Icon name="face_6" class="text-[22px]" />
          </div>
          <div>
            <span class="text-[12px] font-semibold uppercase tracking-wider text-primary">Identitas Dukuh</span>
            <h2 class="text-lg font-bold text-base-content">{identitasDukuh.namaDukuh}</h2>
          </div>
        </div>
        <div class="mt-4 flex flex-wrap gap-4 text-sm text-base-content/70">
          <span class="flex items-center gap-1.5">
            <Icon name="school" class="text-[16px]" /> {identitasDukuh.pendidikan}
          </span>
          <span class="flex items-center gap-1.5">
            <Icon name="location_on" class="text-[16px]" /> {identitasDukuh.alamat}
          </span>
        </div>
      </div>
    </div>

    <!-- Demografi -->
    <div>
      <h2 class="mb-4 text-[20px] font-bold text-base-content">Kependudukan & Demografi</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <StatCard label="Total Jiwa" value={demografi.totalJiwa} icon="group" variant="blue" />
        <StatCard label="Laki-laki" value={demografi.totalLakiLaki} icon="male" variant="blue" description={`${Math.round((demografi.totalLakiLaki / demografi.totalJiwa) * 100)}% dari populasi`} />
        <StatCard label="Perempuan" value={demografi.totalPerempuan} icon="female" variant="amber" description={`${Math.round((demografi.totalPerempuan / demografi.totalJiwa) * 100)}% dari populasi`} />
        <StatCard label="Kepala Keluarga" value={demografi.totalKK} icon="home" variant="slate" description={`L: ${demografi.kkLakiLaki} | P: ${demografi.kkPerempuan}`} />
      </div>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <div class="card border border-base-300/70 bg-base-100 shadow-sm">
          <div class="card-body flex-row items-center gap-3 p-4">
            <div class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-base-200 text-base-content/70">
              <Icon name="straighten" class="text-[20px]" />
            </div>
            <div>
              <p class="text-[12px] text-base-content/60">Luas Wilayah</p>
              <p class="text-sm font-bold text-base-content">{demografi.luasWilayah}</p>
            </div>
          </div>
        </div>
        <div class="card border border-base-300/70 bg-base-100 shadow-sm">
          <div class="card-body flex-row items-center gap-3 p-4">
            <div class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-base-200 text-base-content/70">
              <Icon name="grid_view" class="text-[20px]" />
            </div>
            <div>
              <p class="text-[12px] text-base-content/60">Wilayah RT</p>
              <p class="text-sm font-bold text-base-content">{demografi.jumlahRT} Unit RT</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Fasilitas -->
    <div class="grid gap-8 lg:grid-cols-2">
      <div>
        <h2 class="mb-4 flex items-center gap-2 text-[20px] font-bold text-base-content">
          <Icon name="school" class="text-[20px] text-primary" /> Sarana Pendidikan
        </h2>
        <div class="grid gap-2 sm:grid-cols-2">
          {statsPendidikan.map((item) => (
            <div class="card border border-base-300/70 bg-base-100 shadow-sm">
              <div class="card-body flex-row items-center justify-between p-4">
                <div class="flex items-center gap-3">
                  <div class="grid h-8 w-8 place-items-center rounded-lg bg-base-200 text-base-content/70">
                    <Icon name={item.icon} class="text-[16px]" />
                  </div>
                  <span class="text-sm font-medium text-base-content">{item.label}</span>
                </div>
                <Badge label={`${item.value}`} tone="primary" class="tabular-nums" />
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="mb-4 flex items-center gap-2 text-[20px] font-bold text-base-content">
          <Icon name="health_and_safety" class="text-[20px] text-error" /> Sarana Kesehatan
        </h2>
        <div class="grid gap-2">
          {statsKesehatan.map((item) => (
            <div class="card border border-base-300/70 bg-base-100 shadow-sm">
              <div class="card-body flex-row items-center justify-between p-4">
                <div class="flex items-center gap-3">
                  <div class="grid h-8 w-8 place-items-center rounded-lg bg-error/10 text-error">
                    <Icon name={item.icon} class="text-[16px]" />
                  </div>
                  <span class="text-sm font-medium text-base-content">{item.label}</span>
                </div>
                <Badge label={`${item.value}`} tone="error" class="tabular-nums" />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Potensi -->
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="card bg-neutral text-neutral-content shadow-sm">
        <div class="card-body p-6">
          <h2 class="mb-4 flex items-center gap-2 text-base font-bold">
            <Icon name="theater_comedy" class="text-[18px]" /> Seni & Budaya
          </h2>
          <BadgeList
            class="flex flex-wrap gap-2"
            items={potensi.seniBudaya.map((item) => ({
              label: item,
              tone: 'surface' as const,
              variant: 'outline' as const,
              class: 'border-white/10 bg-white/10 text-neutral-content',
            }))}
          />
        </div>
      </div>
      <div class="card bg-primary text-primary-content shadow-sm">
        <div class="card-body p-6">
          <h2 class="mb-4 flex items-center gap-2 text-base font-bold">
            <Icon name="storefront" class="text-[18px]" /> UMKM & Industri
          </h2>
          <BadgeList
            class="flex flex-wrap gap-2"
            items={potensi.umkmIndustri.map((item) => ({
              label: item,
              tone: 'primary' as const,
              variant: 'outline' as const,
              class: 'border-white/20 bg-white/20 text-primary-content',
            }))}
          />
        </div>
      </div>
    </div>

  </section>

</MainLayout>
