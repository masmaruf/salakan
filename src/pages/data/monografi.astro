---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import StatCard from '../../components/ui/StatCard.astro';
import { getPengaturan, getMonografi } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const pengaturan = await getPengaturan();
const monografi = await getMonografi();

if (!monografi) {
  return Astro.redirect('/404');
}

const { identitasDukuh, demografi, fasilitas, potensi } = monografi;
const seo = pengaturan?.seoHalamanData?.monografi;

const breadcrumbItems = [
  { label: 'Beranda', href: '/' },
  { label: 'Pusat Data', href: '/data' },
  { label: 'Monografi', active: true },
];

const statsPendidikan = [
  { label: 'TK/PAUD', value: fasilitas.pendidikan.tkPaud, icon: 'child_care' },
  { label: 'SD', value: fasilitas.pendidikan.sd, icon: 'school' },
  { label: 'SMP', value: fasilitas.pendidikan.smp, icon: 'menu_book' },
  { label: 'SMK', value: fasilitas.pendidikan.smk, icon: 'construction' },
  { label: 'SLB', value: fasilitas.pendidikan.slb, icon: 'accessibility_new' },
  { label: 'PKBM', value: fasilitas.pendidikan.pkbm, icon: 'edit_note' },
  { label: 'PT/Univ', value: fasilitas.pendidikan.universitas, icon: 'account_balance' },
];

const statsKesehatan = [
  { label: 'Puskesmas', value: fasilitas.kesehatan.puskesmas, icon: 'local_hospital' },
  { label: 'Posyandu Balita', value: fasilitas.kesehatan.posyanduBalita, icon: 'baby_changing_station' },
  { label: 'Posyandu Lansia', value: fasilitas.kesehatan.posyanduLansia, icon: 'elderly' },
];
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Monografi & Data Wilayah'))}
  description={resolveSeoText(seo?.seoDescription, 'Data resmi monografi, kependudukan, fasilitas, dan potensi Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section-premium bg-slate-50/50">
    <div class="container-premium relative z-10">
      
      <Breadcrumbs items={breadcrumbItems} />

      <header class="card-premium p-8 md:p-12 mb-16 border border-white/50">
        <div class="grid gap-12 lg:grid-cols-[1.5fr_1fr] items-center relative z-10">
          <div class="space-y-8">
            <span class="badge-blue">
               <span class="material-symbols-outlined text-[18px]">analytics</span> Profil Wilayah Resmi
            </span>
            <h1 class="hero-title text-gradient !mb-4 leading-none truncate overflow-visible">Data Monografi</h1>
            <p class="max-w-2xl text-xl font-bold text-slate-400 leading-relaxed">
              Informasi komprehensif profil kependudukan, sarana prasarana, serta potensi seni dan ekonomi di wilayah Padukuhan Salakan.
            </p>
            <div class="flex flex-wrap gap-4 pt-4">
              <a class="btn-premium btn-premium-sm" href="/data">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span> Kembali ke Indeks
              </a>
            </div>
          </div>

          {/* Card Identitas Dukuh */}
          <div class="relative group">
             <div class="absolute -inset-4 bg-gradient-to-br from-blue-500/10 to-indigo-500/10 rounded-[3rem] blur-2xl transition group-hover:from-blue-500/20 group-hover:to-indigo-500/20"></div>
             <div class="relative bg-white/70 backdrop-blur-xl border border-white/50 p-8 rounded-[2.5rem] shadow-sm overflow-hidden">
                <div class="flex items-center gap-5 mb-6">
                   <div class="h-16 w-16 rounded-2xl bg-blue-600 flex items-center justify-center text-white shadow-lg shadow-blue-200">
                      <span class="material-symbols-outlined text-3xl">face_6</span>
                   </div>
                   <div>
                      <span class="text-label text-blue-600">Identitas Dukuh</span>
                      <h3 class="text-xl font-black text-slate-900">{identitasDukuh.namaDukuh}</h3>
                   </div>
                </div>
                <div class="space-y-4">
                   <div class="flex items-center gap-3 text-slate-500 font-bold">
                      <span class="material-symbols-outlined text-lg text-blue-500">school</span>
                      <span class="text-sm">{identitasDukuh.pendidikan}</span>
                   </div>
                   <div class="flex items-center gap-3 text-slate-500 font-bold">
                      <span class="material-symbols-outlined text-lg text-blue-500">location_on</span>
                      <span class="text-sm">{identitasDukuh.alamat}</span>
                   </div>
                </div>
             </div>
          </div>
        </div>
      </header>

      <div class="space-y-16">
        {/* Section Demografi */}
        <div class="space-y-8">
           <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-2xl bg-emerald-100 text-emerald-600 flex items-center justify-center shadow-inner">
                 <span class="material-symbols-outlined">group</span>
              </div>
              <h2 class="text-3xl font-black text-slate-900 tracking-tight">Kependudukan & Demografi</h2>
           </div>

           <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
              <StatCard label="Total Jiwa" value={demografi.totalJiwa} icon="group" variant="blue" />
              <StatCard label="Laki-laki" value={demografi.totalLakiLaki} icon="male" variant="blue" description={`${Math.round((demografi.totalLakiLaki / demografi.totalJiwa) * 100)}% dari populasi`} />
              <StatCard label="Perempuan" value={demografi.totalPerempuan} icon="female" variant="amber" description={`${Math.round((demografi.totalPerempuan / demografi.totalJiwa) * 100)}% dari populasi`} />
              <StatCard label="Kepala Keluarga" value={demografi.totalKK} icon="home" variant="slate" description={`L: ${demografi.kkLakiLaki} | P: ${demografi.kkPerempuan}`} />
           </div>

           <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              <div class="flex items-center gap-4 p-6 bg-white rounded-3xl border border-slate-100 shadow-sm transition hover:shadow-md">
                 <div class="h-12 w-12 rounded-xl bg-orange-50 text-orange-600 flex items-center justify-center">
                    <span class="material-symbols-outlined">straighten</span>
                 </div>
                 <div>
                    <span class="block text-label text-slate-400">Luas Wilayah</span>
                    <strong class="text-lg font-black text-slate-800">{demografi.luasWilayah}</strong>
                 </div>
              </div>
              <div class="flex items-center gap-4 p-6 bg-white rounded-3xl border border-slate-100 shadow-sm transition hover:shadow-md">
                 <div class="h-12 w-12 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center">
                    <span class="material-symbols-outlined">grid_view</span>
                 </div>
                 <div>
                    <span class="block text-label text-slate-400">Wilayah RT</span>
                    <strong class="text-lg font-black text-slate-800">{demografi.jumlahRT} Unit RT</strong>
                 </div>
              </div>
           </div>
        </div>

        {/* Section Fasilitas */}
        <div class="grid gap-12 lg:grid-cols-2">
           <div class="space-y-8">
              <div class="flex items-center gap-4">
                 <div class="h-12 w-12 rounded-2xl bg-blue-100 text-blue-600 flex items-center justify-center shadow-inner">
                    <span class="material-symbols-outlined">school</span>
                 </div>
                 <h2 class="text-2xl font-black text-slate-900 tracking-tight">Sarana Pendidikan</h2>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                 {statsPendidikan.map((item) => (
                    <div class="flex items-center justify-between p-5 bg-white rounded-3xl border border-slate-100 shadow-sm transition hover:border-blue-200 group">
                       <div class="flex items-center gap-4">
                          <div class="h-10 w-10 rounded-lg bg-slate-50 text-slate-400 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors">
                             <span class="material-symbols-outlined text-xl">{item.icon}</span>
                          </div>
                          <span class="font-bold text-slate-700">{item.label}</span>
                       </div>
                       <strong class="font-black text-blue-700">{item.value}</strong>
                    </div>
                 ))}
              </div>
           </div>

           <div class="space-y-8">
              <div class="flex items-center gap-4">
                 <div class="h-12 w-12 rounded-2xl bg-red-100 text-red-600 flex items-center justify-center shadow-inner">
                    <span class="material-symbols-outlined">health_and_safety</span>
                 </div>
                 <h2 class="text-2xl font-black text-slate-900 tracking-tight">Sarana Kesehatan</h2>
              </div>
              <div class="grid gap-4">
                 {statsKesehatan.map((item) => (
                    <div class="flex items-center justify-between p-6 bg-white rounded-[2rem] border border-slate-100 shadow-sm transition hover:border-red-200 group">
                       <div class="flex items-center gap-4">
                          <div class="h-12 w-12 rounded-xl bg-red-50 text-red-600 flex items-center justify-center group-hover:bg-red-600 group-hover:text-white transition-colors">
                             <span class="material-symbols-outlined text-2xl">{item.icon}</span>
                          </div>
                          <span class="text-lg font-bold text-slate-700">{item.label}</span>
                       </div>
                       <strong class="text-2xl font-black text-red-600">{item.value}</strong>
                    </div>
                 ))}
              </div>
           </div>
        </div>

        {/* Section Potensi */}
        <div class="grid gap-8 lg:grid-cols-2">
           <div class="card-premium p-10 bg-slate-900 text-white border-0 overflow-hidden relative shadow-2xl shadow-slate-200">
              <div class="absolute -right-10 -bottom-10 h-40 w-40 bg-white/5 rounded-full blur-3xl"></div>
              <div class="relative z-10 space-y-8">
                 <div class="flex items-center gap-4">
                    <div class="h-12 w-12 rounded-2xl bg-white/10 text-white flex items-center justify-center">
                       <span class="material-symbols-outlined">theater_comedy</span>
                    </div>
                    <h2 class="text-2xl font-black tracking-tight uppercase">Seni & Budaya</h2>
                 </div>
                 <div class="flex flex-wrap gap-3">
                    {potensi.seniBudaya.map((item) => (
                       <span class="px-5 py-2.5 rounded-full bg-white/10 border border-white/10 text-sm font-bold hover:bg-white/20 transition cursor-default">
                          {item}
                       </span>
                    ))}
                 </div>
              </div>
           </div>

           <div class="card-premium p-10 bg-blue-600 text-white border-0 overflow-hidden relative shadow-2xl shadow-blue-200">
              <div class="absolute -right-10 -bottom-10 h-40 w-40 bg-white/10 rounded-full blur-3xl"></div>
              <div class="relative z-10 space-y-8">
                 <div class="flex items-center gap-4">
                    <div class="h-12 w-12 rounded-2xl bg-white/20 text-white flex items-center justify-center">
                       <span class="material-symbols-outlined">storefront</span>
                    </div>
                    <h2 class="text-2xl font-black tracking-tight uppercase">UMKM & Industri</h2>
                 </div>
                 <div class="flex flex-wrap gap-3">
                    {potensi.umkmIndustri.map((item) => (
                       <span class="px-5 py-2.5 rounded-full bg-white/20 border border-white/20 text-sm font-bold hover:bg-white/30 transition cursor-default">
                          {item}
                       </span>
                    ))}
                 </div>
              </div>
           </div>
        </div>
      </div>

    </div>
  </section>
</MainLayout>
