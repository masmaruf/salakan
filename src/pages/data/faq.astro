---
import MainLayout from '../../layouts/MainLayout.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import { getFaq, getPengaturan } from '../../lib/content';
import { renderMarkdown } from '../../lib/rich-text';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';
import { generateFaqSchema } from '../../lib/seo';
import { Schema } from 'astro-seo-schema';

const [faqItems, pengaturan] = await Promise.all([getFaq(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.faq;
const items = faqItems
  .filter(({ entry }) => entry.statusTampil === 'tampil')
  .sort((a, b) => a.entry.urutan - b.entry.urutan);

const categories = [...new Set(items.map(({ entry }) => entry.kategori))];

// Generate FAQ structured data for Google rich results
const faqSchema = generateFaqSchema(
  items.map(({ entry }) => ({
    question: entry.pertanyaan,
    answer: entry.jawaban,
  }))
);

import Icon from '../../components/ui/Icon.tsx';
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'FAQ'))}
  description={resolveSeoText(seo?.seoDescription, 'Pertanyaan yang sering diajukan warga Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <Schema item={faqSchema} />

  <PageIntro
    title="Tanya & Jawab (FAQ)"
    description="Pertanyaan yang sering diajukan warga mengenai layanan dan informasi Padukuhan Salakan."
    breadcrumbs={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'FAQ', active: true },
    ]}
  />

  <section class="container-premium py-8">
    {categories.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {categories.map((cat) => (
          <span class="text-[12px] font-semibold px-3 py-1.5 rounded-full bg-surface-container-low text-on-surface-variant border border-outline-variant">
            {cat}
          </span>
        ))}
      </div>
    )}

    <div class="space-y-4">
      {items.map(({ entry }, idx) => (
        <details class="group bg-surface-container-lowest border border-outline-variant rounded-xl transition-all hover:shadow-sm open:shadow-md">
          <summary class="cursor-pointer p-5 flex items-start gap-4 list-none">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary-container text-on-primary-container text-[12px] font-bold mt-0.5">
              {String(idx + 1).padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <span class="section-kicker-muted">{entry.kategori}</span>
              <h2 class="text-base font-bold text-on-surface leading-tight mt-1 group-hover:text-m3-primary transition-colors">{entry.pertanyaan}</h2>
            </div>
            <Icon name="expand_more" class="text-[20px] text-outline shrink-0 mt-1 transition-transform group-open:rotate-180" />
          </summary>
          <div class="px-5 pb-5 pl-17">
            <div class="article-rich soft-panel ml-12 text-sm leading-relaxed text-on-surface-variant" set:html={renderMarkdown(entry.jawaban)} />
          </div>
        </details>
      ))}
    </div>
  </section>

</MainLayout>
