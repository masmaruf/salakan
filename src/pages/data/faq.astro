---
import MainLayout from '../../layouts/MainLayout.astro';
import CmsIcon from '../../components/CmsIcon.astro';
import { getFaq, getPengaturan } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [faqItems, pengaturan] = await Promise.all([getFaq(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.faq;
const items = faqItems
  .filter(({ entry }) => entry.statusTampil === 'tampil')
  .sort((a, b) => a.entry.urutan - b.entry.urutan);

const categories = [...new Set(items.map(({ entry }) => entry.kategori))];
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'FAQ'))}
  description={resolveSeoText(seo?.seoDescription, 'Pertanyaan yang sering diajukan warga Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section-premium bg-slate-50/50">
    <div class="container-premium relative z-10">
      
      {/* Breadcrumb Premium */}
      <nav class="flex text-sm font-bold text-slate-400 uppercase tracking-[0.2em] mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center gap-3">
          <li><a href="/" class="hover:text-blue-600 transition">Beranda</a></li>
          <li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
          <li><a href="/data" class="hover:text-blue-600 transition">Pusat Data</a></li>
          <li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
          <li class="text-blue-700 bg-blue-50 px-3 py-1 rounded-full text-[0.7rem] ring-1 ring-blue-100">Bantuan (FAQ)</li>
        </ol>
      </nav>

      <div class="card-premium p-8 md:p-12 mb-16">
        <div class="grid gap-12 lg:grid-cols-[1.2fr_auto] items-center relative z-10">
          <div class="space-y-8">
            <span class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-2 text-[0.7rem] font-black text-indigo-700 uppercase tracking-widest ring-1 ring-indigo-100">
               <span class="material-symbols-outlined text-[18px]">help_center</span> Pusat Pengetahuan Warga
            </span>
            <h1 class="hero-title text-gradient !mb-4 leading-none">Pertanyaan Umum (FAQ)</h1>
            <p class="max-w-2xl text-xl font-bold text-slate-400 leading-relaxed">
              Temukan jawaban cepat untuk pertanyaan yang sering diajukan mengenai layanan, administrasi, dan kegiatan di Padukuhan Salakan.
            </p>
            <div class="flex flex-wrap gap-4 pt-4">
              <a class="inline-flex h-14 items-center gap-3 rounded-full bg-slate-900 px-8 text-sm font-black text-white shadow-xl transition-all hover:bg-blue-600 hover:-translate-y-0.5" href="/data">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span> Kembali ke Indeks
              </a>
              <a class="inline-flex h-14 items-center gap-3 rounded-full bg-white px-8 text-sm font-black text-slate-700 border border-slate-100 shadow-sm hover:shadow-md transition-all" href="/kontak">Ajukan Pertanyaan</a>
            </div>
          </div>
          <div class="flex flex-col items-center justify-center rounded-[2rem] bg-white p-10 shadow-sm border border-slate-100 min-w-[180px]">
             <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600 mb-4 shadow-inner">
               <span class="material-symbols-outlined text-4xl">live_help</span>
             </div>
             <strong class="text-5xl font-black text-slate-900 leading-none">{items.length}</strong>
             <span class="mt-3 text-[0.65rem] font-black text-slate-400 uppercase tracking-[0.2em]">Total Topik</span>
          </div>
        </div>
      </div>

      {categories.length > 1 && (
        <div class="flex flex-wrap items-center gap-4 mb-10">
          <span class="flex items-center gap-2 text-xs font-black text-slate-400 uppercase tracking-[0.2em] mr-2">
            <span class="material-symbols-outlined text-[18px]">segment</span> Filter Kategori:
          </span>
          {categories.map((cat) => (
            <span class="inline-flex items-center rounded-full bg-white px-6 py-2.5 text-sm font-black text-slate-600 shadow-sm border border-slate-100 transition hover:bg-indigo-600 hover:text-white cursor-default">{cat}</span>
          ))}
        </div>
      )}

      <div class="grid gap-6">
        {items.map(({ entry }, idx) => (
          <article class="group relative rounded-[2.5rem] bg-white p-8 md:p-10 shadow-sm border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1 overflow-hidden">
            <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition">
              <span class="material-symbols-outlined text-9xl text-indigo-100">contact_support</span>
            </div>
            <div class="relative z-10 flex items-start gap-8">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600 shadow-inner group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                <span class="text-2xl font-black">{String(idx + 1).padStart(2, '0')}</span>
              </div>
              <div class="min-w-0 flex-1 space-y-4">
                <span class="inline-flex items-center rounded-full bg-slate-100 px-4 py-1 text-[0.65rem] font-black text-slate-500 uppercase tracking-widest">{entry.kategori}</span>
                <h2 class="text-2xl font-black tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors leading-[1.2]">{entry.pertanyaan}</h2>
                <div class="mt-4 rounded-3xl bg-slate-50/50 p-6 md:p-8 text-lg font-bold text-slate-400 leading-relaxed border border-slate-100/50 group-hover:bg-white group-hover:shadow-sm transition-all italic">
                   "{entry.jawaban}"
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
    </div>
  </section>
</MainLayout>
