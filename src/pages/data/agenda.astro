---
import MainLayout from '../../layouts/MainLayout.astro';
import CmsIcon from '../../components/CmsIcon.astro';
import { formatTanggal, getAgenda, sortByDateDesc, getPengaturan } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [agendaItems, pengaturan] = await Promise.all([getAgenda(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.agenda;
const items = sortByDateDesc(
  agendaItems
    .filter(({ entry }) => entry.statusPublikasi === 'publish')
    .map(({ slug, entry }) => ({ slug, entry }))
);
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Agenda'))}
  description={resolveSeoText(seo?.seoDescription, 'Jadwal kegiatan warga dan agenda Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section-premium bg-slate-50/50">
    <div class="container-premium relative z-10">
      
      {/* Breadcrumb Premium */}
      <nav class="flex text-sm font-bold text-slate-400 uppercase tracking-[0.2em] mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center gap-3">
          <li><a href="/" class="hover:text-blue-600 transition">Beranda</a></li>
          <li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
          <li><a href="/data" class="hover:text-blue-600 transition">Pusat Data</a></li>
          <li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
          <li class="text-blue-700 bg-blue-50 px-3 py-1 rounded-full text-[0.7rem] ring-1 ring-blue-100">Agenda</li>
        </ol>
      </nav>

      <div class="card-premium p-8 md:p-12 mb-16">
        <div class="relative z-10 space-y-8">
          <span class="inline-flex items-center gap-2 rounded-full bg-amber-50 px-4 py-2 text-[0.7rem] font-black text-amber-700 uppercase tracking-widest ring-1 ring-amber-100">
            <span class="material-symbols-outlined text-[18px]">event_note</span> Kalender Kegiatan Warga
          </span>
          <h1 class="hero-title text-gradient !mb-4 leading-none">Agenda Padukuhan</h1>
          <p class="max-w-2xl text-xl font-bold text-slate-400 leading-relaxed">
            Halaman jadwal kegiatan, kerja bakti, dan program pembangunan. Tetap terhubung dengan agenda komunitas Anda.
          </p>
        </div>
      </div>

      <div class="grid gap-8">
        {items.map(({ slug, entry }) => (
          <article class="group relative rounded-[2.5rem] bg-white p-8 md:p-10 shadow-sm border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1 overflow-hidden" id={slug}>
            <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition">
              <span class="material-symbols-outlined text-9xl">calendar_today</span>
            </div>
            <div class="relative z-10">
              <div class="flex flex-wrap items-start justify-between gap-6 mb-8">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="inline-flex items-center gap-2 rounded-full bg-amber-100 px-4 py-2 text-xs font-black text-amber-700 ring-1 ring-amber-200">
                    <span class="material-symbols-outlined text-[16px]">event</span> {formatTanggal(entry.tanggal)}
                  </span>
                  <span class="inline-flex items-center gap-2 rounded-full bg-blue-100 px-4 py-2 text-xs font-black text-blue-700 ring-1 ring-blue-200">
                    <span class="material-symbols-outlined text-[16px]">schedule</span> {entry.waktuMulai} - {entry.waktuSelesai}
                  </span>
                </div>
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-[1.25rem] bg-slate-900 text-white shadow-xl transition-transform group-hover:scale-110">
                  <span class="material-symbols-outlined text-[32px]">event_available</span>
                </div>
              </div>

              <h2 class="text-3xl font-black tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors leading-[1.1]">{entry.judul}</h2>
              <p class="mt-6 text-lg font-bold text-slate-400 leading-relaxed">{entry.ringkasan}</p>

              <div class="mt-8 grid gap-4 sm:grid-cols-3">
                <div class="flex items-center gap-4 rounded-2xl bg-slate-50 p-5 border border-slate-100/50">
                  <div class="grid h-10 w-10 place-items-center rounded-xl bg-white text-blue-600 shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">location_on</span>
                  </div>
                  <div>
                    <p class="text-[0.6rem] font-black text-slate-400 uppercase tracking-widest leading-none mb-1.5">Lokasi</p>
                    <p class="text-sm font-black text-slate-900">{entry.lokasi}</p>
                  </div>
                </div>
                <div class="flex items-center gap-4 rounded-2xl bg-slate-50 p-5 border border-slate-100/50">
                  <div class="grid h-10 w-10 place-items-center rounded-xl bg-white text-emerald-600 shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">person</span>
                  </div>
                  <div>
                    <p class="text-[0.6rem] font-black text-slate-400 uppercase tracking-widest leading-none mb-1.5">Penanggung Jawab</p>
                    <p class="text-sm font-black text-slate-900">{entry.kontakPic}</p>
                  </div>
                </div>
                <div class="flex items-center gap-4 rounded-2xl bg-slate-50 p-5 border border-slate-100/50">
                  <div class="grid h-10 w-10 place-items-center rounded-xl bg-white text-amber-600 shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">info</span>
                  </div>
                  <div>
                    <p class="text-[0.6rem] font-black text-slate-400 uppercase tracking-widest leading-none mb-1.5">Status</p>
                    <p class="text-sm font-black text-slate-900">Agenda Aktif</p>
                  </div>
                </div>
              </div>

              <div class="mt-8 rounded-3xl bg-slate-50/50 p-6 text-[0.95rem] font-medium leading-relaxed text-slate-600 border border-slate-100/50 italic">
                "{entry.deskripsi}"
              </div>

              <div class="mt-8">
                <a class="inline-flex items-center gap-3 rounded-full bg-slate-900 px-8 py-3 text-sm font-black text-white shadow-xl transition-all hover:bg-blue-600 hover:-translate-y-0.5" href={`/agenda/${slug}`}>
                  Detail Kegiatan <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
    </div>
  </section>
</MainLayout>
