---
import MainLayout from '../../layouts/MainLayout.astro';
import CmsIcon from '../../components/CmsIcon.astro';
import { formatTanggal, getAgenda, sortByDateDesc, getPengaturan } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [agendaItems, pengaturan] = await Promise.all([getAgenda(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.agenda;
const items = sortByDateDesc(
  agendaItems
    .filter(({ entry }) => entry.statusPublikasi === 'publish')
    .map(({ slug, entry }) => ({ slug, entry }))
);
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Agenda'))}
  description={resolveSeoText(seo?.seoDescription, 'Jadwal kegiatan warga dan agenda Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section">
    <div class="container space-y-5">
      <div class="surface-card space-y-4 p-6 md:p-8">
        <span class="badge badge-outline w-fit">Sub menu data</span>
        <h1 class="text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Agenda</h1>
        <p class="max-w-3xl text-base leading-8 text-slate-600">
          Halaman ini menampilkan agenda warga dan kegiatan padukuhan dalam susunan yang ringkas, mudah dipindai, dan tetap nyaman dibaca di perangkat mobile.
        </p>
      </div>

      <div class="grid gap-4">
        {items.map(({ slug, entry }) => (
          <article class="surface-card flex flex-col gap-4 p-5 md:p-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="space-y-2">
                <div class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
                  <span class="badge badge-outline">{formatTanggal(entry.tanggal)}</span>
                  <span class="badge badge-outline">{entry.waktuMulai} - {entry.waktuSelesai}</span>
                </div>
                <h2 class="text-2xl font-bold tracking-tight text-slate-950">{entry.judul}</h2>
              </div>
              <span class="grid h-12 w-12 place-items-center rounded-[var(--radius-md)] bg-violet-50 text-violet-700">
                <CmsIcon name="event" class="size-6" />
              </span>
            </div>
            <p class="text-body-md text-slate-600">{entry.ringkasan}</p>
            <div class="grid gap-3 text-sm text-slate-600 md:grid-cols-3">
              <p><strong class="text-slate-950">Lokasi:</strong> {entry.lokasi}</p>
              <p><strong class="text-slate-950">PIC:</strong> {entry.kontakPic}</p>
              <p><strong class="text-slate-950">Waktu:</strong> {entry.waktuMulai} - {entry.waktuSelesai}</p>
            </div>
            <div class="rounded-[var(--radius-lg)] border border-slate-200 bg-slate-50 p-4 text-sm leading-7 text-slate-600">
              {entry.deskripsi}
            </div>
            <a class="btn btn-outline w-fit rounded-[var(--radius-md)]" href={`/agenda/${slug}`}>Lihat detail agenda</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
