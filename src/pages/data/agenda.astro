---
import MainLayout from '../../layouts/MainLayout.astro';
import CmsIcon from '../../components/CmsIcon.astro';
import { formatTanggal, getAgenda, sortByDateDesc, getPengaturan } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [agendaItems, pengaturan] = await Promise.all([getAgenda(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.agenda;
const items = sortByDateDesc(
  agendaItems
    .filter(({ entry }) => entry.statusPublikasi === 'publish')
    .map(({ slug, entry }) => ({ slug, entry }))
);
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Agenda'))}
  description={resolveSeoText(seo?.seoDescription, 'Jadwal kegiatan warga dan agenda Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section relative overflow-hidden bg-slate-50 min-h-screen">
    <div class="absolute -top-32 right-10 h-[500px] w-[500px] rounded-full bg-blue-400/20 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-20 -left-40 h-[600px] w-[600px] rounded-full bg-emerald-200/15 blur-[100px] pointer-events-none"></div>

    <div class="container relative z-10 py-12 md:py-16 space-y-10">
      <div class="rounded-[2.5rem] bg-white/70 backdrop-blur-3xl shadow-[0_12px_40px_rgb(0,0,0,0.04)] p-8 md:p-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <span class="material-symbols-outlined text-9xl">date_range</span>
        </div>
        <div class="relative z-10 space-y-6">
          <span class="inline-flex items-center gap-2 rounded-full bg-amber-50 px-4 py-1.5 text-xs font-bold text-amber-700 uppercase tracking-widest shadow-sm">
            <span class="material-symbols-outlined text-[16px]">event</span> Jadwal Kegiatan
          </span>
          <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl bg-gradient-to-r from-slate-900 to-slate-600 bg-clip-text text-transparent">Agenda Padukuhan</h1>
          <p class="max-w-2xl text-lg font-medium leading-relaxed text-slate-500">
            Jadwal kegiatan warga dan program padukuhan dalam susunan yang ringkas, mudah dipindai, dan nyaman dibaca di semua perangkat.
          </p>
        </div>
      </div>

      <div class="grid gap-6">
        {items.map(({ slug, entry }) => (
          <article class="group relative rounded-[2rem] bg-white/80 backdrop-blur-3xl p-6 md:p-8 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all hover:shadow-[0_20px_40px_rgb(0,0,0,0.06)] hover:-translate-y-1 overflow-hidden" id={slug}>
            <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition">
              <span class="material-symbols-outlined text-8xl">calendar_month</span>
            </div>
            <div class="relative z-10">
              <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-3 py-1.5 text-xs font-bold text-amber-700">
                    <span class="material-symbols-outlined text-[14px]">event</span> {formatTanggal(entry.tanggal)}
                  </span>
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-3 py-1.5 text-xs font-bold text-blue-700">
                    <span class="material-symbols-outlined text-[14px]">schedule</span> {entry.waktuMulai} - {entry.waktuSelesai}
                  </span>
                </div>
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-600 shadow-inner group-hover:bg-amber-600 group-hover:text-white transition">
                  <span class="material-symbols-outlined text-[28px]">event_note</span>
                </div>
              </div>

              <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors md:text-3xl">{entry.judul}</h2>
              <p class="mt-3 text-base font-medium leading-relaxed text-slate-500">{entry.ringkasan}</p>

              <div class="mt-6 grid gap-4 text-sm sm:grid-cols-3">
                <div class="flex items-center gap-3 rounded-2xl bg-white p-4 shadow-[0_2px_15px_rgb(0,0,0,0.02)]">
                  <span class="material-symbols-outlined text-[20px] text-blue-500">location_on</span>
                  <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Lokasi</p>
                    <p class="font-bold text-slate-900">{entry.lokasi}</p>
                  </div>
                </div>
                <div class="flex items-center gap-3 rounded-2xl bg-white p-4 shadow-[0_2px_15px_rgb(0,0,0,0.02)]">
                  <span class="material-symbols-outlined text-[20px] text-emerald-500">person</span>
                  <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">PIC</p>
                    <p class="font-bold text-slate-900">{entry.kontakPic}</p>
                  </div>
                </div>
                <div class="flex items-center gap-3 rounded-2xl bg-white p-4 shadow-[0_2px_15px_rgb(0,0,0,0.02)]">
                  <span class="material-symbols-outlined text-[20px] text-amber-500">timer</span>
                  <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Durasi</p>
                    <p class="font-bold text-slate-900">{entry.waktuMulai} - {entry.waktuSelesai}</p>
                  </div>
                </div>
              </div>

              <div class="mt-6 rounded-2xl bg-slate-50 p-5 text-sm font-medium leading-relaxed text-slate-600">{entry.deskripsi}</div>

              <div class="mt-6">
                <a class="inline-flex items-center gap-2 rounded-full bg-slate-50 px-6 py-3 text-sm font-bold text-slate-700 transition hover:bg-blue-600 hover:text-white hover:shadow-md hover:-translate-y-0.5" href={`/agenda/${slug}`}>
                  <span class="material-symbols-outlined text-[18px]">arrow_forward</span> Lihat Detail
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
