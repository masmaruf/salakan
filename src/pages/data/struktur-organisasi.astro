---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { getStrukturOrganisasi, getPengaturan } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [organisasiItems, pengaturan] = await Promise.all([getStrukturOrganisasi(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.strukturOrganisasi;
const items = organisasiItems
  .filter(({ entry }) => entry.statusPublikasi === 'publish')
  .sort((a, b) => a.entry.urutanTampil - b.entry.urutanTampil);

const bidangLabels = {
  pimpinan: 'Pimpinan Padukuhan',
  kegiatan: 'Koordinator Kegiatan',
  wilayah: 'Penghubung Wilayah',
} as const;

const bidangIcons = {
  pimpinan: 'shield_person',
  kegiatan: 'groups',
  wilayah: 'location_city',
} as const;

const grouped = {
  pimpinan: items.filter(({ entry }) => entry.bidang === 'pimpinan'),
  kegiatan: items.filter(({ entry }) => entry.bidang === 'kegiatan'),
  wilayah: items.filter(({ entry }) => entry.bidang === 'wilayah'),
};

import Icon from '../../components/ui/Icon.tsx';
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Struktur Organisasi'))}
  description={resolveSeoText(seo?.seoDescription, 'Susunan organisasi dan peran layanan Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>

  <div class="container-premium pt-8 pb-4">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'Struktur Organisasi', active: true },
    ]} />
    <h1 class="text-[28px] font-bold leading-[36px] text-on-surface">Struktur Organisasi</h1>
    <p class="text-base text-on-surface-variant mt-1 max-w-2xl">
      Daftar aparatur dan pengurus yang bertugas melayani warga Padukuhan Salakan. Total {items.length} posisi aktif.
    </p>
  </div>

  <section class="container-premium py-8">
    <div class="grid gap-8 lg:grid-cols-3">
      {Object.entries(grouped).map(([key, groupItems]) => (
        <div class="space-y-4">
          <div class="flex items-center gap-3 mb-2">
            <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-primary-container/30 text-m3-primary">
              <Icon name={bidangIcons[key as keyof typeof bidangIcons]} class="text-[20px]" />
            </div>
            <div>
              <h2 class="text-base font-bold text-on-surface">{bidangLabels[key as keyof typeof bidangLabels]}</h2>
              <span class="text-[12px] text-on-surface-variant">{groupItems.length} posisi</span>
            </div>
          </div>

          <div class="space-y-3">
            {groupItems.map(({ slug, entry }) => (
              <article class="bg-surface-container-lowest border border-outline-variant rounded-xl p-4 transition-all hover:-translate-y-0.5 hover:shadow-md" id={slug}>
                <span class="text-[12px] font-semibold text-m3-primary">{entry.jabatan}</span>
                <h3 class="text-sm font-bold text-on-surface mt-1">{entry.namaPejabat}</h3>
                <p class="text-sm text-on-surface-variant mt-1 line-clamp-2">{entry.deskripsiTugas}</p>
                <div class="flex items-center gap-1.5 mt-3 pt-3 border-t border-outline-variant/40 text-[12px] text-on-surface-variant">
                  <Icon name="call" class="text-[14px]" /> {entry.kontak}
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</MainLayout>
