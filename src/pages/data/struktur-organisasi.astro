---
import MainLayout from '../../layouts/MainLayout.astro';
import { getPengaturan, getProfil, getStrukturOrganisasi } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const pengaturan = await getPengaturan();
const profil = await getProfil();
const struktur = (await getStrukturOrganisasi())
  .filter(({ entry }) => entry.statusPublikasi === 'publish')
  .sort((a, b) => a.entry.urutanTampil - b.entry.urutanTampil);

const bidangLabels = {
  pimpinan: 'Pimpinan Padukuhan',
  kegiatan: 'Koordinator Kegiatan Warga',
  wilayah: 'Penghubung Wilayah',
} as const;
const bidangIcons = {
  pimpinan: 'shield_person',
  kegiatan: 'groups',
  wilayah: 'location_city',
} as const;
const bidangColors = {
  pimpinan: { bg: 'bg-blue-100', text: 'text-blue-600', hover: 'group-hover:bg-blue-600' },
  kegiatan: { bg: 'bg-emerald-100', text: 'text-emerald-600', hover: 'group-hover:bg-emerald-600' },
  wilayah: { bg: 'bg-amber-100', text: 'text-amber-600', hover: 'group-hover:bg-amber-600' },
} as const;

const grouped = {
  pimpinan: struktur.filter(({ entry }) => entry.bidang === 'pimpinan'),
  kegiatan: struktur.filter(({ entry }) => entry.bidang === 'kegiatan'),
  wilayah: struktur.filter(({ entry }) => entry.bidang === 'wilayah'),
};
const seo = pengaturan?.seoHalamanData?.strukturOrganisasi;
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Struktur Organisasi'))}
  description={resolveSeoText(seo?.seoDescription, 'Susunan organisasi dan peran layanan Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section relative overflow-hidden bg-slate-50 min-h-screen">
    <div class="absolute -top-32 left-20 h-[500px] w-[500px] rounded-full bg-blue-300/20 blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-10 -right-32 h-[600px] w-[600px] rounded-full bg-emerald-200/20 blur-[120px] pointer-events-none"></div>

    <div class="container relative z-10 py-12 md:py-16 space-y-10">
      <div class="rounded-[2.5rem] bg-white/70 backdrop-blur-3xl shadow-[0_12px_40px_rgb(0,0,0,0.04)] p-8 md:p-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <span class="material-symbols-outlined text-9xl">org_chart</span>
        </div>
        <div class="grid gap-10 lg:grid-cols-[1.2fr_auto] items-center relative z-10">
          <div class="space-y-6">
            <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-1.5 text-xs font-bold text-blue-700 uppercase tracking-widest shadow-sm">
              <span class="material-symbols-outlined text-[16px]">account_tree</span> Struktur Resmi
            </span>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl bg-gradient-to-r from-slate-900 to-slate-600 bg-clip-text text-transparent">Susunan Organisasi</h1>
            <p class="max-w-2xl text-lg font-medium leading-relaxed text-slate-500">
              Halaman ini menata pengurus padukuhan ke dalam kelompok yang mudah dipindai. Data dikelola langsung dari CMS Keystatic.
            </p>
            <div class="flex flex-wrap gap-4 pt-2">
              <a class="inline-flex h-12 items-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-blue-500 px-8 text-sm font-bold text-white shadow-[0_8px_20px_rgb(37,99,235,0.3)] hover:shadow-lg transition hover:-translate-y-0.5" href="/data">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span> Kembali ke Data
              </a>
            </div>
          </div>
          <div class="flex flex-col items-center justify-center rounded-3xl bg-white p-8 shadow-[0_4px_20px_rgb(0,0,0,0.03)] min-w-[160px]">
            <span class="material-symbols-outlined text-5xl text-blue-300 mb-2">badge</span>
            <strong class="text-5xl font-black text-slate-900">{struktur.length}</strong>
            <span class="mt-1 text-xs font-bold text-slate-400 uppercase tracking-widest">Posisi</span>
          </div>
        </div>
      </div>

      <div class="grid gap-8 xl:grid-cols-3">
        {Object.entries(grouped).map(([key, items]) => {
          const colors = bidangColors[key as keyof typeof bidangColors];
          return (
            <section class="rounded-[2.5rem] bg-white/80 backdrop-blur-3xl p-8 shadow-[0_12px_40px_rgb(0,0,0,0.04)]">
              <div class="flex items-center gap-4 mb-8">
                <div class={`flex h-14 w-14 items-center justify-center rounded-2xl ${colors.bg} ${colors.text} shadow-inner`}>
                  <span class="material-symbols-outlined text-[28px]">{bidangIcons[key as keyof typeof bidangIcons]}</span>
                </div>
                <div>
                  <h2 class="text-xl font-extrabold tracking-tight text-slate-900">{bidangLabels[key as keyof typeof bidangLabels]}</h2>
                  <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">{items.length} posisi</span>
                </div>
              </div>
              <div class="space-y-4">
                {items.map(({ slug, entry }) => (
                  <article class="group rounded-2xl bg-white p-5 shadow-[0_2px_15px_rgb(0,0,0,0.02)] transition hover:shadow-md hover:-translate-y-0.5" id={slug}>
                    <p class="text-sm font-bold text-blue-600 mb-1">{entry.jabatan}</p>
                    <h3 class="text-lg font-extrabold tracking-tight text-slate-900">{entry.namaPejabat}</h3>
                    <p class="mt-2 text-sm font-medium leading-relaxed text-slate-500">{entry.deskripsiTugas}</p>
                    <div class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-slate-50 px-4 py-2 text-sm font-bold text-slate-600">
                      <span class="material-symbols-outlined text-[16px]">call</span> {entry.kontak}
                    </div>
                  </article>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    </div>
  </section>
</MainLayout>
