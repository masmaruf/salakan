---
import MainLayout from '../../layouts/MainLayout.astro';
import { formatTanggal, getPengaturan, getPengumuman, sortByDateDesc } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const pengaturan = await getPengaturan();
const pengumuman = sortByDateDesc(await getPengumuman())
  .filter(({ entry }) => entry.statusPublikasi === 'publish')
  .sort((a, b) => Number(b.entry.unggulan) - Number(a.entry.unggulan));
const [featured, ...others] = pengumuman;
const latestDate = featured ? formatTanggal(featured.entry.tanggal) : '-';
const seo = pengaturan?.seoHalamanData?.pengumuman;
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Pengumuman Warga'))}
  description={resolveSeoText(seo?.seoDescription, 'Halaman data pengumuman untuk melihat informasi aktif warga Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section relative overflow-hidden bg-slate-50 min-h-screen">
    <div class="absolute -top-32 -right-32 h-[600px] w-[600px] rounded-full bg-blue-400/20 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-20 -left-40 h-[500px] w-[500px] rounded-full bg-emerald-300/15 blur-[100px] pointer-events-none"></div>

    <div class="container relative z-10 py-12 md:py-16 space-y-10">
      <div class="grid gap-6 lg:grid-cols-[1.2fr_auto]">
        <div class="rounded-[2.5rem] bg-gradient-to-br from-blue-600 via-indigo-600 to-blue-700 p-8 md:p-12 text-white shadow-[0_20px_60px_rgb(37,99,235,0.3)] relative overflow-hidden">
          <div class="absolute top-0 right-0 p-8 opacity-10">
            <span class="material-symbols-outlined text-9xl">campaign</span>
          </div>
          <div class="relative z-10 space-y-6">
            <span class="inline-flex items-center gap-2 rounded-full bg-white/15 backdrop-blur px-4 py-1.5 text-xs font-bold uppercase tracking-widest">
              <span class="material-symbols-outlined text-[16px]">notifications_active</span>
              Pusat Pengumuman
            </span>
            <h1 class="max-w-3xl text-4xl font-extrabold tracking-tight md:text-5xl lg:text-6xl leading-[1.1]">Papan Informasi Resmi Warga</h1>
            <p class="max-w-2xl text-lg font-medium leading-relaxed text-blue-100">
              Semua pengumuman aktif tersaji transparan, dengan sorotan utama di bagian atas dan daftar ringkas di bawahnya.
            </p>
            <div class="flex flex-wrap gap-4 pt-4">
              <a class="inline-flex h-12 items-center gap-2 rounded-full bg-white px-8 text-sm font-bold text-slate-900 shadow-md hover:shadow-lg transition" href="/data">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span> Kembali ke Data
              </a>
              <a class="inline-flex h-12 items-center gap-2 rounded-full bg-white/15 backdrop-blur px-8 text-sm font-bold text-white hover:bg-white/25 transition" href="/kontak">Hubungi Layanan</a>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-4 min-w-[280px]">
          <article class="group rounded-3xl bg-white/80 backdrop-blur-3xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition hover:shadow-lg hover:-translate-y-1">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-100 text-blue-600 mb-3 shadow-inner group-hover:bg-blue-600 group-hover:text-white transition">
              <span class="material-symbols-outlined text-[24px]">inbox</span>
            </div>
            <small class="text-xs font-bold text-slate-400 uppercase tracking-widest">Total Aktif</small>
            <strong class="mt-1 block text-4xl font-black tracking-tight text-slate-900">{pengumuman.length}</strong>
          </article>
          <article class="group rounded-3xl bg-white/80 backdrop-blur-3xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition hover:shadow-lg hover:-translate-y-1">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-600 mb-3 shadow-inner group-hover:bg-emerald-600 group-hover:text-white transition">
              <span class="material-symbols-outlined text-[24px]">update</span>
            </div>
            <small class="text-xs font-bold text-slate-400 uppercase tracking-widest">Terakhir Diperbarui</small>
            <strong class="mt-1 block text-2xl font-bold tracking-tight text-slate-900">{latestDate}</strong>
          </article>
        </div>
      </div>

      {featured ? (
        <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
          <article class="group relative rounded-[2.5rem] bg-white/80 backdrop-blur-3xl p-8 md:p-10 shadow-[0_12px_40px_rgb(0,0,0,0.04)] transition hover:shadow-[0_20px_50px_rgb(0,0,0,0.08)] hover:-translate-y-1 overflow-hidden">
            <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition">
              <span class="material-symbols-outlined text-9xl">priority_high</span>
            </div>
            <div class="relative z-10">
              <div class="flex flex-wrap items-center gap-3 mb-6">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-4 py-1.5 text-xs font-bold text-amber-700">
                  <span class="material-symbols-outlined text-[14px]">star</span> Sorotan Utama
                </span>
                <time class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1.5 text-xs font-bold text-slate-600" datetime={featured.entry.tanggal}>
                  <span class="material-symbols-outlined text-[14px]">event</span> {formatTanggal(featured.entry.tanggal)}
                </time>
              </div>
              <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl group-hover:text-blue-700 transition-colors">{featured.entry.judul}</h2>
              <p class="mt-5 text-lg font-medium leading-relaxed text-slate-500">{featured.entry.ringkasan}</p>
              <div class="mt-6 rounded-2xl bg-slate-50 p-5 text-base leading-relaxed text-slate-600">{featured.entry.isi}</div>
            </div>
          </article>

          <div class="flex flex-col gap-4">
            {others.slice(0, 3).map(({ slug, entry }) => (
              <article class="group relative rounded-3xl bg-white/80 backdrop-blur-3xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition hover:shadow-lg hover:-translate-y-1" id={slug}>
                <div class="flex items-start justify-between gap-4 mb-4">
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-3 py-1 text-xs font-bold text-blue-700">
                    <span class="material-symbols-outlined text-[14px]">campaign</span> Pengumuman
                  </span>
                  <time class="text-xs font-bold text-slate-400" datetime={entry.tanggal}>{formatTanggal(entry.tanggal)}</time>
                </div>
                <h3 class="text-xl font-bold tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors">{entry.judul}</h3>
                <p class="mt-3 text-sm font-medium leading-relaxed text-slate-500">{entry.ringkasan}</p>
                <details class="mt-4 rounded-2xl bg-slate-50 p-4">
                  <summary class="cursor-pointer list-none text-sm font-bold text-blue-600 hover:text-blue-800 transition flex items-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">expand_more</span> Baca detail
                  </summary>
                  <p class="mt-3 text-sm leading-relaxed text-slate-600">{entry.isi}</p>
                </details>
              </article>
            ))}
          </div>
        </div>
      ) : (
        <article class="rounded-[2.5rem] bg-white/80 backdrop-blur-3xl p-10 text-center shadow-[0_12px_40px_rgb(0,0,0,0.04)]">
          <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">notifications_off</span>
          <h2 class="text-2xl font-bold tracking-tight text-slate-900">Belum ada pengumuman aktif</h2>
          <p class="mt-3 text-slate-500">Tambahkan item di Keystatic dengan status tampil agar muncul di sini.</p>
        </article>
      )}

      {others.length > 3 && (
        <section class="space-y-6">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Pengumuman Lainnya</h2>
          <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {others.slice(3).map(({ slug, entry }) => (
              <article class="group rounded-3xl bg-white/80 backdrop-blur-3xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition hover:shadow-lg hover:-translate-y-1" id={slug}>
                <time class="flex items-center gap-1.5 text-xs font-bold text-blue-600 mb-3" datetime={entry.tanggal}>
                  <span class="material-symbols-outlined text-[14px]">event</span> {formatTanggal(entry.tanggal)}
                </time>
                <h3 class="text-lg font-bold tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors">{entry.judul}</h3>
                <p class="mt-3 text-sm font-medium leading-relaxed text-slate-500">{entry.ringkasan}</p>
              </article>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>
</MainLayout>
