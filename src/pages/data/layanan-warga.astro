---
import MainLayout from '../../layouts/MainLayout.astro';
import CmsIcon from '../../components/CmsIcon.astro';
import { getLayananWarga, getPengaturan } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [layananItems, pengaturan] = await Promise.all([getLayananWarga(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.layananWarga;
const items = layananItems
  .filter(({ entry }) => entry.statusTampil === 'tampil')
  .sort((a, b) => a.entry.namaLayanan.localeCompare(b.entry.namaLayanan, 'id'));
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Layanan Warga'))}
  description={resolveSeoText(seo?.seoDescription, 'Informasi layanan warga, syarat, langkah, dan kontak layanan Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section-premium bg-slate-50/50">
    <div class="container-premium relative z-10">
      
      {/* Breadcrumb Premium */}
      <nav class="flex text-sm font-bold text-slate-400 uppercase tracking-[0.2em] mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center gap-3">
          <li><a href="/" class="hover:text-blue-600 transition">Beranda</a></li>
          <li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
          <li><a href="/data" class="hover:text-blue-600 transition">Pusat Data</a></li>
          <li><span class="material-symbols-outlined text-[16px]">chevron_right</span></li>
          <li class="text-blue-700 bg-blue-50 px-3 py-1 rounded-full text-[0.7rem] ring-1 ring-blue-100">Layanan Warga</li>
        </ol>
      </nav>

      <div class="card-premium p-8 md:p-12 mb-16">
        <div class="relative z-10 space-y-8">
          <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-2 text-[0.7rem] font-black text-blue-700 uppercase tracking-widest ring-1 ring-blue-100">
             <span class="material-symbols-outlined text-[18px]">handshake</span> Portal Pelayanan Publik
          </span>
          <h1 class="hero-title text-gradient !mb-4 leading-none text-slate-900 md:text-5xl lg:text-6xl">Satu Pintu Layanan Warga</h1>
          <p class="max-w-2xl text-xl font-bold text-slate-400 leading-relaxed">
            Informasi komprehensif mengenai prosedur administrasi, persyaratan dokumen, dan kanal komunikasi resmi untuk kebutuhan warga Salakan.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <a class="inline-flex h-14 items-center gap-3 rounded-full bg-slate-900 px-8 text-sm font-black text-white shadow-xl transition-all hover:bg-blue-600 hover:-translate-y-0.5" href="/data">
              <span class="material-symbols-outlined text-[20px]">arrow_back</span> Kembali ke Indeks
            </a>
          </div>
        </div>
      </div>

      <div class="grid gap-10 lg:grid-cols-2">
        {items.map(({ entry }) => (
          <article class="group relative rounded-[3rem] bg-white p-8 md:p-10 shadow-sm border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1 overflow-hidden">
            <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition">
              <span class="material-symbols-outlined text-9xl">support_agent</span>
            </div>
            <div class="relative z-10 flex flex-col h-full">
              <div class="flex items-start justify-between gap-6 mb-8">
                <div class="flex-1 min-w-0">
                  <h2 class="text-3xl font-black tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors leading-[1.1]">{entry.namaLayanan}</h2>
                  <p class="mt-4 text-lg font-bold text-slate-400 leading-relaxed">{entry.ringkasan}</p>
                </div>
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600 shadow-inner group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
                  <span class="material-symbols-outlined text-[32px]">description</span>
                </div>
              </div>

              <div class="grid gap-6 md:grid-cols-2 flex-1">
                <div class="rounded-3xl bg-slate-50 p-6 md:p-8 border border-slate-100/50">
                  <p class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-widest mb-6">
                    <span class="material-symbols-outlined text-[18px] text-blue-500">checklist</span> Syarat Utama
                  </p>
                  <ul class="space-y-4 text-[0.95rem] font-medium leading-relaxed text-slate-600">
                    {entry.syarat.map((item: string) => (
                      <li class="flex items-start gap-3">
                        <span class="material-symbols-outlined mt-0.5 text-[18px] text-emerald-500">check_circle</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="rounded-3xl bg-blue-50/30 p-6 md:p-8 border border-blue-100/20">
                  <p class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-widest mb-6">
                    <span class="material-symbols-outlined text-[18px] text-amber-500">format_list_numbered</span> Alur Proses
                  </p>
                  <ol class="space-y-4 text-[0.95rem] font-medium leading-relaxed text-slate-600">
                    {entry.langkah.map((item: string, idx: number) => (
                      <li class="flex items-start gap-4">
                        <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-white text-xs font-black text-blue-700 shadow-sm border border-blue-100 ring-2 ring-blue-50">{idx + 1}</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ol>
                </div>
              </div>

              <div class="mt-8 flex flex-wrap gap-4 pt-8 border-t border-slate-100">
                <div class="flex items-center gap-3 rounded-2xl bg-white px-5 py-3 shadow-sm border border-slate-100 text-sm font-black text-slate-700">
                  <span class="material-symbols-outlined text-[20px] text-blue-500">call</span> {entry.kontak}
                </div>
                <div class="flex items-center gap-3 rounded-2xl bg-white px-5 py-3 shadow-sm border border-slate-100 text-sm font-black text-slate-700">
                  <span class="material-symbols-outlined text-[20px] text-emerald-500">schedule</span> {entry.jamLayanan}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
    </div>
  </section>
</MainLayout>
