---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import LayananCard from '../../components/ui/LayananCard.astro';
import { getHalamanCopy, getLayananWarga, getPengaturan } from '../../lib/content';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [layananItems, pengaturan] = await Promise.all([getLayananWarga(), getPengaturan()]);
const halaman = await getHalamanCopy();
const seo = pengaturan?.seoHalamanData?.layananWarga;
const items = layananItems
  .filter(({ entry }) => entry.statusTampil === 'tampil')
  .sort((a, b) => a.entry.namaLayanan.localeCompare(b.entry.namaLayanan, 'id'));

const highlightedServices = items.slice(0, 3).map(({ slug, entry }) => ({
  slug,
  title: entry.namaLayanan,
  description: entry.ringkasan,
}));
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Layanan Warga'))}
  description={resolveSeoText(seo?.seoDescription, 'Informasi layanan warga, syarat, langkah, kontak layanan, dan pelacakan pengajuan Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <div class="container-premium pt-8 pb-4">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'Layanan Warga', active: true },
    ]} />
    <div class="mt-4 grid gap-6 lg:grid-cols-[1.15fr_0.85fr] lg:items-stretch">
      <div class="card border border-outline-variant/60 bg-base-100/80 shadow-sm">
        <div class="card-body gap-5 p-6 sm:p-7">
          <div class="badge badge-soft badge-primary w-fit rounded-full px-3 py-3 text-[12px] font-semibold uppercase tracking-[0.18em]">
            Pelayanan Padukuhan
          </div>
          <div>
            <h1 class="text-[30px] font-bold leading-[38px] tracking-tight text-on-surface sm:text-[38px] sm:leading-[46px]">
              {halaman.layananWarga.pageTitle}
            </h1>
            <p class="mt-3 max-w-2xl text-base leading-relaxed text-on-surface-variant">
          {halaman.layananWarga.pageDescription}
            </p>
          </div>
          <div class="card-actions gap-3">
            <a class="btn btn-primary rounded-full px-5 shadow-none" href="/dasbor/buat-surat">
              {halaman.layananWarga.primaryCtaLabel}
            </a>
            <a class="btn btn-outline rounded-full px-5" href="/dasbor/lacak-surat">
              {halaman.layananWarga.secondaryCtaLabel}
            </a>
          </div>
        </div>
      </div>

      <aside class="card border border-primary/10 bg-primary/5 shadow-none">
        <div class="card-body p-5 sm:p-6">
          <div class="flex items-center justify-between gap-3">
            <p class="text-[12px] font-semibold uppercase tracking-[0.18em] text-primary">{halaman.layananWarga.quickAccessLabel}</p>
            <span class="badge badge-outline border-primary/30 text-primary">Cepat</span>
          </div>
          <div class="mt-1 grid gap-3">
          {highlightedServices.map((service) => (
            <a class="card border border-primary/10 bg-base-100/75 shadow-none transition hover:-translate-y-0.5 hover:border-primary/30 hover:bg-base-100" href={`#${service.slug}`}>
              <div class="card-body gap-1 p-4">
                <h2 class="text-sm font-bold text-on-surface">{service.title}</h2>
                <p class="text-sm leading-relaxed text-on-surface-variant line-clamp-2">{service.description}</p>
              </div>
            </a>
          ))}
          </div>
        </div>
      </aside>
    </div>
  </div>

  <section class="container-premium pb-6">
    <div class="stats stats-vertical w-full overflow-hidden border border-outline-variant/50 bg-base-100 shadow-none md:stats-horizontal">
      {halaman.layananWarga.features.map((feature) => (
        <div class="stat gap-2 px-5 py-4">
          <div class="stat-title text-[12px] font-semibold uppercase tracking-[0.16em] text-primary">{feature.title}</div>
          <div class="stat-desc whitespace-normal text-sm leading-relaxed text-on-surface-variant">{feature.description}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="container-premium py-8">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-2xl font-bold text-on-surface">{halaman.layananWarga.listTitle}</h2>
        <p class="mt-1 text-sm text-on-surface-variant">{halaman.layananWarga.listDescription}</p>
      </div>
      <span class="badge badge-lg badge-soft badge-primary rounded-full px-4">{items.length} {halaman.layananWarga.listCountSuffix}</span>
    </div>

    <div class="grid gap-4 lg:grid-cols-2">
      {items.map(({ slug, entry }) => (
        <LayananCard
          id={slug}
          namaLayanan={entry.namaLayanan}
          ringkasan={entry.ringkasan}
          syarat={entry.syarat}
          langkah={entry.langkah}
          kontak={entry.kontak}
          jamLayanan={entry.jamLayanan}
        />
      ))}
    </div>
  </section>
</MainLayout>

