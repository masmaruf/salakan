---
import MainLayout from '../../layouts/MainLayout.astro';
import CmsIcon from '../../components/CmsIcon.astro';
import { getLayananWarga, getPengaturan } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [layananItems, pengaturan] = await Promise.all([getLayananWarga(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.layananWarga;
const items = layananItems
  .filter(({ entry }) => entry.statusTampil === 'tampil')
  .sort((a, b) => a.entry.namaLayanan.localeCompare(b.entry.namaLayanan, 'id'));
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Layanan Warga'))}
  description={resolveSeoText(seo?.seoDescription, 'Informasi layanan warga, syarat, langkah, dan kontak layanan Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section relative overflow-hidden bg-slate-50 min-h-screen">
    <div class="absolute top-20 -right-32 h-[500px] w-[500px] rounded-full bg-blue-300/20 blur-[100px] pointer-events-none"></div>
    <div class="absolute -bottom-20 left-10 h-[600px] w-[600px] rounded-full bg-emerald-200/20 blur-[120px] pointer-events-none"></div>

    <div class="container relative z-10 py-12 md:py-16 space-y-10">
      <div class="rounded-[2.5rem] bg-white/70 backdrop-blur-3xl shadow-[0_12px_40px_rgb(0,0,0,0.04)] p-8 md:p-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <span class="material-symbols-outlined text-9xl">support_agent</span>
        </div>
        <div class="relative z-10 space-y-6">
          <span class="inline-flex items-center gap-2 rounded-full bg-emerald-50 px-4 py-1.5 text-xs font-bold text-emerald-700 uppercase tracking-widest shadow-sm">
            <span class="material-symbols-outlined text-[16px]">handshake</span> Pelayanan Publik
          </span>
          <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl bg-gradient-to-r from-slate-900 to-slate-600 bg-clip-text text-transparent">Layanan Warga</h1>
          <p class="max-w-2xl text-lg font-medium leading-relaxed text-slate-500">
            Ringkasan layanan warga disusun sederhana agar syarat, langkah, dan kontak bisa dibaca cepat tanpa harus membuka banyak halaman.
          </p>
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        {items.map(({ entry }) => (
          <article class="group relative rounded-[2rem] bg-white/80 backdrop-blur-3xl p-6 md:p-8 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all hover:shadow-[0_20px_40px_rgb(0,0,0,0.06)] hover:-translate-y-1 overflow-hidden">
            <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition">
              <span class="material-symbols-outlined text-7xl">assignment</span>
            </div>
            <div class="relative z-10">
              <div class="flex items-start justify-between gap-4 mb-5">
                <div>
                  <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors">{entry.namaLayanan}</h2>
                  <p class="mt-2 text-base font-medium leading-relaxed text-slate-500">{entry.ringkasan}</p>
                </div>
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-blue-100 text-blue-600 shadow-inner group-hover:bg-blue-600 group-hover:text-white transition">
                  <span class="material-symbols-outlined text-[28px]">description</span>
                </div>
              </div>

              <div class="grid gap-4 md:grid-cols-2">
                <div class="rounded-2xl bg-slate-50 p-5">
                  <p class="flex items-center gap-2 text-sm font-bold text-slate-900 mb-3">
                    <span class="material-symbols-outlined text-[18px] text-blue-500">checklist</span> Syarat
                  </p>
                  <ul class="space-y-2 text-sm font-medium leading-relaxed text-slate-600">
                    {entry.syarat.map((item: string) => (
                      <li class="flex items-start gap-2">
                        <span class="material-symbols-outlined mt-0.5 text-[16px] text-emerald-500">check_circle</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="rounded-2xl bg-blue-50/50 p-5">
                  <p class="flex items-center gap-2 text-sm font-bold text-slate-900 mb-3">
                    <span class="material-symbols-outlined text-[18px] text-amber-500">format_list_numbered</span> Langkah
                  </p>
                  <ol class="space-y-2 text-sm font-medium leading-relaxed text-slate-600">
                    {entry.langkah.map((item: string, idx: number) => (
                      <li class="flex items-start gap-3">
                        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-blue-100 text-xs font-black text-blue-700">{idx + 1}</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ol>
                </div>
              </div>

              <div class="mt-5 flex flex-wrap gap-4">
                <div class="flex items-center gap-2 rounded-full bg-white px-4 py-2 shadow-sm text-sm font-bold text-slate-700">
                  <span class="material-symbols-outlined text-[18px] text-blue-500">call</span> {entry.kontak}
                </div>
                <div class="flex items-center gap-2 rounded-full bg-white px-4 py-2 shadow-sm text-sm font-bold text-slate-700">
                  <span class="material-symbols-outlined text-[18px] text-emerald-500">schedule</span> {entry.jamLayanan}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
