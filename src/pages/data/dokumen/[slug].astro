---
import MainLayout from '../../../layouts/MainLayout.astro';
import { formatTanggal, getDokumen } from '../../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../../lib/site';

export async function getStaticPaths() {
  const items = await getDokumen();

  return items
    .filter(({ entry }) => entry.statusPublikasi === 'publish')
    .map((item) => ({
      params: { slug: item.slug },
      props: { item },
    }));
}

const { item } = Astro.props;
const { entry, slug } = item;

const kategoriLabels = {
  layanan: 'Layanan Warga',
  arsip: 'Arsip Publik',
  kegiatan: 'Dokumen Kegiatan',
  regulasi: 'Regulasi',
} as const;

const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.judul));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage);
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImage}>
  <section class="section">
    <div class="container max-w-5xl space-y-6">
      <nav class="breadcrumbs text-sm text-slate-500">
        <ul>
          <li><a href="/">Beranda</a></li>
          <li><a href="/data">Data</a></li>
          <li><a href="/data/dokumen">Dokumen</a></li>
          <li class="text-slate-700">{entry.judul}</li>
        </ul>
      </nav>

      <article class="surface-card overflow-hidden p-6 md:p-8">
        <div class="flex flex-wrap items-center gap-3">
          <span class="badge badge-primary badge-outline">{kategoriLabels[entry.kategori]}</span>
          {entry.unggulan && <span class="badge badge-outline">Dokumen unggulan</span>}
          <time class="badge badge-ghost" datetime={entry.tanggalUpdate}>{formatTanggal(entry.tanggalUpdate)}</time>
        </div>

        <div class="mt-5 grid gap-6 lg:grid-cols-[minmax(0,1fr)_280px]">
          <div class="space-y-5">
            <div class="space-y-3">
              <h1 class="text-3xl font-extrabold tracking-tight text-slate-950 md:text-5xl">{entry.judul}</h1>
              <p class="max-w-3xl text-base leading-8 text-slate-600 md:text-lg">{entry.ringkasan}</p>
            </div>

            <div class="rounded-[var(--radius-lg)] border border-slate-200 bg-slate-50 p-5 md:p-6">
              <h2 class="text-xl font-bold tracking-tight text-slate-950">Deskripsi dokumen</h2>
              <p class="mt-3 text-sm leading-8 text-slate-600 md:text-base">{entry.deskripsi}</p>
            </div>
          </div>

          <aside class="space-y-4">
            <div class="rounded-[var(--radius-lg)] border border-slate-200 bg-white p-5 shadow-sm">
              <p class="text-sm font-semibold text-slate-500">ID dokumen</p>
              <strong class="mt-2 block text-base font-bold text-slate-950">{slug}</strong>
            </div>
            <div class="rounded-[var(--radius-lg)] border border-slate-200 bg-white p-5 shadow-sm">
              <p class="text-sm font-semibold text-slate-500">Pembaruan terakhir</p>
              <strong class="mt-2 block text-base font-bold text-slate-950">{formatTanggal(entry.tanggalUpdate)}</strong>
            </div>
            <div class="rounded-[var(--radius-lg)] border border-slate-200 bg-white p-5 shadow-sm">
              <p class="text-sm font-semibold text-slate-500">Kategori</p>
              <strong class="mt-2 block text-base font-bold text-slate-950">{kategoriLabels[entry.kategori]}</strong>
            </div>
            <div class="flex flex-wrap gap-3">
              {entry.fileDokumen ? (
                <a class="brand-button btn w-full rounded-[var(--radius-md)]" href={entry.fileDokumen} target="_blank" rel="noreferrer">
                  Buka file dokumen
                </a>
              ) : (
                <span class="badge badge-ghost w-full justify-center px-4 py-4">File belum ditambahkan</span>
              )}
              <a class="btn btn-outline w-full rounded-[var(--radius-md)]" href="/data/dokumen">
                Kembali ke katalog
              </a>
            </div>
          </aside>
        </div>
      </article>
    </div>
  </section>
</MainLayout>
