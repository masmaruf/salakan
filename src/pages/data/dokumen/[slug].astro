---
import MainLayout from '../../../layouts/MainLayout.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import { formatTanggal, getDokumen } from '../../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../../lib/site';

const { slug } = Astro.params;
const items = await getDokumen();
const item = items.find((i) => i.slug === slug && i.entry.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/404');
}

const { entry } = item;

const kategoriLabels = {
  layanan: 'Layanan Warga',
  arsip: 'Arsip Publik',
  kegiatan: 'Dokumen Kegiatan',
  regulasi: 'Regulasi',
} as const;

const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.judul));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage);
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImage}>

  <article class="container-premium max-w-3xl py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'Dokumen', href: '/data/dokumen' },
      { label: entry.judul, active: true },
    ]} />

    <header class="mb-6">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="text-[12px] font-semibold px-2.5 py-1 rounded-md bg-primary-container text-on-primary-container">
          {kategoriLabels[entry.kategori]}
        </span>
        {entry.unggulan && (
          <span class="text-[12px] font-semibold px-2.5 py-1 rounded-md bg-amber-100 text-amber-800 flex items-center gap-1">
            <span class="material-symbols-outlined text-[12px]">star</span> Unggulan
          </span>
        )}
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-on-surface leading-tight tracking-tight">{entry.judul}</h1>
      <p class="mt-3 text-base text-on-surface-variant leading-relaxed">{entry.ringkasan}</p>
      <div class="flex items-center gap-4 mt-4 pt-4 border-t border-outline-variant/40 text-sm text-on-surface-variant">
        <time class="flex items-center gap-1.5" datetime={entry.tanggalUpdate}>
          <span class="material-symbols-outlined text-[16px]">calendar_today</span>
          {formatTanggal(entry.tanggalUpdate)}
        </time>
        <span class="text-[12px] text-outline">ID: {slug}</span>
      </div>
    </header>

    <div class="rounded-xl bg-surface-container-low border border-outline-variant p-5 mb-6">
      <h2 class="text-[20px] font-bold text-on-surface mb-3">Deskripsi Dokumen</h2>
      <p class="text-base text-on-surface-variant leading-relaxed">{entry.deskripsi}</p>
    </div>

    <div class="flex flex-wrap gap-3">
      {entry.fileDokumen ? (
        <a class="inline-flex items-center gap-2 rounded-xl bg-m3-primary px-5 py-3 text-sm font-semibold text-on-primary transition-all hover:-translate-y-0.5 hover:shadow-md" href={entry.fileDokumen} target="_blank" rel="noreferrer">
          <span class="material-symbols-outlined text-[18px]">download</span> Buka File Dokumen
        </a>
      ) : (
        <span class="inline-flex items-center gap-2 rounded-xl bg-surface-container-low px-5 py-3 text-sm font-medium text-on-surface-variant border border-outline-variant">
          <span class="material-symbols-outlined text-[18px]">lock</span> File belum ditambahkan
        </span>
      )}
      <a class="inline-flex items-center gap-2 rounded-xl bg-surface-container-lowest border border-outline-variant px-5 py-3 text-sm font-semibold text-on-surface-variant hover:bg-primary-container hover:text-on-primary-container transition-colors" href="/data/dokumen">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Kembali ke katalog
      </a>
    </div>
  </article>

</MainLayout>
