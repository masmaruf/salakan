---
import MainLayout from '../../../layouts/MainLayout.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import ContentMeta from '../../../components/ui/ContentMeta.astro';
import InfoCard from '../../../components/ui/InfoCard.astro';
import ActionLinkButton from '../../../components/ui/ActionLinkButton.astro';
import { formatTanggal, getDokumen, kategoriLabelsDokumen } from '../../../lib/content';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../../lib/site';

const { slug } = Astro.params;
const items = await getDokumen();
const item = items.find((i) => i.slug === slug && i.entry.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/404');
}

const { entry } = item;

const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.judul));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage);

import Icon from '../../../components/ui/Icon.tsx';
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImage}>

  <article class="container-premium max-w-3xl py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'Dokumen', href: '/data/dokumen' },
      { label: entry.judul, active: true },
    ]} />

    <header class="mb-6">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="rounded-md bg-primary-container px-2.5 py-1 text-[12px] font-semibold text-on-primary-container">
          {kategoriLabelsDokumen[entry.kategori]}
        </span>
        {entry.unggulan && (
          <span class="flex items-center gap-1 rounded-md bg-amber-100 px-2.5 py-1 text-[12px] font-semibold text-amber-800">
            <Icon name="star" class="text-[12px]" /> Unggulan
          </span>
        )}
      </div>
      <h1 class="text-2xl font-bold leading-tight tracking-tight text-on-surface sm:text-3xl">{entry.judul}</h1>
      <p class="mt-3 text-base leading-relaxed text-on-surface-variant">{entry.ringkasan}</p>
      <ContentMeta
        class="mt-4 flex items-center gap-4 border-t border-outline-variant/40 pt-4"
        items={[
          { icon: 'calendar_today', text: formatTanggal(entry.tanggalUpdate), datetime: entry.tanggalUpdate, accentClass: 'text-on-surface-variant' },
          { icon: 'tag', text: `ID: ${slug}`, accentClass: 'text-outline' },
        ]}
        iconClass="text-[16px]"
      />
    </header>

    <InfoCard title="Deskripsi Dokumen" class="mb-6 rounded-xl border border-outline-variant bg-surface-container-low p-5">
      <p class="text-base leading-relaxed text-on-surface-variant">{entry.deskripsi}</p>
    </InfoCard>

    <div class="flex flex-wrap gap-3">
      {entry.fileDokumen ? (
        <ActionLinkButton href={entry.fileDokumen} label="Buka File Dokumen" icon="download" variant="primary" target="_blank" rel="noreferrer" />
      ) : (
        <span class="inline-flex items-center gap-2 rounded-xl border border-outline-variant bg-surface-container-low px-5 py-3 text-sm font-medium text-on-surface-variant">
          <Icon name="lock" class="text-[18px]" /> File belum ditambahkan
        </span>
      )}
      <ActionLinkButton href="/data/dokumen" label="Kembali ke katalog" icon="arrow_back" />
    </div>
  </article>

</MainLayout>
