---
import MainLayout from '../../layouts/MainLayout.astro';
import { formatTanggal, getDokumen, getPengaturan, sortByDateDesc } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const pengaturan = await getPengaturan();
const dokumen = (await getDokumen())
  .filter(({ entry }) => entry.statusPublikasi === 'publish')
  .sort((a, b) => {
    if (a.entry.unggulan !== b.entry.unggulan) return Number(b.entry.unggulan) - Number(a.entry.unggulan);
    if (a.entry.urutanTampil !== b.entry.urutanTampil) return a.entry.urutanTampil - b.entry.urutanTampil;
    return new Date(b.entry.tanggalUpdate).getTime() - new Date(a.entry.tanggalUpdate).getTime();
  });
const kategoriLabels = {
  layanan: 'Layanan Warga',
  arsip: 'Arsip Publik',
  kegiatan: 'Dokumen Kegiatan',
  regulasi: 'Regulasi',
} as const;
const totalKategori = new Set(dokumen.map(({ entry }) => entry.kategori)).size;
const seo = pengaturan?.seoHalamanData?.dokumen;
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Dokumen'))}
  description={resolveSeoText(seo?.seoDescription, 'Halaman dokumen warga untuk arsip layanan, format surat, dan dokumen publik Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section">
    <div class="container space-y-8">
      <div class="grid gap-5 lg:grid-cols-[minmax(0,1.15fr)_360px]">
        <div class="surface-card ui-radius-xl p-7 md:p-9">
          <span class="badge badge-primary badge-outline">Sub data dokumen</span>
          <h1 class="mt-5 max-w-3xl text-3xl font-extrabold tracking-tight text-slate-950 md:text-5xl">Dokumen warga tersusun rapi dalam katalog yang mudah dipindai</h1>
          <p class="mt-4 max-w-2xl text-sm leading-8 text-slate-600 md:text-base">
            Halaman ini menampilkan daftar dokumen yang dikelola dari Keystatic, mulai dari format layanan dasar, arsip publik, hingga dokumen kegiatan kampung.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="btn brand-button" href="/data">Kembali ke data</a>
            <a class="btn btn-outline" href="/kontak">Tanyakan dokumen</a>
          </div>
        </div>

        <div class="grid gap-4">
          <article class="surface-card ui-radius-lg p-5">
            <p class="text-sm font-semibold text-slate-500">Jumlah dokumen tampil</p>
            <strong class="mt-2 block text-4xl font-extrabold tracking-tight text-slate-950">{dokumen.length}</strong>
          </article>
          <article class="surface-card ui-radius-lg p-5">
            <p class="text-sm font-semibold text-slate-500">Kategori aktif</p>
            <strong class="mt-2 block text-4xl font-extrabold tracking-tight text-slate-950">{totalKategori}</strong>
            <p class="mt-2 text-sm leading-7 text-slate-600">Data ini otomatis mengikuti pengelompokan kategori dari CMS.</p>
          </article>
        </div>
      </div>

      <div class="grid gap-4 xl:grid-cols-3">
        {dokumen.map(({ slug, entry }) => (
          <article class="surface-card ui-radius-lg p-5" id={slug}>
            <div class="flex flex-wrap items-center justify-between gap-3">
              <span class="badge badge-outline">{kategoriLabels[entry.kategori]}</span>
              <time class="text-sm text-slate-500" datetime={entry.tanggalUpdate}>{formatTanggal(entry.tanggalUpdate)}</time>
            </div>
            <h2 class="mt-4 text-xl font-bold tracking-tight text-slate-950">
              <a class="transition-colors hover:text-violet-700" href={`/data/dokumen/${slug}`}>{entry.judul}</a>
            </h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">{entry.ringkasan}</p>
            <p class="ui-radius-md mt-4 bg-slate-50 px-4 py-4 text-sm leading-7 text-slate-600">{entry.deskripsi}</p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a class="btn btn-outline" href={`/data/dokumen/${slug}`}>Detail dokumen</a>
              {entry.fileDokumen ? (
                <a class="btn btn-outline" href={entry.fileDokumen} target="_blank" rel="noreferrer">Buka file</a>
              ) : (
                <span class="badge badge-ghost px-4 py-3">File belum ditambahkan</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
