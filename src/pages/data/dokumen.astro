---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { formatTanggal, getDokumen, getPengaturan } from '../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [dokumenItems, pengaturan] = await Promise.all([getDokumen(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.dokumen;
const dokumen = dokumenItems
  .filter(({ entry }) => entry.statusPublikasi === 'publish')
  .sort((a, b) => {
    if (a.entry.unggulan !== b.entry.unggulan) return Number(b.entry.unggulan) - Number(a.entry.unggulan);
    if (a.entry.urutanTampil !== b.entry.urutanTampil) return a.entry.urutanTampil - b.entry.urutanTampil;
    return new Date(b.entry.tanggalUpdate).getTime() - new Date(a.entry.tanggalUpdate).getTime();
  });

const breadcrumbItems = [
  { label: 'Beranda', href: '/' },
  { label: 'Pusat Data', href: '/data' },
  { label: 'Arsip Dokumen', active: true },
];

const kategoriLabels = {
  layanan: 'Layanan Warga',
  arsip: 'Arsip Publik',
  kegiatan: 'Dokumen Kegiatan',
  regulasi: 'Regulasi',
} as const;
const totalKategori = new Set(dokumen.map(({ entry }) => entry.kategori)).size;
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Dokumen'))}
  description={resolveSeoText(seo?.seoDescription, 'Arsip dokumen warga Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>
  <section class="section-premium bg-slate-50/50">
    <div class="container-premium relative z-10">
      
          <div class="flex gap-4 lg:flex-col xl:flex-row">
            <div class="flex flex-col items-center justify-center rounded-[2rem] bg-white p-8 shadow-sm border border-slate-100 min-w-[160px]">
              <strong class="text-5xl font-black text-slate-900 leading-none">{dokumen.length}</strong>
              <span class="mt-3 text-[0.65rem] font-black text-blue-600 uppercase tracking-[0.2em]">Dokumen</span>
            </div>
            <div class="flex flex-col items-center justify-center rounded-[2rem] bg-white p-8 shadow-sm border border-slate-100 min-w-[160px]">
              <strong class="text-5xl font-black text-slate-900 leading-none">{totalKategori}</strong>
              <span class="mt-3 text-[0.65rem] font-black text-emerald-600 uppercase tracking-[0.2em]">Kategori</span>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
        {dokumen.map(({ slug, entry }) => (
          <article class="group relative rounded-[2.5rem] bg-white p-8 shadow-sm border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-2 overflow-hidden" id={slug}>
            <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition">
              <span class="material-symbols-outlined text-8xl">article</span>
            </div>
            <div class="relative z-10 flex flex-col h-full">
              <div class="flex items-center justify-between gap-3 mb-6">
                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[0.65rem] font-black text-slate-500 uppercase tracking-widest">{kategoriLabels[entry.kategori]}</span>
                <time class="text-[0.65rem] font-black text-slate-300 uppercase tracking-widest" datetime={entry.tanggalUpdate}>{formatTanggal(entry.tanggalUpdate)}</time>
              </div>
              <h2 class="text-2xl font-black tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors leading-snug">
                <a href={`/data/dokumen/${slug}`}>{entry.judul}</a>
              </h2>
              <p class="mt-4 text-[0.95rem] font-bold text-slate-400 leading-relaxed line-clamp-2">{entry.ringkasan}</p>
              
              <div class="mt-auto pt-8 flex flex-wrap gap-3">
                <a class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-5 py-2.5 text-xs font-black text-blue-700 transition hover:bg-blue-600 hover:text-white hover:shadow-lg" href={`/data/dokumen/${slug}`}>
                  <span class="material-symbols-outlined text-[18px]">visibility</span> LIHAT DETAIL
                </a>
                {entry.fileDokumen ? (
                  <a class="inline-flex items-center gap-2 rounded-full bg-emerald-50 px-5 py-2.5 text-xs font-black text-emerald-700 transition hover:bg-emerald-600 hover:text-white hover:shadow-lg" href={entry.fileDokumen} target="_blank" rel="noreferrer">
                    <span class="material-symbols-outlined text-[18px]">download</span> UNDUH BERKAS
                  </a>
                ) : (
                  <span class="inline-flex items-center gap-2 rounded-full bg-slate-50 px-5 py-2.5 text-xs font-black text-slate-300 italic ring-1 ring-slate-100">
                    <span class="material-symbols-outlined text-[16px]">lock</span> BELUM TERSEDIA
                  </span>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
    </div>
  </section>
</MainLayout>
