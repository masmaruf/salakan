---
import MainLayout from '../../layouts/MainLayout.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import Badge from '../../components/ui/Badge.astro';
import PageSection from '../../components/PageSection.astro';
import InlineAction from '../../components/ui/InlineAction.astro';
import FilterToolbar from '../../components/ui/FilterToolbar.astro';
import PillFilterBar from '../../components/ui/PillFilterBar.astro';
import EmptyStateCard from '../../components/ui/EmptyStateCard.astro';
import { formatTanggal, getDokumen, getHalamanCopy, getPengaturan } from '../../lib/content';
import { KATEGORI_DOKUMEN, kategoriLabelsDokumen } from '../../lib/content-taxonomy';
import { markdownToText } from '../../lib/rich-text';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';
import Icon from '../../components/ui/Icon.tsx';

const [dokumenItems, pengaturan] = await Promise.all([getDokumen(), getPengaturan()]);
const halaman = await getHalamanCopy();
const seo = pengaturan?.seoHalamanData?.dokumen;
const dokumenSemua = dokumenItems
  .filter(({ entry }) => entry.statusPublikasi === 'publish')
  .sort((a, b) => {
    if (a.entry.unggulan !== b.entry.unggulan) return Number(b.entry.unggulan) - Number(a.entry.unggulan);
    if (a.entry.urutanTampil !== b.entry.urutanTampil) return a.entry.urutanTampil - b.entry.urutanTampil;
    return new Date(b.entry.tanggalUpdate).getTime() - new Date(a.entry.tanggalUpdate).getTime();
  });

const kategoriParam = Astro.url.searchParams.get('kategori') ?? 'semua';
const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const normalizedQuery = query.toLowerCase();
const activeKategori = ['semua', ...KATEGORI_DOKUMEN].includes(kategoriParam) ? kategoriParam : 'semua';

const dokumen = dokumenSemua.filter(({ entry }) => {
  if (activeKategori !== 'semua' && entry.kategori !== activeKategori) return false;

  if (!normalizedQuery) return true;

  const haystack = [entry.judul, entry.ringkasan, markdownToText(entry.deskripsi), kategoriLabelsDokumen[entry.kategori]]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();

  return haystack.includes(normalizedQuery);
});
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'Dokumen'))}
  description={resolveSeoText(seo?.seoDescription, 'Arsip dokumen warga Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage)}
>

  <PageIntro
    title={halaman.dokumen.title}
    description={`${dokumenSemua.length} ${halaman.dokumen.descriptionSuffix}`}
    breadcrumbs={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'Arsip Dokumen', active: true },
    ]}
  />

  <section class="container-premium pb-4 pt-4 sm:pt-5">
    <FilterToolbar
      eyebrow="Filter Arsip"
      title="Telusuri dokumen publik"
      description="Katalog dokumen dirapikan dengan pola filter yang seragam agar warga lebih cepat menemukan arsip layanan, kegiatan, maupun regulasi."
      resultText={query || activeKategori !== 'semua' ? `Menampilkan ${dokumen.length} dokumen${query ? ` untuk "${query}"` : ''}${activeKategori !== 'semua' ? ` pada kategori ${kategoriLabelsDokumen[activeKategori as keyof typeof kategoriLabelsDokumen]}` : ''}.` : 'Semua dokumen publik ditampilkan dari pembaruan terbaru.'}
    >
      <div slot="active" class="flex flex-wrap items-center gap-2">
        {(query || activeKategori !== 'semua') && (
          <a class="btn btn-outline btn-sm rounded-full" href="/data/dokumen">
            <Icon name="restart_alt" class="text-[16px]" />
            Reset filter
          </a>
        )}
      </div>

      <div slot="filters" class="grid gap-4">
        <PillFilterBar
          items={[
            { href: query ? `/data/dokumen?q=${encodeURIComponent(query)}` : '/data/dokumen', label: 'Semua kategori', active: activeKategori === 'semua' },
            ...KATEGORI_DOKUMEN.map((item) => ({
              href: `/data/dokumen?kategori=${item}${query ? `&q=${encodeURIComponent(query)}` : ''}`,
              label: kategoriLabelsDokumen[item],
              active: activeKategori === item,
            })),
          ]}
        />

        <form action="/data/dokumen" method="get" class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
          <div class="grid gap-2">
            <label for="dokumen-search" class="detail-label">Cari judul, ringkasan, atau kategori dokumen</label>
            <div class="input input-bordered flex items-center gap-3 rounded-2xl bg-base-100">
              <Icon name="search" class="text-[20px] text-primary" />
              <input
                id="dokumen-search"
                name="q"
                type="search"
                value={query}
                placeholder="Contoh: surat domisili, arsip rapat, pedoman"
                class="w-full border-0 bg-transparent p-0 text-sm text-base-content outline-none placeholder:text-base-content/45"
              />
            </div>
            {activeKategori !== 'semua' && <input type="hidden" name="kategori" value={activeKategori} />}
          </div>
          <button type="submit" class="btn btn-primary rounded-full">
            <Icon name="search" class="text-[16px]" />
            Terapkan
          </button>
        </form>
      </div>
    </FilterToolbar>
  </section>

  <PageSection sectionClass="pb-10 pt-3 sm:pb-14">
    {dokumen.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {dokumen.map(({ slug, entry }) => (
          <article class="card group flex flex-col border border-base-300/70 bg-base-100 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md" id={slug}>
            <div class="card-body p-5">
            <div class="mb-3 flex items-center justify-between gap-2">
              <Badge label={kategoriLabelsDokumen[entry.kategori]} tone="primary" class="px-2 py-1" />
              <time class="badge badge-ghost rounded-full px-3 py-3 text-[12px]" datetime={entry.tanggalUpdate}>
                {formatTanggal(entry.tanggalUpdate)}
              </time>
            </div>

            <h2 class="text-base font-bold leading-tight text-base-content transition-colors group-hover:text-primary sm:text-lg">
              <a href={`/data/dokumen/${slug}`}>{entry.judul}</a>
            </h2>
            <p class="mt-2 flex-1 line-clamp-2 text-sm text-base-content/65">{entry.ringkasan}</p>

            <div class="mt-4 flex flex-wrap gap-2 border-t border-base-300/70 pt-3">
              <InlineAction href={`/data/dokumen/${slug}`} label={halaman.dokumen.detailLabel} icon="visibility" class="btn btn-ghost btn-sm rounded-full text-primary" />
              {entry.fileDokumen ? (
                <InlineAction href={entry.fileDokumen} label={halaman.dokumen.downloadLabel} icon="download" target="_blank" rel="noreferrer" class="btn btn-outline btn-sm rounded-full" />
              ) : (
                <InlineAction as="span" label={halaman.dokumen.unavailableLabel} icon="lock" tone="muted" class="btn btn-disabled btn-sm rounded-full" />
              )}
            </div>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <EmptyStateCard message="Belum ada dokumen yang cocok dengan filter saat ini." />
    )}
  </PageSection>

</MainLayout>
