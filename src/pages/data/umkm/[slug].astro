---
import CmsIcon from '../../../components/CmsIcon.astro';
import MainLayout from '../../../layouts/MainLayout.astro';
import { getUmkm } from '../../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../../lib/site';

export async function getStaticPaths() {
  const items = await getUmkm();

  return items
    .filter(({ entry }) => entry.statusPublikasi === 'publish')
    .map((item) => ({
      params: { slug: item.slug },
      props: { item },
    }));
}

const { item } = Astro.props;
const { entry, slug } = item;

const kategoriLabels = {
  kuliner: 'Kuliner',
  kerajinan: 'Kerajinan',
  jasa: 'Jasa',
  perdagangan: 'Perdagangan',
} as const;

function normalizeWhatsapp(value: string) {
  return value.replace(/[^\d]/g, '');
}

const whatsappUrl = `https://wa.me/${normalizeWhatsapp(entry.whatsapp)}?text=${encodeURIComponent(`Halo, saya ingin mengetahui informasi UMKM ${entry.namaUsaha}.`)}`;
const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.namaUsaha));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage, entry.gambar);
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImage}>
  <section class="section">
    <div class="container max-w-6xl space-y-6">
      <nav class="breadcrumbs text-sm text-slate-500">
        <ul>
          <li><a href="/">Beranda</a></li>
          <li><a href="/data">Data</a></li>
          <li><a href="/data/umkm">UMKM</a></li>
          <li class="text-slate-700">{entry.namaUsaha}</li>
        </ul>
      </nav>

      <article class="surface-card overflow-hidden">
        <div class="grid gap-0 lg:grid-cols-[minmax(0,1.1fr)_420px]">
          <div class="bg-gradient-to-br from-rose-50 via-white to-sky-50 p-6 md:p-8">
            <div class="overflow-hidden rounded-[var(--radius-xl)] border border-slate-200 bg-white shadow-sm">
              {entry.gambar ? (
                <img class="aspect-[16/10] h-full w-full object-cover" src={entry.gambar} alt={entry.altGambar || entry.namaUsaha} loading="lazy" />
              ) : (
                <div class="grid aspect-[16/10] place-items-center text-slate-400">
                  <CmsIcon name="storefront" class="size-14" />
                </div>
              )}
            </div>
          </div>

          <div class="p-6 md:p-8">
            <div class="flex flex-wrap items-center gap-3">
              <span class="badge border-blue-200 bg-blue-50 text-blue-700">{kategoriLabels[entry.kategori]}</span>
              {entry.unggulan && <span class="badge badge-outline">UMKM unggulan</span>}
              <span class="badge badge-ghost">{entry.pemilik}</span>
            </div>

            <div class="mt-5 space-y-4">
              <h1 class="text-3xl font-extrabold tracking-tight text-slate-950 md:text-5xl">{entry.namaUsaha}</h1>
              <p class="text-base leading-8 text-slate-600 md:text-lg">{entry.ringkasan}</p>
              <div class="rounded-[var(--radius-lg)] border border-slate-200 bg-slate-50 p-5">
                <p class="text-sm leading-8 text-slate-600 md:text-base">{entry.deskripsi}</p>
              </div>
            </div>

            <div class="mt-6 grid gap-3 md:grid-cols-2">
              <div class="rounded-[var(--radius-lg)] border border-slate-200 bg-white p-4 shadow-sm">
                <p class="text-sm font-semibold text-slate-500">Pemilik</p>
                <strong class="mt-2 block text-base font-bold text-slate-950">{entry.pemilik}</strong>
              </div>
              <div class="rounded-[var(--radius-lg)] border border-slate-200 bg-white p-4 shadow-sm">
                <p class="text-sm font-semibold text-slate-500">Lokasi</p>
                <strong class="mt-2 block text-base font-bold text-slate-950">{entry.lokasi}</strong>
              </div>
            </div>

            {entry.produkUnggulan?.length ? (
              <div class="mt-6">
                <p class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-500">Produk unggulan</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {entry.produkUnggulan.map((product: string) => (
                    <span class="badge badge-outline">{product}</span>
                  ))}
                </div>
              </div>
            ) : null}

            <div class="mt-6 flex flex-wrap gap-3">
              <a class="btn w-full rounded-[var(--radius-md)] border-0 bg-[#dcfce7] text-emerald-800 shadow-none hover:bg-[#bbf7d0] md:w-auto" href={whatsappUrl} target="_blank" rel="noreferrer">
                <CmsIcon name="whatsapp" class="size-5" />
                Hubungi via WhatsApp
              </a>
              <a class="btn btn-outline w-full rounded-[var(--radius-md)] md:w-auto" href="/data/umkm">
                Kembali ke katalog
              </a>
            </div>

            <p class="mt-5 text-xs text-slate-500">ID usaha: {slug}</p>
          </div>
        </div>
      </article>
    </div>
  </section>
</MainLayout>
