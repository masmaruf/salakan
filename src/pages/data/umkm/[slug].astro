---
import CmsIcon from '../../../components/CmsIcon.astro';
import MainLayout from '../../../layouts/MainLayout.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import { getUmkm } from '../../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../../lib/site';

const { slug } = Astro.params;
const items = await getUmkm();
const item = items.find((i) => i.slug === slug && i.entry.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/404');
}

const { entry } = item;

const kategoriLabels = {
  kuliner: 'Kuliner',
  kerajinan: 'Kerajinan',
  jasa: 'Jasa',
  perdagangan: 'Perdagangan',
} as const;

function normalizeWhatsapp(value: string) {
  return value.replace(/[^\d]/g, '');
}

const whatsappUrl = `https://wa.me/${normalizeWhatsapp(entry.whatsapp)}?text=${encodeURIComponent(`Halo, saya ingin mengetahui informasi UMKM ${entry.namaUsaha}.`)}`;
const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.namaUsaha));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage, entry.gambar);
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImage}>

  <article class="container-premium max-w-4xl py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'UMKM', href: '/data/umkm' },
      { label: entry.namaUsaha, active: true },
    ]} />

    <div class="grid gap-6 lg:grid-cols-[1.1fr_1fr]">
      <!-- Image -->
      <div class="rounded-xl overflow-hidden border border-outline-variant bg-surface-container-low">
        {entry.gambar ? (
          <img class="aspect-[16/10] w-full object-cover" src={entry.gambar} alt={entry.altGambar || entry.namaUsaha} loading="lazy" />
        ) : (
          <div class="grid aspect-[16/10] place-items-center text-on-surface-variant">
            <CmsIcon name="storefront" class="size-14" />
          </div>
        )}
      </div>

      <!-- Content -->
      <div>
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <span class="text-[12px] font-semibold px-2.5 py-1 rounded-md bg-primary-container text-on-primary-container">
            {kategoriLabels[entry.kategori]}
          </span>
          {entry.unggulan && (
            <span class="text-[12px] font-semibold px-2.5 py-1 rounded-md bg-amber-100 text-amber-800 flex items-center gap-1">
              <span class="material-symbols-outlined text-[12px]">star</span> Unggulan
            </span>
          )}
        </div>

        <h1 class="text-2xl sm:text-3xl font-bold text-on-surface leading-tight tracking-tight">{entry.namaUsaha}</h1>
        <p class="mt-2 text-base text-on-surface-variant">{entry.ringkasan}</p>

        <div class="grid gap-3 sm:grid-cols-2 mt-4">
          <div class="rounded-xl border border-outline-variant bg-surface-container-lowest p-4">
            <p class="text-[12px] text-on-surface-variant uppercase tracking-wider mb-1">Pemilik</p>
            <p class="text-sm font-bold text-on-surface">{entry.pemilik}</p>
          </div>
          <div class="rounded-xl border border-outline-variant bg-surface-container-lowest p-4">
            <p class="text-[12px] text-on-surface-variant uppercase tracking-wider mb-1">Lokasi</p>
            <p class="text-sm font-bold text-on-surface">{entry.lokasi}</p>
          </div>
        </div>

        {entry.produkUnggulan?.length > 0 && (
          <div class="mt-4">
            <p class="text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider mb-2">Produk Unggulan</p>
            <div class="flex flex-wrap gap-2">
              {entry.produkUnggulan.map((product: string) => (
                <span class="text-[12px] font-semibold px-3 py-1.5 rounded-full bg-surface-container-low text-on-surface-variant border border-outline-variant">
                  {product}
                </span>
              ))}
            </div>
          </div>
        )}

        <div class="rounded-xl bg-surface-container-low border border-outline-variant p-4 mt-4">
          <p class="text-sm text-on-surface-variant leading-relaxed">{entry.deskripsi}</p>
        </div>

        <div class="flex flex-wrap gap-3 mt-5">
          <a class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-5 py-3 text-sm font-semibold text-white transition-all hover:-translate-y-0.5 hover:shadow-md" href={whatsappUrl} target="_blank" rel="noreferrer">
            <span class="material-symbols-outlined text-[18px]">chat</span> Hubungi via WhatsApp
          </a>
          <a class="inline-flex items-center gap-2 rounded-xl bg-surface-container-lowest border border-outline-variant px-5 py-3 text-sm font-semibold text-on-surface-variant hover:bg-primary-container hover:text-on-primary-container transition-colors" href="/data/umkm">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span> Kembali
          </a>
        </div>
      </div>
    </div>
  </article>

</MainLayout>
