---
import CmsIcon from '../../../components/CmsIcon.astro';
import MainLayout from '../../../layouts/MainLayout.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import InfoCard from '../../../components/ui/InfoCard.astro';
import ActionLinkButton from '../../../components/ui/ActionLinkButton.astro';
import { getUmkm } from '../../../lib/content';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../../lib/site';

const { slug } = Astro.params;
const items = await getUmkm();
const item = items.find((i) => i.slug === slug && i.entry.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/404');
}

const { entry } = item;

const kategoriLabels = {
  kuliner: 'Kuliner',
  kerajinan: 'Kerajinan',
  jasa: 'Jasa',
  perdagangan: 'Perdagangan',
} as const;

function normalizeWhatsapp(value: string) {
  return value.replace(/[^\d]/g, '');
}

const whatsappUrl = `https://wa.me/${normalizeWhatsapp(entry.whatsapp)}?text=${encodeURIComponent(`Halo, saya ingin mengetahui informasi UMKM ${entry.namaUsaha}.`)}`;
const seoTitle = withSiteTitle(resolveSeoText(entry.seoTitle, entry.namaUsaha));
const seoDescription = resolveSeoText(entry.seoDescription, entry.ringkasan);
const seoImage = resolveSeoImage(entry.ogImage, entry.gambar);

import Icon from '../../../components/ui/Icon.tsx';
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImage}>

  <article class="container-premium max-w-4xl py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'UMKM', href: '/data/umkm' },
      { label: entry.namaUsaha, active: true },
    ]} />

    <div class="grid gap-6 lg:grid-cols-[1.1fr_1fr]">
      <div class="overflow-hidden rounded-xl border border-outline-variant bg-surface-container-low">
        {entry.gambar ? (
          <img class="aspect-[16/10] w-full object-cover" src={entry.gambar} alt={entry.altGambar || entry.namaUsaha} loading="lazy" />
        ) : (
          <div class="grid aspect-[16/10] place-items-center text-on-surface-variant">
            <CmsIcon name="storefront" class="size-14" />
          </div>
        )}
      </div>

      <div>
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="rounded-md bg-primary-container px-2.5 py-1 text-[12px] font-semibold text-on-primary-container">
            {kategoriLabels[entry.kategori]}
          </span>
          {entry.unggulan && (
            <span class="flex items-center gap-1 rounded-md bg-amber-100 px-2.5 py-1 text-[12px] font-semibold text-amber-800">
              <Icon name="star" class="text-[12px]" /> Unggulan
            </span>
          )}
        </div>

        <h1 class="text-2xl font-bold leading-tight tracking-tight text-on-surface sm:text-3xl">{entry.namaUsaha}</h1>
        <p class="mt-2 text-base text-on-surface-variant">{entry.ringkasan}</p>

        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <InfoCard title="Pemilik">
            <p class="text-sm font-bold text-on-surface">{entry.pemilik}</p>
          </InfoCard>
          <InfoCard title="Lokasi">
            <p class="text-sm font-bold text-on-surface">{entry.lokasi}</p>
          </InfoCard>
        </div>

        {entry.produkUnggulan?.length > 0 && (
          <div class="mt-4">
            <p class="mb-2 text-[12px] font-semibold uppercase tracking-wider text-on-surface-variant">Produk Unggulan</p>
            <div class="flex flex-wrap gap-2">
              {entry.produkUnggulan.map((product: string) => (
                <span class="rounded-full border border-outline-variant bg-surface-container-low px-3 py-1.5 text-[12px] font-semibold text-on-surface-variant">
                  {product}
                </span>
              ))}
            </div>
          </div>
        )}

        <InfoCard class="mt-4 rounded-xl border border-outline-variant bg-surface-container-low p-4">
          <p class="text-sm leading-relaxed text-on-surface-variant">{entry.deskripsi}</p>
        </InfoCard>

        <div class="mt-5 flex flex-wrap gap-3">
          <ActionLinkButton href={whatsappUrl} label="Hubungi via WhatsApp" icon="chat" variant="success" target="_blank" rel="noreferrer" />
          <ActionLinkButton href="/data/umkm" label="Kembali" icon="arrow_back" />
        </div>
      </div>
    </div>
  </article>

</MainLayout>
