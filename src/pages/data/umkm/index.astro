---
import MainLayout from '../../../layouts/MainLayout.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import CmsIcon from '../../../components/CmsIcon.astro';
import { getUmkm, getPengaturan } from '../../../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../../lib/site';

const [umkmItems, pengaturan] = await Promise.all([getUmkm(), getPengaturan()]);
const seo = pengaturan?.seoHalamanData?.umkm;
const items = umkmItems
  .filter(({ entry }) => entry.statusPublikasi === 'publish')
  .sort((a, b) => {
    if (a.entry.unggulan !== b.entry.unggulan) return Number(b.entry.unggulan) - Number(a.entry.unggulan);
    return a.entry.urutanTampil - b.entry.urutanTampil;
  });

const kategoriLabels = {
  kuliner: 'Kuliner',
  kerajinan: 'Kerajinan',
  jasa: 'Jasa',
  perdagangan: 'Perdagangan',
} as const;

function normalizeWhatsapp(value: string) {
  return value.replace(/[^\d]/g, '');
}
---

<MainLayout
  title={withSiteTitle(resolveSeoText(seo?.seoTitle, 'UMKM'))}
  description={resolveSeoText(seo?.seoDescription, 'Katalog UMKM dan potensi ekonomi warga Padukuhan Salakan.')}
  image={resolveSeoImage(seo?.ogImage, items[0]?.entry.gambar)}
>

  <div class="container-premium pt-8 pb-4">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Pusat Data', href: '/data' },
      { label: 'UMKM', active: true },
    ]} />
    <h1 class="text-[28px] font-bold leading-[36px] text-on-surface">Katalog UMKM</h1>
    <p class="text-base text-on-surface-variant mt-1">
      {items.length} usaha warga terdaftar di Padukuhan Salakan.
    </p>
  </div>

  <section class="container-premium py-8">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {items.map(({ slug, entry }) => (
        <article class="group bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden transition-all hover:-translate-y-0.5 hover:shadow-md flex flex-col" id={slug}>
          <div class="aspect-[16/10] bg-surface-container-low">
            {entry.gambar ? (
              <img class="h-full w-full object-cover" src={entry.gambar} alt={entry.altGambar || entry.namaUsaha} loading="lazy" />
            ) : (
              <div class="grid h-full place-items-center text-on-surface-variant">
                <CmsIcon name="storefront" class="size-12" />
              </div>
            )}
          </div>

          <div class="p-5 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[12px] font-semibold px-2 py-1 rounded-md bg-primary-container text-on-primary-container">
                {kategoriLabels[entry.kategori]}
              </span>
              {entry.unggulan && (
                <span class="text-[12px] font-semibold px-2 py-1 rounded-md bg-amber-100 text-amber-800 flex items-center gap-1">
                  <span class="material-symbols-outlined text-[12px]">star</span> Unggulan
                </span>
              )}
            </div>

            <h2 class="text-base font-bold text-on-surface leading-tight group-hover:text-m3-primary transition-colors sm:text-lg">
              <a href={`/data/umkm/${slug}`}>{entry.namaUsaha}</a>
            </h2>
            <p class="text-sm text-on-surface-variant mt-2 line-clamp-2 flex-1">{entry.ringkasan}</p>

            <div class="text-[12px] font-medium text-outline mt-3">
              <span class="material-symbols-outlined text-[14px] align-middle mr-0.5">location_on</span>
              {entry.lokasi}
            </div>

            <div class="flex flex-wrap gap-2 mt-4 pt-3 border-t border-outline-variant/40">
              <a class="inline-flex items-center gap-1 text-[12px] font-semibold text-m3-primary hover:underline" href={`/data/umkm/${slug}`}>
                <span class="material-symbols-outlined text-[14px]">visibility</span> Detail
              </a>
              <a class="inline-flex items-center gap-1 text-[12px] font-semibold text-emerald-700 hover:underline" href={`https://wa.me/${normalizeWhatsapp(entry.whatsapp)}?text=${encodeURIComponent(`Halo, saya ingin mengetahui informasi UMKM ${entry.namaUsaha}.`)}`} target="_blank" rel="noreferrer">
                <span class="material-symbols-outlined text-[14px]">chat</span> WhatsApp
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

</MainLayout>
