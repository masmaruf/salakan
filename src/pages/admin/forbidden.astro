---
import MainLayout from '../../layouts/MainLayout.astro';

export const prerender = false;

const url = new URL(Astro.request.url);
const blockedArea = url.searchParams.get('area') || '/admin/users';
---

<MainLayout
  title="Akses Ditolak | Padukuhan Salakan"
  description="Halaman penolakan akses untuk area admin yang tidak diizinkan."
  noIndex={true}
>
  <section class="section">
    <div class="container max-w-3xl">
      <div class="surface-card space-y-5 p-6 md:p-8">
        <span class="badge badge-outline w-fit">Akses dibatasi</span>
        <h1 class="page-title font-extrabold text-slate-950">Area ini tidak tersedia untuk role editor</h1>
        <p class="text-body-md text-slate-600">
          Akun editor hanya diizinkan mengelola collection pada grup <strong>Editorial</strong> dan <strong>Data Kampung</strong>.
          Area lain seperti pengaturan situs, akun admin, profil, dan singleton lain dibatasi untuk admin yang lebih tinggi.
        </p>
        <div class="ui-radius-lg border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
          Area yang diblokir: <strong>{blockedArea}</strong>
        </div>
        <div class="flex flex-wrap gap-3">
          <a class="brand-button btn rounded-[var(--radius-md)]" href="/admin/users">Kembali ke panel admin</a>
          <a class="btn btn-outline rounded-[var(--radius-md)]" href="/admin/logout">Logout</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
