---
import MainLayout from '../../layouts/MainLayout.astro';
import {
  type AdminSession,
  createAdminSessionValue,
  getAdminSession,
  getSessionCookieName,
  isAdminConfigured,
  validateAdminLogin,
} from '../../lib/admin-auth';
import { siteMeta } from '../../lib/site';

export const prerender = false;

const url = new URL(Astro.request.url);
const requestedNextPath = url.searchParams.get('next') || '/admin/users';
const configured = isAdminConfigured();
const existingSession = getAdminSession(Astro.cookies.get(getSessionCookieName())?.value);

let errorMessage = '';
let loginResult: AdminSession | null = null;

function getSafeNextPath(value: string) {
  if (!value.startsWith('/')) return '/admin/users';
  if (value.startsWith('//')) return '/admin/users';
  if (value.startsWith('/admin/login')) return '/admin/users';
  return value;
}

function isAllowedFormOrigin(request: Request) {
  const requestUrl = new URL(request.url);
  const cfPagesUrl = process.env.CF_PAGES_URL || null;
  const allowedOrigins = new Set([
    requestUrl.origin,
    siteMeta.siteUrl,
    ...(cfPagesUrl ? [cfPagesUrl] : []),
  ]);

  const originHeader = request.headers.get('origin');
  if (originHeader) {
    if (allowedOrigins.has(originHeader)) return true;
    try {
      const originUrl = new URL(originHeader);
      if (originUrl.hostname.endsWith('.pages.dev') && originUrl.hostname.includes('salakan')) {
        return true;
      }
    } catch {}
    return false;
  }

  const refererHeader = request.headers.get('referer');
  if (refererHeader) {
    try {
      const refererUrl = new URL(refererHeader);
      if (allowedOrigins.has(refererUrl.origin)) return true;
      if (refererUrl.hostname.endsWith('.pages.dev') && refererUrl.hostname.includes('salakan')) {
        return true;
      }
      return false;
    } catch {
      return false;
    }
  }

  return true;
}

const nextPath = getSafeNextPath(requestedNextPath);

if (Astro.request.method === 'POST') {
  if (!isAllowedFormOrigin(Astro.request)) {
    errorMessage = 'Pengiriman form ditolak karena asal permintaan tidak valid.';
  } else {
    const formData = await Astro.request.formData();
    const username = String(formData.get('username') || '');
    const password = String(formData.get('password') || '');
    const nextTarget = getSafeNextPath(String(formData.get('next') || '/admin/users'));

    if (!configured) {
      errorMessage = 'Akun admin belum dikonfigurasi di file environment.';
    } else {
      loginResult = validateAdminLogin(username, password);
    }

    if (!loginResult) {
      errorMessage = 'Username atau password tidak cocok.';
    } else {
      Astro.cookies.set(getSessionCookieName(), createAdminSessionValue(loginResult), {
        httpOnly: true,
        sameSite: 'strict',
        secure: Astro.url.protocol === 'https:',
        path: '/',
        maxAge: 60 * 60 * 8,
      });

      return Astro.redirect(nextTarget);
    }
  }
}

import Icon from '../../components/ui/Icon.tsx';
---

<MainLayout
  title="Login Admin | Padukuhan Salakan"
  description="Halaman login admin untuk mengakses panel pengelolaan konten Padukuhan Salakan."
  noIndex={true}
>
  <section class="relative overflow-hidden bg-slate-50 min-h-[calc(100vh-76px)] flex items-center justify-center py-12">
    {/* Glowing Orbs */}
    <div class="absolute -top-32 -left-32 h-[600px] w-[600px] rounded-full bg-blue-400/20 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 h-[500px] w-[500px] rounded-full bg-emerald-300/15 blur-[100px] pointer-events-none"></div>

    <div class="container-premium relative z-10 grid items-center justify-center gap-10 py-8 grid-cols-1 lg:grid-cols-2 max-w-6xl mx-auto w-full">
      
      {/* Panel Kiri - Info */}
      <div class="rounded-[2.5rem] bg-gradient-to-br from-blue-600 via-indigo-600 to-blue-700 p-8 md:p-12 text-white shadow-[0_20px_60px_rgb(37,99,235,0.3)] relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-10">
          <Icon name="admin_panel_settings" class="text-[72px]" />
        </div>
        <div class="relative z-10 space-y-6">
          <span class="inline-flex items-center gap-2 rounded-full bg-white/15 backdrop-blur px-4 py-1.5 text-xs font-bold uppercase tracking-widest">
            <Icon name="lock" class="text-[16px]" />
            Area Pengelola
          </span>
          <h1 class="max-w-[14ch] text-4xl font-extrabold tracking-tight md:text-5xl lg:text-6xl leading-[1.1]">
            Masuk ke Panel Admin
          </h1>
          <p class="max-w-xl text-lg font-medium leading-relaxed text-blue-100">
            Gunakan akun admin untuk memperbarui pengumuman, berita kegiatan, galeri,
            dan informasi profil padukuhan melalui Pages CMS yang menyimpan perubahan langsung ke repository Git.
          </p>

          <div class="grid gap-4 pt-4">
            <article class="group flex items-start gap-4 rounded-2xl bg-white/10 backdrop-blur p-5 transition hover:bg-white/15">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/15 transition group-hover:bg-white/25">
                <Icon name="edit_note" class="text-[20px]" />
              </div>
              <div>
                <strong class="block text-base font-bold">Konten Warga Tetap Rapi</strong>
                <span class="mt-1 block text-sm leading-relaxed text-white/70">Pengumuman, kegiatan, dan galeri dapat diperbarui dari satu tempat.</span>
              </div>
            </article>
            <article class="group flex items-start gap-4 rounded-2xl bg-white/10 backdrop-blur p-5 transition hover:bg-white/15">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/15 transition group-hover:bg-white/25">
                <Icon name="shield" class="text-[20px]" />
              </div>
              <div>
                <strong class="block text-base font-bold">Akses Terbatas & Aman</strong>
                <span class="mt-1 block text-sm leading-relaxed text-white/70">Panel ini hanya ditujukan untuk admin pengelola konten resmi padukuhan.</span>
              </div>
            </article>
            <article class="group flex items-start gap-4 rounded-2xl bg-white/10 backdrop-blur p-5 transition hover:bg-white/15">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/15 transition group-hover:bg-white/25">
                <Icon name="supervised_user_circle" class="text-[20px]" />
              </div>
              <div>
                <strong class="block text-base font-bold">Role Editor Dibatasi</strong>
                <span class="mt-1 block text-sm leading-relaxed text-white/70">Editor hanya dapat membuka collection Editorial dan Data Kampung.</span>
              </div>
            </article>
          </div>
        </div>
      </div>

      {/* Panel Kanan - Form Login */}
      <div class="rounded-[2.5rem] bg-white/80 backdrop-blur-3xl p-8 md:p-10 shadow-[0_12px_40px_rgb(0,0,0,0.04)] self-center">
        <div class="space-y-4">
          <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-1.5 text-xs font-bold text-blue-700 uppercase tracking-widest shadow-sm">
            <Icon name="key" class="text-[16px]" /> Admin CMS
          </span>
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 bg-gradient-to-r from-slate-900 to-slate-600 bg-clip-text text-transparent">Masuk</h2>
          <p class="text-base font-medium leading-relaxed text-slate-500">Login untuk membuka area pengelolaan konten.</p>
        </div>

        {existingSession && (
          <div class="mt-6 rounded-2xl bg-blue-50 p-5 text-sm font-medium text-blue-800">
            <div class="flex items-center gap-2 mb-3">
              <Icon name="check_circle" class="text-[18px]" />
              Sedang login sebagai <strong>{existingSession.username}</strong> (<strong class="capitalize">{existingSession.role}</strong>)
            </div>
            <div class="flex flex-wrap gap-2">
              <a class="inline-flex items-center gap-1.5 rounded-full bg-white px-5 py-2 text-sm font-bold text-blue-700 shadow-sm transition hover:shadow-md hover:-translate-y-0.5" href="https://app.pagescms.org/" target="_blank" rel="noreferrer">
                <Icon name="dashboard" class="text-[16px]" /> Pages CMS
              </a>
              <a class="inline-flex items-center gap-1.5 rounded-full bg-white px-5 py-2 text-sm font-bold text-slate-600 shadow-sm transition hover:shadow-md hover:-translate-y-0.5" href="/admin/logout">
                <Icon name="logout" class="text-[16px]" /> Logout
              </a>
              {existingSession.role === 'superadmin' && (
                <a class="inline-flex items-center gap-1.5 rounded-full bg-white px-5 py-2 text-sm font-bold text-slate-600 shadow-sm transition hover:shadow-md hover:-translate-y-0.5" href="/admin/users">
                  <Icon name="group" class="text-[16px]" /> Kelola User
                </a>
              )}
            </div>
          </div>
        )}

        {!configured && (
          <div class="mt-6 flex items-start gap-3 rounded-2xl bg-red-50 p-5 text-sm font-medium text-red-700">
            <Icon name="error" class="text-[20px] mt-0.5" />
            <span>Kredensial admin belum aktif. Pastikan <code class="font-bold">ADMIN_USERS_JSON</code> sudah diisi di <code class="font-bold">.env</code>.</span>
          </div>
        )}

        {errorMessage && (
          <div class="mt-6 flex items-center gap-3 rounded-2xl bg-red-50 p-5 text-sm font-bold text-red-700">
            <Icon name="warning" class="text-[20px]" />
            {errorMessage}
          </div>
        )}

        <form method="POST" class="mt-8 grid gap-5">
          <input type="hidden" name="next" value={nextPath} />

          <label class="grid gap-2">
            <span class="flex items-center gap-1.5 text-sm font-bold text-slate-700">
              <Icon name="person" class="text-[16px] text-blue-500" /> Username
            </span>
            <input
              class="w-full rounded-2xl bg-white px-5 py-3.5 text-base font-medium shadow-[0_2px_15px_rgb(0,0,0,0.04)] focus:outline-none focus:ring-2 focus:ring-blue-200 transition placeholder:text-slate-400"
              type="text"
              name="username"
              placeholder="Masukkan username admin"
              autocomplete="username"
              required
            />
          </label>

          <label class="grid gap-2">
            <span class="flex items-center gap-1.5 text-sm font-bold text-slate-700">
              <Icon name="lock" class="text-[16px] text-blue-500" /> Password
            </span>
            <input
              class="w-full rounded-2xl bg-white px-5 py-3.5 text-base font-medium shadow-[0_2px_15px_rgb(0,0,0,0.04)] focus:outline-none focus:ring-2 focus:ring-blue-200 transition placeholder:text-slate-400"
              type="password"
              name="password"
              placeholder="Masukkan password"
              autocomplete="current-password"
              required
            />
          </label>

          <button class="mt-2 inline-flex h-14 w-full items-center justify-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-blue-500 text-base font-bold text-white shadow-[0_8px_20px_rgb(37,99,235,0.3)] transition hover:shadow-[0_12px_28px_rgb(37,99,235,0.4)] hover:-translate-y-0.5 active:translate-y-0" type="submit">
            <Icon name="login" class="text-[20px]" />
            Masuk ke Admin
          </button>
        </form>

        <p class="mt-6 text-sm font-medium leading-relaxed text-slate-400 text-center">
          Setelah berhasil login, Anda akan diarahkan ke panel <span class="font-bold text-slate-600">/admin/users</span>.
        </p>
      </div>
    </div>
  </section>
</MainLayout>
