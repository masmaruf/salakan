---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DashboardStatCard from '../../components/ui/DashboardStatCard.astro';
import { db, Pengajuan, desc } from 'astro:db';
import { getPengajuanStatusMeta } from '../../lib/pengajuan';

const riwayat = await db
  .select()
  .from(Pengajuan)
  .orderBy(desc(Pengajuan.created_at))
  .limit(20);

const stats = {
  selesai: riwayat.filter((r) => r.status === 'selesai').length,
  proses: riwayat.filter((r) => r.status === 'menunggu' || r.status === 'diproses' || r.status === 'perlu_revisi').length,
  revisi: riwayat.filter((r) => r.status === 'perlu_revisi').length,
};

function formatTgl(d: Date) {
  return new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }).format(d);
}

import Icon from '../../components/ui/Icon.tsx';
---

<DashboardLayout title="E-Surat & Pengantar" activeMenu="berkeluarga" description="Layanan pengajuan surat administrasi warga mandiri.">
  <div class="mb-10 flex flex-col gap-3">
    <h2 class="text-gradient">Layanan Persuratan RT/RW</h2>
    <p class="max-w-3xl text-base font-medium leading-relaxed text-slate-500 lg:text-lg">Pantau proses pengajuan surat pengantar KTP, domisili, atau keterangan tidak mampu langsung dari dasbor Anda tanpa harus menunggu lama di balai.</p>
    <div class="flex flex-wrap gap-3 pt-2">
      <a href="/dasbor/buat-surat" class="inline-flex h-11 items-center gap-2 rounded-full bg-blue-600 px-6 text-sm font-black text-white shadow-[0_10px_25px_rgba(37,99,235,0.3)] transition-all hover:-translate-y-0.5 hover:bg-blue-700">
        <Icon name="add_circle" class="text-[18px]" /> Buat Pengajuan Baru
      </a>
      <a href="/dasbor/lacak-surat" class="inline-flex h-11 items-center gap-2 rounded-full border border-slate-200 bg-white px-6 text-sm font-black text-slate-700 transition-all hover:bg-slate-50">
        <Icon name="travel_explore" class="text-[18px]" /> Lacak Status Surat
      </a>
    </div>
  </div>

  <div class="mb-10 grid grid-cols-1 gap-6 md:grid-cols-3">
    <DashboardStatCard label="Selesai Dicetak" value={stats.selesai} description="Pengajuan yang sudah selesai dan siap dipakai warga." tone="blue" icon="verified" />
    <DashboardStatCard label="Masih Berjalan" value={stats.proses} description="Pengajuan yang masih menunggu, diproses, atau perlu revisi." tone="amber" icon="hourglass_empty" />
    <DashboardStatCard label="Perlu Tindak Lanjut" value={stats.revisi} description="Berkas yang perlu diperbaiki sebelum bisa diproses lanjut." tone="orange" icon="edit_note" />
  </div>

  <div class="overflow-hidden rounded-[2.5rem] border border-white/50 bg-white/70 shadow-[0_12px_40px_rgba(0,0,0,0.04)] backdrop-blur-3xl">
    <div class="flex flex-wrap items-center justify-between gap-6 border-b border-white/40 bg-white/20 px-8 py-8">
      <div class="space-y-1">
        <h3 class="text-xl font-extrabold tracking-tight text-slate-900">Riwayat Pengajuan</h3>
        <p class="text-label">Daftar permohonan terbaru dan status terkini</p>
      </div>
      <a href="/dasbor/lacak-surat" class="inline-flex h-12 items-center gap-2 rounded-full border border-slate-200 bg-white px-6 text-sm font-black text-slate-700 transition-all hover:bg-slate-50">
        <Icon name="travel_explore" class="text-[20px]" /> Cek status dengan tiket
      </a>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-left text-[0.95rem] text-slate-600">
        <thead class="border-b border-white/40 bg-slate-50/30 text-label">
          <tr>
            <th class="px-8 py-5">Tiket</th>
            <th class="px-8 py-5">Jenis Surat</th>
            <th class="px-8 py-5">Tanggal</th>
            <th class="px-8 py-5">Status</th>
            <th class="px-8 py-5 text-right">Arah</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/40">
          {riwayat.length === 0 ? (
            <tr>
              <td colspan="5" class="px-8 py-10 text-center font-medium text-slate-400">
                Belum ada riwayat pengajuan surat.
              </td>
            </tr>
          ) : (
            riwayat.map((item) => {
              const statusMeta = getPengajuanStatusMeta(item.status);
              return (
                <tr class="group transition-all hover:bg-white/40">
                  <td class="px-8 py-6 font-mono text-xs font-black text-blue-600">#{item.nomor_surat.split('/')[0]}</td>
                  <td class="px-8 py-6">
                    <p class="font-extrabold text-slate-900">Surat Pengantar</p>
                    <p class="mt-0.5 max-w-[220px] truncate text-[0.7rem] font-bold text-slate-400">Keperluan: {item.keperluan}</p>
                  </td>
                  <td class="px-8 py-6 font-bold text-slate-500">{formatTgl(item.created_at)}</td>
                  <td class="px-8 py-6">
                    <span class:list={['inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-bold', statusMeta.badgeClass]}>
                      <span class:list={['h-2 w-2 rounded-full', statusMeta.dotClass]}></span>
                      {statusMeta.label}
                    </span>
                  </td>
                  <td class="px-8 py-6 text-right">
                    <a href={`/dasbor/lacak-surat?ticket=${encodeURIComponent(item.nomor_surat)}`} class="inline-flex h-9 items-center gap-1.5 rounded-xl bg-slate-50 px-4 text-xs font-bold text-slate-600 shadow-sm transition-all hover:bg-blue-600 hover:text-white">
                      <Icon name="visibility" class="text-[14px]" /> Lacak
                    </a>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>
    <div class="border-t border-white/40 bg-slate-50/20 px-8 py-6 text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-slate-400">Menampilkan {riwayat.length} pengajuan terbaru</p>
    </div>
  </div>
</DashboardLayout>
