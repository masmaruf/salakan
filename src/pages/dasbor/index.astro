---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Pengajuan, desc } from 'astro:db';

const riwayat = await db
  .select()
  .from(Pengajuan)
  .orderBy(desc(Pengajuan.created_at))
  .limit(20);

const stats = {
  selesai: riwayat.filter(r => r.status === 'selesai').length,
  proses: riwayat.filter(r => r.status === 'menunggu' || r.status === 'diproses').length,
  ditolak: riwayat.filter(r => r.status === 'ditolak').length
};

function formatTgl(d: Date) {
  return new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }).format(d);
}
---

<DashboardLayout title="E-Surat & Pengantar" activeMenu="berkeluarga" description="Layanan pengajuan surat administrasi warga mandiri.">
   <div class="flex flex-col gap-3 mb-10">
      <h2 class="text-gradient">Layanan Persuratan RT/RW</h2>
      <p class="text-base lg:text-lg font-medium text-slate-500 max-w-3xl leading-relaxed">Pantau proses pengajuan surat pengantar KTP, domisili, atau keterangan tidak mampu langsung dari dasbor Anda tanpa harus menunggu lama di balai.</p>
   </div>

   <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      <div class="group card-premium">
         <div class="absolute -top-4 -right-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-8xl text-blue-600">task_alt</span>
         </div>
         <p class="text-xs font-black uppercase tracking-[0.12em] text-blue-500 mb-2">Selesai Dicetak</p>
         <div class="flex items-center justify-between">
            <strong class="text-5xl font-black tracking-tight text-slate-900">{stats.selesai}</strong>
            <div class="h-14 w-14 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 shadow-inner group-hover:bg-blue-600 group-hover:text-white transition-all">
               <span class="material-symbols-outlined text-[32px]">verified</span>
            </div>
         </div>
      </div>
      
      <div class="group card-premium">
         <div class="absolute -top-4 -right-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-8xl text-amber-600">pending_actions</span>
         </div>
         <p class="text-xs font-black uppercase tracking-[0.12em] text-amber-500 mb-2">Dalam Proses RT</p>
         <div class="flex items-center justify-between">
            <strong class="text-5xl font-black tracking-tight text-slate-900">{stats.proses}</strong>
            <div class="h-14 w-14 rounded-2xl bg-amber-50 flex items-center justify-center text-amber-600 shadow-inner group-hover:bg-amber-600 group-hover:text-white transition-all">
               <span class="material-symbols-outlined text-[32px]">hourglass_empty</span>
            </div>
         </div>
      </div>

      <div class="group card-premium">
         <div class="absolute -top-4 -right-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <span class="material-symbols-outlined text-8xl text-slate-400">draft</span>
         </div>
         <p class="text-xs font-black uppercase tracking-[0.12em] text-slate-400 mb-2">Ditolak / Draft</p>
         <div class="flex items-center justify-between">
            <strong class="text-5xl font-black tracking-tight text-slate-900">{stats.ditolak}</strong>
            <div class="h-14 w-14 rounded-2xl bg-slate-50 flex items-center justify-center text-slate-400 shadow-inner group-hover:bg-slate-600 group-hover:text-white transition-all">
               <span class="material-symbols-outlined text-[32px]">edit_document</span>
            </div>
         </div>
      </div>
   </div>

   <div class="rounded-[2.5rem] bg-white/70 backdrop-blur-3xl shadow-[0_12px_40px_rgba(0,0,0,0.04)] overflow-hidden border border-white/50">
      <div class="px-8 py-8 flex flex-wrap items-center justify-between gap-6 border-b border-white/40 bg-white/20">
         <div class="space-y-1">
            <h3 class="text-xl font-extrabold text-slate-900 tracking-tight">Riwayat Pengajuan</h3>
            <p class="text-label">Daftar permohonan terbaru</p>
         </div>
         <a href="/dasbor/buat-surat" class="inline-flex h-12 items-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-indigo-700 px-8 text-sm font-black text-white shadow-[0_10px_25px_rgba(37,99,235,0.3)] hover:shadow-[0_15px_35px_rgba(37,99,235,0.4)] hover:-translate-y-1 transition-all active:translate-y-0">
            <span class="material-symbols-outlined text-[20px]">add_circle</span> Buat Pengajuan Baru
         </a>
      </div>
      
      <div class="overflow-x-auto">
         <table class="w-full text-left text-[0.95rem] text-slate-600 border-collapse">
            <thead class="bg-slate-50/30 text-label border-b border-white/40">
               <tr>
                  <th class="px-8 py-5">Tiket</th>
                  <th class="px-8 py-5">Jenis Surat</th>
                  <th class="px-8 py-5">Tanggal</th>
                  <th class="px-8 py-5">Status</th>
                  <th class="px-8 py-5 text-right">Navigasi</th>
               </tr>
            </thead>
            <tbody class="divide-y divide-white/40">
               {riwayat.length === 0 ? (
                  <tr>
                    <td colspan="5" class="px-8 py-10 text-center text-slate-400 font-medium">
                      Belum ada riwayat pengajuan surat.
                    </td>
                  </tr>
                ) : (
                  riwayat.map((item) => (
                    <tr class="group hover:bg-white/40 transition-all">
                      <td class="px-8 py-6 font-mono text-xs font-black text-blue-600">#{item.nomor_surat.split('/')[0]}</td>
                      <td class="px-8 py-6">
                         <p class="font-extrabold text-slate-900">Surat Pengantar</p>
                         <p class="text-[0.7rem] font-bold text-slate-400 mt-0.5 truncate max-w-[200px]">Keperluan: {item.keperluan}</p>
                      </td>
                      <td class="px-8 py-6 font-bold text-slate-500">{formatTgl(item.created_at)}</td>
                      <td class="px-8 py-6">
                         {item.status === 'selesai' && (
                           <span class="badge-emerald">
                              <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                              Siap Diambil
                           </span>
                         )}
                         {item.status === 'diproses' && (
                           <span class="badge-blue">
                              <span class="h-2 w-2 rounded-full bg-blue-500 animate-pulse"></span>
                              Sedang Proses
                           </span>
                         )}
                         {item.status === 'menunggu' && (
                           <span class="badge-amber">
                              <span class="h-2 w-2 rounded-full bg-amber-500 animate-pulse"></span>
                              Review Pak RT
                           </span>
                         )}
                         {item.status === 'ditolak' && (
                           <span class="badge-rose">
                              <span class="h-2 w-2 rounded-full bg-rose-500"></span>
                              Ditolak
                           </span>
                         )}
                      </td>
                      <td class="px-8 py-6 text-right">
                         <button class="inline-flex h-9 items-center gap-1.5 rounded-xl bg-slate-50 px-4 text-xs font-bold text-slate-600 hover:bg-blue-600 hover:text-white transition-all shadow-sm">
                            <span class="material-symbols-outlined text-[14px]">visibility</span> Detail
                         </button>
                      </td>
                    </tr>
                  ))
                )}
            </tbody>
         </table>
      </div>
      <div class="px-8 py-6 bg-slate-50/20 border-t border-white/40 text-center">
         <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Menampilkan {riwayat.length} pengajuan terbaru</p>
      </div>
   </div>
</DashboardLayout>
