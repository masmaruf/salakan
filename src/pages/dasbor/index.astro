---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="E-Surat & Pengantar" activeMenu="berkeluarga" description="Layanan pengajuan surat administrasi warga mandiri.">
   <div class="flex flex-col gap-2 mb-8">
      <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-slate-900">Layanan Persuratan RT/RW</h2>
      <p class="text-sm lg:text-base text-slate-500 max-w-2xl">Pantau proses pengajuan surat pengantar KTP, domisili, atau keterangan tidak mampu langsung dari dasbor Anda tanpa harus menunggu lama di balai.</p>
   </div>

   <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
      <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
         <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Selesai Dicetak</p>
         <div class="mt-2 flex items-center justify-between">
            <strong class="text-3xl font-extrabold text-blue-700">2</strong>
            <span class="material-symbols-outlined text-3xl text-blue-100">task_alt</span>
         </div>
      </div>
      <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
         <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Dalam Proses RT</p>
         <div class="mt-2 flex items-center justify-between">
            <strong class="text-3xl font-extrabold text-amber-500">1</strong>
            <span class="material-symbols-outlined text-3xl text-amber-100">pending_actions</span>
         </div>
      </div>
      <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
         <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Ditolak / Draft</p>
         <div class="mt-2 flex items-center justify-between">
            <strong class="text-3xl font-extrabold text-slate-900">0</strong>
            <span class="material-symbols-outlined text-3xl text-slate-100">draft</span>
         </div>
      </div>
   </div>

   <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
         <div>
            <h3 class="text-base font-bold text-slate-900">Riwayat Pengajuan</h3>
            <p class="text-xs text-slate-500 mt-1">Daftar permohonan surat 30 hari terakhir.</p>
         </div>
         <button class="bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm px-4 py-2 rounded-lg shadow-md transition-colors flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">add</span> Buat Pengajuan Baru
         </button>
      </div>
      
      <div class="overflow-x-auto">
         <table class="w-full text-left text-sm text-slate-600 border-collapse">
            <thead class="bg-slate-50 border-b border-slate-100 text-xs uppercase font-bold text-slate-400">
               <tr>
                  <th class="px-6 py-4">Nomor Tiket</th>
                  <th class="px-6 py-4">Jenis Surat</th>
                  <th class="px-6 py-4">Tanggal Pengajuan</th>
                  <th class="px-6 py-4">Status Verifikasi</th>
                  <th class="px-6 py-4 text-right">Aksi</th>
               </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
               <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-mono text-xs font-bold text-slate-900">#SLK-0091</td>
                  <td class="px-6 py-4 font-semibold text-slate-700">Surat Pengantar Domisili</td>
                  <td class="px-6 py-4">30 Mar 2026</td>
                  <td class="px-6 py-4">
                     <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-2.5 py-1 text-xs font-semibold text-amber-700 border border-amber-200">
                        <span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span>
                        Review Pak RT
                     </span>
                  </td>
                  <td class="px-6 py-4 text-right">
                     <button class="text-blue-600 hover:text-blue-800 font-semibold text-sm">Lihat Detail</button>
                  </td>
               </tr>
               <tr class="bg-slate-50/50 hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-mono text-xs font-bold text-slate-900">#SLK-0042</td>
                  <td class="px-6 py-4 font-semibold text-slate-700">Surat Keterangan Tidak Mampu (SKTM)</td>
                  <td class="px-6 py-4">12 Feb 2026</td>
                  <td class="px-6 py-4">
                     <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700 border border-emerald-200">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                        Selesai Dicetak
                     </span>
                  </td>
                  <td class="px-6 py-4 text-right">
                     <button class="text-blue-600 hover:text-blue-800 font-semibold text-sm">Unduh PDF</button>
                  </td>
               </tr>
            </tbody>
         </table>
      </div>
   </div>
</DashboardLayout>
