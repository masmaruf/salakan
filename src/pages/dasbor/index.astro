---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import DashboardStatCard from '../../components/ui/DashboardStatCard.astro';
import { getPengajuanStatusMeta } from '../../lib/pengajuan';
import { getRecentPengajuanRecords } from '../../lib/dynamic-data';

const riwayat = await getRecentPengajuanRecords(20);

const stats = {
  selesai: riwayat.filter((r) => r.status === 'selesai').length,
  proses: riwayat.filter((r) => r.status === 'menunggu' || r.status === 'diproses' || r.status === 'perlu_revisi').length,
  revisi: riwayat.filter((r) => r.status === 'perlu_revisi').length,
};

function formatTgl(d: string | Date) {
  return new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(d));
}

import Icon from '../../components/ui/Icon.tsx';
---

<DashboardLayout title="E-Surat & Pengantar" activeMenu="berkeluarga" description="Layanan pengajuan surat administrasi warga mandiri.">
  <div class="mb-10 flex flex-col gap-3">
    <h2 class="text-gradient">Layanan Persuratan RT/RW</h2>
    <p class="max-w-3xl text-base font-medium leading-relaxed text-base-content/65 lg:text-lg">Pantau proses pengajuan surat pengantar KTP, domisili, atau keterangan tidak mampu langsung dari dasbor Anda tanpa harus menunggu lama di balai.</p>
    <div class="flex flex-wrap gap-3 pt-2">
      <a href="/dasbor/buat-surat" class="btn btn-primary rounded-full">
        <Icon name="add_circle" class="text-[18px]" /> Buat Pengajuan Baru
      </a>
      <a href="/dasbor/lacak-surat" class="btn btn-outline btn-primary rounded-full">
        <Icon name="travel_explore" class="text-[18px]" /> Lacak Status Surat
      </a>
    </div>
  </div>

  <div class="mb-10 grid grid-cols-1 gap-6 md:grid-cols-3">
    <DashboardStatCard label="Selesai Dicetak" value={stats.selesai} description="Pengajuan yang sudah selesai dan siap dipakai warga." tone="blue" icon="verified" />
    <DashboardStatCard label="Masih Berjalan" value={stats.proses} description="Pengajuan yang masih menunggu, diproses, atau perlu revisi." tone="amber" icon="hourglass_empty" />
    <DashboardStatCard label="Perlu Tindak Lanjut" value={stats.revisi} description="Berkas yang perlu diperbaiki sebelum bisa diproses lanjut." tone="orange" icon="edit_note" />
  </div>

  <div class="card border border-base-300/70 bg-base-100 shadow-sm">
    <div class="card-body flex flex-wrap items-center justify-between gap-6 border-b border-base-300/70 p-6 sm:p-8">
      <div class="space-y-1">
        <h3 class="text-xl font-extrabold tracking-tight text-base-content">Riwayat Pengajuan</h3>
        <p class="text-label">Daftar permohonan terbaru dan status terkini</p>
      </div>
      <a href="/dasbor/lacak-surat" class="btn btn-outline btn-primary rounded-full">
        <Icon name="travel_explore" class="text-[20px]" /> Cek status dengan tiket
      </a>
    </div>

    <div class="overflow-x-auto">
      <table class="table table-zebra w-full">
        <thead class="text-base-content/60">
          <tr>
            <th>Tiket</th>
            <th>Jenis Surat</th>
            <th>Tanggal</th>
            <th>Status</th>
            <th class="text-right">Arah</th>
          </tr>
        </thead>
        <tbody>
          {riwayat.length === 0 ? (
            <tr>
              <td colspan="5" class="py-10 text-center font-medium text-base-content/45">
                Belum ada riwayat pengajuan surat.
              </td>
            </tr>
          ) : (
            riwayat.map((item) => {
              const statusMeta = getPengajuanStatusMeta(item.status);
              return (
                <tr class="group">
                  <td class="font-mono text-xs font-black text-primary">#{item.nomor_surat.split('/')[0]}</td>
                  <td>
                    <p class="font-extrabold text-base-content">Surat Pengantar</p>
                    <p class="mt-0.5 max-w-[220px] truncate text-[0.7rem] font-bold text-base-content/45">Keperluan: {item.keperluan}</p>
                  </td>
                  <td class="font-bold text-base-content/65">{formatTgl(item.created_at)}</td>
                  <td>
                    <Badge
                      label={statusMeta.label}
                      tone={statusMeta.tone}
                      variant={statusMeta.variant}
                      icon={statusMeta.icon}
                      class="px-3 py-2 text-sm font-bold"
                    />
                  </td>
                  <td class="text-right">
                    <a href={`/dasbor/lacak-surat?ticket=${encodeURIComponent(item.nomor_surat)}`} class="btn btn-ghost btn-xs rounded-full text-primary hover:bg-primary hover:text-primary-content">
                      <Icon name="visibility" class="text-[14px]" /> Lacak
                    </a>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>
    <div class="border-t border-base-300/70 bg-base-200/50 px-8 py-6 text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-base-content/45">Menampilkan {riwayat.length} pengajuan terbaru</p>
    </div>
  </div>
</DashboardLayout>
