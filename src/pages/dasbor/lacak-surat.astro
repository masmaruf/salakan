---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import TrackingSuratForm from '../../components/TrackingSuratForm';
import Icon from '../../components/ui/Icon.tsx';
import DashboardPanel from '../../components/ui/DashboardPanel.astro';

const initialTicket = Astro.url.searchParams.get('ticket') ?? '';
---

<DashboardLayout
  title="Lacak Status Pengajuan"
  activeMenu="lacak-surat"
  description="Periksa status pengajuan surat warga dengan nomor tiket dan NIK pemohon."
>
  <div class="mb-10 flex flex-col gap-3">
    <a
      href="/dasbor"
      class="btn btn-outline btn-sm w-fit rounded-xl border-slate-200 bg-white text-xs font-bold text-slate-500 shadow-sm transition-all hover:border-blue-100 hover:bg-blue-50 hover:text-blue-600 active:scale-[0.98]"
    >
      <Icon name="arrow_back" class="text-[16px]" /> Kembali ke Dasbor
    </a>
    <h2 class="text-gradient">Lacak Status Pengajuan</h2>
    <p class="max-w-3xl text-base font-medium leading-relaxed text-slate-500 lg:text-lg">
      Warga bisa memeriksa progres surat mandiri kapan saja menggunakan nomor tiket pengajuan dan NIK pemohon.
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <TrackingSuratForm client:load initialTicket={initialTicket} />

    <DashboardPanel>
      <p class="text-xs font-black uppercase tracking-widest text-slate-500">Cara pakai</p>
      <ol class="mt-4 space-y-4 text-sm text-slate-600">
        <li class="flex gap-3">
          <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-blue-50 font-black text-blue-600">1</span>
          Masukkan nomor tiket yang diterima setelah formulir berhasil dikirim.
        </li>
        <li class="flex gap-3">
          <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-blue-50 font-black text-blue-600">2</span>
          Isi NIK pemohon yang sama dengan data pada formulir.
        </li>
        <li class="flex gap-3">
          <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-blue-50 font-black text-blue-600">3</span>
          Bila status perlu revisi atau ditolak, cek catatan pengurus lalu hubungi RT atau ajukan ulang.
        </li>
      </ol>

      <div class="mt-6 rounded-2xl bg-slate-50 p-4">
        <p class="text-xs font-black uppercase tracking-widest text-slate-400">Butuh bantuan cepat?</p>
        <div class="mt-3 flex flex-col gap-3">
          <a class="btn btn-primary rounded-xl text-sm font-bold shadow-sm hover:-translate-y-0.5 active:scale-[0.98]" href="/dasbor/buat-surat">
            <Icon name="add_circle" class="text-[18px]" /> Buat pengajuan baru
          </a>
          <a class="btn btn-outline rounded-xl border-slate-200 bg-white text-sm font-bold text-slate-700 shadow-sm hover:-translate-y-0.5 hover:bg-slate-50 active:scale-[0.98]" href="/data/layanan-warga">
            <Icon name="support_agent" class="text-[18px]" /> Lihat panduan layanan
          </a>
        </div>
      </div>
    </DashboardPanel>
  </div>
</DashboardLayout>
