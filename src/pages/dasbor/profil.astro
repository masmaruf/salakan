---
import { getCollection } from 'astro:content';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DashboardPanel from '../../components/ui/DashboardPanel.astro';
import DashboardStatCard from '../../components/ui/DashboardStatCard.astro';
import CopyButton from '../../components/ui/CopyButton.astro';
import { getDashboardContent, getMonografi, getPengaturan } from '../../lib/content';
import { getMonografiSummary } from '../../lib/monografi-summary';
import Icon from '../../components/ui/Icon.tsx';

const [dashboardContent, monografi, pengaturan, rtItems] = await Promise.all([getDashboardContent(), getMonografi(), getPengaturan(), getCollection('rt')]);
const content = dashboardContent?.profil;
const daftarRt = rtItems.filter((item) => item.data.aktif).sort((a, b) => a.data.nomor_rt.localeCompare(b.data.nomor_rt));
const dokumenKeluarga = content?.checklistItems ?? ['Kartu Keluarga', 'KTP anggota keluarga'];
const monografiSummary = getMonografiSummary(monografi);

function normalizedPhone(value?: string) {
  if (!value) return '';
  return value.startsWith('62') ? `0${value.slice(2)}` : value;
}
---

<DashboardLayout title="Data Keluarga (KK)" activeMenu="profil" description="Ringkasan data wilayah dan kesiapan administrasi keluarga warga.">
  <div class="mb-10 flex flex-col gap-3">
    <a href="/dasbor" class="inline-flex w-fit items-center gap-1.5 rounded-xl border border-slate-200 bg-white px-4 py-2 text-xs font-bold text-slate-500 shadow-sm transition-all hover:bg-blue-50 hover:text-blue-600"><Icon name="arrow_back" class="text-[16px]" /> Kembali ke Dasbor</a>
    <h2 class="text-gradient">Data Keluarga (KK)</h2>
    <p class="max-w-3xl text-base font-medium leading-relaxed text-slate-500 lg:text-lg">{content?.intro ?? 'Ringkasan data keluarga dan wilayah warga.'}</p>
  </div>

  <div class="mb-8 grid gap-6 md:grid-cols-3">
    <DashboardStatCard label="Total KK" value={monografiSummary.totalKK} description={content?.stats?.totalKk ?? 'Kepala keluarga yang tercatat pada monografi saat ini.'} tone="blue" icon="family_restroom" />
    <DashboardStatCard label="Total Jiwa" value={monografiSummary.totalJiwa} description={content?.stats?.totalJiwa ?? 'Ringkasan populasi warga yang bisa dipakai sebagai konteks layanan.'} tone="emerald" icon="groups" />
    <DashboardStatCard label="RT Aktif" value={monografiSummary.jumlahRT || daftarRt.length} description={content?.stats?.rtAktif ?? 'Penghubung wilayah yang bisa dihubungi bila ada penyesuaian data keluarga.'} tone="amber" icon="account_tree" />
  </div>

  <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <DashboardPanel title={content?.checklistTitle ?? 'Checklist Data Inti'} icon="fact_check">
      <ul class="mt-4 grid gap-3 text-sm text-slate-600 sm:grid-cols-2">{dokumenKeluarga.map((item) => <li class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-3 font-medium">{item}</li>)}</ul>
      <div class="mt-5 rounded-2xl border border-blue-100 bg-blue-50 px-4 py-4 text-sm leading-relaxed text-blue-900">{content?.checklistNote ?? 'Siapkan dokumen inti sebelum mengajukan layanan.'}</div>
    </DashboardPanel>

    <div class="grid gap-6">
      <DashboardPanel title={content?.activeRtTitle ?? 'Kontak RT Aktif'} icon="groups">
        <div class="mt-4 space-y-3">
          {daftarRt.map((item) => (
            <div class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-black text-slate-900">RT {item.data.nomor_rt}</p>
                  <p class="mt-1 text-sm font-medium text-slate-600">Ketua: {item.data.nama_ketua}</p>
                  <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-slate-400">{normalizedPhone(item.data.no_hp_ketua) || 'Kontak belum dicantumkan'}</p>
                </div>
                <a href={`/ketua-rt#rt-${item.data.nomor_rt}`} class="inline-flex items-center gap-1 text-[12px] font-semibold text-blue-600 hover:underline">
                  <Icon name="open_in_new" class="text-[14px]" />
                  Buka
                </a>
              </div>
              {item.data.no_hp_ketua && (
                <div class="mt-3">
                  <CopyButton value={normalizedPhone(item.data.no_hp_ketua)} label="Salin nomor" class="w-full justify-center border-slate-200 bg-white text-slate-700 hover:bg-slate-100" />
                </div>
              )}
            </div>
          ))}
        </div>
      </DashboardPanel>

      <DashboardPanel title={content?.serviceAddressTitle ?? 'Alamat Layanan'} icon="home_pin">
        <p class="mt-4 whitespace-pre-line text-sm leading-relaxed text-slate-600">{pengaturan?.alamat ?? 'Alamat layanan belum diatur.'}</p>
      </DashboardPanel>
    </div>
  </div>
</DashboardLayout>
