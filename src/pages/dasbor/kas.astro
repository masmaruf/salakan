---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DashboardPanel from '../../components/ui/DashboardPanel.astro';
import DashboardStatCard from '../../components/ui/DashboardStatCard.astro';
import { formatTanggal, getDashboardContent, getKasRt } from '../../lib/content';
import Icon from '../../components/ui/Icon.tsx';

const [dashboardContent, reportsRaw] = await Promise.all([getDashboardContent(), getKasRt()]);
const content = dashboardContent?.kas;
const reports = reportsRaw.filter((item) => item.entry.statusPublikasi === 'publish').sort((a, b) => new Date(b.entry.tanggalUpdate).getTime() - new Date(a.entry.tanggalUpdate).getTime());
const latest = reports[0] ?? null;
const totalPemasukan = reports.reduce((sum, item) => sum + item.entry.pemasukan, 0);
const totalPengeluaran = reports.reduce((sum, item) => sum + item.entry.pengeluaran, 0);
const totalSaldo = reports.reduce((sum, item) => sum + item.entry.saldoAkhir, 0);
function formatRupiah(value: number) { return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(value); }
---

<DashboardLayout title="Transparansi Kas RT" activeMenu="kas" description="Ringkasan kas RT berbasis data lokal yang bisa dibaca warga secara cepat.">
  <div class="mb-10 flex flex-col gap-3">
    <a href="/dasbor" class="inline-flex w-fit items-center gap-1.5 rounded-xl border border-slate-200 bg-white px-4 py-2 text-xs font-bold text-slate-500 shadow-sm transition-all hover:bg-blue-50 hover:text-blue-600"><Icon name="arrow_back" class="text-[16px]" /> Kembali ke Dasbor</a>
    <h2 class="text-gradient">Transparansi Kas RT</h2>
    <p class="max-w-3xl text-base font-medium leading-relaxed text-slate-500 lg:text-lg">{content?.intro ?? 'Halaman ini sekarang membaca ringkasan laporan kas dari konten lokal.'}</p>
  </div>

  <div class="mb-8 grid gap-6 md:grid-cols-3">
    <DashboardStatCard label="Total Pemasukan" value={formatRupiah(totalPemasukan)} description={content?.stats?.pemasukan ?? 'Akumulasi pemasukan dari laporan kas yang sedang ditayangkan.'} tone="blue" icon="trending_up" />
    <DashboardStatCard label="Total Pengeluaran" value={formatRupiah(totalPengeluaran)} description={content?.stats?.pengeluaran ?? 'Ringkasan dana yang sudah dipakai untuk operasional dan kegiatan warga.'} tone="amber" icon="payments" />
    <DashboardStatCard label="Total Saldo" value={formatRupiah(totalSaldo)} description={content?.stats?.saldo ?? 'Saldo tercatat dari laporan yang sedang dipublikasikan.'} tone="emerald" icon="account_balance_wallet" />
  </div>

  <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
    <DashboardPanel title={content?.latestTitle ?? 'Laporan Terbaru'} icon="receipt_long">
      {latest ? (
        <div class="mt-4 space-y-4">
          <div class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-4"><p class="text-xs font-black uppercase tracking-[0.12em] text-blue-500">Periode</p><p class="mt-2 text-lg font-black text-slate-900">{latest.entry.periode}</p><p class="mt-1 text-sm text-slate-500">Diperbarui {formatTanggal(latest.entry.tanggalUpdate)}</p></div>
          <p class="text-sm leading-relaxed text-slate-600">{latest.entry.ringkasan}</p>
          <div class="grid gap-3 sm:grid-cols-3"><div class="rounded-2xl bg-white px-4 py-4 shadow-sm"><p class="text-[11px] font-black uppercase tracking-[0.12em] text-slate-400">Masuk</p><p class="mt-2 text-sm font-black text-slate-900">{formatRupiah(latest.entry.pemasukan)}</p></div><div class="rounded-2xl bg-white px-4 py-4 shadow-sm"><p class="text-[11px] font-black uppercase tracking-[0.12em] text-slate-400">Keluar</p><p class="mt-2 text-sm font-black text-slate-900">{formatRupiah(latest.entry.pengeluaran)}</p></div><div class="rounded-2xl bg-white px-4 py-4 shadow-sm"><p class="text-[11px] font-black uppercase tracking-[0.12em] text-slate-400">Saldo</p><p class="mt-2 text-sm font-black text-slate-900">{formatRupiah(latest.entry.saldoAkhir)}</p></div></div>
          {latest.entry.catatan && <p class="text-sm leading-relaxed text-slate-500">{latest.entry.catatan}</p>}
        </div>
      ) : <p class="mt-4 text-sm text-slate-500">{content?.emptyMessage ?? 'Belum ada laporan kas yang dipublikasikan.'}</p>}
    </DashboardPanel>

    <DashboardPanel title={content?.historyTitle ?? 'Riwayat Periode'} icon="timeline">
      <div class="mt-4 space-y-3">{reports.map((item) => <div class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-4"><div class="flex flex-wrap items-center justify-between gap-3"><div><p class="text-sm font-black text-slate-900">{item.entry.periode}</p><p class="mt-1 text-xs font-semibold uppercase tracking-wide text-slate-400">{formatTanggal(item.entry.tanggalUpdate)}</p></div><span class="rounded-full bg-white px-3 py-1 text-xs font-black text-emerald-700 shadow-sm">{formatRupiah(item.entry.saldoAkhir)}</span></div></div>)}</div>
      <a href="/data/kas-rt" class="mt-5 inline-flex items-center gap-2 rounded-full bg-slate-900 px-5 py-3 text-sm font-bold text-white transition hover:bg-blue-600">{content?.publicCtaLabel ?? 'Buka halaman publik'} <Icon name="arrow_forward" class="text-[16px]" /></a>
    </DashboardPanel>
  </div>
</DashboardLayout>
