---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import InfoCard from '../components/ui/InfoCard.astro';
import ActionLinkButton from '../components/ui/ActionLinkButton.astro';
import CopyButton from '../components/ui/CopyButton.astro';
import { getHalamanCopy, getPengaturan, normalizeWhatsapp } from '../lib/content';

const pengaturan = await getPengaturan();
const halaman = await getHalamanCopy();
const nomorWhatsapp = pengaturan?.kontakWhatsApp ? normalizeWhatsapp(pengaturan.kontakWhatsApp) : '';
const nomorWhatsappDisplay = pengaturan?.kontakWhatsApp ? `0${nomorWhatsapp.replace(/^62/, '')}` : '';
const whatsappLink = nomorWhatsapp ? `https://wa.me/${nomorWhatsapp}` : null;
const alamat = pengaturan?.alamat ?? halaman.kontak.addressFallback;
const email = pengaturan?.email ?? '';
---

<MainLayout title={halaman.kontak.layoutTitle} description={halaman.kontak.layoutDescription}>

  <PageHero
    eyebrow={halaman.kontak.heroEyebrow}
    icon="support_agent"
    title={halaman.kontak.heroTitle}
    description={halaman.kontak.heroDescription}
    orbs={[
      { class: 'absolute -top-16 left-[14%] h-[250px] w-[250px] rounded-full bg-blue-400/20 blur-3xl sm:h-[320px] sm:w-[320px]' },
      { class: 'absolute bottom-[-2rem] right-[10%] h-[220px] w-[220px] rounded-full bg-emerald-400/10 blur-3xl sm:h-[280px] sm:w-[280px]' },
    ]}
  />

  <section class="container-premium pt-4 pb-2">
    <Breadcrumb items={[
      { name: 'Beranda', href: '/' },
      { name: 'Kontak' },
    ]} />
  </section>

  <section class="container-premium py-8 sm:py-10">
    <div class="card border border-base-300/70 bg-base-100 shadow-sm">
      <div class="card-body p-5 sm:p-6">
      <p class="section-kicker">Aksi Cepat</p>
      <h2 class="mt-1 text-2xl font-bold tracking-tight text-base-content">Pilih cara tercepat untuk menghubungi layanan warga</h2>
      <p class="mt-2 max-w-3xl text-sm leading-relaxed text-base-content/65">
        Warga bisa langsung membuka WhatsApp resmi, menyalin nomor kontak, atau lompat ke halaman ketua RT sesuai kebutuhan pelayanan.
      </p>

      <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        {whatsappLink ? (
          <>
            <ActionLinkButton href={whatsappLink} label="Buka WhatsApp" icon="chat" variant="success" target="_blank" rel="noreferrer" class="btn btn-success rounded-full justify-center" />
            <CopyButton value={nomorWhatsappDisplay || nomorWhatsapp} label="Salin nomor WA" class="btn btn-outline rounded-full justify-center" />
          </>
        ) : (
          <div class="alert alert-warning sm:col-span-2 xl:col-span-2">
            <p class="text-sm font-bold">{halaman.kontak.whatsappPendingLabel}</p>
          </div>
        )}
        <ActionLinkButton href="/ketua-rt" label="Pilih Ketua RT" icon="groups" variant="outline" class="btn btn-outline rounded-full justify-center" />
        <CopyButton value={alamat} label="Salin alamat" icon="home_pin" class="btn btn-outline rounded-full justify-center" />
      </div>
      </div>
    </div>
  </section>

  <section class="container-premium py-0 pb-10 sm:pb-14">
    <div class="grid gap-4 xl:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-4">
        <InfoCard title={halaman.kontak.addressTitle} icon="location_on" class="card border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
          <p class="whitespace-pre-line text-sm font-bold leading-relaxed text-on-surface">{alamat}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <CopyButton value={alamat} label="Salin alamat" icon="content_copy" class="btn btn-outline btn-sm rounded-full" />
            <ActionLinkButton href="/profil#lokasi" label="Lihat peta" icon="map" variant="outline" class="btn btn-outline btn-sm rounded-full" />
          </div>
        </InfoCard>

        <InfoCard title={halaman.kontak.whatsappTitle} icon="chat" class="card border border-success/20 bg-success/5 shadow-sm" bodyClass="card-body p-5">
          {whatsappLink ? (
            <>
              <p class="text-sm font-bold text-on-surface">{nomorWhatsappDisplay || nomorWhatsapp}</p>
              <p class="mt-1 text-sm text-on-surface-variant">Gunakan nomor ini untuk pertanyaan umum, konfirmasi layanan, atau arahan ke pengurus terkait.</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <ActionLinkButton href={whatsappLink} label={halaman.kontak.whatsappActionLabel} icon="open_in_new" variant="success" target="_blank" rel="noreferrer" class="btn btn-success btn-sm rounded-full" />
                <CopyButton value={nomorWhatsappDisplay || nomorWhatsapp} label="Salin nomor" class="btn btn-outline btn-sm rounded-full" />
              </div>
            </>
          ) : (
            <div class="alert alert-warning mt-2 text-sm font-bold">{halaman.kontak.whatsappPendingLabel}</div>
          )}
        </InfoCard>
      </div>

      <div class="space-y-4">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-1">
          <InfoCard title={halaman.kontak.emailTitle} icon="mail" class="card border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
            <p class="break-words text-sm font-bold text-on-surface">{email || '-'}</p>
            {email && (
              <div class="mt-4 flex flex-wrap gap-2">
                <ActionLinkButton href={`mailto:${email}`} label="Kirim email" icon="send" variant="outline" class="btn btn-outline btn-sm rounded-full" />
                <CopyButton value={email} label="Salin email" class="btn btn-outline btn-sm rounded-full" />
              </div>
            )}
          </InfoCard>

          <InfoCard title={halaman.kontak.workingHoursTitle} icon="schedule" class="card border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
            <p class="text-sm font-bold leading-relaxed text-on-surface">{pengaturan?.jamLayanan ?? '-'}</p>
          </InfoCard>
        </div>

        <InfoCard title="Butuh jalur yang lebih spesifik?" icon="call" class="card border border-primary/15 bg-primary/5 shadow-sm" bodyClass="card-body p-5">
          <p class="text-sm leading-relaxed text-on-surface-variant">
            Untuk urusan yang perlu tindak lanjut di tingkat lingkungan, pilih ketua RT wilayah Anda agar komunikasi lebih cepat dan sesuai konteks domisili.
          </p>
          <div class="mt-4">
            <ActionLinkButton href="/ketua-rt" label="Buka kontak ketua RT" icon="arrow_forward" variant="outline" class="btn btn-primary rounded-full" />
          </div>
        </InfoCard>
      </div>
    </div>
  </section>

</MainLayout>
