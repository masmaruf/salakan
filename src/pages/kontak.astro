---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import InfoCard from '../components/ui/InfoCard.astro';
import ActionLinkButton from '../components/ui/ActionLinkButton.astro';
import { getPengaturan } from '../lib/content';

const pengaturan = await getPengaturan();
const nomorWhatsapp = pengaturan?.kontakWhatsApp?.replace(/\D/g, '');
const whatsappLink = nomorWhatsapp ? `https://wa.me/${nomorWhatsapp}` : null;

import Icon from '../components/ui/Icon.tsx';
---

<MainLayout title="Kontak | Padukuhan Salakan" description="Alamat dan kontak informasi Padukuhan Salakan.">

  <PageHero
    eyebrow="Hubungi Kami"
    icon="support_agent"
    title="Kontak & Layanan"
    description="Akses jalur komunikasi resmi, alamat sekretariat, dan informasi layanan Padukuhan Salakan dengan lebih cepat."
    orbs={[
      { class: 'absolute -top-16 left-[14%] h-[250px] w-[250px] rounded-full bg-blue-400/20 blur-3xl sm:h-[320px] sm:w-[320px]' },
      { class: 'absolute bottom-[-2rem] right-[10%] h-[220px] w-[220px] rounded-full bg-emerald-400/10 blur-3xl sm:h-[280px] sm:w-[280px]' },
    ]}
  />

  <section class="container-premium py-10 sm:py-14">
    <div class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">
      <div class="space-y-4">
        <InfoCard title="Alamat" icon="location_on">
          <p class="whitespace-pre-line text-sm font-bold text-on-surface">{pengaturan?.alamat ?? 'Sekretariat Padukuhan Salakan'}</p>
        </InfoCard>

        <InfoCard title="WhatsApp" icon="chat">
          {whatsappLink ? (
            <ActionLinkButton href={whatsappLink} label="Hubungi Pengurus" icon="open_in_new" variant="success" target="_blank" rel="noreferrer" class="mt-1 w-full justify-center sm:w-auto sm:justify-start" />
          ) : (
            <p class="mt-1 text-sm font-bold text-on-surface">Dalam pendaftaran</p>
          )}
        </InfoCard>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <InfoCard title="Surel" icon="mail">
            <p class="break-words text-sm font-bold text-on-surface">{pengaturan?.email ?? '-'}</p>
          </InfoCard>
          <InfoCard title="Jam Kerja" icon="schedule">
            <p class="text-sm font-bold text-on-surface">{pengaturan?.jamLayanan ?? '-'}</p>
          </InfoCard>
        </div>
      </div>

      <div class="overflow-hidden rounded-xl border border-outline-variant bg-surface-container-lowest">
        {pengaturan?.linkPeta ? (
          <iframe
            title="Peta Padukuhan Salakan"
            src={pengaturan.linkPeta}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="h-full w-full min-h-[400px] border-none"
          />
        ) : (
          <div class="flex min-h-[400px] flex-col items-center justify-center p-8 text-center">
            <Icon name="wrong_location" class="mb-4 text-[48px] text-outline" />
            <p class="text-base font-bold text-on-surface">Peta Belum Tersedia</p>
            <p class="mt-2 max-w-xs text-sm text-on-surface-variant">
              Sematkan tautan peta melalui dasbor Keystatic agar titik lokasi muncul di sini.
            </p>
          </div>
        )}
      </div>
    </div>
  </section>

</MainLayout>
