---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getPengaturan } from '../lib/keystatic';

const pengaturan = await getPengaturan();
const nomorWhatsapp = pengaturan?.kontakWhatsApp?.replace(/\D/g, '');
const whatsappLink = nomorWhatsapp ? `https://wa.me/${nomorWhatsapp}` : null;
---

<MainLayout title="Kontak | Padukuhan Salakan" description="Alamat dan kontak informasi Padukuhan Salakan.">

  <PageHero
    eyebrow="Hubungi Kami"
    icon="support_agent"
    title="Kontak & Layanan"
    description="Akses jalur komunikasi resmi, alamat sekretariat, dan informasi layanan Padukuhan Salakan dengan lebih cepat."
    orbs={[
      { class: 'absolute -top-16 left-[14%] h-[250px] w-[250px] rounded-full bg-blue-400/20 blur-3xl sm:h-[320px] sm:w-[320px]' },
      { class: 'absolute bottom-[-2rem] right-[10%] h-[220px] w-[220px] rounded-full bg-emerald-400/10 blur-3xl sm:h-[280px] sm:w-[280px]' },
    ]}
  />

  <section class="container-premium py-10 sm:py-14">
    <div class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">

      <!-- Contact Info -->
      <div class="space-y-4">
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5">
          <div class="flex items-center gap-2 text-[12px] font-semibold text-m3-primary uppercase tracking-wider mb-2">
            <span class="material-symbols-outlined text-[16px]">location_on</span> Alamat
          </div>
          <p class="text-sm font-bold text-on-surface whitespace-pre-line">{pengaturan?.alamat ?? 'Sekretariat Padukuhan Salakan'}</p>
        </div>

        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5">
          <div class="flex items-center gap-2 text-[12px] font-semibold text-m3-primary uppercase tracking-wider mb-2">
            <span class="material-symbols-outlined text-[16px]">chat</span> WhatsApp
          </div>
          {whatsappLink ? (
            <a class="mt-1 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-emerald-600 px-5 py-3 text-sm font-semibold text-white transition-all hover:-translate-y-0.5 hover:shadow-md sm:w-auto sm:justify-start" href={whatsappLink} target="_blank" rel="noreferrer">
              <span class="material-symbols-outlined text-[18px]">open_in_new</span> Hubungi Pengurus
            </a>
          ) : (
            <p class="text-sm font-bold text-on-surface mt-1">Dalam pendaftaran</p>
          )}
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5">
            <div class="flex items-center gap-2 text-[12px] font-semibold text-m3-primary uppercase tracking-wider mb-2">
              <span class="material-symbols-outlined text-[16px]">mail</span> Surel
            </div>
            <p class="text-sm font-bold text-on-surface break-words">{pengaturan?.email ?? '-'}</p>
          </div>
          <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5">
            <div class="flex items-center gap-2 text-[12px] font-semibold text-m3-primary uppercase tracking-wider mb-2">
              <span class="material-symbols-outlined text-[16px]">schedule</span> Jam Kerja
            </div>
            <p class="text-sm font-bold text-on-surface">{pengaturan?.jamLayanan ?? '-'}</p>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden">
        {pengaturan?.linkPeta ? (
          <iframe
            title="Peta Padukuhan Salakan"
            src={pengaturan.linkPeta}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="h-full w-full min-h-[400px] border-none"
          />
        ) : (
          <div class="flex flex-col items-center justify-center min-h-[400px] text-center p-8">
            <span class="material-symbols-outlined text-[48px] text-outline mb-4">wrong_location</span>
            <p class="text-base font-bold text-on-surface">Peta Belum Tersedia</p>
            <p class="text-sm text-on-surface-variant mt-2 max-w-xs">
              Sematkan tautan peta melalui dasbor Keystatic agar titik lokasi muncul di sini.
            </p>
          </div>
        )}
      </div>
    </div>
  </section>

</MainLayout>
