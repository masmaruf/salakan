---
import MainLayout from '../../layouts/MainLayout.astro';
import { formatTanggal, getAgenda } from '../../lib/keystatic';
import { resolveSeoText, withSiteTitle } from '../../lib/site';

export async function getStaticPaths() {
  const items = await getAgenda();
  return items
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({
      params: { slug: item.slug },
      props: { item: { slug: item.slug, entry: item.entry! } },
    }));
}

const { item } = Astro.props;
const { entry } = item;
---

<MainLayout
  title={withSiteTitle(resolveSeoText(entry.judul, 'Agenda'))}
  description={resolveSeoText(entry.ringkasan, entry.deskripsi)}
>
  <section class="section">
    <div class="container max-w-4xl">
      <article class="surface-card space-y-8 p-6 md:p-8">
        <nav class="breadcrumbs text-sm text-slate-500">
          <ul>
            <li><a href="/">Beranda</a></li>
            <li><a href="/agenda">Agenda</a></li>
            <li class="text-slate-700">{entry.judul}</li>
          </ul>
        </nav>

        <div class="space-y-4">
          <span class="badge badge-primary badge-outline w-fit">Agenda warga</span>
          <h1 class="page-title font-extrabold text-slate-950">{entry.judul}</h1>
          <p class="text-body-lg text-slate-600">{entry.ringkasan}</p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          <div class="ui-radius-lg border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-500">Tanggal</p>
            <p class="mt-2 text-body-md font-semibold text-slate-900">{formatTanggal(entry.tanggal)}</p>
          </div>
          <div class="ui-radius-lg border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-500">Waktu</p>
            <p class="mt-2 text-body-md font-semibold text-slate-900">{entry.waktuMulai} - {entry.waktuSelesai}</p>
          </div>
          <div class="ui-radius-lg border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-500">Lokasi</p>
            <p class="mt-2 text-body-md font-semibold text-slate-900">{entry.lokasi}</p>
          </div>
        </div>

        <div class="space-y-4 border-t border-slate-200 pt-8">
          <h2 class="section-title font-bold text-slate-950">Detail agenda</h2>
          <p class="text-body-md text-slate-600">{entry.deskripsi}</p>
        </div>

        <div class="ui-radius-lg border border-slate-200 bg-slate-50 p-5">
          <p class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-500">Kontak / PIC</p>
          <p class="mt-3 text-body-md text-slate-700">{entry.kontakPic}</p>
        </div>
      </article>
    </div>
  </section>
</MainLayout>
