---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { formatTanggal, getAgenda } from '../../lib/keystatic';
import { resolveSeoText, withSiteTitle } from '../../lib/site';

const { slug } = Astro.params;
const items = await getAgenda();
const item = items.find((i) => i.slug === slug && i.entry?.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/agenda');
}

const { entry } = item;
---

<MainLayout
  title={withSiteTitle(resolveSeoText(entry.judul, 'Agenda'))}
  description={resolveSeoText(entry.ringkasan, entry.deskripsi)}
>

  <article class="container-premium max-w-3xl py-8">

    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Agenda', href: '/agenda' },
      { label: entry.judul, active: true },
    ]} />

    <!-- Badge + Date -->
    <div class="flex items-center gap-3 mb-3">
      <span class="text-[12px] font-semibold px-2 py-0.5 rounded-md bg-primary-container text-on-primary-container">
        Agenda
      </span>
      <time class="text-[12px] font-medium text-outline" datetime={entry.tanggal}>
        {formatTanggal(entry.tanggal)}
      </time>
    </div>

    <!-- Title -->
    <h1 class="text-2xl sm:text-3xl font-bold text-on-surface leading-tight tracking-tight">
      {entry.judul}
    </h1>

    <!-- Ringkasan -->
    <p class="mt-3 text-base text-on-surface-variant leading-relaxed">
      {entry.ringkasan}
    </p>

    <!-- Info row -->
    <div class="flex flex-wrap gap-x-5 gap-y-2 mt-4 text-sm text-on-surface-variant">
      <span class="inline-flex items-center gap-1.5">
        <span class="material-symbols-outlined text-[18px] text-m3-primary">schedule</span>
        {entry.waktuMulai} – {entry.waktuSelesai}
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="material-symbols-outlined text-[18px] text-m3-primary">location_on</span>
        {entry.lokasi}
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="material-symbols-outlined text-[18px] text-m3-primary">person</span>
        {entry.kontakPic}
      </span>
    </div>

    <!-- Image -->
    {entry.gambarUtama && (
      <div class="mt-6 rounded-xl overflow-hidden">
        <img
          src={entry.gambarUtama}
          alt={entry.altGambarUtama || entry.judul}
          class="w-full h-auto object-cover"
          loading="eager"
        />
      </div>
    )}

    <!-- Deskripsi -->
    <div class="mt-6 pt-5 border-t border-outline-variant/40">
      <p class="text-base text-on-surface-variant leading-relaxed whitespace-pre-line">{entry.deskripsi}</p>
    </div>

    <!-- Back -->
    <div class="mt-8 pt-5 border-t border-outline-variant/40">
      <a href="/agenda" class="inline-flex items-center gap-2 rounded-xl bg-surface-container-lowest border border-outline-variant px-5 py-3 text-sm font-semibold text-on-surface-variant hover:bg-primary-container hover:text-on-primary-container transition-colors">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
        Kembali ke Agenda
      </a>
    </div>

  </article>

</MainLayout>
