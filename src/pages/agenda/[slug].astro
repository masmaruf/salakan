---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import ActionLinkButton from '../../components/ui/ActionLinkButton.astro';
import Badge from '../../components/ui/Badge.astro';
import RelatedContentSection from '../../components/ui/RelatedContentSection.astro';
import { formatTanggal, getAgenda, getGaleri, getKegiatan, getLogKegiatan, getProgram, getStrukturOrganisasi, getKategoriBeritaMap } from '../../lib/content';
import { getAgendaLabelTone, getTagUmumLabel } from '../../lib/content-taxonomy';
import {
  createAgendaRelationItem,
  createBeritaRelationItem,
  createGaleriRelationItem,
  createLembagaRelationItem,
  createLogRelationItem,
  createProgramRelationItem,
} from '../../lib/content-relations';
import { findRelatedContent } from '../../lib/related-content';
import { renderMarkdown } from '../../lib/rich-text';
import { resolveSeoText, toAbsoluteUrl, withSiteTitle } from '../../lib/site';
import { generateEventSchema } from '../../lib/seo';
import { Schema } from 'astro-seo-schema';

const { slug } = Astro.params;
const [items, beritaItems, logItems, programItems, lembagaItems, galeriItems, categoryLabels] = await Promise.all([
  getAgenda(),
  getKegiatan(),
  getLogKegiatan(),
  getProgram(),
  getStrukturOrganisasi(),
  getGaleri(),
  getKategoriBeritaMap(),
]);
const item = items.find((i) => i.slug === slug && i.entry?.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/agenda');
}

const { entry } = item;
type MetaItem = {
  icon: string;
  text: string;
  accentClass: string;
};

const metaItems = [
  entry.waktuMulai ? { icon: 'schedule', text: `${entry.waktuMulai}${entry.waktuSelesai ? ` - ${entry.waktuSelesai}` : ''}`, accentClass: 'text-base-content/70' } : null,
  entry.lokasi ? { icon: 'location_on', text: entry.lokasi, accentClass: 'text-base-content/70' } : null,
  entry.kontakPic ? { icon: 'person', text: entry.kontakPic, accentClass: 'text-base-content/70' } : null,
].filter((meta): meta is MetaItem => meta !== null);

const relatedItems = findRelatedContent(
  createAgendaRelationItem(item),
  [
    ...beritaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => createBeritaRelationItem(candidate, categoryLabels)),
    ...programItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createProgramRelationItem),
    ...logItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLogRelationItem),
    ...lembagaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLembagaRelationItem),
    ...galeriItems.map(createGaleriRelationItem),
  ],
  4,
);

const agendaUrl = toAbsoluteUrl(`/agenda/${item.slug}`);
const eventSchema = generateEventSchema({
  title: entry.judul,
  description: resolveSeoText(entry.ringkasan, entry.deskripsi),
  startDate: entry.waktuMulai ? `${entry.tanggal}T${entry.waktuMulai}` : entry.tanggal,
  endDate: entry.waktuSelesai ? `${entry.tanggal}T${entry.waktuSelesai}` : undefined,
  location: entry.lokasi,
  url: agendaUrl,
});
---

<MainLayout
  title={withSiteTitle(resolveSeoText(entry.judul, 'Agenda'))}
  description={resolveSeoText(entry.ringkasan, entry.deskripsi)}
>

  <Schema item={eventSchema} />

  <article class="container-premium max-w-3xl py-6 sm:py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Agenda', href: '/agenda' },
      { label: entry.judul, active: true },
    ]} />

    <div class="mb-3 flex flex-wrap items-center gap-2 sm:gap-3">
      <Badge label={entry.label || 'Agenda'} tone={getAgendaLabelTone(entry.label)} class="px-2 py-0.5" />
      <Badge label={formatTanggal(entry.tanggal)} tone="surface" variant="ghost" />
      {(entry.tag || []).slice(0, 3).map((tag) => (
        <Badge label={`#${getTagUmumLabel(tag)}`} tone="surface" variant="outline" />
      ))}
    </div>

    <h1 class="text-2xl font-bold leading-tight tracking-tight text-base-content sm:text-3xl">
      {entry.judul}
    </h1>

    <p class="mt-3 text-base leading-relaxed text-base-content/70">
      {entry.ringkasan}
    </p>

    {metaItems.length > 0 && (
      <ContentMeta
        class="mt-4 flex flex-wrap gap-x-5 gap-y-2"
        items={metaItems}
        iconClass="text-[18px] text-primary"
      />
    )}

    {entry.gambarUtama && (
      <div class="card mt-6 overflow-hidden border border-base-300/70 bg-base-100 shadow-sm">
        <img
          src={entry.gambarUtama}
          alt={entry.altGambarUtama || entry.judul}
          class="h-auto w-full object-cover"
          loading="eager"
        />
      </div>
    )}

    <div class="mt-6 border-t border-base-300/70 pt-5">
      <div class="article-rich text-base leading-relaxed text-base-content/75" set:html={renderMarkdown(entry.deskripsi)} />
    </div>

    <div class="mt-8 border-t border-base-300/70 pt-5">
      <ActionLinkButton href="/agenda" label="Kembali ke Agenda" icon="arrow_back" />
    </div>
  </article>

  <RelatedContentSection
    title="Konten Terkait Agenda Ini"
    actionHref="/data"
    actionLabel="Buka pusat data"
    items={relatedItems}
  />

</MainLayout>
