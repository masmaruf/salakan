---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import ActionLinkButton from '../../components/ui/ActionLinkButton.astro';
import Badge from '../../components/ui/Badge.astro';
import PageSection from '../../components/PageSection.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';
import { excerpt, formatTanggal, getAgenda, getKegiatan, getLogKegiatan, getProgram } from '../../lib/content';
import { getAgendaLabelTone, kategoriLogLabels, kategoriLabelsProgram } from '../../lib/content-taxonomy';
import { findRelatedContent } from '../../lib/related-content';
import { markdownToText, renderMarkdown } from '../../lib/rich-text';
import { resolveSeoText, withSiteTitle } from '../../lib/site';

const { slug } = Astro.params;
const [items, beritaItems, logItems, programItems] = await Promise.all([
  getAgenda(),
  getKegiatan(),
  getLogKegiatan(),
  getProgram(),
]);
const item = items.find((i) => i.slug === slug && i.entry?.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/agenda');
}

const { entry } = item;
type MetaItem = {
  icon: string;
  text: string;
  accentClass: string;
};

const metaItems = [
  entry.waktuMulai ? { icon: 'schedule', text: `${entry.waktuMulai}${entry.waktuSelesai ? ` - ${entry.waktuSelesai}` : ''}`, accentClass: 'text-on-surface-variant' } : null,
  entry.lokasi ? { icon: 'location_on', text: entry.lokasi, accentClass: 'text-on-surface-variant' } : null,
  entry.kontakPic ? { icon: 'person', text: entry.kontakPic, accentClass: 'text-on-surface-variant' } : null,
].filter((meta): meta is MetaItem => meta !== null);

const relatedItems = findRelatedContent(
  {
    slug: item.slug,
    title: entry.judul,
    category: entry.label,
    tags: entry.tag ?? [],
    summary: entry.ringkasan,
    extraText: [markdownToText(entry.deskripsi), entry.lokasi ?? '', entry.kontakPic ?? ''],
    date: entry.tanggal,
    href: `/agenda/${item.slug}`,
    typeLabel: entry.label || 'Agenda',
    badgeTone: getAgendaLabelTone(entry.label),
  },
  [
    ...beritaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => ({
        slug: candidate.slug,
        title: candidate.entry.judul,
        category: candidate.entry.kategori,
        tags: candidate.entry.tag ?? [],
        summary: candidate.entry.ringkasan,
        extraText: [candidate.entry.isi ?? ''],
        date: candidate.entry.tanggal,
        href: `/berita/${candidate.slug}`,
        typeLabel: 'Berita',
        badgeTone: 'info' as const,
      })),
    ...programItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => ({
        slug: candidate.slug,
        title: candidate.entry.judul,
        category: candidate.entry.kategori,
        tags: candidate.entry.tag ?? [],
        summary: candidate.entry.ringkasan,
        extraText: [markdownToText(candidate.entry.deskripsi), candidate.entry.lokasi, candidate.entry.penanggungJawab],
        date: candidate.entry.tanggalUpdate,
        href: `/program/${candidate.slug}`,
        typeLabel: kategoriLabelsProgram[candidate.entry.kategori as keyof typeof kategoriLabelsProgram],
        badgeTone: 'surface' as const,
      })),
    ...logItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => ({
        slug: candidate.slug,
        title: candidate.entry.judul,
        category: candidate.entry.kategori,
        tags: candidate.entry.tag ?? [],
        summary: candidate.entry.ringkasan,
        extraText: [candidate.entry.lokasi ?? '', candidate.entry.pihakTerlibat ?? '', candidate.entry.hasilTindakLanjut ?? ''],
        date: candidate.entry.tanggal,
        href: `/log-kegiatan?q=${encodeURIComponent(candidate.entry.judul)}`,
        typeLabel: kategoriLogLabels[candidate.entry.kategori as keyof typeof kategoriLogLabels],
        badgeTone: 'surface' as const,
      })),
  ],
  4,
);
---

<MainLayout
  title={withSiteTitle(resolveSeoText(entry.judul, 'Agenda'))}
  description={resolveSeoText(entry.ringkasan, entry.deskripsi)}
>

  <article class="container-premium max-w-3xl py-6 sm:py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Agenda', href: '/agenda' },
      { label: entry.judul, active: true },
    ]} />

    <div class="mb-3 flex flex-wrap items-center gap-2 sm:gap-3">
      <Badge label={entry.label || 'Agenda'} tone={getAgendaLabelTone(entry.label)} class="px-2 py-0.5" />
      <time class="meta-time" datetime={entry.tanggal}>
        {formatTanggal(entry.tanggal)}
      </time>
      {(entry.tag || []).slice(0, 3).map((tag) => (
        <span class="tag-chip py-0.5">
          #{tag}
        </span>
      ))}
    </div>

    <h1 class="text-2xl font-bold leading-tight tracking-tight text-on-surface sm:text-3xl">
      {entry.judul}
    </h1>

    <p class="mt-3 text-base leading-relaxed text-on-surface-variant">
      {entry.ringkasan}
    </p>

    {metaItems.length > 0 && (
      <ContentMeta
        class="mt-4 flex flex-wrap gap-x-5 gap-y-2"
        items={metaItems}
        iconClass="text-[18px] text-m3-primary"
      />
    )}

    {entry.gambarUtama && (
      <div class="media-frame mt-6">
        <img
          src={entry.gambarUtama}
          alt={entry.altGambarUtama || entry.judul}
          class="h-auto w-full object-cover"
          loading="eager"
        />
      </div>
    )}

    <div class="mt-6 border-t border-outline-variant/40 pt-5">
      <div class="article-rich text-base leading-relaxed text-on-surface-variant" set:html={renderMarkdown(entry.deskripsi)} />
    </div>

    <div class="mt-8 border-t border-outline-variant/40 pt-5">
      <ActionLinkButton href="/agenda" label="Kembali ke Agenda" icon="arrow_back" />
    </div>
  </article>

  {relatedItems.length > 0 && (
    <PageSection sectionClass="bg-surface-container-low/40 py-10" title="Terkait Dengan Agenda Ini" actionHref="/data" actionLabel="Buka pusat data">
      <div class="grid gap-4 lg:grid-cols-2">
        {relatedItems.map((related) => (
          <ArchiveCard
            href={related.href}
            title={related.title}
            summary={excerpt(related.summary || '', 140)}
            badges={[
              { label: related.typeLabel, tone: related.badgeTone ?? 'surface' },
            ]}
            meta={[
              ...(related.date ? [{ icon: 'calendar_today', text: formatTanggal(related.date), datetime: related.date }] : []),
            ]}
          />
        ))}
      </div>
    </PageSection>
  )}

</MainLayout>
