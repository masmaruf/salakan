---
import MainLayout from '../../layouts/MainLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { formatTanggal, getAgenda, sortByDateDesc } from '../../lib/keystatic';

const agendaItems = sortByDateDesc(
  (await getAgenda())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({
      slug: item.slug,
      entry: item.entry!,
    }))
);

const featuredAgenda = agendaItems.find((item) => item.entry.unggulan) ?? agendaItems[0];
const agendaList = agendaItems.filter((item) => item.slug !== featuredAgenda?.slug);
---

<MainLayout title="Agenda | Padukuhan Salakan" description="Agenda kegiatan warga, rapat, dan kegiatan mendatang Padukuhan Salakan.">
  <section class="section">
    <div class="container space-y-6">
      <SectionHeading
        title="Agenda"
        description="Kumpulan agenda mendatang agar kegiatan warga, musyawarah, dan kerja bersama tidak bercampur dengan arsip berita."
      />

      {featuredAgenda && (
        <article class="surface-card grid gap-6 p-6 md:p-7 lg:grid-cols-[minmax(0,1fr)_280px]">
          <div class="space-y-4">
            <span class="badge badge-primary badge-outline w-fit">Agenda unggulan</span>
            <h2 class="section-title font-extrabold text-slate-950">{featuredAgenda.entry.judul}</h2>
            <p class="text-body-lg text-slate-600">{featuredAgenda.entry.ringkasan}</p>
            <div class="flex flex-wrap gap-3 text-sm text-slate-600">
              <span class="badge badge-outline">{formatTanggal(featuredAgenda.entry.tanggal)}</span>
              <span class="badge badge-outline">{featuredAgenda.entry.waktuMulai} - {featuredAgenda.entry.waktuSelesai}</span>
              <span class="badge badge-outline">{featuredAgenda.entry.lokasi}</span>
            </div>
            <a class="brand-button btn rounded-[var(--radius-md)]" href={`/agenda/${featuredAgenda.slug}`}>Lihat detail agenda</a>
          </div>
          <div class="ui-radius-lg border border-slate-200 bg-slate-50 p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-500">Kontak PIC</p>
            <p class="mt-3 text-body-md text-slate-700">{featuredAgenda.entry.kontakPic}</p>
          </div>
        </article>
      )}

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {agendaList.map(({ slug, entry }) => (
          <article class="surface-card flex flex-col gap-4 p-5">
            <div class="space-y-3">
              <h3 class="card-title font-bold text-slate-950">{entry.judul}</h3>
              <p class="text-body-md text-slate-600">{entry.ringkasan}</p>
            </div>
            <div class="flex flex-wrap gap-2 text-sm text-slate-600">
              <span class="badge badge-outline">{formatTanggal(entry.tanggal)}</span>
              <span class="badge badge-outline">{entry.waktuMulai}</span>
            </div>
            <p class="text-body-sm text-slate-500">{entry.lokasi}</p>
            <a class="btn btn-sm w-fit rounded-[var(--radius-md)] border border-slate-200 bg-white text-slate-700 shadow-none hover:bg-slate-50" href={`/agenda/${slug}`}>
              Lihat detail agenda
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
