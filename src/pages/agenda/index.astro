---
import PageHero from '../../components/PageHero.astro';
import EmptyStateCard from '../../components/ui/EmptyStateCard.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import {
  getAgenda,
  getPengumuman,
  formatTanggal,
  sortByDateDesc,
  excerpt,
} from '../../lib/content';

const [agendaRaw, pengumumanRaw] = await Promise.all([
  getAgenda(),
  getPengumuman(),
]);

const agendaItems = sortByDateDesc(
  agendaRaw
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const pengumumanItems = sortByDateDesc(
  pengumumanRaw
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

type TimelineItem = {
  type: 'agenda' | 'pengumuman';
  slug: string;
  judul: string;
  tanggal: string;
  ringkasan: string;
  lokasi?: string;
  waktuMulai?: string;
  waktuSelesai?: string;
  dotColor: string;
  badgeBg: string;
  badgeText: string;
  badgeLabel: string;
};

const timeline: TimelineItem[] = [
  ...agendaItems.map((item) => ({
    type: 'agenda' as const,
    slug: item.slug,
    judul: item.entry.judul,
    tanggal: item.entry.tanggal,
    ringkasan: item.entry.ringkasan,
    lokasi: item.entry.lokasi,
    waktuMulai: item.entry.waktuMulai,
    waktuSelesai: item.entry.waktuSelesai,
    dotColor: 'bg-m3-primary',
    badgeBg: 'bg-primary-container',
    badgeText: 'text-on-primary-container',
    badgeLabel: 'Agenda',
  })),
  ...pengumumanItems.map((item) => ({
    type: 'pengumuman' as const,
    slug: item.slug,
    judul: item.entry.judul,
    tanggal: item.entry.tanggal,
    ringkasan: item.entry.ringkasan,
    lokasi: undefined,
    waktuMulai: undefined,
    waktuSelesai: undefined,
    dotColor: 'bg-m3-error',
    badgeBg: 'bg-error-container',
    badgeText: 'text-on-error-container',
    badgeLabel: 'Pengumuman',
  })),
].sort((a, b) => new Date(b.tanggal).getTime() - new Date(a.tanggal).getTime());

import Icon from '../../components/ui/Icon.tsx';
---

<MainLayout
  title="Agenda & Pengumuman | Padukuhan Salakan"
  description="Informasi kegiatan padukuhan dan pengumuman terbaru untuk warga."
>

  <PageHero
    eyebrow="Jadwal & Info"
    icon="calendar_month"
    title="Agenda & Pengumuman"
    description="Informasi kegiatan padukuhan dan pengumuman terbaru untuk warga."
    sectionClass="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-14 sm:py-20"
    titleClass="text-2xl font-bold tracking-tight text-white sm:text-3xl md:text-4xl"
    descriptionClass="mx-auto mt-3 max-w-xl text-base font-medium text-blue-100/70"
    badgeClass="mb-4 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 backdrop-blur"
    orbs={[
      { class: 'absolute -top-20 left-1/4 h-[320px] w-[320px] rounded-full bg-blue-500/15 blur-3xl' },
    ]}
  />

  <section class="container-premium py-8 pb-10">
    <h2 class="mb-5 text-[20px] font-bold text-on-surface">Agenda & Pengumuman</h2>

    {timeline.length > 0 ? (
      <div class="relative space-y-5 border-l-2 border-surface-container-high pl-4 sm:pl-5">
        {timeline.map((item) => (
          <a
            class="group relative block pl-5 sm:pl-6"
            href={item.type === 'agenda' ? `/agenda/${item.slug}` : '/agenda'}
          >
            <div class:list={['absolute -left-[11px] top-2 h-4 w-4 rounded-full ring-4 ring-white', item.dotColor]}></div>

            <div class="rounded-xl border border-outline-variant bg-surface-container-lowest p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all group-hover:-translate-y-0.5 group-hover:shadow-md active:scale-[0.98]">
              <div class="mb-2 flex flex-wrap items-start justify-between gap-2">
                <span class:list={['inline-flex items-center rounded-md px-2 py-1 text-[12px] font-semibold', item.badgeBg, item.badgeText]}>
                  {item.badgeLabel}
                </span>
                <span class="text-[12px] font-medium text-outline">{formatTanggal(item.tanggal)}</span>
              </div>

              <h3 class="mb-1 text-sm font-bold leading-snug text-on-surface transition-colors group-hover:text-m3-primary sm:text-base">
                {item.judul}
              </h3>

              {(item.waktuMulai || item.lokasi) && (
                <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-[12px] text-on-surface-variant">
                  {item.waktuMulai && (
                    <span class="flex items-center gap-1">
                      <Icon name="schedule" class="text-[14px]" />
                      {item.waktuMulai}{item.waktuSelesai ? ` – ${item.waktuSelesai}` : ''} WIB
                    </span>
                  )}
                  {item.lokasi && (
                    <span class="flex items-center gap-1">
                      <Icon name="location_on" class="text-[14px]" />
                      {item.lokasi}
                    </span>
                  )}
                </div>
              )}

              <p class="mt-2 line-clamp-2 text-sm text-on-surface-variant">
                {excerpt(item.ringkasan, 150)}
              </p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <EmptyStateCard message="Belum ada agenda atau pengumuman." />
    )}
  </section>

</MainLayout>
