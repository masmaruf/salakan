---
import PageHero from '../../components/PageHero.astro';
import EmptyStateCard from '../../components/ui/EmptyStateCard.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import {
  getAgenda,
  formatTanggal,
  sortByDateDesc,
  excerpt,
} from '../../lib/content';

const agendaItems = sortByDateDesc(
  (await getAgenda())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

type TimelineItem = {
  slug: string;
  judul: string;
  tanggal: string;
  ringkasan: string;
  lokasi?: string;
  waktuMulai?: string;
  waktuSelesai?: string;
  unggulan?: boolean;
  label: string;
  tags: string[];
};

const timeline: TimelineItem[] = agendaItems.map((item) => ({
  slug: item.slug,
  judul: item.entry.judul,
  tanggal: item.entry.tanggal,
  ringkasan: item.entry.ringkasan,
  lokasi: item.entry.lokasi,
  waktuMulai: item.entry.waktuMulai,
  waktuSelesai: item.entry.waktuSelesai,
  unggulan: item.entry.unggulan,
  label: item.entry.label || 'Agenda',
  tags: item.entry.tag || [],
}));

const now = Date.now();
const agendaMingguIni = agendaItems.filter((item) => {
  const diffDays = Math.floor((new Date(item.entry.tanggal).getTime() - now) / (1000 * 60 * 60 * 24));
  return diffDays >= 0 && diffDays <= 7;
}).length;

function getSignal(item: TimelineItem) {
  const diffDays = Math.floor((new Date(item.tanggal).getTime() - now) / (1000 * 60 * 60 * 24));
  if (item.unggulan) return { label: 'Penting', tone: 'error' as const };
  if (diffDays >= 0 && diffDays <= 7) return { label: 'Minggu ini', tone: 'primary' as const };
  if (diffDays >= -3 && diffDays < 0) return { label: 'Baru', tone: 'surface' as const };
  return { label: 'Arsip', tone: 'surface' as const };
}

function getLabelTone(label: string) {
  const normalized = label.trim().toLowerCase();
  if (normalized === 'pengumuman') return 'error' as const;
  if (normalized === 'informasi') return 'surface' as const;
  return 'primary' as const;
}

import Icon from '../../components/ui/Icon.tsx';
---

<MainLayout
  title="Agenda Warga | Padukuhan Salakan"
  description="Informasi kegiatan dan agenda terbaru untuk warga."
>
  <PageHero
    eyebrow="Jadwal & Info"
    icon="calendar_month"
    title="Agenda Warga"
    description="Timeline kegiatan warga, informasi penting, dan agenda yang sedang berjalan di Padukuhan Salakan."
  />

  <section class="container-premium py-8 pb-5">
    <div class="grid gap-4 md:grid-cols-3">
      <div class="section-card rounded-2xl p-5 sm:p-5">
        <p class="section-kicker">Ringkasan</p>
        <p class="mt-2 text-3xl font-black tracking-tight text-on-surface">{timeline.length}</p>
        <p class="mt-1 text-sm text-on-surface-variant">Semua agenda aktif siap dibagikan ke warga.</p>
      </div>
      <div class="section-card rounded-2xl p-5 sm:p-5">
        <p class="section-kicker">Minggu ini</p>
        <p class="mt-2 text-3xl font-black tracking-tight text-on-surface">{agendaMingguIni}</p>
        <p class="mt-1 text-sm text-on-surface-variant">Kegiatan yang sedang atau akan berlangsung dalam 7 hari ke depan.</p>
      </div>
      <div class="section-card rounded-2xl p-5 sm:p-5">
        <p class="section-kicker">Distribusi</p>
        <p class="mt-2 text-base font-bold text-on-surface">Siap dibagikan ke grup RT</p>
        <p class="mt-1 text-sm text-on-surface-variant">Gunakan label seperti pengumuman, informasi, atau pengajian agar warga cepat menangkap konteksnya.</p>
      </div>
    </div>
  </section>

  <section class="container-premium py-3 pb-10">
    {timeline.length > 0 ? (
      <div class="relative space-y-5 border-l-2 border-surface-container-high pl-4 sm:pl-5">
        {timeline.map((item) => {
          const signal = getSignal(item);
          return (
            <a
              class="group relative block pl-5 sm:pl-6"
              href={`/agenda/${item.slug}`}
            >
              <div class="absolute -left-[11px] top-2 h-4 w-4 rounded-full bg-m3-primary ring-4 ring-white"></div>

              <div class="section-card rounded-xl p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)] group-hover:-translate-y-0.5 group-hover:shadow-md active:scale-[0.98]">
                <div class="mb-2 flex flex-wrap items-start justify-between gap-2">
                  <div class="flex flex-wrap items-center gap-2">
                    <Badge label={item.label} tone={getLabelTone(item.label)} class="px-2 py-1" />
                    <Badge label={signal.label} tone={signal.tone} class="px-2 py-1" />
                    {item.tags.slice(0, 2).map((tag) => (
                      <span class="inline-flex items-center rounded-md bg-surface-container px-2 py-1 text-[12px] font-semibold text-on-surface-variant">
                        #{tag}
                      </span>
                    ))}
                  </div>
                  <span class="text-[12px] font-medium text-outline">{formatTanggal(item.tanggal)}</span>
                </div>

                <h3 class="mb-1 text-sm font-bold leading-snug text-on-surface transition-colors group-hover:text-m3-primary sm:text-base">
                  {item.judul}
                </h3>

                {(item.waktuMulai || item.lokasi) && (
                  <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-[12px] text-on-surface-variant">
                    {item.waktuMulai && (
                      <span class="flex items-center gap-1">
                        <Icon name="schedule" class="text-[14px]" />
                        {item.waktuMulai}{item.waktuSelesai ? ` - ${item.waktuSelesai}` : ''}
                      </span>
                    )}
                    {item.lokasi && (
                      <span class="flex items-center gap-1">
                        <Icon name="location_on" class="text-[14px]" />
                        {item.lokasi}
                      </span>
                    )}
                  </div>
                )}

                <p class="mt-2 line-clamp-2 text-sm text-on-surface-variant">
                  {excerpt(item.ringkasan, 150)}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <EmptyStateCard message="Belum ada agenda." />
    )}
  </section>
</MainLayout>

