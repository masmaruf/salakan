---
import MainLayout from '../../layouts/MainLayout.astro';
import {
  getAgenda,
  getPengumuman,
  getLayananWarga,
  formatTanggal,
  sortByDateDesc,
  excerpt,
} from '../../lib/keystatic';

const [agendaRaw, pengumumanRaw, layananRaw] = await Promise.all([
  getAgenda(),
  getPengumuman(),
  getLayananWarga(),
]);

const agendaItems = sortByDateDesc(
  agendaRaw
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const pengumumanItems = sortByDateDesc(
  pengumumanRaw
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const layananItems = layananRaw
  .filter(({ entry }) => entry.statusTampil === 'tampil')
  .sort((a, b) => a.entry.namaLayanan.localeCompare(b.entry.namaLayanan, 'id'));

type TimelineItem = {
  type: 'agenda' | 'pengumuman';
  slug: string;
  judul: string;
  tanggal: string;
  ringkasan: string;
  lokasi?: string;
  waktuMulai?: string;
  waktuSelesai?: string;
  dotColor: string;
  badgeBg: string;
  badgeText: string;
  badgeLabel: string;
};

const timeline: TimelineItem[] = [
  ...agendaItems.map((item) => ({
    type: 'agenda' as const,
    slug: item.slug,
    judul: item.entry.judul,
    tanggal: item.entry.tanggal,
    ringkasan: item.entry.ringkasan,
    lokasi: item.entry.lokasi,
    waktuMulai: item.entry.waktuMulai,
    waktuSelesai: item.entry.waktuSelesai,
    dotColor: 'bg-m3-primary',
    badgeBg: 'bg-primary-container',
    badgeText: 'text-on-primary-container',
    badgeLabel: 'Agenda',
  })),
  ...pengumumanItems.map((item) => ({
    type: 'pengumuman' as const,
    slug: item.slug,
    judul: item.entry.judul,
    tanggal: item.entry.tanggal,
    ringkasan: item.entry.ringkasan,
    lokasi: undefined,
    waktuMulai: undefined,
    waktuSelesai: undefined,
    dotColor: 'bg-m3-error',
    badgeBg: 'bg-error-container',
    badgeText: 'text-on-error-container',
    badgeLabel: 'Pengumuman',
  })),
].sort((a, b) => new Date(b.tanggal).getTime() - new Date(a.tanggal).getTime());
---

<MainLayout
  title="Agenda & Layanan | Padukuhan Salakan"
  description="Informasi kegiatan padukuhan, pengumuman warga, dan layanan administrasi."
>

  <section class="relative isolate overflow-hidden bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-14 sm:py-20">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-20 left-1/4 h-[320px] w-[320px] rounded-full bg-blue-500/15 blur-3xl"></div>
    </div>
    <div class="container-premium relative z-10 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 backdrop-blur mb-4">
        <span class="material-symbols-outlined text-blue-300 text-[16px]">calendar_month</span>
        <span class="text-xs font-bold uppercase tracking-[0.15em] text-blue-200">Jadwal & Info</span>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-white sm:text-3xl md:text-4xl">Agenda & Layanan</h1>
      <p class="mt-3 text-base font-medium text-blue-100/70 max-w-xl mx-auto">Informasi kegiatan padukuhan dan layanan administrasi warga.</p>
    </div>
  </section>


  <!-- ===== TIMELINE ===== -->
  <section class="container-premium py-8 pb-10">
    <h2 class="text-[20px] font-bold text-on-surface mb-5">Agenda & Pengumuman</h2>

    {timeline.length > 0 ? (
      <div class="relative pl-4 sm:pl-5 border-l-2 border-surface-container-high space-y-5">
        {timeline.map((item) => (
          <a
            class="group relative block pl-5 sm:pl-6"
            href={item.type === 'agenda' ? `/agenda/${item.slug}` : '/agenda'}
          >
            {/* Dot */}
            <div class:list={['absolute -left-[11px] top-2 w-4 h-4 rounded-full ring-4 ring-white', item.dotColor]}></div>

            {/* Card */}
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all group-hover:-translate-y-0.5 group-hover:shadow-md active:scale-[0.98]">
              <div class="flex flex-wrap justify-between items-start gap-2 mb-2">
                <span class:list={['inline-flex items-center px-2 py-1 rounded-md text-[12px] font-semibold', item.badgeBg, item.badgeText]}>
                  {item.badgeLabel}
                </span>
                <span class="text-[12px] font-medium text-outline">{formatTanggal(item.tanggal)}</span>
              </div>

              <h3 class="text-sm font-bold text-on-surface leading-snug mb-1 sm:text-base group-hover:text-m3-primary transition-colors">
                {item.judul}
              </h3>

              {(item.waktuMulai || item.lokasi) && (
                <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2 text-[12px] text-on-surface-variant">
                  {item.waktuMulai && (
                    <span class="flex items-center gap-1">
                      <span class="material-symbols-outlined text-[14px]">schedule</span>
                      {item.waktuMulai}{item.waktuSelesai ? ` – ${item.waktuSelesai}` : ''} WIB
                    </span>
                  )}
                  {item.lokasi && (
                    <span class="flex items-center gap-1">
                      <span class="material-symbols-outlined text-[14px]">location_on</span>
                      {item.lokasi}
                    </span>
                  )}
                </div>
              )}

              <p class="text-sm text-on-surface-variant mt-2 line-clamp-2">
                {excerpt(item.ringkasan, 150)}
              </p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="rounded-xl bg-surface-container-lowest border border-outline-variant p-12 text-center text-on-surface-variant">
        Belum ada agenda atau pengumuman.
      </div>
    )}
  </section>

  <!-- ===== LAYANAN ADMINISTRASI ===== -->
  {layananItems.length > 0 && (
    <section class="py-10 bg-surface-container-low/40">
      <div class="container-premium">
        <h2 class="text-[20px] font-bold text-on-surface mb-5">Layanan Administrasi</h2>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {layananItems.map(({ entry }) => (
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)] flex flex-col gap-3">
              <div class="flex items-center gap-3">
                <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-surface-container-high text-m3-primary">
                  <span class="material-symbols-outlined text-[20px]">description</span>
                </div>
                <div class="min-w-0">
                  <h3 class="text-sm font-bold text-on-surface sm:text-base">{entry.namaLayanan}</h3>
                  <p class="text-[12px] text-on-surface-variant line-clamp-1">{entry.ringkasan}</p>
                </div>
              </div>

              {entry.syarat.length > 0 && (
                <ul class="text-[12px] text-on-surface-variant space-y-1 pl-1">
                  {entry.syarat.slice(0, 3).map((s) => (
                    <li class="flex items-start gap-1.5">
                      <span class="material-symbols-outlined text-[12px] mt-0.5 text-outline">check_circle</span>
                      <span class="line-clamp-1">{s}</span>
                    </li>
                  ))}
                </ul>
              )}

              <div class="flex flex-wrap gap-2 mt-auto pt-2 border-t border-outline-variant/40 text-[11px] text-on-surface-variant">
                <span class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-[12px]">call</span>
                  {entry.kontak}
                </span>
                <span class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-[12px]">schedule</span>
                  {entry.jamLayanan}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

</MainLayout>
