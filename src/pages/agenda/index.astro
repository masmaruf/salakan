---
import PageHero from '../../components/PageHero.astro';
import EmptyStateCard from '../../components/ui/EmptyStateCard.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import PillFilterBar from '../../components/ui/PillFilterBar.astro';
import FilterToolbar from '../../components/ui/FilterToolbar.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';
import {
  getAgenda,
  formatTanggal,
  sortByDateDesc,
  excerpt,
} from '../../lib/content';
import { getHalamanCopy } from '../../lib/content';
import Icon from '../../components/ui/Icon.tsx';

const agendaItems = sortByDateDesc(
  (await getAgenda())
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const selectedLabel = Astro.url.searchParams.get('label');
const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const normalizedQuery = query.toLowerCase();

type TimelineItem = {
  slug: string;
  judul: string;
  tanggal: string;
  ringkasan: string;
  lokasi?: string;
  waktuMulai?: string;
  waktuSelesai?: string;
  unggulan?: boolean;
  label: string;
  tags: string[];
};

const timeline: TimelineItem[] = agendaItems.map((item) => ({
  slug: item.slug,
  judul: item.entry.judul,
  tanggal: item.entry.tanggal,
  ringkasan: item.entry.ringkasan,
  lokasi: item.entry.lokasi,
  waktuMulai: item.entry.waktuMulai,
  waktuSelesai: item.entry.waktuSelesai,
  unggulan: item.entry.unggulan,
  label: item.entry.label || 'Agenda',
  tags: item.entry.tag || [],
}));

const availableLabels = Array.from(new Set(timeline.map((item) => item.label).filter(Boolean))).slice(0, 6);

const filterItems = [
  { href: query ? `/agenda?q=${encodeURIComponent(query)}` : '/agenda', label: 'Semua', active: !selectedLabel },
  ...availableLabels.map((label) => ({
    href: `/agenda?label=${encodeURIComponent(label)}${query ? `&q=${encodeURIComponent(query)}` : ''}`,
    label,
    active: selectedLabel === label,
  })),
];

const filteredTimeline = timeline.filter((item) => {
  const matchesLabel = selectedLabel ? item.label === selectedLabel : true;
  const haystack = [
    item.judul,
    item.ringkasan,
    item.lokasi,
    item.label,
    ...item.tags,
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
  const matchesQuery = normalizedQuery ? haystack.includes(normalizedQuery) : true;
  return matchesLabel && matchesQuery;
});

const now = Date.now();
const agendaMingguIni = filteredTimeline.filter((item) => {
  const diffDays = Math.floor((new Date(item.tanggal).getTime() - now) / (1000 * 60 * 60 * 24));
  return diffDays >= 0 && diffDays <= 7;
}).length;
const halaman = await getHalamanCopy();

function getSignal(item: TimelineItem) {
  const diffDays = Math.floor((new Date(item.tanggal).getTime() - now) / (1000 * 60 * 60 * 24));
  if (item.unggulan) return { label: 'Penting', tone: 'error' as const };
  if (diffDays >= 0 && diffDays <= 7) return { label: 'Minggu ini', tone: 'primary' as const };
  if (diffDays >= -3 && diffDays < 0) return { label: 'Baru', tone: 'surface' as const };
  return { label: 'Arsip', tone: 'surface' as const };
}

function getLabelTone(label: string) {
  const normalized = label.trim().toLowerCase();
  if (normalized === 'pengumuman') return 'error' as const;
  if (normalized === 'informasi') return 'surface' as const;
  return 'primary' as const;
}
---

<MainLayout
  title={halaman.agendaIndex.layoutTitle}
  description={halaman.agendaIndex.layoutDescription}
>
  <PageHero
    eyebrow={halaman.agendaIndex.heroEyebrow}
    icon="calendar_month"
    title={halaman.agendaIndex.heroTitle}
    description={halaman.agendaIndex.heroDescription}
  />

  <section class="container-premium py-8 pb-5">
    <div class="grid gap-4 md:grid-cols-3">
      <div class="section-card rounded-2xl p-5 sm:p-5">
        <p class="section-kicker">{halaman.agendaIndex.stats.totalLabel}</p>
        <p class="mt-2 text-3xl font-black tracking-tight text-on-surface">{filteredTimeline.length}</p>
        <p class="mt-1 text-sm text-on-surface-variant">{halaman.agendaIndex.stats.totalDescription}</p>
      </div>
      <div class="section-card rounded-2xl p-5 sm:p-5">
        <p class="section-kicker">{halaman.agendaIndex.stats.weeklyLabel}</p>
        <p class="mt-2 text-3xl font-black tracking-tight text-on-surface">{agendaMingguIni}</p>
        <p class="mt-1 text-sm text-on-surface-variant">{halaman.agendaIndex.stats.weeklyDescription}</p>
      </div>
      <div class="section-card rounded-2xl p-5 sm:p-5">
        <p class="section-kicker">{halaman.agendaIndex.stats.distributionLabel}</p>
        <p class="mt-2 text-base font-bold text-on-surface">{halaman.agendaIndex.stats.distributionTitle}</p>
        <p class="mt-1 text-sm text-on-surface-variant">{halaman.agendaIndex.stats.distributionDescription}</p>
      </div>
    </div>
  </section>

  <section class="container-premium py-3 pb-4">
    <FilterToolbar
      eyebrow="Filter Agenda"
      title="Temukan agenda yang relevan"
      description="Pola arsip dibuat lebih konsisten agar warga bisa memindai agenda, pengumuman, dan informasi penting dari satu ritme tampilan yang sama."
      resultText={query || selectedLabel ? `Menampilkan ${filteredTimeline.length} agenda${query ? ` untuk "${query}"` : ''}${selectedLabel ? ` pada label ${selectedLabel}` : ''}.` : 'Semua agenda publik ditampilkan dari yang paling baru.'}
    >
      <div slot="active" class="flex flex-wrap items-center gap-2">
        {(selectedLabel || query) && (
          <a class="inline-action" href="/agenda">
            <Icon name="restart_alt" class="text-[16px]" />
            Reset filter
          </a>
        )}
      </div>

      <div slot="filters" class="grid gap-4">
        <PillFilterBar items={filterItems} />
        <form action="/agenda" method="get" class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
          <div class="grid gap-2">
            <label for="agenda-search" class="detail-label">Cari agenda, lokasi, atau tag</label>
            <div class="flex items-center gap-3 rounded-2xl border border-outline-variant bg-surface-container-lowest px-4 py-3">
              <Icon name="search" class="text-[20px] text-outline" />
              <input
                id="agenda-search"
                name="q"
                type="search"
                value={query}
                placeholder="Contoh: posyandu, rapat, pengajian"
                class="w-full border-0 bg-transparent p-0 text-sm text-on-surface outline-none placeholder:text-on-surface-variant"
              />
            </div>
            {selectedLabel && <input type="hidden" name="label" value={selectedLabel} />}
          </div>
          <button type="submit" class="action-pill-dark">
            <Icon name="search" class="text-[16px]" />
            Terapkan pencarian
          </button>
        </form>
      </div>
    </FilterToolbar>
  </section>

  <section class="container-premium py-3 pb-10">
    {filteredTimeline.length > 0 ? (
      <div class="grid gap-4 lg:grid-cols-2">
        {filteredTimeline.map((item) => {
          const signal = getSignal(item);
          return (
            <ArchiveCard
              href={`/agenda/${item.slug}`}
              title={item.judul}
              summary={excerpt(item.ringkasan, 150)}
              badges={[
                { label: item.label, tone: getLabelTone(item.label) },
                { label: signal.label, tone: signal.tone },
              ]}
              meta={[
                { icon: 'calendar_today', text: formatTanggal(item.tanggal), datetime: item.tanggal },
                ...(item.waktuMulai ? [{ icon: 'schedule', text: `${item.waktuMulai}${item.waktuSelesai ? ` - ${item.waktuSelesai}` : ''} WIB` }] : []),
                ...(item.lokasi ? [{ icon: 'location_on', text: item.lokasi }] : []),
              ]}
            >
              {item.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {item.tags.slice(0, 3).map((tag) => (
                    <span class="tag-chip">#{tag}</span>
                  ))}
                </div>
              )}
            </ArchiveCard>
          );
        })}
      </div>
    ) : (
      <EmptyStateCard message={halaman.agendaIndex.emptyMessage} />
    )}
  </section>
</MainLayout>
