---
import MainLayout from '../layouts/MainLayout.astro';
import CmsIcon from '../components/CmsIcon.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getPengaturan } from '../lib/keystatic';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../lib/site';

const pengaturan = await getPengaturan();
const menuData = pengaturan?.menuData;
const dataItems = menuData?.items?.filter((item) => item.status === 'tampil') ?? [];
const dataSeo = pengaturan?.seoHalamanData?.dataUtama;
const highlights = [
  { label: 'Indeks Aktif', value: `${dataItems.length}`, icon: 'inventory_2', color: 'text-blue-600', bg: 'bg-blue-100' },
  { label: 'Akurasi Ruang Data', value: '100%', icon: 'verified_user', color: 'text-emerald-600', bg: 'bg-emerald-100' },
  { label: 'Akses Warga', value: 'Kilat', icon: 'bolt', color: 'text-amber-500', bg: 'bg-amber-100' },
];
---

<MainLayout
  title={withSiteTitle(resolveSeoText(dataSeo?.seoTitle, 'Data & Informasi Kampung'))}
  description={resolveSeoText(dataSeo?.seoDescription, menuData?.description ?? 'Pusat akses data, dokumen, dan informasi kampung Padukuhan Salakan.')}
  image={resolveSeoImage(dataSeo?.ogImage)}
>
  <section class="section-premium bg-slate-50/50">
    <div class="container-premium relative z-10">
      <div class="rounded-[2.5rem] bg-white/70 backdrop-blur-3xl shadow-[0_12px_40px_rgb(0,0,0,0.05)] grid gap-10 p-8 md:p-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)] items-center relative overflow-hidden">
        
        {/* Detail Latar Card */}
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,1),rgba(255,255,255,0.4))] -z-10"></div>

        <div class="space-y-6">
          <span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1.5 text-xs font-bold text-blue-700 uppercase tracking-widest shadow-sm">
            <span class="material-symbols-outlined text-[16px]">database</span>
            Pusat Katalog
          </span>
          <h1 class="hero-title text-gradient !mb-6">
            {menuData?.title ?? 'Data & Informasi'}
          </h1>
          <p class="max-w-2xl text-xl font-medium leading-relaxed text-slate-500">
            {menuData?.description ?? 'Pusat integrasi akses data kependudukan, arsip dokumen, direktori UMKM, penerima bantuan, dan struktur kepengurusan desa.'}
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <a class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-blue-500 px-8 text-sm font-bold text-white shadow-[0_8px_20px_rgb(37,99,235,0.3)] hover:shadow-[0_12px_24px_rgb(37,99,235,0.4)] transition hover:-translate-y-0.5" href="#katalog-data">
              <span class="material-symbols-outlined text-[18px]">grid_view</span>
              Lihat Katalog
            </a>
            <a class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-white px-8 text-sm font-bold text-slate-700 shadow-sm hover:bg-slate-50 hover:shadow-md transition" href="/data/pengumuman">
              Papan Pengumuman
            </a>
          </div>
        </div>
        
        <div class="grid gap-4">
          {highlights.map((item) => (
            <article class="group flex items-center gap-5 rounded-3xl bg-white p-5 shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition hover:shadow-lg hover:-translate-y-1">
              <div class={`flex h-14 w-14 items-center justify-center rounded-2xl ${item.bg} ${item.color} shadow-inner transition group-hover:scale-110`}>
                 <span class="material-symbols-outlined text-[28px]">{item.icon}</span>
              </div>
              <div>
                <small class="block text-sm font-bold text-slate-400 uppercase tracking-wider">{item.label}</small>
                <strong class="block text-2xl font-black tracking-tight text-slate-900">{item.value}</strong>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="katalog-data" class="section-premium bg-white">
      <div class="absolute inset-x-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-slate-100 to-transparent"></div>
      
      <div class="container-premium">
        <div class="mb-14">
           <SectionHeading
             title="Indeks Kategori Data"
             description="Pilih kategori di bawah untuk menelusuri data publik yang dikelola secara transparan oleh aparatur desa."
           />
        </div>

        <div class="grid gap-6 md:gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {dataItems.map((item) => (
            <a class="group relative flex flex-col gap-5 rounded-[2rem] bg-slate-50/50 p-6 md:p-8 transition-all hover:bg-white hover:shadow-[0_20px_40px_rgb(0,0,0,0.06)] hover:-translate-y-2" href={item.href}>
              <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                 <CmsIcon name={item.icon} class="size-24" />
              </div>
              <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-100 to-white shadow-sm text-blue-600 transition group-hover:bg-blue-600 group-hover:text-white group-hover:shadow-[0_8px_20px_rgb(37,99,235,0.3)]">
                <CmsIcon name={item.icon} class="size-8" />
              </div>
              <div class="relative z-10 mt-2 space-y-2">
                <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors">{item.label}</h2>
                <p class="text-sm font-medium leading-relaxed text-slate-500 line-clamp-3">{item.description}</p>
              </div>
              <div class="relative z-10 mt-auto pt-6 flex items-center text-sm font-bold text-blue-600 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
                Akses Data <span class="material-symbols-outlined ml-1 text-[18px]">arrow_forward</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
</MainLayout>
