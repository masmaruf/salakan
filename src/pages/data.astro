---
import MainLayout from '../layouts/MainLayout.astro';
import DataCard from '../components/ui/DataCard.astro';
import Icon from '../components/ui/Icon.tsx';
import { getPengaturan } from '../lib/content';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../lib/site';

const pengaturan = await getPengaturan();
const menuData = pengaturan?.menuData;
const dataItems = menuData?.items?.filter((item) => item.status === 'tampil') ?? [];
const dataSeo = pengaturan?.seoHalamanData?.dataUtama;
---

<MainLayout
  title={withSiteTitle(resolveSeoText(dataSeo?.seoTitle, 'Data & Informasi Kampung'))}
  description={resolveSeoText(dataSeo?.seoDescription, menuData?.description ?? 'Pusat akses data, dokumen, dan informasi kampung Padukuhan Salakan.')}
  image={resolveSeoImage(dataSeo?.ogImage)}
>

  <div class="container-premium pt-8 pb-4">
    <h1 class="text-[28px] font-bold leading-[36px] text-on-surface">{menuData?.title ?? 'Data & Informasi'}</h1>
    <p class="text-base text-on-surface-variant mt-1 max-w-2xl">
      {menuData?.description ?? 'Pusat akses data kependudukan, arsip dokumen, direktori UMKM, dan struktur kepengurusan desa.'}
    </p>
  </div>

  <section class="container-premium py-4">
    <a href="/ketua-rt" class="group grid gap-5 rounded-[1.75rem] border border-outline-variant bg-surface-container-lowest p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md sm:p-6 lg:grid-cols-[1fr_auto] lg:items-center">
      <div class="flex gap-4">
        <div class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-primary-container/40 text-m3-primary transition group-hover:bg-m3-primary group-hover:text-on-primary">
          <Icon name="contact_phone" class="text-[24px]" />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-m3-primary">Layanan cepat warga</p>
          <h2 class="mt-1 text-xl font-bold tracking-tight text-on-surface">Hubungi Ketua RT</h2>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-on-surface-variant">Pilih RT sesuai tempat tinggal Anda untuk konsultasi pelayanan warga, koordinasi lingkungan, atau hal yang perlu ditindaklanjuti di tingkat RT.</p>
        </div>
      </div>
      <span class="inline-flex w-fit items-center gap-2 rounded-full bg-slate-900 px-5 py-3 text-sm font-bold text-white transition group-hover:bg-m3-primary">
        Pilih RT <Icon name="arrow_forward" class="text-[16px]" />
      </span>
    </a>
  </section>

  <section class="container-premium py-8">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {dataItems.map((item) => (
        <DataCard
          label={item.label}
          href={item.href}
          description={item.description}
          icon={item.icon}
        />
      ))}
    </div>
  </section>

</MainLayout>
