        <a class="text-label-md font-label-md text-primary hover:underline focus:outline-none focus:ring-2 focus:ring-primary rounded" href="/berita">Lihat Semua</a>
      </div>
      <div class="flex flex-col gap-md">
        {beritaItems.length > 0 ? (
          beritaItems.map((item) => {
            const category = item.entry.kategori || 'Lingkungan';
            const label = categoryLabels[category.toLowerCase()] || category;
            const isDesa = label === 'Desa';
            const imgSrc = item.entry.gambarUtama || item.entry.gambar || 'https://via.placeholder.com/100x100';
            
            return (
              <a 
                key={item.slug}
                class="group flex gap-md items-center p-sm rounded-xl hover:bg-surface-container-low transition-colors focus:outline-none focus:ring-2 focus:ring-primary border border-transparent hover:border-outline-variant"
                href={`/berita/${item.slug}`}
              >
                <div class="flex-shrink-0 w-24 h-24 rounded-lg overflow-hidden relative">
                  <img 
                    alt={item.entry.judul}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    src={imgSrc}
                    loading="lazy"
                  />
