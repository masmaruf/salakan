        alt="{heroSection?.gambarAlt ?? 'Pemandangan Padukuhan Salakan'}" 
        class="absolute inset-0 w-full h-full object-cover" 
        src="{heroSection?.gambar ?? 'https://lh3.googleusercontent.com/aida-public/AB6AXuCMk6Y6HrLhBOWQtQYJsRsxCPPOZQHretQh2gkaMMXtQ4DH362eQUDs1I4iRv9y_6vii45cpGoJ5WiPQUkxquJncggiJUjgNKNX7P4hWPQJjrrfU0ULgdndt__IOaBAnnADeteX0A9SzVdQu3znx5LZysOou41QosnuRzx4xcgf9nhPi2VArsnibaR3PMaNwKLKVMvJU-RmptAgTSf8BVTwIIeF_o8Ss831HjGJFg6ZhW5sqEJMW1KR2FUfWG_EDTiBdiw1U26K-Q'}" 
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-on-surface/90 via-on-surface/40 to-transparent"></div>
      <div class="relative p-md z-10 w-full text-center">
        <h2 class="text-headline-lg-mobile font-headline-lg-mobile text-on-primary mb-xs">
          {heroSection?.title ?? 'Selamat Datang di Portal Resmi Salakan'}
        </h2>
        <p class="text-body-lg font-body-lg text-surface-container-lowest opacity-90">
          {heroSection?.intro ?? 'Transparan, Interaktif, & Berdaya'}
        </p>
      </div>
    </section>

    
    <!-- QUICK MENU (Bento Grid Style) -->
    <section>
      <div class="grid grid-cols-2 gap-sm">
        <!-- Agenda -->
        <a 
