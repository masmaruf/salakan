---
import {
  getBeranda,
  getPengumuman,
  getKegiatan,
  getGaleri,
  formatTanggal,
  sortByDateDesc,
} from '../lib/keystatic';

// Ambil data yang diperlukan
const [beranda, pengumumanItems, kegiatanItems, galeriItems] = await Promise.all([
  getBeranda(),
  getPengumuman(),
  getKegiatan(),
  getGaleri(),
]);

// Proses pengumuman (ambil 2 terbaru)
const pengumuman = sortByDateDesc(
  pengumumanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 2);

// Proses kegiatan untuk agenda (ambil 2 terbaru)
const agendaItems = sortByDateDesc(
  kegiatanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 2);

// Proses berita (ambil 2 terbaru)
const beritaItems = sortByDateDesc(
  kegiatanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 2);

const heroSection = beranda?.hero;

// Kategori label untuk berita
const categoryLabels: Record<string, string> = {
  kegiatan: 'Lingkungan',
  pengumuman: 'Desa',
  pelayanan: 'Layanan',
  potensi: 'Potensi',
};

// Format tanggal untuk agenda
function formatAgendaDate(date: Date | string): string {
  const d = new Date(date);
  const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
  const dayName = days[d.getDay()];
  const day = d.getDate();
  const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
  const monthName = months[d.getMonth()];
  return `${dayName}, ${day} ${monthName}`;
}

// Format tanggal relatif untuk berita
function formatRelativeDate(date: Date | string): string {
  const now = new Date();
  const d = new Date(date);
  const diffDays = Math.floor((now.getTime() - d.getTime()) / (1000 * 60 * 60 * 24));
  if (diffDays === 0) return 'Hari ini';
  if (diffDays === 1) return '1 Hari yang lalu';
  if (diffDays < 7) return `${diffDays} Hari yang lalu`;
  return formatTanggal(date);
}
---

<html lang="id">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>Salakan.id - Portal Informasi Padukuhan Salakan</title>
  
  <!-- Google Fonts: Plus Jakarta Sans -->
  <link href="https://fonts.googleapis.com" rel="preconnect"/>
  <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  
  <!-- Material Symbols -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  
  <!-- Tailwind CSS -->
  <style>
    @import "tailwindcss";
    @plugin "daisyui";
  </style>
  
  <!-- Custom Styles -->
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      -webkit-tap-highlight-color: transparent;
    }
    body {
      min-height: max(884px, 100dvh);
    }
    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: var(--surface-container-lowest); }
    ::-webkit-scrollbar-thumb { 
      background: var(--surface-container-high); 
      border-radius: 4px; 
    }
    ::-webkit-scrollbar-thumb:hover { background: var(--surface-container-highest); }
    
    /* Safe area padding for mobile */
    .pb-safe {
      padding-bottom: env(safe-area-inset-bottom);
    }
  </style>
</head>

<body class="bg-surface text-on-surface antialiased pb-24 flex flex-col min-h-screen">
  
  <!-- ==================== TOP APP BAR ==================== -->
