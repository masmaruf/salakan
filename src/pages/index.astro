        <a class="text-label-md font-label-md text-primary hover:underline focus:outline-none focus:ring-2 focus:ring-primary rounded" href="/agenda">Lihat Semua</a>
      </div>
      <div class="space-y-sm">
        {agendaItems.length > 0 ? (
          agendaItems.map((item) => (
            <a 
              key={item.slug} 
              class="bg-surface-container-lowest rounded-xl p-md shadow-[0_4px_12px_rgba(15,23,42,0.05)] border-l-4 border-l-tertiary border-y border-r border-outline-variant flex items-center gap-md hover:bg-surface-container transition-colors focus:outline-none focus:ring-2 focus:ring-primary"
              href={`/berita/${item.slug}`}
            >
              <div class="flex-shrink-0 bg-tertiary-container/30 w-12 h-12 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-tertiary" data-icon="group_work">group_work</span>
              </div>
              <div>
                <p class="text-label-sm font-label-sm text-on-surface-variant mb-xs">
