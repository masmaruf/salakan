---
import MainLayout from '../layouts/MainLayout.astro';
import NewsGrid from '../components/NewsGrid.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import PageHero from '../components/PageHero.astro';
import PageSection from '../components/PageSection.astro';
import EmptyStateCard from '../components/ui/EmptyStateCard.astro';
import Badge from '../components/ui/Badge.astro';
import {
  getBeranda,
  getKegiatan,
  getAgenda,
  getGaleri,
  getLogKegiatan,
  getLayananWarga,
  getMonografi,
  sortByDateDesc,
  excerpt,
} from '../lib/content';
import { getMonografiSummary } from '../lib/monografi-summary';

const [beranda, kegiatanItems, agendaRaw, galeriItems, logItems, layananItems, monografi] = await Promise.all([
  getBeranda(),
  getKegiatan(),
  getAgenda(),
  getGaleri(),
  getLogKegiatan(),
  getLayananWarga(),
  getMonografi(),
]);

const hero = beranda?.hero;
const beritaSection = beranda?.berita;
const galeriSection = beranda?.galeri;
const penutup = beranda?.penutup;
const now = Date.now();
const monografiSummary = getMonografiSummary(monografi);

const agendaPublished = sortByDateDesc(
  agendaRaw
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const agendaTerdekat = agendaPublished.slice(0, 6);

const berita = sortByDateDesc(
  kegiatanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 3);

const galeri = sortByDateDesc(
  galeriItems.map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 3);

const layananPrioritas = layananItems
  .filter((item) => item.entry?.statusTampil === 'tampil')
  .slice(0, 3)
  .map((item) => ({
    slug: item.slug,
    title: item.entry.namaLayanan,
    description: item.entry.ringkasan,
  }));

const logTerbaru = sortByDateDesc(
  logItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 3);

const statsData = [
  { value: agendaPublished.length, label: hero?.stats?.agendaLabel ?? 'Agenda aktif', icon: 'event' },
  { value: kegiatanItems.filter((i) => i.entry?.statusPublikasi === 'publish').length, label: hero?.stats?.kegiatanLabel ?? 'Berita terdokumentasi', icon: 'newspaper' },
  { value: galeriItems.length, label: hero?.stats?.galeriLabel ?? 'Galeri tersedia', icon: 'photo_library' },
];

const panelLinks = hero?.panelLinks?.filter((link) => link.status === 'tampil') ?? [];

function formatAgendaDate(date: Date | string): string {
  const d = new Date(date);
  const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
  return `${days[d.getDay()]}, ${d.getDate()} ${months[d.getMonth()]}`;
}

function getSignal(item: { tanggal: string; unggulan?: boolean }) {
  const diffDays = Math.floor((new Date(item.tanggal).getTime() - now) / (1000 * 60 * 60 * 24));
  if (item.unggulan) return { label: 'Penting', tone: 'error' as const };
  if (diffDays >= 0 && diffDays <= 7) return { label: 'Minggu ini', tone: 'primary' as const };
  if (diffDays >= -3 && diffDays < 0) return { label: 'Baru', tone: 'surface' as const };
  return { label: 'Info', tone: 'surface' as const };
}

function getLabelTone(label?: string) {
  const normalized = label?.trim().toLowerCase() ?? '';
  if (normalized === 'pengumuman') return 'error' as const;
  if (normalized === 'informasi') return 'surface' as const;
  return 'primary' as const;
}

const pusatInformasi = agendaTerdekat.slice(0, 4).map((item) => ({
  href: `/agenda/${item.slug}`,
  title: item.entry.judul,
  description: excerpt(item.entry.ringkasan, 120),
  date: formatAgendaDate(item.entry.tanggal),
  label: item.entry.label || 'Agenda',
  signal: getSignal({ tanggal: item.entry.tanggal, unggulan: item.entry.unggulan }),
}));

const pembaruanTerbaru = [
  ...berita.map((item) => ({
    href: `/berita/${item.slug}`,
    title: item.entry.judul,
    description: excerpt(item.entry.ringkasan, 110),
    date: item.entry.tanggal,
    badge: item.entry.kategori || 'Berita',
    tone: 'info' as const,
    type: 'Berita',
  })),
  ...logTerbaru.map((item) => ({
    href: '/log-kegiatan',
    title: item.entry.judul,
    description: excerpt(item.entry.ringkasan, 110),
    date: item.entry.tanggal,
    badge: item.entry.kategori,
    tone: 'surface' as const,
    type: 'Log Dukuh',
  })),
]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 4);

import Icon from '../components/ui/Icon.tsx';
---

<MainLayout
  title="Beranda | Padukuhan Salakan"
  description={hero?.intro ?? 'Portal warga Padukuhan Salakan untuk agenda, berita, profil wilayah, galeri, dan informasi kontak.'}
>
  <PageHero
    eyebrow={hero?.eyebrow ?? 'Padukuhan Salakan'}
    icon="location_on"
    title={hero?.title ?? 'Pusat informasi warga Padukuhan Salakan'}
    description={hero?.intro ?? 'Selamat datang di website Padukuhan Salakan.'}
    sectionClass="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 pt-16 pb-28 sm:pt-24 sm:pb-36"
    titleClass="text-3xl font-bold leading-[1.1] tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl"
    descriptionClass="mx-auto max-w-2xl text-base font-medium leading-relaxed text-blue-100/70 sm:text-lg"
    contentClass="mx-auto max-w-3xl space-y-6 text-center"
    badgeClass="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 backdrop-blur"
    orbs={[
      { class: 'absolute -top-24 left-1/3 h-[480px] w-[480px] rounded-full bg-blue-500/15 blur-3xl' },
      { class: 'absolute -bottom-24 right-1/4 h-[380px] w-[380px] rounded-full bg-indigo-500/15 blur-3xl' },
    ]}
  >
    <div class="flex flex-wrap items-center justify-center gap-3 pt-4">
      <a
        class="hero-cta-primary"
        href={hero?.primaryCtaHref ?? '/agenda'}
      >
        <Icon name="event" class="text-[18px]" />
        {hero?.primaryCtaLabel ?? 'Lihat agenda warga'}
      </a>
      <a
        class="hero-cta-secondary"
        href={hero?.secondaryCtaHref ?? '/profil'}
      >
        {hero?.secondaryCtaLabel ?? 'Baca profil padukuhan'}
        <Icon name="arrow_forward" class="text-[18px] text-blue-700" />
      </a>
    </div>

    <div class="mx-auto mt-14 grid max-w-xl grid-cols-3 gap-3 sm:gap-4">
      {statsData.map((s) => (
        <div class="flex flex-col items-center gap-2 rounded-2xl border border-white/12 bg-white/8 px-3 py-5 backdrop-blur-sm">
          <div class="grid h-14 w-14 place-items-center rounded-2xl bg-white text-slate-900 shadow-lg shadow-slate-950/15">
            <Icon name={s.icon} class="text-[30px] text-blue-700" />
          </div>
          <strong class="text-2xl font-bold text-white sm:text-3xl">{s.value}</strong>
          <span class="text-center text-[0.62rem] font-bold uppercase leading-tight tracking-[0.12em] text-blue-100/85">{s.label}</span>
        </div>
      ))}
    </div>
  </PageHero>

  {panelLinks.length > 0 && (
    <section class="relative z-20 -mt-14">
      <div class="container-premium">
        <div class="grid gap-3 sm:grid-cols-3">
          {panelLinks.map((link) => (
            <a class="group section-card section-card-hover flex items-start gap-4" href={link.href}>
              <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary-container/30 text-m3-primary transition-colors group-hover:bg-primary-container group-hover:text-on-primary-container">
                <Icon name={link.icon} class="text-[22px]" />
              </div>
              <div class="min-w-0">
                <h3 class="text-sm font-bold text-on-surface sm:text-base">{link.title}</h3>
                <p class="mt-1 text-xs font-medium leading-relaxed text-on-surface-variant sm:text-sm">{link.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="container-premium pt-8 sm:pt-10">
    <a
      href="/ketua-rt"
      class="group grid gap-5 overflow-hidden rounded-[1.75rem] border border-emerald-100 bg-gradient-to-br from-emerald-50 via-white to-blue-50 p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md sm:p-6 lg:grid-cols-[1fr_auto] lg:items-center"
    >
      <div class="flex gap-4">
        <div class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-emerald-600 text-white shadow-sm transition group-hover:scale-105">
          <Icon name="contact_phone" class="text-[24px]" />
        </div>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.14em] text-emerald-700">Konsultasi pelayanan warga per RT</p>
          <h2 class="mt-1 text-2xl font-black tracking-tight text-on-surface">Hubungi ketua RT</h2>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-on-surface-variant sm:text-base">
            Pilih RT sesuai tempat tinggal Anda untuk konsultasi surat keterangan, koordinasi lingkungan, atau hal yang perlu ditindaklanjuti di tingkat RT.
          </p>
        </div>
      </div>
      <span class="action-pill-dark w-fit group-hover:bg-emerald-700">
        Hubungi ketua RT <Icon name="arrow_forward" class="text-[16px]" />
      </span>
    </a>
  </section>

  <section class="container-premium py-5 sm:py-6">
    <div class="grid gap-4 md:grid-cols-3">
      <div class="section-card">
        <p class="section-kicker">Statistik Wilayah</p>
        <p class="mt-2 text-3xl font-black tracking-tight text-on-surface">{monografiSummary.totalJiwa}</p>
        <p class="mt-1 text-sm text-on-surface-variant">Total jiwa yang tercatat dari data monografi padukuhan.</p>
      </div>
      <div class="section-card">
        <p class="section-kicker">Kepala Keluarga</p>
        <p class="mt-2 text-3xl font-black tracking-tight text-on-surface">{monografiSummary.totalKK}</p>
        <p class="mt-1 text-sm text-on-surface-variant">Jumlah KK aktif sebagai konteks utama pelayanan warga.</p>
      </div>
      <div class="section-card">
        <p class="section-kicker">Cakupan RT</p>
        <p class="mt-2 text-3xl font-black tracking-tight text-on-surface">{monografiSummary.jumlahRT}</p>
        <p class="mt-1 text-sm text-on-surface-variant">Ringkasan wilayah aktif yang saat ini terlayani di padukuhan.</p>
      </div>
    </div>
  </section>

  <section class="container-premium py-10 sm:py-14">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="section-kicker">Command Center Warga</p>
        <h2 class="mt-1 text-2xl font-bold tracking-tight text-on-surface">Tiga blok terpenting untuk dibuka setiap hari</h2>
      </div>
      <p class="max-w-2xl text-sm leading-relaxed text-on-surface-variant">
        Beranda dirapikan agar warga langsung melihat agenda terdekat, layanan cepat, dan pembaruan terbaru tanpa perlu pindah-pindah halaman lebih dulu.
      </p>
    </div>

    <div class="grid gap-5 xl:grid-cols-3">
      <div class="section-card">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="section-kicker">Agenda Terdekat</p>
            <h2 class="mt-1 text-2xl font-bold tracking-tight text-on-surface">Apa yang perlu diketahui minggu ini</h2>
          </div>
          <a class="action-link-inline" href="/agenda">
            Buka agenda lengkap <Icon name="arrow_forward" class="text-[16px]" />
          </a>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {pusatInformasi.map((item) => (
            <a class="section-subcard section-subcard-hover" href={item.href}>
              <div class="flex flex-wrap items-center gap-2">
                <Badge label={item.label} tone={getLabelTone(item.label)} class="px-2.5 py-1" />
                <Badge label={item.signal.label} tone={item.signal.tone} class="px-2.5 py-1" />
              </div>
              <h3 class="mt-3 line-clamp-2 text-base font-bold leading-tight text-on-surface">{item.title}</h3>
              <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-on-surface-variant">{item.date}</p>
              <p class="mt-2 line-clamp-2 text-sm text-on-surface-variant">{item.description}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="section-card">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="section-kicker">Layanan Cepat</p>
            <h2 class="mt-1 text-2xl font-bold tracking-tight text-on-surface">Akses yang paling sering dibutuhkan warga</h2>
          </div>
          <a class="action-link-inline" href="/data/layanan-warga">
            Buka layanan <Icon name="arrow_forward" class="text-[16px]" />
          </a>
        </div>
        <div class="mt-5 space-y-3">
          {layananPrioritas.map((item) => (
            <a class="section-subcard section-subcard-hover block" href={`/data/layanan-warga#${item.slug}`}>
              <h3 class="text-sm font-bold text-on-surface sm:text-base">{item.title}</h3>
              <p class="mt-1 text-sm text-on-surface-variant line-clamp-2">{item.description}</p>
            </a>
          ))}
        </div>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <a class="inline-flex min-h-[44px] items-center justify-center gap-2 rounded-full bg-primary-container px-5 py-3 text-sm font-bold text-on-primary-container transition hover:-translate-y-0.5" href="/dasbor/buat-surat">
            <Icon name="description" class="text-[18px]" /> Ajukan surat
          </a>
          <a class="inline-flex min-h-[44px] items-center justify-center gap-2 rounded-full border border-outline-variant bg-white px-5 py-3 text-sm font-bold text-on-surface transition hover:bg-surface-container-low" href="/dasbor/lacak-surat">
            <Icon name="travel_explore" class="text-[18px]" /> Lacak tiket
          </a>
        </div>
      </div>

      <div class="section-card">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="section-kicker">Pembaruan Terbaru</p>
            <h2 class="mt-1 text-2xl font-bold tracking-tight text-on-surface">Arsip yang baru ditambahkan</h2>
          </div>
          <a class="action-link-inline" href="/berita">
            Buka arsip <Icon name="arrow_forward" class="text-[16px]" />
          </a>
        </div>
        <div class="mt-5 space-y-3">
          {pembaruanTerbaru.map((item) => (
            <a class="section-subcard section-subcard-hover block" href={item.href}>
              <div class="flex flex-wrap items-center gap-2">
                <Badge label={item.type} tone="surface" class="px-2.5 py-1" />
                <Badge label={item.badge} tone={item.tone} class="px-2.5 py-1" />
              </div>
              <h3 class="mt-3 text-sm font-bold leading-tight text-on-surface sm:text-base">{item.title}</h3>
              <p class="mt-1 text-[11px] font-semibold uppercase tracking-wide text-on-surface-variant">{formatAgendaDate(item.date)}</p>
              <p class="mt-2 line-clamp-2 text-sm text-on-surface-variant">{item.description}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PageSection title="Agenda Terdekat" actionHref="/agenda" actionLabel="Lihat semua">
    {agendaTerdekat.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {agendaTerdekat.map((item) => (
          <a
            class="group overflow-hidden rounded-xl border border-outline-variant bg-surface-container-lowest transition-all hover:-translate-y-1 hover:shadow-md active:scale-[0.98]"
            href={`/agenda/${item.slug}`}
          >
            <div class="flex h-full flex-col p-5">
              <div class="mb-3 flex items-center gap-3">
                <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary-container/30 text-m3-primary">
                  <Icon name="event" class="text-[22px]" />
                </div>
                <div>
                  <Badge label={item.entry.label || 'Agenda'} tone={getLabelTone(item.entry.label)} class="px-2 py-0.5" />
                  <p class="mt-1 text-[11px] font-medium text-on-surface-variant">{formatAgendaDate(item.entry.tanggal)}</p>
                </div>
              </div>
              <h3 class="text-base font-bold leading-tight text-on-surface transition-colors line-clamp-2 group-hover:text-m3-primary sm:text-lg">
                {item.entry.judul}
              </h3>
              <p class="mt-2 flex-1 text-sm text-on-surface-variant line-clamp-2">
                {excerpt(item.entry.ringkasan, 120)}
              </p>
              {item.entry.lokasi && (
                <div class="mt-4 flex items-center gap-1.5 border-t border-outline-variant/50 pt-3 text-xs font-medium text-on-surface-variant">
                  <Icon name="location_on" class="text-[14px]" />
                  <span class="truncate">{item.entry.lokasi}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <EmptyStateCard message="Belum ada agenda terdekat" />
    )}
  </PageSection>

  <PageSection title={beritaSection?.title ?? 'Berita terbaru'} actionHref="/berita" actionLabel={beritaSection?.ctaLabel ?? 'Lihat semua'}>
    {berita.length > 0 ? (
      <NewsGrid items={berita} />
    ) : (
      <EmptyStateCard message="Belum ada berita terbaru" />
    )}
  </PageSection>

  <PageSection sectionClass="bg-surface-container-low/50 py-10 sm:py-14" title={galeriSection?.title ?? 'Galeri pilihan'} actionHref="/galeri" actionLabel={galeriSection?.ctaLabel ?? 'Buka galeri'}>
    {galeri.length > 0 ? (
      <GalleryGrid items={galeri} />
    ) : (
      <EmptyStateCard message="Belum ada galeri tersedia" />
    )}
  </PageSection>

  {penutup && (
    <PageHero
      eyebrow={penutup.eyebrow}
      title={penutup.title}
      description={penutup.description}
      icon="grid_view"
      sectionClass="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16 sm:py-20"
      containerClass="container-premium relative z-10"
      contentClass="mx-auto max-w-2xl text-center"
      titleClass="mt-6 text-2xl font-bold leading-tight tracking-tight text-white sm:text-3xl md:text-4xl"
      descriptionClass="mt-4 text-base font-medium leading-relaxed text-blue-100/70 sm:text-lg"
      badgeClass="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 backdrop-blur"
      badgeIconClass="hidden"
      badgeTextClass="text-xs font-bold uppercase tracking-[0.15em] text-blue-200"
      orbs={[
        { class: 'absolute left-1/2 top-1/2 h-[420px] w-[420px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-500/10 blur-3xl' },
      ]}
    >
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          class="inline-flex items-center gap-2 rounded-full bg-primary-container px-7 py-3.5 text-sm font-bold text-on-primary-container shadow-lg transition-all hover:-translate-y-0.5"
          href={penutup.primaryCtaHref}
        >
          <Icon name="grid_view" class="text-[18px]" />
          {penutup.primaryCtaLabel}
        </a>
        <a
          class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-6 py-3 text-sm font-bold text-white backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:bg-white/20"
          href={penutup.secondaryCtaHref}
        >
          {penutup.secondaryCtaLabel}
          <Icon name="arrow_forward" class="text-[16px]" />
        </a>
      </div>
    </PageHero>
  )}
</MainLayout>


