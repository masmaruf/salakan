---
import MainLayout from '../layouts/MainLayout.astro';
import NewsGrid from '../components/NewsGrid.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import PageSection from '../components/PageSection.astro';
import EmptyStateCard from '../components/ui/EmptyStateCard.astro';
import Badge from '../components/ui/Badge.astro';
import { Image } from 'astro:assets';
import {
  getBeranda,
  getKegiatan,
  getAgenda,
  getGaleri,
  getMonografi,
  sortByDateDesc,
  excerpt,
} from '../lib/content';
import { getAgendaLabelTone } from '../lib/content-taxonomy';
import { getMonografiSummary } from '../lib/monografi-summary';

const [beranda, kegiatanItems, agendaRaw, galeriItems, monografi] = await Promise.all([
  getBeranda(),
  getKegiatan(),
  getAgenda(),
  getGaleri(),
  getMonografi(),
]);

const hero = beranda?.hero;
const beritaSection = beranda?.berita;
const galeriSection = beranda?.galeri;
const penutup = beranda?.penutup;
const monografiSummary = getMonografiSummary(monografi);

const agendaPublished = sortByDateDesc(
  agendaRaw
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const agendaTerdekat = agendaPublished.slice(0, 6);

const berita = sortByDateDesc(
  kegiatanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 3);

const galeri = sortByDateDesc(
  galeriItems.map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 3);

const berandaStats = [
  { value: agendaPublished.length, label: hero?.stats?.agendaLabel ?? 'Agenda aktif' },
  { value: kegiatanItems.filter((i) => i.entry?.statusPublikasi === 'publish').length, label: hero?.stats?.kegiatanLabel ?? 'Berita terdokumentasi' },
  { value: galeriItems.length, label: hero?.stats?.galeriLabel ?? 'Galeri tersedia' },
  { value: monografiSummary.totalJiwa, label: 'Total jiwa tercatat' },
  { value: monografiSummary.totalKK, label: 'Kepala keluarga' },
  { value: monografiSummary.jumlahRT, label: 'Cakupan RT' },
];

const panelLinks = hero?.panelLinks?.filter((link) => link.status === 'tampil') ?? [];
const panelTints = ['bg-m3-primary/5', 'bg-surface-container-lowest', 'bg-surface-container-lowest', 'bg-m3-tertiary/8'];

function formatAgendaDate(date: Date | string): string {
  const d = new Date(date);
  const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
  return `${days[d.getDay()]}, ${d.getDate()} ${months[d.getMonth()]}`;
}

import Icon from '../components/ui/Icon.tsx';
---

<MainLayout
  title="Beranda | Padukuhan Salakan"
  description={hero?.intro ?? 'Portal warga Padukuhan Salakan untuk agenda, berita, profil wilayah, galeri, dan informasi kontak.'}
>
  {/* ===== HERO — asymmetric split, sudut konsisten M3 rounded-xl ===== */}
  <section class="bg-base-100 pt-6 pb-2 sm:pt-8">
    <div class="container-premium">
      <div class="grid overflow-hidden rounded-xl bg-neutral lg:h-[400px] lg:grid-cols-[1.05fr_0.95fr]">
        <div class="flex flex-col justify-center px-5 py-10 sm:px-10 sm:py-14 lg:px-12">
          <h1 class="max-w-xl text-3xl font-bold leading-[1.12] tracking-tight text-neutral-content sm:text-4xl lg:text-[2.75rem]">
            {hero?.title ?? 'Pusat informasi warga Padukuhan Salakan'}
          </h1>
          <p class="mt-4 max-w-md text-sm leading-relaxed text-neutral-content/70 sm:text-base">
            {hero?.intro ?? 'Selamat datang di website Padukuhan Salakan.'}
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <a class="btn btn-accent" href={hero?.primaryCtaHref ?? '/agenda'}>
              <Icon name="event" class="text-[18px]" />
              {hero?.primaryCtaLabel ?? 'Lihat agenda warga'}
            </a>
            <a class="btn border border-neutral-content/30 bg-transparent !text-neutral-content hover:bg-neutral-content hover:!text-neutral" href={hero?.secondaryCtaHref ?? '/profil'}>
              {hero?.secondaryCtaLabel ?? 'Baca profil padukuhan'}
              <Icon name="arrow_forward" class="text-[18px]" />
            </a>
          </div>
        </div>

        <div class="relative h-[220px] sm:h-[300px] lg:h-full">
          <Image
            src="/images/1002185119.webp"
            alt="Anak-anak dan warga Padukuhan Salakan dalam kegiatan bersama"
            width={1200}
            height={1400}
            class="h-full w-full object-cover object-bottom"
            loading="eager"
            decoding="async"
            sizes="(max-width: 1024px) 100vw, 45vw"
          />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/55 to-transparent px-5 py-4 sm:px-8">
            <p class="text-xs font-semibold text-white/90 sm:text-sm">Kebersamaan warga Padukuhan Salakan</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ===== SALAKAN DALAM ANGKA — kartu M3, bukan grid divide kaku ===== */}
  <section class="border-b border-outline-variant/40 bg-surface-container-low/30">
    <div class="container-premium grid grid-cols-2 gap-3 py-6 sm:grid-cols-3 sm:gap-4 lg:grid-cols-6">
      {berandaStats.map((s) => (
        <div class="rounded-xl border border-outline-variant/60 bg-surface-container-lowest p-4 text-center shadow-[0_4px_12px_rgba(15,23,42,0.04)] transition-all hover:-translate-y-0.5 hover:shadow-md sm:p-5">
          <p class="text-2xl font-bold tracking-tight text-on-surface sm:text-3xl">{s.value}</p>
          <p class="mt-1.5 text-[11px] font-semibold uppercase leading-tight tracking-[0.08em] text-on-surface-variant">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ===== LAYANAN UTAMA — bento 2x2, bukan 3 kartu seragam ===== */}
  {panelLinks.length > 0 && (
    <section class="container-premium py-12 sm:py-16">
      <h2 class="text-2xl font-bold tracking-tight text-on-surface sm:text-3xl">{hero?.panelTitle ?? 'Layanan utama warga dalam satu halaman'}</h2>
      {hero?.panelNote && <p class="mt-2 max-w-2xl text-sm leading-relaxed text-on-surface-variant sm:text-base">{hero.panelNote}</p>}

      <div class="mt-7 grid gap-4 sm:grid-cols-2">
        {panelLinks.map((link, i) => (
          <a
            class:list={['group flex items-start gap-4 overflow-hidden rounded-xl border border-outline-variant p-6 shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md active:scale-[0.99]', panelTints[i % panelTints.length]]}
            href={link.href}
          >
            <div class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-m3-primary text-on-primary transition-transform group-hover:scale-105">
              <Icon name={link.icon} class="text-[24px]" />
            </div>
            <div class="min-w-0">
              <p class="text-base font-bold text-on-surface">{link.title}</p>
              <p class="mt-1.5 text-sm leading-relaxed text-on-surface-variant">{link.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* ===== KONSULTASI RT — strip M3 dengan border-l aksen ===== */}
  <section class="container-premium pb-4">
    <a
      href="/ketua-rt"
      class="group flex items-center gap-5 overflow-hidden rounded-xl border border-outline-variant bg-surface-container-lowest shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:shadow-md"
    >
      <div class="hidden h-full w-1.5 shrink-0 self-stretch bg-m3-primary sm:block" aria-hidden="true"></div>
      <div class="flex flex-1 items-center gap-4 p-5 sm:p-6">
        <div class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-primary-container/40 text-m3-primary transition-colors group-hover:bg-m3-primary group-hover:text-on-primary">
          <Icon name="contact_phone" class="text-[22px]" />
        </div>
        <div class="min-w-0 flex-1">
          <h2 class="text-lg font-bold tracking-tight text-on-surface sm:text-xl">Hubungi ketua RT</h2>
          <p class="mt-1 max-w-xl text-sm leading-relaxed text-on-surface-variant">
            Pilih RT sesuai tempat tinggal Anda untuk konsultasi surat keterangan, koordinasi lingkungan, atau hal yang perlu ditindaklanjuti di tingkat RT.
          </p>
        </div>
        <span class="hidden shrink-0 sm:inline-flex">
          <span class="btn btn-primary gap-1.5">
            Hubungi <Icon name="arrow_forward" class="text-[16px]" />
          </span>
        </span>
      </div>
    </a>
  </section>

  <PageSection title="Agenda Terdekat" actionHref="/agenda" actionLabel="Lihat semua">
    {agendaTerdekat.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {agendaTerdekat.map((item) => (
          <a
            class="card group overflow-hidden border border-outline-variant bg-surface-container-lowest shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md active:scale-[0.98]"
            href={`/agenda/${item.slug}`}
          >
            <div class="card-body flex h-full flex-col p-5">
              <div class="mb-3 flex items-center gap-3">
                <div class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-primary-container/40 text-m3-primary">
                  <Icon name="event" class="text-[22px]" />
                </div>
                <div>
                  <Badge label={item.entry.label || 'Agenda'} tone={getAgendaLabelTone(item.entry.label)} class="px-2 py-0.5" />
                  <p class="mt-1 text-[11px] font-medium text-on-surface-variant">{formatAgendaDate(item.entry.tanggal)}</p>
                </div>
              </div>
              <h3 class="text-base font-bold leading-tight text-on-surface transition-colors line-clamp-2 group-hover:text-m3-primary sm:text-lg">
                {item.entry.judul}
              </h3>
              <p class="mt-2 flex-1 text-sm text-on-surface-variant line-clamp-2">
                {excerpt(item.entry.ringkasan, 120)}
              </p>
              {item.entry.lokasi && (
                <div class="mt-4 flex items-center gap-1.5 border-t border-outline-variant/50 pt-3 text-xs font-medium text-on-surface-variant">
                  <Icon name="location_on" class="text-[14px]" />
                  <span class="truncate">{item.entry.lokasi}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <EmptyStateCard message="Belum ada agenda terdekat" />
    )}
  </PageSection>

  <PageSection title={beritaSection?.title ?? 'Berita terbaru'} actionHref="/berita" actionLabel={beritaSection?.ctaLabel ?? 'Lihat semua'}>
    {berita.length > 0 ? (
      <NewsGrid items={berita} />
    ) : (
      <EmptyStateCard message="Belum ada berita terbaru" />
    )}
  </PageSection>

  <PageSection sectionClass="bg-base-200/50 py-10 sm:py-14" title={galeriSection?.title ?? 'Galeri pilihan'} actionHref="/galeri" actionLabel={galeriSection?.ctaLabel ?? 'Buka galeri'}>
    {galeri.length > 0 ? (
      <GalleryGrid items={galeri} />
    ) : (
      <EmptyStateCard message="Belum ada galeri tersedia" />
    )}
  </PageSection>

  {/* ===== PENUTUP — strip solid singkat, beda layout dari hero ===== */}
  {penutup && (
    <section class="bg-primary py-14 sm:py-16">
      <div class="container-premium flex flex-col items-center gap-6 text-center">
        <h2 class="max-w-2xl text-2xl font-bold leading-tight tracking-tight text-primary-content sm:text-3xl">
          {penutup.title}
        </h2>
        <p class="max-w-xl text-sm leading-relaxed text-primary-content/80 sm:text-base">
          {penutup.description}
        </p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            class="btn bg-base-100 text-base-content border-base-100 hover:bg-base-200"
            href={penutup.primaryCtaHref}
          >
            <Icon name="grid_view" class="text-[18px]" />
            {penutup.primaryCtaLabel}
          </a>
          <a
            class="btn border border-primary-content/40 bg-transparent !text-primary-content hover:bg-primary-content hover:!text-primary"
            href={penutup.secondaryCtaHref}
          >
            {penutup.secondaryCtaLabel}
            <Icon name="arrow_forward" class="text-[16px]" />
          </a>
        </div>
      </div>
    </section>
  )}
</MainLayout>
