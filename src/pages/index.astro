---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import {
  getBeranda,
  getGaleri,
  getKegiatan,
  getPengaturan,
  getPengumuman,
  getProfil,
  getKategoriBeritaMap,
  formatTanggal,
  sortByDateDesc,
} from '../lib/keystatic';

const [categoryLabels, profil, pengaturan, beranda, pengumumanItems, kegiatanItems, galeriItems] = await Promise.all([
  getKategoriBeritaMap(),
  getProfil(),
  getPengaturan(),
  getBeranda(),
  getPengumuman(),
  getKegiatan(),
  getGaleri(),
]);

const pengumuman = sortByDateDesc(
  pengumumanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
)
  .sort((a, b) => Number(b.entry.unggulan) - Number(a.entry.unggulan))
  .slice(0, 4);

const featuredPengumuman = pengumuman[0];
const secondaryPengumuman = pengumuman.slice(1, 4);

const kegiatan = sortByDateDesc(
  kegiatanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const featuredNews = kegiatan[0];
const newsList = kegiatan.filter((item) => item.slug !== featuredNews?.slug).slice(0, 3);

const galeri = sortByDateDesc(
  galeriItems.map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 3);

const heroSection = beranda?.hero;
const quickLinks = (heroSection?.panelLinks ?? []).filter((item) => item.status === 'tampil');
const pengumumanSection = beranda?.pengumuman;
const beritaSection = beranda?.berita;
const galeriSection = beranda?.galeri;
const penutupSection = beranda?.penutup;

const heroStats = [
  { label: heroSection?.stats?.pengumumanLabel ?? 'Pengumuman aktif', value: `${pengumuman.length}` },
  { label: heroSection?.stats?.kegiatanLabel ?? 'Berita terdokumentasi', value: `${kegiatan.length}` },
  { label: heroSection?.stats?.galeriLabel ?? 'Galeri tersedia', value: `${galeriItems.length}` },
];
---

<MainLayout>
  <section class="section pb-6 md:pb-8">
    <div class="container grid items-stretch gap-4 lg:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)]">
      <div class="rounded-[var(--radius-xl)] bg-[image:var(--hero-grad)] px-7 py-8 text-white shadow-[0_18px_46px_rgba(88,76,193,0.14)] md:px-10 md:py-10">
        <span class="badge badge-primary badge-outline w-fit border-white/20 bg-white/15 text-white">
          {heroSection?.eyebrow ?? 'Padukuhan Salakan'}
        </span>
        <h1 class="mt-4 max-w-[12ch] text-4xl font-extrabold leading-[0.95] tracking-[-0.045em] text-white md:text-6xl xl:text-7xl">
          {heroSection?.title ?? 'Pusat informasi warga Padukuhan Salakan'}
        </h1>
        <p class="mt-4 max-w-3xl text-body-lg text-white/90">
          {heroSection?.intro ??
            pengaturan?.sambutanBeranda ??
            'Portal ini disiapkan untuk menyajikan pengumuman, agenda kegiatan, dokumentasi warga, dan informasi padukuhan secara cepat dan rapi.'}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="brand-button btn rounded-[var(--radius-md)]" href={heroSection?.primaryCtaHref ?? '/data/pengumuman'}>
            {heroSection?.primaryCtaLabel ?? 'Lihat pengumuman'}
          </a>
          <a class="btn rounded-[var(--radius-md)] border-white/25 bg-white/10 text-white hover:bg-white/15 hover:text-white" href={heroSection?.secondaryCtaHref ?? '/profil'}>
            {heroSection?.secondaryCtaLabel ?? 'Baca profil padukuhan'}
          </a>
        </div>
        <div class="mt-6 grid gap-3 md:grid-cols-3">
          {heroStats.map((stat) => (
            <article class="rounded-[var(--radius-lg)] border border-white/15 bg-white/15 p-4 backdrop-blur">
              <strong class="block text-2xl font-extrabold text-white">{stat.value}</strong>
              <span class="mt-1 block text-sm leading-6 text-white/80">{stat.label}</span>
            </article>
          ))}
        </div>
      </div>

      <aside class="surface-card flex flex-col justify-between gap-5 p-5 md:p-6">
        <div class="space-y-3">
          <span class="badge badge-outline w-fit">
            {heroSection?.panelLabel ?? 'Informasi utama warga'}
          </span>
          <h2 class="section-title font-extrabold text-slate-950">
            {heroSection?.panelTitle ?? 'Layanan utama warga dalam satu halaman'}
          </h2>
          <p class="text-body-md text-slate-600">
            {heroSection?.panelNote ??
              'Website ini dirancang agar warga cepat menemukan pengumuman, berita, data kampung, dan layanan komunikasi resmi.'}
          </p>
        </div>
        <div class="grid gap-3">
          {quickLinks.map((item) => (
            <a class="grid grid-cols-[3rem_1fr] items-start gap-4 rounded-[var(--radius-lg)] border border-slate-200 bg-white px-4 py-4 transition-all hover:-translate-y-0.5 hover:shadow-sm" href={item.href}>
              <span class="grid h-12 w-12 place-items-center rounded-[var(--radius-md)] bg-gradient-to-br from-violet-100 to-blue-100 font-['Material_Symbols_Outlined'] text-2xl text-violet-700">
                {item.icon}
              </span>
              <span>
                <strong class="block text-base font-bold text-slate-950">{item.title}</strong>
                <small class="mt-1 block text-body-sm text-slate-500">{item.description}</small>
              </span>
            </a>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section pt-0" id="pengumuman-prioritas">
    <div class="container">
      <SectionHeading
        title={pengumumanSection?.title ?? 'Pengumuman prioritas'}
        description={pengumumanSection?.description ?? 'Bagian ini menempatkan informasi paling penting untuk warga di posisi paling mudah terlihat.'}
      />
      <div class="grid gap-4 lg:grid-cols-[minmax(0,1.15fr)_minmax(300px,0.85fr)]">
        {featuredPengumuman && (
          <article class="surface-card flex flex-col gap-4 p-5 md:p-6">
            <div class="flex flex-wrap items-center gap-3">
              <time class="text-sm font-medium text-slate-500" datetime={featuredPengumuman.entry.tanggal}>
                {formatTanggal(featuredPengumuman.entry.tanggal)}
              </time>
            </div>
            <h2 class="section-title font-extrabold text-slate-950">{featuredPengumuman.entry.judul}</h2>
            <p class="text-body-lg text-slate-600">{featuredPengumuman.entry.ringkasan}</p>
            <div class="border-t border-slate-200 pt-4 text-body-sm text-slate-600">
              {featuredPengumuman.entry.isi}
            </div>
            <a class="brand-button btn w-fit rounded-[var(--radius-md)]" href="/data/pengumuman">
              {pengumumanSection?.ctaLabel ?? 'Buka halaman pengumuman'}
            </a>
          </article>
        )}

        <div class="grid gap-4">
          {secondaryPengumuman.map(({ entry }) => (
            <article class="surface-card flex flex-col gap-3 p-5">
              <div class="flex flex-wrap items-center gap-3">
                <time class="text-sm font-medium text-slate-500" datetime={entry.tanggal}>{formatTanggal(entry.tanggal)}</time>
              </div>
              <h3 class="card-title font-bold text-slate-950">{entry.judul}</h3>
              <p class="text-body-md text-slate-600">{entry.ringkasan}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0" id="berita-editorial">
    <div class="container">
      <SectionHeading
        title={beritaSection?.title ?? 'Berita terbaru'}
        description={beritaSection?.description ?? 'Satu berita unggulan ditampilkan lebih dominan, sementara artikel lain tetap mudah dipindai warga lewat format editorial yang ringkas.'}
        href="/berita"
        linkLabel={beritaSection?.ctaLabel ?? 'Lihat semua berita'}
      />
      <div class="grid gap-4 lg:grid-cols-[minmax(0,1.15fr)_minmax(300px,0.85fr)]">
        {featuredNews && (
          <article class="surface-card overflow-hidden p-5 md:p-6">
            {featuredNews.entry.gambarUtama && (
              <div
                class="mb-5 min-h-[18rem] rounded-[var(--radius-lg)] bg-cover bg-center"
                style={`background-image:url('${featuredNews.entry.gambarUtama}')`}
              />
            )}
            <div class="flex flex-col gap-4">
              <div class="flex flex-wrap items-center gap-3">
                <a class="badge badge-primary badge-outline" href={`/berita/kategori/${featuredNews.entry.kategori}`}>
                  {categoryLabels[featuredNews.entry.kategori] ?? featuredNews.entry.kategori}
                </a>
                <time class="text-sm font-medium text-slate-500" datetime={featuredNews.entry.tanggal}>
                  {formatTanggal(featuredNews.entry.tanggal)}
                </time>
              </div>
              <h2 class="section-title font-extrabold text-slate-950">{featuredNews.entry.judul}</h2>
              <p class="text-body-lg text-slate-600">{featuredNews.entry.ringkasan}</p>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <a class="brand-button btn rounded-[var(--radius-md)]" href={`/berita/${featuredNews.slug}`}>
                  Baca artikel
                </a>
              </div>
            </div>
          </article>
        )}

        <div class="grid gap-4">
          {newsList.map(({ slug, entry }) => (
            <article class="surface-card flex flex-col gap-3 p-5">
              <div class="flex flex-wrap items-center gap-3">
                <a class="badge badge-primary badge-outline" href={`/berita/kategori/${entry.kategori}`}>
                  {categoryLabels[entry.kategori] ?? entry.kategori}
                </a>
                <time class="text-sm font-medium text-slate-500" datetime={entry.tanggal}>{formatTanggal(entry.tanggal)}</time>
              </div>
              <h3 class="card-title font-bold text-slate-950">{entry.judul}</h3>
              <p class="text-body-md text-slate-600">{entry.ringkasan}</p>
              <a class="btn btn-sm w-fit rounded-[var(--radius-md)]" href={`/berita/${slug}`}>
                Baca ringkas
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <SectionHeading
        title={galeriSection?.title ?? 'Galeri pilihan'}
        description={galeriSection?.description ?? 'Dokumentasi visual tetap hadir di beranda, tetapi dibuat lebih ringkas agar fokus utama tetap pada informasi warga.'}
        href="/galeri"
        linkLabel={galeriSection?.ctaLabel ?? 'Buka galeri lengkap'}
      />
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {galeri.map(({ entry }) => (
          <article class="surface-card flex flex-col gap-4 p-5">
            {entry.gambar && (
              <div
                class="min-h-44 rounded-[var(--radius-lg)] bg-cover bg-center"
                style={`background-image:url('${entry.gambar}')`}
              />
            )}
            <div class="flex flex-col items-start gap-3">
              <h3 class="card-title font-bold text-slate-950">{entry.judul}</h3>
              <p class="text-body-md text-slate-600">{entry.caption}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="surface-card flex flex-col gap-5 p-6 md:flex-row md:items-center md:justify-between md:p-7">
        <div class="space-y-3">
          <span class="badge badge-outline w-fit">{penutupSection?.eyebrow ?? 'Lanjutkan pencarian informasi'}</span>
          <h2 class="section-title font-extrabold text-slate-950">
            {penutupSection?.title ?? 'Butuh data kampung atau ingin menghubungi layanan warga?'}
          </h2>
          <p class="max-w-3xl text-body-lg text-slate-600">
            {penutupSection?.description ??
              'Beranda ini dibuat sebagai pintu masuk. Untuk eksplorasi lebih lanjut, gunakan katalog data kampung atau langsung menuju halaman kontak resmi.'}
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a class="brand-button btn rounded-[var(--radius-md)]" href={penutupSection?.primaryCtaHref ?? '/data'}>
            {penutupSection?.primaryCtaLabel ?? 'Buka data kampung'}
          </a>
          <a class="btn btn-outline rounded-[var(--radius-md)]" href={penutupSection?.secondaryCtaHref ?? '/kontak'}>
            {penutupSection?.secondaryCtaLabel ?? 'Kontak & layanan'}
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
