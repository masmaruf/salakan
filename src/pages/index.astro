---
import MainLayout from '../layouts/MainLayout.astro';
import CmsIcon from '../components/CmsIcon.astro';
import SectionHeading from '../components/SectionHeading.astro';
import {
  getBeranda,
  getGaleri,
  getKegiatan,
  getPengaturan,
  getPengumuman,
  getProfil,
  getKategoriBeritaMap,
  formatTanggal,
  sortByDateDesc,
} from '../lib/keystatic';

const [categoryLabels, profil, pengaturan, beranda, pengumumanItems, kegiatanItems, galeriItems] = await Promise.all([
  getKategoriBeritaMap(),
  getProfil(),
  getPengaturan(),
  getBeranda(),
  getPengumuman(),
  getKegiatan(),
  getGaleri(),
]);

const pengumuman = sortByDateDesc(
  pengumumanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
)
  .sort((a, b) => Number(b.entry.unggulan) - Number(a.entry.unggulan))
  .slice(0, 4);

const featuredPengumuman = pengumuman[0];
const secondaryPengumuman = pengumuman.slice(1, 4);

const kegiatan = sortByDateDesc(
  kegiatanItems
    .filter((item) => item.entry?.statusPublikasi === 'publish')
    .map((item) => ({ slug: item.slug, entry: item.entry! }))
);

const featuredNews = kegiatan[0];
const newsList = kegiatan.filter((item) => item.slug !== featuredNews?.slug).slice(0, 3);

const galeri = sortByDateDesc(
  galeriItems.map((item) => ({ slug: item.slug, entry: item.entry! }))
).slice(0, 3);

const heroSection = beranda?.hero;
const quickLinks = (heroSection?.panelLinks ?? []).filter((item) => item.status === 'tampil');
const pengumumanSection = beranda?.pengumuman;
const beritaSection = beranda?.berita;
const galeriSection = beranda?.galeri;
const penutupSection = beranda?.penutup;

const heroStats = [
  { label: heroSection?.stats?.pengumumanLabel ?? 'Pengumuman aktif', value: `${pengumuman.length}` },
  { label: heroSection?.stats?.kegiatanLabel ?? 'Berita terdokumentasi', value: `${kegiatan.length}` },
  { label: heroSection?.stats?.galeriLabel ?? 'Galeri tersedia', value: `${galeriItems.length}` },
];
---

<MainLayout>
  {/* Hero Section Borderless dengan Ornamen Gradasi Besar */}
  <section class="relative overflow-hidden bg-slate-50 pb-16 pt-20 md:pb-24 md:pt-28">
    
    {/* Ornamen Bola Gradasi Dekoratif (Graphics/Gradients) */}
    <div class="absolute -top-40 -right-40 h-[600px] w-[600px] rounded-full bg-blue-300/30 blur-[120px] pointer-events-none"></div>
    <div class="absolute top-20 -left-64 h-[500px] w-[500px] rounded-full bg-emerald-200/20 blur-[100px] pointer-events-none"></div>

    <div class="container relative z-10 grid gap-12 lg:grid-cols-[minmax(0,1.1fr)_minmax(340px,0.9fr)] lg:items-center">
      <div class="flex flex-col items-start gap-6 py-6">
        <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1.5 text-xs font-bold tracking-wide shadow-sm text-blue-700 uppercase ring-1 ring-slate-100">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-600"></span>
          </span>
          {heroSection?.eyebrow ?? 'Portal Resmi Padukuhan'}
        </span>
        
        {/* Teks dengan efek Gradasi (Gradient Text) */}
        <h1 class="max-w-[14ch] text-5xl font-extrabold leading-[1.1] tracking-tight bg-gradient-to-br from-slate-900 via-blue-900 to-blue-700 bg-clip-text text-transparent md:text-6xl lg:text-7xl drop-shadow-sm">
          {heroSection?.title ?? 'Pusat Informasi Warga Salakan'}
        </h1>
        <p class="max-w-xl text-lg leading-relaxed text-slate-600 md:text-xl font-medium">
          {heroSection?.intro ??
            pengaturan?.sambutanBeranda ??
            'Sistem informasi terpadu yang menyajikan pengumuman, agenda, dokumentasi, dan pelayanan administrasi secara transparan.'}
        </p>
        <div class="mt-4 flex flex-wrap gap-4">
          <a class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-gradient-to-b from-blue-500 to-blue-700 px-8 text-sm font-bold text-white shadow-[0_8px_20px_rgb(37,99,235,0.25)] hover:shadow-[0_8px_30px_rgb(37,99,235,0.4)] transition-all hover:-translate-y-0.5" href={heroSection?.primaryCtaHref ?? '/data/pengumuman'}>
            <span class="material-symbols-outlined text-[18px]">touch_app</span>
            {heroSection?.primaryCtaLabel ?? 'Layanan Warga'}
          </a>
          <a class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-white px-8 text-sm font-bold text-slate-700 shadow-sm hover:shadow-md transition-all hover:bg-slate-50" href={heroSection?.secondaryCtaHref ?? '/profil'}>
            <span class="material-symbols-outlined text-[18px]">account_balance</span>
            {heroSection?.secondaryCtaLabel ?? 'Profil Desa'}
          </a>
        </div>
        
        <div class="mt-4 flex w-full items-center gap-8 pt-8">
          {heroStats.map((stat) => (
            <div class="flex flex-col items-start relative group">
              <strong class="text-3xl font-black bg-gradient-to-r from-blue-600 to-emerald-500 bg-clip-text text-transparent">{stat.value}</strong>
              <span class="mt-1 text-[0.7rem] font-bold text-slate-400 uppercase tracking-widest">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <aside class="flex flex-col gap-4 relative">
        <div class="absolute -right-10 top-1/2 -z-10 h-64 w-64 -translate-y-1/2 rounded-full bg-gradient-to-br from-blue-400/20 to-purple-400/20 blur-3xl"></div>
        {quickLinks.map((item, id) => (
          <a class="group relative flex items-center gap-5 rounded-2xl bg-white/80 backdrop-blur p-5 shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all hover:shadow-[0_20px_40px_rgb(0,0,0,0.08)] hover:-translate-y-1" href={item.href}>
             <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-blue-50 to-emerald-50 text-blue-600 group-hover:from-blue-600 group-hover:to-blue-500 group-hover:text-white transition-all shadow-inner">
               <CmsIcon name={item.icon} class="size-7" />
             </div>
             <div class="flex flex-col">
               <strong class="text-lg font-bold text-slate-900 group-hover:text-blue-700 transition-colors">{item.title}</strong>
               <span class="mt-0.5 text-sm font-medium text-slate-500 line-clamp-1">{item.description}</span>
             </div>
             <div class="ml-auto opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-blue-600">
                <span class="material-symbols-outlined">arrow_forward_ios</span>
             </div>
          </a>
        ))}
      </aside>
    </div>
  </section>

  <section class="section bg-white relative" id="pengumuman-prioritas">
    <div class="container py-16 md:py-24">
      <div class="mb-12 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 md:text-5xl flex items-center gap-4">
             <span class="grid h-12 w-12 place-items-center bg-amber-100 text-amber-600 rounded-2xl">
               <span class="material-symbols-outlined text-[28px]">campaign</span>
             </span>
             {pengumumanSection?.title ?? 'Pengumuman Resmi'}
          </h2>
          <p class="mt-4 max-w-2xl text-lg font-medium text-slate-500">{pengumumanSection?.description ?? 'Informasi penting terbaru langsung dari meja pengurus aparatur desa.'}</p>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-[1.5fr_1fr]">
        {featuredPengumuman && (
          <article class="group relative flex flex-col justify-between overflow-hidden rounded-3xl bg-amber-50 p-8 md:p-10 transition-all hover:shadow-[0_24px_54px_rgb(251,191,36,0.15)] hover:-translate-y-1">
             <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-9xl text-amber-600">notifications_active</span>
             </div>
             <div class="relative z-10">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-200/60 px-3 py-1 text-xs font-bold text-amber-900 uppercase tracking-wider backdrop-blur">
                  <span class="h-2 w-2 rounded-full bg-amber-600 animate-pulse"></span>
                  Pengumuman Prioritas
                </span>
                <h3 class="mt-6 text-3xl font-extrabold leading-[1.2] tracking-tight text-slate-900 md:text-4xl group-hover:text-blue-800 transition-colors">
                  <a href={`/pengumuman/${featuredPengumuman.slug}`}>
                    <span class="absolute inset-0"></span>
                    {featuredPengumuman.entry.judul}
                  </a>
                </h3>
                <p class="mt-5 text-lg font-medium leading-relaxed text-slate-700 max-w-2xl line-clamp-3">
                  {featuredPengumuman.entry.ringkasan}
                </p>
             </div>
             <div class="relative z-10 mt-10 flex items-center justify-between">
                <time class="flex items-center gap-2 text-sm font-bold text-slate-500 bg-white/60 px-4 py-2 rounded-full" datetime={featuredPengumuman.entry.tanggal}>
                  <span class="material-symbols-outlined text-[16px]">calendar_today</span>
                  {formatTanggal(featuredPengumuman.entry.tanggal)}
                </time>
                <a class="flex items-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-bold text-blue-700 shadow-sm transition hover:shadow-md hover:scale-105" href="/data/pengumuman">
                  {pengumumanSection?.ctaLabel ?? 'Baca Selengkapnya'} <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
             </div>
          </article>
        )}

        <div class="flex flex-col gap-4">
          {secondaryPengumuman.map(({ entry, slug }) => (
            <article class="group flex flex-col justify-center rounded-2xl bg-slate-50/50 p-6 transition-all hover:bg-white hover:shadow-[0_12px_30px_rgb(0,0,0,0.06)] hover:-translate-y-1">
               <time class="flex items-center gap-1.5 text-xs font-bold text-blue-600 mb-2" datetime={entry.tanggal}>
                  <span class="material-symbols-outlined text-[14px]">event</span>
                  {formatTanggal(entry.tanggal)}
               </time>
               <h4 class="text-lg font-bold leading-snug text-slate-900 group-hover:text-blue-700 transition-colors line-clamp-2">
                 <a href={`/pengumuman/${slug}`}>
                   <span class="absolute inset-0"></span>
                   {entry.judul}
                 </a>
               </h4>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-slate-50/80 relative" id="berita-editorial">
    <div class="absolute inset-x-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-slate-200 to-transparent"></div>
    <div class="container py-16 md:py-24">
      <SectionHeading
        title={beritaSection?.title ?? 'Liputan Kegiatan Warga'}
        description={beritaSection?.description ?? 'Kabar terbaru, kegiatan gotong royong, dan dokumentasi program berkelanjutan kemasyarakatan.'}
        href="/berita"
        linkLabel={beritaSection?.ctaLabel ?? 'Indeks Berita Lengkap'}
      />
      
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 mt-12">
        {kegiatan.slice(0, 3).map(({ slug, entry }) => (
          <article class="group flex flex-col overflow-hidden rounded-[2rem] bg-white shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all hover:shadow-[0_24px_50px_rgb(0,0,0,0.08)] hover:-translate-y-2">
            {entry.gambarUtama ? (
              <div class="h-56 w-full overflow-hidden relative">
                <img src={entry.gambarUtama} alt={entry.judul} class="h-full w-full object-cover transition duration-700 group-hover:scale-110" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent"></div>
                <span class="absolute bottom-4 left-4 rounded-full bg-blue-600/90 px-3 py-1.5 text-[0.65rem] font-bold text-white uppercase tracking-wider backdrop-blur shadow-sm">
                  {categoryLabels[entry.kategori] ?? entry.kategori}
                </span>
              </div>
            ) : (
              <div class="h-56 w-full bg-gradient-to-br from-slate-100 to-slate-50 flex items-center justify-center relative">
                 <span class="material-symbols-outlined text-6xl text-slate-300">image</span>
                 <span class="absolute bottom-4 left-4 rounded-full bg-blue-600/90 px-3 py-1.5 text-[0.65rem] font-bold text-white uppercase tracking-wider backdrop-blur shadow-sm">
                   {categoryLabels[entry.kategori] ?? entry.kategori}
                 </span>
              </div>
            )}
            <div class="flex flex-1 flex-col p-6 md:p-8">
              <time class="flex items-center gap-1.5 text-xs font-bold text-slate-400" datetime={entry.tanggal}>
                {formatTanggal(entry.tanggal)}
              </time>
              <h3 class="mt-3 text-xl font-extrabold leading-snug tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors line-clamp-3">
                 <a href={`/berita/${slug}`} class="focus:outline-none">
                   <span class="absolute inset-0" aria-hidden="true" />
                   {entry.judul}
                 </a>
              </h3>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section relative overflow-hidden bg-white text-center">
    <div class="absolute inset-x-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-slate-200 to-transparent"></div>
    <div class="absolute bottom-0 left-1/2 -z-10 h-[400px] w-full max-w-3xl -translate-x-1/2 rounded-full bg-gradient-to-t from-blue-100/40 to-transparent blur-[100px]"></div>

    <div class="container py-20 md:py-32">
      <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-3xl bg-blue-50 text-blue-600 shadow-inner mb-8">
         <span class="material-symbols-outlined text-4xl">admin_panel_settings</span>
      </div>
      <h2 class="mx-auto max-w-4xl text-4xl font-black tracking-tight text-slate-900 md:text-5xl lg:text-5xl">
        {penutupSection?.title ?? 'Butuh Pelayanan Administrasi Warga?'}
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-xl font-medium text-slate-500">
        {penutupSection?.description ?? 'Gunakan portal terpadu untuk mengajukan dokumen RT/RW dengan cepat dan aman secara digital tanpa antre.'}
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a class="inline-flex h-14 items-center justify-center gap-2 rounded-full bg-slate-900 px-8 text-base font-bold text-white shadow-xl hover:bg-blue-700 hover:shadow-2xl hover:-translate-y-1 transition-all" href={penutupSection?.primaryCtaHref ?? '/dasbor'}>
          <span class="material-symbols-outlined">login</span>
          {penutupSection?.primaryCtaLabel ?? 'Login Portal Warga'}
        </a>
        <a class="inline-flex h-14 items-center justify-center gap-2 rounded-full bg-blue-50 px-8 text-base font-bold text-blue-700 shadow-sm hover:bg-blue-100 transition-colors" href={penutupSection?.secondaryCtaHref ?? '/kontak'}>
          <span class="material-symbols-outlined">support_agent</span>
          {penutupSection?.secondaryCtaLabel ?? 'Hubungi Pengurus'}
        </a>
      </div>
    </div>
  </section>
</MainLayout>
