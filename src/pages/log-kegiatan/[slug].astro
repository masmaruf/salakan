---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import BadgeList from '../../components/ui/BadgeList.astro';
import InfoCard from '../../components/ui/InfoCard.astro';
import ActionLinkButton from '../../components/ui/ActionLinkButton.astro';
import RelatedContentSection from '../../components/ui/RelatedContentSection.astro';
import {
  getAgenda,
  getGaleri,
  getKegiatan,
  getKategoriBeritaMap,
  getLogKegiatan,
  getProgram,
  getStrukturOrganisasi,
} from '../../lib/content';
import {
  createAgendaRelationItem,
  createBeritaRelationItem,
  createGaleriRelationItem,
  createLembagaRelationItem,
  createLogRelationItem,
  createProgramRelationItem,
} from '../../lib/content-relations';
import { kategoriLogLabels, statusPublikasiLogLabels } from '../../lib/log-kegiatan';
import { findRelatedContent } from '../../lib/related-content';
import { renderMarkdown } from '../../lib/rich-text';
import { resolveSeoText, withSiteTitle } from '../../lib/site';

const { slug } = Astro.params;
const [items, agendaItems, beritaItems, programItems, lembagaItems, galeriItems, categoryLabels] = await Promise.all([
  getLogKegiatan(),
  getAgenda(),
  getKegiatan(),
  getProgram(),
  getStrukturOrganisasi(),
  getGaleri(),
  getKategoriBeritaMap(),
]);

const item = items.find((entry) => entry.slug === slug && entry.entry.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/log-kegiatan');
}

const { entry } = item;
const waktuLabel = entry.waktuMulai && entry.waktuSelesai
  ? `${entry.waktuMulai} - ${entry.waktuSelesai} WIB`
  : entry.waktuMulai
    ? `${entry.waktuMulai} WIB`
    : entry.waktuSelesai
      ? `Selesai ${entry.waktuSelesai} WIB`
      : '';

const relatedItems = findRelatedContent(
  createLogRelationItem(item),
  [
    ...agendaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createAgendaRelationItem),
    ...beritaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => createBeritaRelationItem(candidate, categoryLabels)),
    ...programItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createProgramRelationItem),
    ...items
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLogRelationItem),
    ...lembagaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLembagaRelationItem),
    ...galeriItems.map(createGaleriRelationItem),
  ],
  4,
);
---

<MainLayout
  title={withSiteTitle(resolveSeoText(entry.judul, 'Log Kegiatan Dukuh'))}
  description={resolveSeoText(entry.ringkasan, entry.hasilTindakLanjut)}
>
  <article class="container-premium max-w-4xl py-6 sm:py-8">
    <Breadcrumbs
      items={[
        { label: 'Beranda', href: '/' },
        { label: 'Log Kegiatan', href: '/log-kegiatan' },
        { label: entry.judul, active: true },
      ]}
    />

    <header class="mb-6">
      <BadgeList
        class="mb-3 flex flex-wrap gap-2"
        items={[
          { label: kategoriLogLabels[entry.kategori], tone: 'surface' },
          { label: statusPublikasiLogLabels[entry.statusPublikasi], tone: 'success' },
        ]}
      />
      <h1 class="text-2xl font-bold leading-tight tracking-tight text-base-content sm:text-3xl">
        {entry.judul}
      </h1>
      <p class="mt-3 text-base leading-relaxed text-base-content/70">{entry.ringkasan}</p>

      <ContentMeta
        class="mt-4 flex flex-wrap gap-x-5 gap-y-2 border-t border-base-300/70 pt-4"
        items={[
          { icon: 'calendar_today', text: new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(entry.tanggal)), datetime: entry.tanggal, accentClass: 'text-base-content/70' },
          ...(waktuLabel ? [{ icon: 'schedule', text: waktuLabel, accentClass: 'text-base-content/70' }] : []),
          ...(entry.lokasi ? [{ icon: 'location_on', text: entry.lokasi, accentClass: 'text-base-content/70' }] : []),
          ...(entry.pihakTerlibat ? [{ icon: 'group', text: entry.pihakTerlibat, accentClass: 'text-base-content/70' }] : []),
        ]}
        iconClass="text-[16px] text-primary"
      />
    </header>

    <div class="grid gap-5 lg:grid-cols-[1.15fr_0.85fr]">
      <InfoCard title="Ringkasan Kegiatan" class="card border border-base-300/70 bg-base-100 shadow-sm">
        <div class="article-rich text-base leading-relaxed text-base-content/75" set:html={renderMarkdown(entry.ringkasan)} />
        {entry.hasilTindakLanjut && (
          <div class="mt-5 rounded-2xl border border-emerald-100 bg-emerald-50/80 p-4">
            <p class="detail-label text-emerald-700">Hasil atau tindak lanjut</p>
            <div class="article-rich mt-3 text-sm leading-relaxed text-emerald-950" set:html={renderMarkdown(entry.hasilTindakLanjut)} />
          </div>
        )}
      </InfoCard>

      <div class="grid gap-4">
        {entry.fotoDokumentasi && (
          <InfoCard title="Dokumentasi" class="card border border-base-300/70 bg-base-100 shadow-sm">
            <img
              src={entry.fotoDokumentasi}
              alt={`Dokumentasi ${entry.judul}`}
              class="h-64 w-full rounded-2xl object-cover"
              loading="eager"
            />
          </InfoCard>
        )}
        <InfoCard title="Rangkuman Operasional" class="card border border-base-300/70 bg-base-100 shadow-sm">
          <dl class="grid gap-3 text-sm text-base-content/70">
            <div>
              <dt class="detail-label">Kategori</dt>
              <dd class="mt-1 font-medium text-base-content">{kategoriLogLabels[entry.kategori]}</dd>
            </div>
            <div>
              <dt class="detail-label">Lokasi</dt>
              <dd class="mt-1 font-medium text-base-content">{entry.lokasi || 'Menyesuaikan lokasi layanan atau kegiatan'}</dd>
            </div>
            <div>
              <dt class="detail-label">Pihak terlibat</dt>
              <dd class="mt-1 font-medium text-base-content">{entry.pihakTerlibat || 'Koordinasi internal padukuhan'}</dd>
            </div>
          </dl>
        </InfoCard>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap gap-3 border-t border-base-300/70 pt-5">
      <ActionLinkButton href="/log-kegiatan" label="Kembali ke log kegiatan" icon="arrow_back" />
      <ActionLinkButton href="/data" label="Buka pusat data" icon="grid_view" />
    </div>
  </article>

  <RelatedContentSection
    title="Konten Terkait Log Ini"
    actionHref="/log-kegiatan"
    actionLabel="Lihat semua log"
    items={relatedItems}
  />
</MainLayout>
