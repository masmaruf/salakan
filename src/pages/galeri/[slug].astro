---
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import Badge from '../../components/ui/Badge.astro';
import Icon from '../../components/ui/Icon.tsx';
import { formatTanggal, getGaleri, sortByDateDesc } from '../../lib/content';
import { resolveSeoText, withSiteTitle } from '../../lib/site';

const { slug } = Astro.params;
const galeriItems = sortByDateDesc(
  (await getGaleri()).map((item) => ({
    slug: item.slug,
    entry: item.entry!,
  })),
);

const item = galeriItems.find((candidate) => candidate.slug === slug);

if (!item) {
  return Astro.redirect('/galeri');
}

const { entry } = item;
const description = resolveSeoText(entry.deskripsi, entry.caption);
const descriptionParagraphs = description
  .split(/\n+/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
const relatedItems = galeriItems.filter((candidate) => candidate.slug !== item.slug).slice(0, 3);
---

<MainLayout
  title={withSiteTitle(entry.judul)}
  description={description}
  image={entry.gambar}
>
  <article class="container-premium max-w-5xl py-6 sm:py-8">
    <Breadcrumbs items={[
      { label: 'Beranda', href: '/' },
      { label: 'Galeri', href: '/galeri' },
      { label: entry.judul, active: true },
    ]} />

    <header class="card border border-base-300/70 bg-base-100 shadow-sm">
      <div class="card-body gap-4 p-5 sm:p-6">
        <div class="flex flex-wrap items-center gap-2">
          <Badge label="Galeri" tone="primary" />
          <Badge label={formatTanggal(entry.tanggal)} tone="surface" variant="ghost" />
        </div>

        <div class="max-w-3xl">
          <h1 class="text-2xl font-bold leading-tight tracking-tight text-base-content sm:text-3xl md:text-4xl">
            {entry.judul}
          </h1>
          <p class="mt-3 text-base leading-relaxed text-base-content/70 sm:text-lg">
            {entry.caption}
          </p>
        </div>

        <ContentMeta
          class="flex flex-wrap gap-x-5 gap-y-2 border-t border-base-300/70 pt-4"
          iconClass="text-[18px] text-primary"
          items={[{ icon: 'calendar_today', text: formatTanggal(entry.tanggal), datetime: entry.tanggal, accentClass: 'text-base-content/70' }]}
        />
      </div>
    </header>

    {entry.gambar && (
      <div class="card mt-6 overflow-hidden border border-base-300/70 bg-base-100 shadow-sm">
        <Image
          src={entry.gambar}
          alt={entry.judul}
          width={1280}
          height={960}
          loading="eager"
          class="h-auto w-full object-cover"
        />
      </div>
    )}

    <div class="mt-6 grid gap-5 lg:grid-cols-[1fr_20rem]">
      <section class="card border border-base-300/70 bg-base-100 shadow-sm">
        <div class="card-body p-5 sm:p-6">
          <p class="section-kicker">Deskripsi Dokumentasi</p>
          <div class="mt-3 space-y-4 text-base leading-relaxed text-base-content/75">
            {descriptionParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      </section>

      <aside class="card h-fit border border-primary/20 bg-primary/5 shadow-sm">
        <div class="card-body p-5">
          <p class="section-kicker">Dokumentasi Lengkap</p>
          <h2 class="mt-2 text-lg font-bold text-base-content">Buka folder Google Drive</h2>
          <p class="mt-2 text-sm leading-relaxed text-base-content/70">
            Foto lengkap disimpan di Google Drive agar arsip kegiatan tetap rapi dan mudah dibagikan.
          </p>
          {entry.googleDriveUrl ? (
            <a
              href={entry.googleDriveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary mt-4 w-full rounded-full"
            >
              <Icon name="folder_open" class="text-[18px]" />
              Buka Google Drive
            </a>
          ) : (
            <div class="alert alert-warning mt-4 text-sm">
              <Icon name="info" class="text-[18px]" />
              <span>Tautan Google Drive belum tersedia untuk dokumentasi ini.</span>
            </div>
          )}
          <a href="/galeri" class="btn btn-outline btn-primary mt-2 w-full rounded-full">
            <Icon name="arrow_back" class="text-[18px]" />
            Kembali ke Galeri
          </a>
        </div>
      </aside>
    </div>
  </article>

  {relatedItems.length > 0 && (
    <section class="container-premium pb-10">
      <div class="border-t border-base-300/70 pt-6">
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="section-kicker">Galeri Lainnya</p>
            <h2 class="mt-1 text-xl font-bold text-base-content">Dokumentasi terkait</h2>
          </div>
          <a href="/galeri" class="btn btn-outline btn-primary btn-sm rounded-full">Lihat semua</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          {relatedItems.map(({ slug: relatedSlug, entry: relatedEntry }) => (
            <a href={`/galeri/${relatedSlug}`} class="card border border-base-300/70 bg-base-100 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
              <div class="card-body p-4">
                <time class="text-xs font-semibold text-base-content/60" datetime={relatedEntry.tanggal}>{formatTanggal(relatedEntry.tanggal)}</time>
                <h3 class="mt-2 text-sm font-bold leading-snug text-base-content">{relatedEntry.judul}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</MainLayout>
