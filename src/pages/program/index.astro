---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PageSection from '../../components/PageSection.astro';
import BadgeList from '../../components/ui/BadgeList.astro';
import StatCard from '../../components/ui/StatCard.astro';
import EmptyStateCard from '../../components/ui/EmptyStateCard.astro';
import ActionLinkButton from '../../components/ui/ActionLinkButton.astro';
import MetricGrid from '../../components/ui/MetricGrid.astro';
import {
  formatTanggal,
  getPengaturan,
  getProgram,
} from '../../lib/content';
import { kategoriLabelsProgram, statusProgramLabels, tahapProgramLabels } from '../../lib/content-taxonomy';
import { excerptMarkdown, markdownToText } from '../../lib/rich-text';
import { resolveSeoImage, resolveSeoText, withSiteTitle } from '../../lib/site';

const [pengaturan, items] = await Promise.all([getPengaturan(), getProgram()]);
const programSeo = pengaturan?.seoHalamanData?.program;

const statusToneMap = {
  rencana: 'warning',
  berjalan: 'primary',
  selesai: 'success',
} as const;

const tahapToneMap = {
  inisiasi: 'surface',
  persiapan: 'warning',
  pelaksanaan: 'primary',
  pemantauan: 'info',
  tuntas: 'success',
} as const;

const programs = items
  .filter((item) => item.entry?.statusPublikasi === 'publish')
  .sort((a, b) => {
    const featuredDiff = Number(b.entry.unggulan) - Number(a.entry.unggulan);
    if (featuredDiff !== 0) return featuredDiff;

    const statusWeight = { berjalan: 0, rencana: 1, selesai: 2 } as const;
    const statusDiff =
      statusWeight[a.entry.statusProgram as keyof typeof statusWeight] -
      statusWeight[b.entry.statusProgram as keyof typeof statusWeight];
    if (statusDiff !== 0) return statusDiff;

    return (a.entry.urutanTampil ?? 0) - (b.entry.urutanTampil ?? 0);
  });

const featuredProgram = programs.find((item) => item.entry.unggulan) ?? programs[0] ?? null;

const stats = {
  total: programs.length,
  berjalan: programs.filter((item) => item.entry.statusProgram === 'berjalan').length,
  selesai: programs.filter((item) => item.entry.statusProgram === 'selesai').length,
};
---

<MainLayout
  title={withSiteTitle(resolveSeoText(programSeo?.seoTitle, 'Program Warga'))}
  description={resolveSeoText(programSeo?.seoDescription, 'Pantau program kerja, pembangunan, dan tindak lanjut layanan warga Padukuhan Salakan.')}
  image={resolveSeoImage(programSeo?.ogImage)}
>
  <PageHero
    eyebrow="Transparansi Publik"
    icon="timeline"
    title="Program warga yang sedang berjalan bisa dipantau dari satu halaman"
    description="Halaman ini merangkum program kerja, pembangunan, dan perbaikan layanan yang sedang dikerjakan agar warga lebih mudah mengikuti arah tindak lanjut padukuhan."
  />

  <section class="container-premium py-6 sm:py-8">
    <div class="grid gap-4 md:grid-cols-3">
      <StatCard label="Total Program" value={stats.total} icon="timeline" variant="blue" description="Program yang sedang ditayangkan untuk dipantau warga." />
      <StatCard label="Sedang Berjalan" value={stats.berjalan} icon="pending_actions" variant="amber" description="Fase kerja aktif yang masih membutuhkan perhatian pelaksanaan." />
      <StatCard label="Selesai" value={stats.selesai} icon="task_alt" variant="emerald" description="Program yang sudah dituntaskan dan bisa dilihat hasil ringkasnya." />
    </div>
  </section>

  {featuredProgram && (
    <PageSection sectionClass="py-8 sm:py-10" title="Sorotan Utama" eyebrow="Program Prioritas">
      <article class="section-card grid gap-5 p-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div>
          <BadgeList
            items={[
              { label: kategoriLabelsProgram[featuredProgram.entry.kategori as keyof typeof kategoriLabelsProgram], tone: 'surface' },
              { label: statusProgramLabels[featuredProgram.entry.statusProgram as keyof typeof statusProgramLabels], tone: statusToneMap[featuredProgram.entry.statusProgram as keyof typeof statusToneMap] },
              { label: tahapProgramLabels[featuredProgram.entry.tahapProgram as keyof typeof tahapProgramLabels], tone: tahapToneMap[featuredProgram.entry.tahapProgram as keyof typeof tahapToneMap] },
            ]}
          />
          <h2 class="mt-4 text-2xl font-bold tracking-tight text-on-surface sm:text-3xl">{featuredProgram.entry.judul}</h2>
          <p class="mt-3 text-base leading-relaxed text-on-surface-variant">{featuredProgram.entry.ringkasan}</p>
          {featuredProgram.entry.targetHasilSingkat && (
            <div class="mt-4 rounded-2xl border border-outline-variant/50 bg-surface-container-low px-4 py-4">
              <p class="section-kicker-muted text-[11px] tracking-[0.12em] text-outline">Target hasil</p>
              <p class="mt-2 text-sm leading-relaxed text-on-surface">{featuredProgram.entry.targetHasilSingkat}</p>
            </div>
          )}
          <p class="mt-4 text-sm leading-relaxed text-on-surface-variant">{excerptMarkdown(featuredProgram.entry.deskripsi, 280)}</p>
        </div>

        <div class="grid gap-3">
          <MetricGrid
            class="grid gap-3"
            items={[
              { label: 'Lokasi', value: featuredProgram.entry.lokasi },
              { label: 'Periode', value: featuredProgram.entry.periode },
              { label: 'Tahap saat ini', value: tahapProgramLabels[featuredProgram.entry.tahapProgram as keyof typeof tahapProgramLabels] },
              { label: 'Pembaruan Terakhir', value: formatTanggal(featuredProgram.entry.tanggalUpdate) },
            ]}
          />
          <div class="pt-1">
            <ActionLinkButton href={`/program/${featuredProgram.slug}`} label="Lihat detail program" icon="arrow_forward" variant="primary" />
          </div>
        </div>
      </article>
    </PageSection>
  )}

  <PageSection sectionClass="py-8 sm:py-10" title="Daftar Program" eyebrow="Ringkasan Pelaksanaan">
    {programs.length > 0 ? (
      <div class="grid gap-4 lg:grid-cols-2">
        {programs.map((item) => (
          <a
            href={`/program/${item.slug}`}
            class="group section-card section-card-hover rounded-2xl p-5 sm:p-5"
          >
            <BadgeList
              items={[
                { label: kategoriLabelsProgram[item.entry.kategori as keyof typeof kategoriLabelsProgram], tone: 'surface' },
                { label: statusProgramLabels[item.entry.statusProgram as keyof typeof statusProgramLabels], tone: statusToneMap[item.entry.statusProgram as keyof typeof statusToneMap] },
                { label: tahapProgramLabels[item.entry.tahapProgram as keyof typeof tahapProgramLabels], tone: tahapToneMap[item.entry.tahapProgram as keyof typeof tahapToneMap] },
                { label: 'Prioritas', tone: 'info', visible: item.entry.unggulan },
              ]}
            />
            <h3 class="mt-4 text-lg font-bold leading-tight text-on-surface transition-colors group-hover:text-m3-primary">
              {item.entry.judul}
            </h3>
            <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-on-surface-variant">{item.entry.ringkasan}</p>
            {item.entry.targetHasilSingkat && (
              <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-on-surface">{item.entry.targetHasilSingkat}</p>
            )}
            <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-on-surface-variant">{markdownToText(item.entry.deskripsi)}</p>
            <div class="mt-4 grid gap-2 border-t border-outline-variant/50 pt-4 text-sm text-on-surface-variant sm:grid-cols-2">
              <div>
                <p class="section-kicker-muted text-[11px] tracking-[0.12em] text-outline">Lokasi</p>
                <p class="mt-1 line-clamp-2">{item.entry.lokasi}</p>
              </div>
              <div>
                <p class="section-kicker-muted text-[11px] tracking-[0.12em] text-outline">Periode</p>
                <p class="mt-1">{item.entry.periode}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <EmptyStateCard message="Belum ada program yang ditayangkan." />
    )}
  </PageSection>
</MainLayout>
