---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import InfoCard from '../../components/ui/InfoCard.astro';
import BadgeList from '../../components/ui/BadgeList.astro';
import ActionLinkButton from '../../components/ui/ActionLinkButton.astro';
import PageSection from '../../components/PageSection.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';
import {
  excerpt,
  formatTanggal,
  getAgenda,
  getHalamanCopy,
  getLogKegiatan,
  getProgram,
} from '../../lib/content';
import { kategoriLabelsProgram, kategoriLogLabels, statusProgramLabels, tahapProgramLabels } from '../../lib/content-taxonomy';
import { findRelatedContent } from '../../lib/related-content';
import { markdownToText, renderMarkdown } from '../../lib/rich-text';
import { resolveSeoText, withSiteTitle } from '../../lib/site';

const { slug } = Astro.params;
const [items, agendaItems, logItems] = await Promise.all([getProgram(), getAgenda(), getLogKegiatan()]);
const halaman = await getHalamanCopy();
const item = items.find((entry) => entry.slug === slug && entry.entry.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/program');
}

const { entry } = item;
const statusToneMap = {
  rencana: 'warning',
  berjalan: 'primary',
  selesai: 'success',
} as const;

const tahapToneMap = {
  inisiasi: 'surface',
  persiapan: 'warning',
  pelaksanaan: 'primary',
  pemantauan: 'info',
  tuntas: 'success',
} as const;

const relatedItems = findRelatedContent(
  {
    slug: item.slug,
    title: entry.judul,
    category: entry.kategori,
    tags: entry.tag ?? [],
    summary: entry.ringkasan,
    extraText: [markdownToText(entry.deskripsi), entry.lokasi, entry.penanggungJawab, ...(entry.manfaat ?? [])],
    date: entry.tanggalUpdate,
    href: `/program/${item.slug}`,
    typeLabel: kategoriLabelsProgram[entry.kategori as keyof typeof kategoriLabelsProgram],
    badgeTone: 'surface',
  },
  [
    ...agendaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => ({
        slug: candidate.slug,
        title: candidate.entry.judul,
        category: candidate.entry.label,
        tags: candidate.entry.tag ?? [],
        summary: candidate.entry.ringkasan,
        extraText: [markdownToText(candidate.entry.deskripsi), candidate.entry.lokasi ?? '', candidate.entry.kontakPic ?? ''],
        date: candidate.entry.tanggal,
        href: `/agenda/${candidate.slug}`,
        typeLabel: candidate.entry.label || 'Agenda',
        badgeTone: 'primary' as const,
      })),
    ...logItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => ({
        slug: candidate.slug,
        title: candidate.entry.judul,
        category: candidate.entry.kategori,
        tags: candidate.entry.tag ?? [],
        summary: candidate.entry.ringkasan,
        extraText: [candidate.entry.lokasi ?? '', candidate.entry.pihakTerlibat ?? '', candidate.entry.hasilTindakLanjut ?? ''],
        date: candidate.entry.tanggal,
        href: `/log-kegiatan?q=${encodeURIComponent(candidate.entry.judul)}`,
        typeLabel: kategoriLogLabels[candidate.entry.kategori as keyof typeof kategoriLogLabels],
        badgeTone: 'surface' as const,
      })),
  ],
  4,
);
---

<MainLayout
  title={withSiteTitle(resolveSeoText(entry.judul, 'Program Warga'))}
  description={resolveSeoText(entry.ringkasan, entry.deskripsi)}
>
  <article class="container-premium max-w-4xl py-6 sm:py-8">
    <Breadcrumbs
      items={[
        { label: 'Beranda', href: '/' },
        { label: 'Program', href: '/program' },
        { label: entry.judul, active: true },
      ]}
    />

    <header class="mb-6">
      <BadgeList
        class="mb-3 flex flex-wrap items-center gap-2"
        items={[
          { label: kategoriLabelsProgram[entry.kategori as keyof typeof kategoriLabelsProgram], tone: 'surface' },
          { label: statusProgramLabels[entry.statusProgram as keyof typeof statusProgramLabels], tone: statusToneMap[entry.statusProgram as keyof typeof statusToneMap] },
          { label: tahapProgramLabels[entry.tahapProgram as keyof typeof tahapProgramLabels], tone: tahapToneMap[entry.tahapProgram as keyof typeof tahapToneMap] },
          { label: halaman.programDetail.priorityLabel, tone: 'info', visible: entry.unggulan },
        ]}
      />

      <h1 class="text-2xl font-bold leading-tight tracking-tight text-on-surface sm:text-3xl">
        {entry.judul}
      </h1>
      <p class="mt-3 text-base leading-relaxed text-on-surface-variant">{entry.ringkasan}</p>

      <ContentMeta
        class="mt-4 flex flex-wrap gap-x-5 gap-y-2 border-t border-outline-variant/40 pt-4"
        items={[
          { icon: 'calendar_today', text: `${halaman.programDetail.updatedPrefix} ${formatTanggal(entry.tanggalUpdate)}`, datetime: entry.tanggalUpdate, accentClass: 'text-on-surface-variant' },
          { icon: 'location_on', text: entry.lokasi, accentClass: 'text-on-surface-variant' },
          { icon: 'person', text: entry.penanggungJawab, accentClass: 'text-on-surface-variant' },
          { icon: 'flag', text: tahapProgramLabels[entry.tahapProgram as keyof typeof tahapProgramLabels], accentClass: 'text-on-surface-variant' },
        ]}
        iconClass="text-[16px] text-m3-primary"
      />
    </header>

    <div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
      <InfoCard title={halaman.programDetail.summaryTitle} class="soft-panel">
        <div class="article-rich text-base leading-relaxed text-on-surface-variant" set:html={renderMarkdown(entry.deskripsi)} />
      </InfoCard>

      <div class="grid gap-4">
        <InfoCard title={halaman.programDetail.periodTitle} class="soft-panel">
          <p class="text-sm font-medium text-on-surface">{entry.periode}</p>
        </InfoCard>
        <InfoCard title={halaman.programDetail.fundingTitle} class="soft-panel">
          <p class="text-sm font-medium text-on-surface">{entry.sumberDana || '-'}</p>
        </InfoCard>
        <InfoCard title={halaman.programDetail.budgetTitle} class="soft-panel">
          <p class="text-sm font-medium text-on-surface">{entry.anggaran || halaman.programDetail.budgetFallback}</p>
        </InfoCard>
        <InfoCard title="Target Hasil" class="soft-panel">
          <p class="text-sm font-medium text-on-surface">{entry.targetHasilSingkat || 'Masih diperdalam bersama tim pelaksana.'}</p>
        </InfoCard>
      </div>
    </div>

    {entry.manfaat.length > 0 && (
      <InfoCard title={halaman.programDetail.benefitsTitle} class="soft-panel mt-5">
        <ul class="grid gap-3 text-sm leading-relaxed text-on-surface-variant sm:grid-cols-2">
          {entry.manfaat.map((point) => (
            <li class="rounded-xl border border-outline-variant/60 bg-white px-4 py-3">{point}</li>
          ))}
        </ul>
      </InfoCard>
    )}

    <div class="mt-8 flex flex-wrap gap-3 border-t border-outline-variant/40 pt-5">
      <ActionLinkButton href="/program" label={halaman.programDetail.backToProgramsLabel} icon="arrow_back" />
      <ActionLinkButton href="/data" label={halaman.programDetail.openDataCenterLabel} icon="grid_view" />
    </div>
  </article>

  {relatedItems.length > 0 && (
    <PageSection sectionClass="bg-surface-container-low/40 py-10" title="Data Terkait Program Ini" actionHref="/data" actionLabel="Buka pusat data">
      <div class="grid gap-4 lg:grid-cols-2">
        {relatedItems.map((related) => (
          <ArchiveCard
            href={related.href}
            title={related.title}
            summary={excerpt(related.summary || '', 140)}
            badges={[
              { label: related.typeLabel, tone: related.badgeTone ?? 'surface' },
            ]}
            meta={[
              ...(related.date ? [{ icon: 'calendar_today', text: formatTanggal(related.date), datetime: related.date }] : []),
            ]}
          />
        ))}
      </div>
    </PageSection>
  )}
</MainLayout>
