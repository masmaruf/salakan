---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import InfoCard from '../../components/ui/InfoCard.astro';
import Badge from '../../components/ui/Badge.astro';
import ActionLinkButton from '../../components/ui/ActionLinkButton.astro';
import {
  formatTanggal,
  getProgram,
  kategoriLabelsProgram,
  statusProgramLabels,
} from '../../lib/content';
import { resolveSeoText, withSiteTitle } from '../../lib/site';

const { slug } = Astro.params;
const items = await getProgram();
const item = items.find((entry) => entry.slug === slug && entry.entry.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/program');
}

const { entry } = item;
const statusToneMap = {
  rencana: 'warning',
  berjalan: 'primary',
  selesai: 'success',
} as const;
---

<MainLayout
  title={withSiteTitle(resolveSeoText(entry.judul, 'Program Warga'))}
  description={resolveSeoText(entry.ringkasan, entry.deskripsi)}
>
  <article class="container-premium max-w-4xl py-6 sm:py-8">
    <Breadcrumbs
      items={[
        { label: 'Beranda', href: '/' },
        { label: 'Program', href: '/program' },
        { label: entry.judul, active: true },
      ]}
    />

    <header class="mb-6">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <Badge label={kategoriLabelsProgram[entry.kategori as keyof typeof kategoriLabelsProgram]} tone="surface" />
        <Badge label={statusProgramLabels[entry.statusProgram as keyof typeof statusProgramLabels]} tone={statusToneMap[entry.statusProgram as keyof typeof statusToneMap]} />
        {entry.unggulan && <Badge label="Prioritas Warga" tone="info" />}
      </div>

      <h1 class="text-2xl font-bold leading-tight tracking-tight text-on-surface sm:text-3xl">
        {entry.judul}
      </h1>
      <p class="mt-3 text-base leading-relaxed text-on-surface-variant">{entry.ringkasan}</p>

      <ContentMeta
        class="mt-4 flex flex-wrap gap-x-5 gap-y-2 border-t border-outline-variant/40 pt-4"
        items={[
          { icon: 'calendar_today', text: `Diperbarui ${formatTanggal(entry.tanggalUpdate)}`, datetime: entry.tanggalUpdate, accentClass: 'text-on-surface-variant' },
          { icon: 'location_on', text: entry.lokasi, accentClass: 'text-on-surface-variant' },
          { icon: 'person', text: entry.penanggungJawab, accentClass: 'text-on-surface-variant' },
        ]}
        iconClass="text-[16px] text-m3-primary"
      />
    </header>

    <div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
      <InfoCard title="Ringkasan Pelaksanaan" class="rounded-xl border border-outline-variant bg-surface-container-low p-5">
        <p class="whitespace-pre-line text-base leading-relaxed text-on-surface-variant">{entry.deskripsi}</p>
      </InfoCard>

      <div class="grid gap-4">
        <InfoCard title="Periode" class="rounded-xl border border-outline-variant bg-surface-container-low p-5">
          <p class="text-sm font-medium text-on-surface">{entry.periode}</p>
        </InfoCard>
        <InfoCard title="Sumber Dana" class="rounded-xl border border-outline-variant bg-surface-container-low p-5">
          <p class="text-sm font-medium text-on-surface">{entry.sumberDana || '-'}</p>
        </InfoCard>
        <InfoCard title="Anggaran" class="rounded-xl border border-outline-variant bg-surface-container-low p-5">
          <p class="text-sm font-medium text-on-surface">{entry.anggaran || 'Belum dicantumkan'}</p>
        </InfoCard>
      </div>
    </div>

    {entry.manfaat.length > 0 && (
      <InfoCard title="Manfaat untuk Warga" class="mt-5 rounded-xl border border-outline-variant bg-surface-container-low p-5">
        <ul class="grid gap-3 text-sm leading-relaxed text-on-surface-variant sm:grid-cols-2">
          {entry.manfaat.map((point) => (
            <li class="rounded-xl border border-outline-variant/60 bg-white px-4 py-3">{point}</li>
          ))}
        </ul>
      </InfoCard>
    )}

    <div class="mt-8 flex flex-wrap gap-3 border-t border-outline-variant/40 pt-5">
      <ActionLinkButton href="/program" label="Kembali ke daftar program" icon="arrow_back" />
      <ActionLinkButton href="/data" label="Buka pusat data" icon="grid_view" />
    </div>
  </article>
</MainLayout>
