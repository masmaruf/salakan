---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ContentMeta from '../../components/ui/ContentMeta.astro';
import InfoCard from '../../components/ui/InfoCard.astro';
import BadgeList from '../../components/ui/BadgeList.astro';
import ActionLinkButton from '../../components/ui/ActionLinkButton.astro';
import RelatedContentSection from '../../components/ui/RelatedContentSection.astro';
import {
  formatTanggal,
  getAgenda,
  getGaleri,
  getHalamanCopy,
  getKategoriBeritaMap,
  getKegiatan,
  getLogKegiatan,
  getProgram,
  getStrukturOrganisasi,
} from '../../lib/content';
import { kategoriLabelsProgram, statusProgramLabels, tahapProgramLabels } from '../../lib/content-taxonomy';
import {
  createAgendaRelationItem,
  createBeritaRelationItem,
  createGaleriRelationItem,
  createLembagaRelationItem,
  createLogRelationItem,
  createProgramRelationItem,
} from '../../lib/content-relations';
import { findRelatedContent } from '../../lib/related-content';
import { renderMarkdown } from '../../lib/rich-text';
import { resolveSeoText, withSiteTitle } from '../../lib/site';

const { slug } = Astro.params;
const [items, agendaItems, logItems, beritaItems, lembagaItems, galeriItems, categoryLabels] = await Promise.all([
  getProgram(),
  getAgenda(),
  getLogKegiatan(),
  getKegiatan(),
  getStrukturOrganisasi(),
  getGaleri(),
  getKategoriBeritaMap(),
]);
const halaman = await getHalamanCopy();
const item = items.find((entry) => entry.slug === slug && entry.entry.statusPublikasi === 'publish');

if (!item) {
  return Astro.redirect('/program');
}

const { entry } = item;
const statusToneMap = {
  rencana: 'warning',
  berjalan: 'primary',
  selesai: 'success',
} as const;

const tahapToneMap = {
  inisiasi: 'surface',
  persiapan: 'warning',
  pelaksanaan: 'primary',
  pemantauan: 'info',
  tuntas: 'success',
} as const;

const relatedItems = findRelatedContent(
  createProgramRelationItem(item),
  [
    ...agendaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createAgendaRelationItem),
    ...logItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLogRelationItem),
    ...beritaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map((candidate) => createBeritaRelationItem(candidate, categoryLabels)),
    ...lembagaItems
      .filter((candidate) => candidate.entry?.statusPublikasi === 'publish')
      .map(createLembagaRelationItem),
    ...galeriItems.map(createGaleriRelationItem),
  ],
  4,
);
---

<MainLayout
  title={withSiteTitle(resolveSeoText(entry.judul, 'Program Warga'))}
  description={resolveSeoText(entry.ringkasan, entry.deskripsi)}
>
  <article class="container-premium max-w-4xl py-6 sm:py-8">
    <Breadcrumbs
      items={[
        { label: 'Beranda', href: '/' },
        { label: 'Program', href: '/program' },
        { label: entry.judul, active: true },
      ]}
    />

    <header class="mb-6">
      <BadgeList
        class="mb-3 flex flex-wrap items-center gap-2"
        items={[
          { label: kategoriLabelsProgram[entry.kategori as keyof typeof kategoriLabelsProgram], tone: 'surface' },
          { label: statusProgramLabels[entry.statusProgram as keyof typeof statusProgramLabels], tone: statusToneMap[entry.statusProgram as keyof typeof statusToneMap] },
          { label: tahapProgramLabels[entry.tahapProgram as keyof typeof tahapProgramLabels], tone: tahapToneMap[entry.tahapProgram as keyof typeof tahapToneMap] },
          { label: halaman.programDetail.priorityLabel, tone: 'info', visible: entry.unggulan },
        ]}
      />

      <h1 class="text-2xl font-bold leading-tight tracking-tight text-on-surface sm:text-3xl">
        {entry.judul}
      </h1>
      <p class="mt-3 text-base leading-relaxed text-on-surface-variant">{entry.ringkasan}</p>

      <ContentMeta
        class="mt-4 flex flex-wrap gap-x-5 gap-y-2 border-t border-base-300/70 pt-4"
        items={[
          { icon: 'calendar_today', text: `${halaman.programDetail.updatedPrefix} ${formatTanggal(entry.tanggalUpdate)}`, datetime: entry.tanggalUpdate, accentClass: 'text-on-surface-variant' },
          { icon: 'location_on', text: entry.lokasi, accentClass: 'text-on-surface-variant' },
          { icon: 'person', text: entry.penanggungJawab, accentClass: 'text-on-surface-variant' },
          { icon: 'flag', text: tahapProgramLabels[entry.tahapProgram as keyof typeof tahapProgramLabels], accentClass: 'text-on-surface-variant' },
        ]}
        iconClass="text-[16px] text-m3-primary"
      />
    </header>

    <div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
      <InfoCard title={halaman.programDetail.summaryTitle} class="card border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
        <div class="article-rich text-base leading-relaxed text-on-surface-variant" set:html={renderMarkdown(entry.deskripsi)} />
      </InfoCard>

      <div class="grid gap-4">
        <InfoCard title={halaman.programDetail.periodTitle} class="card border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
          <p class="text-sm font-medium text-on-surface">{entry.periode}</p>
        </InfoCard>
        <InfoCard title={halaman.programDetail.fundingTitle} class="card border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
          <p class="text-sm font-medium text-on-surface">{entry.sumberDana || '-'}</p>
        </InfoCard>
        <InfoCard title={halaman.programDetail.budgetTitle} class="card border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
          <p class="text-sm font-medium text-on-surface">{entry.anggaran || halaman.programDetail.budgetFallback}</p>
        </InfoCard>
        <InfoCard title="Target Hasil" class="card border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
          <p class="text-sm font-medium text-on-surface">{entry.targetHasilSingkat || 'Masih diperdalam bersama tim pelaksana.'}</p>
        </InfoCard>
      </div>
    </div>

    {entry.manfaat.length > 0 && (
      <InfoCard title={halaman.programDetail.benefitsTitle} class="card mt-5 border border-base-300/70 bg-base-100 shadow-sm" bodyClass="card-body p-5">
        <ul class="grid gap-3 text-sm leading-relaxed text-on-surface-variant sm:grid-cols-2">
          {entry.manfaat.map((point) => (
            <li class="rounded-xl border border-base-300/70 bg-base-200/60 px-4 py-3 text-base-content/75">{point}</li>
          ))}
        </ul>
      </InfoCard>
    )}

    <div class="mt-8 flex flex-wrap gap-3 border-t border-base-300/70 pt-5">
      <ActionLinkButton href="/program" label={halaman.programDetail.backToProgramsLabel} icon="arrow_back" />
      <ActionLinkButton href="/data" label={halaman.programDetail.openDataCenterLabel} icon="grid_view" />
    </div>
  </article>

  <RelatedContentSection
    title="Konten Terkait Program Ini"
    actionHref="/data"
    actionLabel="Buka pusat data"
    items={relatedItems}
  />
</MainLayout>
