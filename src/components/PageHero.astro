---
import Badge from './ui/Badge.astro';
import type { BadgeTone, BadgeVariant } from '../lib/ui-badge';

interface Props {
  title: string;
  description?: string;
  icon?: string;
  eyebrow?: string;
  eyebrowTone?: BadgeTone;
  eyebrowVariant?: BadgeVariant;
  sectionClass?: string;
  containerClass?: string;
  contentClass?: string;
  titleClass?: string;
  descriptionClass?: string;
  eyebrowClass?: string;
  eyebrowIconClass?: string;
  overlayClass?: string;
  backgroundImage?: string;
  orbs?: Array<{
    class: string;
  }>;
}

const {
  title,
  description,
  icon = 'info',
  eyebrow,
  eyebrowTone = 'surface',
  eyebrowVariant = 'outline',
  sectionClass = 'bg-neutral py-12 sm:py-16 lg:py-20',
  containerClass = 'container-premium relative z-10',
  contentClass = 'mx-auto max-w-3xl flex flex-col items-center text-center',
  titleClass = 'text-3xl font-bold tracking-tight text-neutral-content sm:text-4xl md:text-5xl',
  descriptionClass = 'mx-auto mt-4 max-w-2xl text-sm font-medium leading-relaxed text-neutral-content/70 sm:text-base md:text-lg',
  eyebrowClass = 'mb-4 border-neutral-content/18 bg-neutral-content/10 text-neutral-content/85 backdrop-blur-sm',
  eyebrowIconClass = 'text-[16px] text-accent',
  overlayClass = 'absolute inset-0 bg-neutral/45',
  backgroundImage,
  orbs = [
    { class: 'absolute -top-16 right-[12%] h-[260px] w-[260px] rounded-full bg-primary/20 blur-3xl sm:h-[340px] sm:w-[340px]' },
    { class: 'absolute bottom-0 left-[8%] h-[220px] w-[220px] rounded-full bg-accent/15 blur-3xl sm:h-[280px] sm:w-[280px]' },
  ],
} = Astro.props;
---

<section class:list={['relative isolate overflow-hidden', sectionClass]}>
  {backgroundImage && (
    <img src={backgroundImage} alt="" class="absolute inset-0 h-full w-full object-cover" aria-hidden="true" />
  )}
  {backgroundImage && <div class={overlayClass}></div>}
  <div class="pointer-events-none absolute inset-0">
    {orbs.map((orb) => (
      <div class={orb.class}></div>
    ))}
  </div>
  <div class={containerClass}>
    <div class={contentClass}>
      {eyebrow && (
        <Badge
          label={eyebrow}
          icon={icon}
          iconClass={eyebrowIconClass}
          tone={eyebrowTone}
          variant={eyebrowVariant}
          class={eyebrowClass}
        />
      )}
      <h1 class={titleClass}>{title}</h1>
      {description && (
        <p class={descriptionClass}>{description}</p>
      )}
      <slot />
    </div>
  </div>
</section>
