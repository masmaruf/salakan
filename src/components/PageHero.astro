---
interface Props {
  title: string;
  description?: string;
  icon?: string;
  eyebrow?: string;
  sectionClass?: string;
  containerClass?: string;
  contentClass?: string;
  titleClass?: string;
  descriptionClass?: string;
  badgeClass?: string;
  badgeIconClass?: string;
  badgeTextClass?: string;
  orbs?: Array<{
    class: string;
  }>;
}

const {
  title,
  description,
  icon = 'info',
  eyebrow,
  sectionClass = 'bg-gradient-to-br from-slate-950 via-blue-950 to-slate-900 py-12 sm:py-16 lg:py-20',
  containerClass = 'container-premium relative z-10',
  contentClass = 'mx-auto max-w-3xl text-center',
  titleClass = 'text-3xl font-bold tracking-tight text-white sm:text-4xl md:text-5xl',
  descriptionClass = 'mx-auto mt-4 max-w-2xl text-sm font-medium leading-relaxed text-blue-100/75 sm:text-base md:text-lg',
  badgeClass = 'mb-4 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-4 py-1.5 backdrop-blur',
  badgeIconClass = 'text-[16px] text-blue-300',
  badgeTextClass = 'text-xs font-bold uppercase tracking-[0.15em] text-blue-200',
  orbs = [
    { class: 'absolute -top-16 right-[12%] h-[260px] w-[260px] rounded-full bg-blue-400/20 blur-3xl sm:h-[340px] sm:w-[340px]' },
    { class: 'absolute bottom-0 left-[8%] h-[220px] w-[220px] rounded-full bg-cyan-400/10 blur-3xl sm:h-[280px] sm:w-[280px]' },
  ],
} = Astro.props;
---

<section class:list={['relative isolate overflow-hidden', sectionClass]}>
  <div class="pointer-events-none absolute inset-0">
    {orbs.map((orb) => (
      <div class={orb.class}></div>
    ))}
  </div>
  <div class={containerClass}>
    <div class={contentClass}>
      {eyebrow && (
        <div class={badgeClass}>
          <span class:list={['material-symbols-outlined', badgeIconClass]}>{icon}</span>
          <span class={badgeTextClass}>{eyebrow}</span>
        </div>
      )}
      <h1 class={titleClass}>{title}</h1>
      {description && (
        <p class={descriptionClass}>{description}</p>
      )}
      <slot />
    </div>
  </div>
</section>
