---
import { Image } from 'astro:assets';
import { formatTanggal } from '../lib/keystatic';

interface Item {
  slug: string;
  entry: {
    judul: string;
    tanggal: string;
    gambar?: string;
    caption: string;
  };
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
  {items.map(({ slug, entry }) => (
    <article class="group bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden transition-all hover:-translate-y-0.5 hover:shadow-md">
      {entry.gambar && (
        <Image
          src={entry.gambar}
          alt={entry.judul}
          width={960}
          height={720}
          loading="lazy"
          decoding="async"
          sizes="(max-width: 960px) 100vw, 33vw"
          class="h-64 w-full object-cover bg-surface-container-low"
        />
      )}
      <div class="p-5">
        <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
          <span class="text-[12px] font-semibold px-2 py-1 rounded-md bg-primary-container text-on-primary-container">Galeri</span>
          <time class="text-[12px] font-medium text-outline" datetime={entry.tanggal}>{formatTanggal(entry.tanggal)}</time>
        </div>
        <h3 class="text-base font-bold text-on-surface leading-tight group-hover:text-m3-primary transition-colors sm:text-lg">{entry.judul}</h3>
        <p class="text-sm text-on-surface-variant mt-2 line-clamp-2">{entry.caption}</p>
      </div>
    </article>
  ))}
</div>
