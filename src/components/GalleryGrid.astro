---
import { Image } from 'astro:assets';
import Badge from './ui/Badge.astro';
import { formatTanggal } from '../lib/content';

interface Item {
  slug: string;
  entry: {
    judul: string;
    tanggal: string;
    gambar?: string;
    caption: string;
  };
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2 sm:gap-5 xl:grid-cols-3">
  {items.map(({ slug, entry }) => (
    <a
      href={`/galeri/${slug}`}
      class="card group scroll-mt-28 overflow-hidden border border-base-300/70 bg-base-100 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-base-100"
      aria-label={`Buka detail galeri ${entry.judul}`}
    >
      <article id={slug}>
        {entry.gambar && (
          <Image
            src={entry.gambar}
            alt={entry.judul}
            width={960}
            height={720}
            loading="lazy"
            decoding="async"
            sizes="(max-width: 960px) 100vw, 33vw"
            class="h-56 w-full bg-base-200 object-cover sm:h-64"
          />
        )}
        <div class="card-body gap-2 p-4 sm:p-5">
          <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
            <Badge label="Galeri" tone="primary" />
            <time class="badge badge-ghost rounded-full px-3 py-3 text-[11px] font-semibold sm:text-[12px]" datetime={entry.tanggal}>{formatTanggal(entry.tanggal)}</time>
          </div>
          <h3 class="text-base font-bold leading-tight text-base-content transition-colors group-hover:text-primary sm:text-lg">{entry.judul}</h3>
          <p class="mt-2 line-clamp-2 text-sm text-base-content/65">{entry.caption}</p>
          <span class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-primary">
            Lihat detail
            <span aria-hidden="true">→</span>
          </span>
        </div>
      </article>
    </a>
  ))}
</div>
