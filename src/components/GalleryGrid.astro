---
import { Image } from 'astro:assets';
import Badge from './ui/Badge.astro';
import { formatTanggal } from '../lib/content';

interface Item {
  slug: string;
  entry: {
    judul: string;
    tanggal: string;
    gambar?: string;
    caption: string;
  };
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2 sm:gap-5 xl:grid-cols-3">
  {items.map(({ slug, entry }) => (
    <article class="group overflow-hidden rounded-2xl border border-outline-variant bg-surface-container-lowest transition-all hover:-translate-y-0.5 hover:shadow-md">
      {entry.gambar && (
        <Image
          src={entry.gambar}
          alt={entry.judul}
          width={960}
          height={720}
          loading="lazy"
          decoding="async"
          sizes="(max-width: 960px) 100vw, 33vw"
          class="h-56 w-full bg-surface-container-low object-cover sm:h-64"
        />
      )}
      <div class="p-4 sm:p-5">
        <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
          <Badge label="Galeri" tone="primary" />
          <time class="text-[11px] font-medium text-outline sm:text-[12px]" datetime={entry.tanggal}>{formatTanggal(entry.tanggal)}</time>
        </div>
        <h3 class="text-base font-bold leading-tight text-on-surface transition-colors group-hover:text-m3-primary sm:text-lg">{entry.judul}</h3>
        <p class="mt-2 line-clamp-2 text-sm text-on-surface-variant">{entry.caption}</p>
      </div>
    </article>
  ))}
</div>
