---
import { Image } from 'astro:assets';
import Badge from './ui/Badge.astro';
import { formatTanggal } from '../lib/content';

interface Item {
  slug: string;
  entry: {
    judul: string;
    tanggal: string;
    gambar?: string;
    caption: string;
  };
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2 sm:gap-5 xl:grid-cols-3">
  {items.map(({ slug, entry }) => (
    <article id={slug} class="card group scroll-mt-28 overflow-hidden border border-outline-variant bg-surface-container-lowest shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md active:scale-[0.98]">
      {entry.gambar && (
        <Image
          src={entry.gambar}
          alt={entry.judul}
          width={960}
          height={720}
          loading="lazy"
          decoding="async"
          sizes="(max-width: 960px) 100vw, 33vw"
          class="h-56 w-full bg-surface-container object-cover sm:h-64"
        />
      )}
      <div class="card-body gap-2 p-4 sm:p-5">
        <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
          <Badge label="Galeri" tone="primary" />
          <Badge label={formatTanggal(entry.tanggal)} tone="surface" variant="ghost" class="sm:text-[12px]" />
        </div>
        <h3 class="text-base font-bold leading-tight text-on-surface transition-colors group-hover:text-m3-primary sm:text-lg">{entry.judul}</h3>
        <p class="mt-2 line-clamp-2 text-sm text-on-surface-variant">{entry.caption}</p>
      </div>
    </article>
  ))}
</div>
