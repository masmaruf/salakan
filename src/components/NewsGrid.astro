---
import { Image } from 'astro:assets';
import Badge from './ui/Badge.astro';
import { excerpt, formatTanggal, getKategoriBeritaMap } from '../lib/content';
import { getBeritaCategoryTone } from '../lib/content-taxonomy';

interface Item {
  slug: string;
  entry: {
    judul: string;
    tanggal: string;
    kategori: string;
    jenisKonten?: string;
    gambarUtama?: string;
    altGambarUtama?: string;
    ringkasan: string;
  };
}

interface Props {
  items: Item[];
  compact?: boolean;
}

const { items, compact = false } = Astro.props;
const categoryLabels = await getKategoriBeritaMap();

import Icon from './ui/Icon.tsx';
---

<div class:list={['grid', compact ? 'grid-cols-1 gap-6 lg:grid-cols-2' : 'grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 xl:grid-cols-3']}>
  {items.map(({ slug, entry }) => (
    <a href={`/berita/${slug}`} class="card group h-full overflow-hidden border border-base-300/70 bg-base-100 shadow-sm transition-all hover:-translate-y-1 hover:border-primary/30 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40">
      <div class="relative aspect-[16/10] w-full overflow-hidden bg-base-200">
        {entry.gambarUtama ? (
          <Image
            src={entry.gambarUtama}
            alt={entry.altGambarUtama || entry.judul}
            width={960}
            height={540}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
            sizes={compact ? '(max-width: 960px) 100vw, 50vw' : '(max-width: 960px) 100vw, 33vw'}
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-base-200">
            <Icon name="image" class="text-[48px] text-base-content/25" />
          </div>
        )}
      </div>

      <div class="card-body flex flex-1 flex-col gap-1.5 p-4 sm:p-5">
        <div class="flex flex-wrap items-center gap-2">
          <Badge label={categoryLabels[entry.kategori] ?? entry.kategori} tone={getBeritaCategoryTone(entry.kategori)} />
          <span class="flex items-center gap-1 text-[11px] font-medium text-base-content/55 sm:text-[12px]">
            <Icon name="schedule" class="text-[14px]" />
            {formatTanggal(entry.tanggal)}
          </span>
        </div>
        <h3 class="mt-1 line-clamp-2 text-base font-bold leading-snug text-base-content transition-colors group-hover:text-primary sm:text-[1.05rem]">
          {entry.judul}
        </h3>
        <p class="mt-0.5 line-clamp-3 text-sm leading-relaxed text-base-content/65 sm:line-clamp-2">
          {compact ? excerpt(entry.ringkasan, 110) : entry.ringkasan}
        </p>
      </div>
    </a>
  ))}
</div>
