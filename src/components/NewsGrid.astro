---
import { Image } from 'astro:assets';
import { excerpt, formatTanggal, getKategoriBeritaMap } from '../lib/keystatic';

interface Item {
  slug: string;
  entry: {
    judul: string;
    tanggal: string;
    kategori: string;
    jenisKonten?: string;
    gambarUtama?: string;
    altGambarUtama?: string;
    ringkasan: string;
  };
}

interface Props {
  items: Item[];
  compact?: boolean;
}

const { items, compact = false } = Astro.props;
const categoryLabels = await getKategoriBeritaMap();
const gridClass = compact ? 'grid-cols-1 gap-4 lg:grid-cols-2' : 'grid-cols-1 gap-5 xl:grid-cols-3 md:grid-cols-2';
---

<div class:list={['grid gap-10', gridClass]}>
  {items.map(({ slug, entry }) => (
    <article class="card-premium group !p-0 overflow-hidden flex flex-col h-full bg-white transition-all transform hover:-translate-y-2 hover:shadow-2xl">
      <div class="relative overflow-hidden aspect-video">
        {entry.gambarUtama ? (
          <Image
            src={entry.gambarUtama}
            alt={entry.altGambarUtama || entry.judul}
            width={960}
            height={540}
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
            decoding="async"
            sizes={compact ? '(max-width: 960px) 100vw, 50vw' : '(max-width: 960px) 100vw, 33vw'}
          />
        ) : (
          <div class="h-full w-full bg-slate-100 flex items-center justify-center">
             <span class="material-symbols-outlined text-6xl text-slate-200">image</span>
          </div>
        )}
        <div class="absolute top-4 left-4">
           <span class="badge-premium !py-1.5 !px-4 !bg-blue-600/90 !text-white !backdrop-blur-md shadow-lg">{categoryLabels[entry.kategori] ?? entry.kategori}</span>
        </div>
      </div>

      <div class="flex flex-1 flex-col p-8">
        <time class="mb-4 flex items-center gap-2 text-xs font-black text-blue-600 uppercase tracking-widest" datetime={entry.tanggal}>
          <span class="material-symbols-outlined text-[16px]">calendar_month</span>
          {formatTanggal(entry.tanggal)}
        </time>
        
        <div class="space-y-4 flex-1">
          <h3 class="text-2xl font-black tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors leading-[1.25] line-clamp-2">
            <a href={`/berita/${slug}`}>{entry.judul}</a>
          </h3>
          <p class="text-[0.95rem] font-bold text-slate-400 leading-relaxed line-clamp-3">
            {compact ? excerpt(entry.ringkasan, 110) : entry.ringkasan}
          </p>
        </div>

        <div class="mt-8 pt-6 border-t border-slate-50">
          <a class="inline-flex items-center gap-3 text-xs font-black text-slate-900 uppercase tracking-widest group-hover:text-blue-600 transition" href={`/berita/${slug}`}>
             Selengkapnya <span class="material-symbols-outlined text-lg transition-transform group-hover:translate-x-1">arrow_forward</span>
          </a>
        </div>
      </div>
    </article>
  ))}
</div>
