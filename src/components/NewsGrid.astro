---
import { Image } from 'astro:assets';
import { excerpt, formatTanggal, getKategoriBeritaMap } from '../lib/keystatic';

interface Item {
  slug: string;
  entry: {
    judul: string;
    tanggal: string;
    kategori: string;
    jenisKonten?: string;
    gambarUtama?: string;
    altGambarUtama?: string;
    ringkasan: string;
  };
}

interface Props {
  items: Item[];
  compact?: boolean;
}

const { items, compact = false } = Astro.props;
const categoryLabels = await getKategoriBeritaMap();

function getCategoryClass(kategori: string): string {
  const key = kategori.toLowerCase();
  if (key.includes('pengumuman')) return 'bg-error-container text-on-error-container';
  if (key.includes('kegiatan') || key.includes('warga')) return 'bg-blue-100 text-blue-800';
  if (key.includes('gotong') || key.includes('lingkungan')) return 'bg-sky-100 text-sky-800';
  if (key.includes('pelayanan') || key.includes('layanan')) return 'bg-amber-100 text-amber-800';
  if (key.includes('potensi') || key.includes('umkm')) return 'bg-emerald-100 text-emerald-800';
  if (key.includes('artikel')) return 'bg-surface-variant text-on-surface-variant border border-outline-variant';
  return 'bg-primary-container text-on-primary-container';
}
---

<div class:list={['grid', compact ? 'grid-cols-1 gap-6 lg:grid-cols-2' : 'grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3 sm:gap-8']}>
  {items.map(({ slug, entry }) => (
    <a href={`/berita/${slug}`} class="group flex h-full flex-col rounded-2xl transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/40">
      {/* Image */}
      <div class="relative aspect-[16/10] w-full overflow-hidden rounded-2xl">
        {entry.gambarUtama ? (
          <Image
            src={entry.gambarUtama}
            alt={entry.altGambarUtama || entry.judul}
            width={960}
            height={540}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
            sizes={compact ? '(max-width: 960px) 100vw, 50vw' : '(max-width: 960px) 100vw, 33vw'}
          />
        ) : (
          <div class="h-full w-full bg-surface-container-low flex items-center justify-center">
            <span class="material-symbols-outlined text-[48px] text-outline-variant">image</span>
          </div>
        )}
      </div>

      {/* Content */}
      <div class="flex flex-1 flex-col gap-1.5 px-1 pt-3">
        <div class="flex flex-wrap items-center gap-2">
          <span class:list={['rounded-md px-2.5 py-1 text-[11px] font-semibold sm:text-[12px]', getCategoryClass(entry.kategori)]}>
            {categoryLabels[entry.kategori] ?? entry.kategori}
          </span>
          <span class="flex items-center gap-1 text-[11px] font-medium text-outline sm:text-[12px]">
            <span class="material-symbols-outlined text-[14px]">schedule</span>
            {formatTanggal(entry.tanggal)}
          </span>
        </div>
        <h3 class="mt-1 text-base font-bold leading-snug text-on-surface transition-colors line-clamp-2 group-hover:text-m3-primary sm:text-[1.05rem]">
          {entry.judul}
        </h3>
        <p class="mt-0.5 text-sm leading-relaxed text-on-surface-variant line-clamp-3 sm:line-clamp-2">
          {compact ? excerpt(entry.ringkasan, 110) : entry.ringkasan}
        </p>
      </div>
    </a>
  ))}
</div>
