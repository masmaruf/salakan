---
interface Props {
  title: string;
  description: string;
  href?: string;
  linkLabel?: string;
  center?: boolean;
}

const { title, description, href, linkLabel, center = false } = Astro.props;
const wrapperClass = center
  ? 'mb-6 flex flex-col items-center gap-4 text-center md:mb-8'
  : 'mb-6 flex flex-col gap-4 md:mb-8 md:flex-row md:items-end md:justify-between';
---

<div class={wrapperClass}>
  <div class="space-y-4">
    <h2 class="text-gradient mb-0">{title}</h2>
    <p class={`max-w-3xl font-bold text-slate-400 ${center ? 'mx-auto' : ''}`}>{description}</p>
  </div>
  {href && linkLabel && (
    <a class="btn-premium-ghost shrink-0 border border-slate-100 bg-white shadow-sm" href={href}>
      {linkLabel} <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
    </a>
  )}
</div>
