---
interface Props {
  title: string;
  description: string;
  href?: string;
  linkLabel?: string;
  center?: boolean;
}

const { title, description, href, linkLabel, center = false } = Astro.props;
const wrapperClass = center
  ? 'mb-6 flex flex-col items-center gap-4 text-center md:mb-8'
  : 'mb-6 flex flex-col gap-4 md:mb-8 md:flex-row md:items-end md:justify-between';
---

<div class={wrapperClass}>
  <div class="space-y-2">
    <h2 class="section-title font-extrabold text-slate-950">{title}</h2>
    <p class={`max-w-3xl text-body-md text-slate-600 ${center ? 'mx-auto' : ''}`}>{description}</p>
  </div>
  {href && linkLabel && (
    <a class="btn btn-sm btn-ghost rounded-full bg-white text-slate-700 shadow-sm hover:bg-blue-50 hover:text-blue-700" href={href}>
      {linkLabel}
    </a>
  )}
</div>
