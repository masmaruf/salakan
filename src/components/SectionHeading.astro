---
interface Props {
  title: string;
  description: string;
  href?: string;
  linkLabel?: string;
}

const { title, description, href, linkLabel } = Astro.props;
---

<div class="mb-6 flex flex-col gap-4 md:mb-8 md:flex-row md:items-end md:justify-between">
  <div class="space-y-2">
    <h2 class="section-title font-extrabold text-slate-950">{title}</h2>
    <p class="max-w-3xl text-body-md text-slate-600">{description}</p>
  </div>
  {href && linkLabel && (
    <a class="btn btn-sm btn-ghost rounded-[var(--radius-md)] border border-slate-200 bg-white text-slate-700 shadow-none hover:border-violet-200 hover:bg-violet-50 hover:text-violet-700" href={href}>
      {linkLabel}
    </a>
  )}
</div>
