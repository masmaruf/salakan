---
import { navItems } from '../lib/site';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="sticky top-0 z-20 border-b border-slate-200/90 bg-white/95 backdrop-blur-xl">
  <div class="container py-3.5 md:py-4">
    <div class="grid items-center gap-4 md:grid-cols-[1fr_auto_1fr]">
      <div class="flex items-center justify-between md:justify-start">
        <a class="inline-flex shrink-0 items-center gap-3" href="/">
          <span class="grid h-10 w-10 place-items-center rounded-[var(--radius-md)] bg-gradient-to-br from-violet-600 via-indigo-500 to-blue-500 font-['Plus_Jakarta_Sans'] text-sm font-extrabold text-white md:h-11 md:w-11 md:text-base">
            PS
          </span>
          <span class="block">
            <strong class="block text-[0.95rem] font-extrabold tracking-tight text-slate-950 md:text-base">Padukuhan Salakan</strong>
            <small class="mt-0.5 block text-xs text-slate-500">Portal informasi warga</small>
          </span>
        </a>

        <details class="group relative md:hidden">
          <summary class="btn btn-ghost relative h-10 min-h-10 w-10 rounded-[var(--radius-md)] border border-slate-200 bg-white p-0 shadow-none">
            <span class="material-symbols-outlined transition-opacity group-open:opacity-0">menu</span>
            <span class="material-symbols-outlined absolute inset-0 grid place-items-center opacity-0 transition-opacity group-open:opacity-100">close</span>
          </summary>
          <div class="fixed inset-x-0 top-[84px] z-30 px-3 pb-4 group-open:block">
            <div class="surface-card max-h-[calc(100vh-108px)] overflow-y-auto p-4 shadow-[0_18px_48px_rgba(15,23,42,0.12)]">
              <div class="space-y-1 border-b border-slate-200 pb-4">
                <strong class="block text-base font-bold text-slate-950">Menu navigasi</strong>
                <small class="block text-sm leading-6 text-slate-500">Akses halaman utama dan katalog data warga dengan lebih cepat.</small>
              </div>
              <div class="mt-4 grid gap-2">
                {navItems.map((item) => {
                  const isActive =
                    item.href === '/'
                      ? currentPath === item.href
                      : currentPath.startsWith(item.href);

                  return (
                    <a
                      class:list={[
                        'rounded-[var(--radius-md)] border px-4 py-3.5 text-sm font-semibold transition-colors',
                        isActive
                          ? 'border-violet-200 bg-violet-50 text-violet-700'
                          : 'border-slate-200 bg-white text-slate-800 hover:bg-slate-50',
                      ]}
                      href={item.href}
                    >
                      {item.label}
                    </a>
                  );
                })}
              </div>
            </div>
          </div>
        </details>
      </div>

      <nav aria-label="Navigasi utama" class="hidden md:block">
        <ul class="flex items-center justify-center gap-8">
          {navItems.map((item) => {
            const isActive =
              item.href === '/'
                ? currentPath === item.href
                : currentPath.startsWith(item.href);

            return (
              <li>
                <a
                  class:list={[
                    'relative inline-flex items-center rounded-[var(--radius-md)] px-3 py-2 text-[0.95rem] font-medium tracking-tight transition-all duration-200',
                    isActive
                      ? 'bg-violet-50 text-violet-700'
                      : 'text-slate-500 hover:bg-slate-50 hover:text-slate-900',
                  ]}
                  href={item.href}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.label}
                  {isActive && (
                    <span class="absolute inset-x-3 -bottom-[0.45rem] h-0.5 rounded-full bg-gradient-to-r from-violet-500 to-blue-500"></span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div class="hidden md:block" aria-hidden="true"></div>
    </div>
  </div>
</header>
