---
import { getPengaturan } from '../lib/keystatic';
import { navItems } from '../lib/site';
import SearchDialog from './SearchDialog.tsx';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const pengaturan = await getPengaturan();
const dataSubmenu = pengaturan?.menuData?.items?.filter((item) => item.status === 'tampil') ?? [];
const isDataActive = currentPath === '/data' || currentPath.startsWith('/data/');
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl shadow-sm transition-all">
  <div class="container py-3">
    <div class="grid items-center gap-4 md:grid-cols-[1fr_auto_1fr]">
      <div class="flex items-center justify-between md:justify-start">
        <a class="inline-flex shrink-0 items-center gap-3 group" href="/">
          <span class="grid h-10 w-10 place-items-center rounded-[var(--radius-md)] bg-blue-600 font-['Roboto'] text-sm font-bold text-white transition-transform group-hover:scale-105">
            PS
          </span>
          <span class="block">
            <strong class="block text-sm font-bold text-slate-900 leading-tight">Padukuhan Salakan</strong>
            <small class="block text-[0.65rem] font-medium tracking-wide text-slate-500 uppercase mt-0.5">Pemerintah Desa</small>
          </span>
        </a>

        <details class="group relative md:hidden">
          <summary class="btn btn-ghost relative h-10 min-h-10 w-10 rounded-md bg-transparent p-0 text-slate-500 hover:text-slate-900 border-none cursor-pointer">
            <span class="material-symbols-outlined transition-opacity group-open:opacity-0">menu</span>
            <span class="material-symbols-outlined absolute inset-0 grid place-items-center opacity-0 transition-opacity group-open:opacity-100">close</span>
          </summary>
          <div class="fixed inset-x-0 top-[60px] z-50 px-4 pb-4 group-open:block">
             <div class="rounded-2xl bg-white/95 backdrop-blur-3xl p-4 shadow-[0_24px_64px_rgba(15,23,42,0.15)] mt-2">
                <div class="mt-2 grid gap-1">
                   {navItems.map((item) => {
                     const isActive =
                       item.href === '/'
                         ? currentPath === item.href
                         : currentPath.startsWith(item.href);
   
                     return (
                       <>
                         <a
                           class:list={[
                             'rounded-lg px-4 py-3 text-sm font-medium transition-colors',
                             isActive
                               ? 'bg-blue-50 text-blue-700 font-semibold'
                               : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900',
                           ]}
                           href={item.href}
                         >
                           {item.label}
                         </a>
                         {item.href === '/data' && (
                           <div class="ml-4 mt-1 grid gap-1 border-l-2 border-slate-100 pl-4 py-1">
                             {dataSubmenu.map((subItem) => {
                                const isSubActive = currentPath === subItem.href || currentPath.startsWith(`${subItem.href}/`);
                                return (
                                  <a
                                    class:list={[
                                      'rounded-md px-3 py-2 text-sm transition-colors',
                                      isSubActive
                                        ? 'text-blue-700 font-medium'
                                        : 'text-slate-500 hover:text-slate-900',
                                    ]}
                                    href={subItem.href}
                                  >
                                    {subItem.label}
                                  </a>
                                );
                             })}
                           </div>
                         )}
                       </>
                     );
                   })}
                 </div>
                 <div class="mt-4 pt-4 border-t border-slate-100 grid">
                    <a href="/dasbor" class="flex items-center justify-center gap-2 rounded-lg bg-blue-600 text-white px-4 py-2.5 text-sm font-semibold hover:bg-blue-700 transition">
                       Portal Warga
                    </a>
                 </div>
             </div>
          </div>
        </details>
      </div>

      <nav aria-label="Navigasi utama" class="hidden md:block">
        <ul class="flex items-center justify-center gap-1">
          {navItems.map((item) => {
            const isActive =
              item.href === '/'
                ? currentPath === item.href
                : currentPath.startsWith(item.href);

            if (item.href === '/data') {
              return (
                <li class="relative group/nav cursor-pointer">
                   <div
                     class:list={[
                       'relative inline-flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium transition-colors',
                       isDataActive
                         ? 'text-blue-700 bg-blue-50/50'
                         : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50',
                     ]}
                   >
                     <span>{item.label}</span>
                     <span class="material-symbols-outlined text-[16px] text-slate-400 group-hover/nav:rotate-180 transition-transform duration-200">expand_more</span>
                   </div>
                   
                   {/* Dropdown Menu (Hover based instead of Details) */}
                   <div class="absolute left-1/2 top-full z-50 mt-1 w-64 -translate-x-1/2 opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all duration-200 transform translate-y-2 group-hover/nav:translate-y-0">
                      {/* Invisible bridge to keep hover state active */}
                      <div class="h-2 w-full absolute -top-2 left-0"></div>
                      
                      <div class="rounded-xl border border-slate-100 bg-white p-2 shadow-xl">
                        <a
                           class:list={[
                             'block rounded-md px-3 py-2 transition-colors',
                             currentPath === '/data' ? 'bg-blue-50 text-blue-700' : 'hover:bg-slate-50 text-slate-700',
                           ]}
                           href="/data"
                        >
                           <span class="block text-sm font-semibold">Pusat Data Warga</span>
                        </a>
                        <div class="my-1 border-t border-slate-50"></div>
                        {dataSubmenu.map((subItem) => {
                           const isSubActive = currentPath === subItem.href || currentPath.startsWith(`${subItem.href}/`);
                           return (
                             <a
                               class:list={[
                                 'block rounded-md px-3 py-2 transition-colors',
                                 isSubActive ? 'bg-blue-50 text-blue-700' : 'hover:bg-slate-50 text-slate-600 hover:text-slate-900',
                               ]}
                               href={subItem.href}
                             >
                               <span class="block text-sm font-medium">{subItem.label}</span>
                             </a>
                           );
                        })}
                      </div>
                   </div>
                </li>
              );
            }

            return (
              <li>
                <a
                  class:list={[
                    'relative inline-flex items-center rounded-md px-3 py-2 text-sm font-medium transition-colors',
                    isActive
                      ? 'text-blue-700 bg-blue-50/50'
                      : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50',
                  ]}
                  href={item.href}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div class="hidden md:flex justify-end items-center gap-2">
        <SearchDialog client:idle />
        <a href="/dasbor" class="flex items-center justify-center gap-1.5 rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-600 transition-colors">
           Dasbor Warga
        </a>
      </div>
    </div>
  </div>
</header>
