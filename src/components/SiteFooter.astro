---
import { getPengaturan } from '../lib/content';

const year = new Date().getFullYear();
const pengaturan = await getPengaturan();
const alamat = pengaturan?.alamat ?? '';
const whatsapp = pengaturan?.kontakWhatsApp ?? '';
const email = pengaturan?.email ?? 'info@salakan.id';
const waDisplay = whatsapp ? `0${whatsapp.replace(/^62/, '')}` : '';

import Icon from './ui/Icon.tsx';
---

<footer class="border-t border-outline-variant/60 bg-surface-container-low/40 pt-10 pb-6">
  <div class="container-premium">

    <!-- Top: Brand + Contact row -->
    <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">

      <!-- Brand -->
      <div class="space-y-3 max-w-sm">
        <div class="flex items-center gap-2.5">
          <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-on-surface text-surface text-xs font-bold">PS</span>
          <span class="text-base font-bold tracking-tight text-on-surface">Padukuhan Salakan</span>
        </div>
        <p class="text-sm leading-relaxed text-on-surface-variant">
          Portal informasi dan layanan warga Padukuhan Salakan. Transparan, terbuka, dan mudah diakses.
        </p>
      </div>

      <!-- Contact chips -->
      <div class="flex flex-wrap gap-2">
        {alamat && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-surface-container-lowest border border-outline-variant px-3 py-1.5 text-[12px] font-medium text-on-surface-variant">
            <Icon name="location_on" class="text-[14px]" />
            {alamat.split('\n')[0]}
          </span>
        )}
        {waDisplay && (
          <a
            href={`https://wa.me/${whatsapp}`}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 rounded-full bg-surface-container-lowest border border-outline-variant px-3 py-1.5 text-[12px] font-medium text-on-surface-variant hover:bg-primary-container hover:text-on-primary-container hover:border-transparent transition-colors"
          >
            <Icon name="chat" class="text-[14px]" />
            {waDisplay}
          </a>
        )}
        {email && (
          <a
            href={`mailto:${email}`}
            class="inline-flex items-center gap-1.5 rounded-full bg-surface-container-lowest border border-outline-variant px-3 py-1.5 text-[12px] font-medium text-on-surface-variant hover:bg-primary-container hover:text-on-primary-container hover:border-transparent transition-colors"
          >
            <Icon name="mail" class="text-[14px]" />
            {email}
          </a>
        )}
      </div>
    </div>

    <!-- Nav links row -->
    <nav class="flex flex-wrap gap-x-6 gap-y-2 mt-8 pt-6 border-t border-outline-variant/40 text-sm font-medium text-on-surface-variant" aria-label="Footer">
      <a class="hover:text-m3-primary transition-colors" href="/">Beranda</a>
      <a class="hover:text-m3-primary transition-colors" href="/profil">Profil</a>
      <a class="hover:text-m3-primary transition-colors" href="/berita">Berita</a>
      <a class="hover:text-m3-primary transition-colors" href="/agenda">Agenda</a>
      <a class="hover:text-m3-primary transition-colors" href="/galeri">Galeri</a>
      <a class="hover:text-m3-primary transition-colors" href="/kontak">Kontak</a>
    </nav>

    <!-- Copyright -->
    <p class="mt-6 text-[12px] text-on-surface-variant/60">
      &copy; {year} Padukuhan Salakan &middot; Portal digital warga
    </p>

  </div>
</footer>
