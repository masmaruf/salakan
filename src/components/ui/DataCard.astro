---
import CmsIcon from '../CmsIcon.astro';

interface Props {
  label: string;
  href: string;
  description: string;
  icon: string;
  eyebrow?: string;
  countLabel?: string;
  meta?: string;
}

const {
  label,
  href,
  description,
  icon,
  eyebrow,
  countLabel,
  meta,
} = Astro.props;

import Icon from './Icon.tsx';
---

<a
  href={href}
  class="group section-card section-card-hover flex h-full flex-col gap-4"
>
  <div class="flex items-start justify-between gap-3">
    <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary-container/30 text-m3-primary transition-colors group-hover:bg-m3-primary group-hover:text-on-primary">
      <CmsIcon name={icon} class="size-6" />
    </div>
    {countLabel && (
      <span class="rounded-full border border-outline-variant bg-white px-3 py-1 text-[11px] font-semibold text-on-surface-variant">
        {countLabel}
      </span>
    )}
  </div>
  <div class="flex-1 space-y-1.5">
    {eyebrow && <p class="section-kicker-muted text-outline">{eyebrow}</p>}
    <h3 class="text-base font-bold text-on-surface group-hover:text-m3-primary transition-colors sm:text-lg">{label}</h3>
    <p class="text-sm text-on-surface-variant line-clamp-3">{description}</p>
  </div>
  <div class="mt-auto flex items-center justify-between gap-3">
    {meta ? <span class="text-[12px] font-medium text-outline">{meta}</span> : <span />}
    <span class="action-link-inline text-[12px] transition-all sm:opacity-0 sm:-translate-x-2 sm:group-hover:translate-x-0 sm:group-hover:opacity-100">
      Akses Data <Icon name="arrow_forward" class="text-[14px]" />
    </span>
  </div>
</a>
