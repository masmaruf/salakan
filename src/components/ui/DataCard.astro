---
import CmsIcon from '../CmsIcon.astro';

interface Props {
  label: string;
  href: string;
  description: string;
  icon: string;
}

const { label, href, description, icon } = Astro.props;
---

<a
  href={href}
  class="group bg-surface-container-lowest border border-outline-variant rounded-xl p-5 transition-all hover:-translate-y-0.5 hover:shadow-md flex flex-col gap-4"
>
  <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary-container/30 text-m3-primary transition-colors group-hover:bg-m3-primary group-hover:text-on-primary">
    <CmsIcon name={icon} class="size-6" />
  </div>
  <div class="space-y-1.5 flex-1">
    <h3 class="text-base font-bold text-on-surface group-hover:text-m3-primary transition-colors sm:text-lg">{label}</h3>
    <p class="text-sm text-on-surface-variant line-clamp-2">{description}</p>
  </div>
  <span class="inline-flex items-center gap-1 text-[12px] font-semibold text-m3-primary opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all mt-auto">
    Akses Data <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
  </span>
</a>
