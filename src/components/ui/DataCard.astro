---
import CmsIcon from '../CmsIcon.astro';

interface Props {
  label: string;
  href: string;
  description: string;
  icon: string;
  eyebrow?: string;
  countLabel?: string;
  meta?: string;
}

const {
  label,
  href,
  description,
  icon,
  eyebrow,
  countLabel,
  meta,
} = Astro.props;

import Icon from './Icon.tsx';
---

<a
  href={href}
  class="card group flex h-full flex-col border border-base-300/70 bg-base-100 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md"
>
  <div class="card-body gap-4 p-5">
  <div class="flex items-start justify-between gap-3">
    <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-content">
      <CmsIcon name={icon} class="size-6" />
    </div>
    {countLabel && (
      <span class="badge badge-outline rounded-full px-3 py-3 text-[11px] font-semibold">
        {countLabel}
      </span>
    )}
  </div>
  <div class="flex-1 space-y-1.5">
    {eyebrow && <p class="section-kicker-muted text-base-content/55">{eyebrow}</p>}
    <h3 class="text-base font-bold text-base-content transition-colors group-hover:text-primary sm:text-lg">{label}</h3>
    <p class="line-clamp-3 text-sm text-base-content/65">{description}</p>
  </div>
  <div class="mt-auto flex items-center justify-between gap-3">
    {meta ? <span class="text-[12px] font-medium text-base-content/55">{meta}</span> : <span />}
    <span class="btn btn-ghost btn-xs rounded-full text-primary transition-all sm:opacity-0 sm:-translate-x-2 sm:group-hover:translate-x-0 sm:group-hover:opacity-100">
      Akses Data <Icon name="arrow_forward" class="text-[14px]" />
    </span>
  </div>
  </div>
</a>
