---
import CmsIcon from '../CmsIcon.astro';
import Badge from './Badge.astro';

interface Props {
  label: string;
  href: string;
  description: string;
  icon: string;
  eyebrow?: string;
  countLabel?: string;
  meta?: string;
}

const {
  label,
  href,
  description,
  icon,
  eyebrow,
  countLabel,
  meta,
} = Astro.props;

import Icon from './Icon.tsx';
---

<a
  href={href}
  class="group flex h-full flex-col overflow-hidden rounded-xl border border-outline-variant bg-surface-container-lowest p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md"
>
  <div class="flex items-start justify-between gap-3">
    <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-content">
      <CmsIcon name={icon} class="size-6" />
    </div>
    {countLabel && (
      <Badge label={countLabel} tone="surface" class="px-3 py-3 text-[11px] font-semibold" />
    )}
  </div>
  <div class="mt-4 flex-1 space-y-1.5">
    {eyebrow && <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">{eyebrow}</p>}
    <h3 class="text-base font-bold text-on-surface transition-colors group-hover:text-m3-primary sm:text-lg">{label}</h3>
    <p class="line-clamp-3 text-sm text-on-surface-variant">{description}</p>
  </div>
  <div class="mt-4 flex items-center justify-between gap-3 border-t border-outline-variant/60 pt-3">
    {meta ? <span class="text-[12px] font-medium text-on-surface-variant/80">{meta}</span> : <span />}
    <span class="inline-flex items-center gap-1 text-[13px] font-semibold text-m3-primary transition-transform group-hover:translate-x-0.5">
      Akses Data <Icon name="arrow_forward" class="text-[14px]" />
    </span>
  </div>
</a>
