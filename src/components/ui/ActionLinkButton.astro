---
interface Props {
  href: string;
  label: string;
  icon?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'success' | 'dark';
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  label,
  icon,
  variant = 'outline',
  target,
  rel,
  class: className = '',
} = Astro.props;

const variantClasses = {
  primary: 'btn-primary',
  secondary: 'btn-secondary',
  outline: 'btn-outline',
  success: 'btn-success',
  dark: 'btn-neutral',
};

import Icon from './Icon.tsx';
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={[
    'btn rounded-full',
    variantClasses[variant],
    className,
  ]}
>
  {icon && <Icon name={icon} class="text-[18px]" />}
  <span>{label}</span>
</a>
