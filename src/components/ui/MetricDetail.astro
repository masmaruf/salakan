---
interface Props {
  label: string;
  value: string | number;
  class?: string;
  valueClass?: string;
}

const {
  label,
  value,
  class: className = '',
  valueClass = '',
} = Astro.props;
---

<div class:list={['card border border-base-300/70 bg-base-200 shadow-none', className]}>
  <div class="card-body p-4">
  <p class="detail-label">{label}</p>
  <p class:list={['mt-1 text-sm font-bold text-base-content', valueClass]}>{value}</p>
  </div>
</div>
