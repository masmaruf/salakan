---
interface Props {
  label: string;
  value: string | number;
  description: string;
  tone?: 'blue' | 'emerald' | 'amber' | 'red' | 'orange';
  icon?: string;
}

const {
  label,
  value,
  description,
  tone = 'blue',
  icon,
} = Astro.props;

const toneClasses = {
  blue: { label: 'text-blue-500', iconBg: 'bg-blue-50', iconText: 'text-blue-600' },
  emerald: { label: 'text-emerald-500', iconBg: 'bg-emerald-50', iconText: 'text-emerald-600' },
  amber: { label: 'text-amber-500', iconBg: 'bg-amber-50', iconText: 'text-amber-600' },
  red: { label: 'text-red-500', iconBg: 'bg-red-50', iconText: 'text-red-600' },
  orange: { label: 'text-orange-500', iconBg: 'bg-orange-50', iconText: 'text-orange-600' },
};

const toneClass = toneClasses[tone];

import Icon from './Icon.tsx';
---

<article class="group card-premium">
  {icon && (
    <div class:list={[
      'absolute right-5 top-5 hidden h-12 w-12 place-items-center rounded-2xl shadow-inner sm:grid',
      toneClass.iconBg,
      toneClass.iconText,
    ]}>
      <Icon name={icon} class="text-[26px]" />
    </div>
  )}
  <p class:list={['mb-2 max-w-[11rem] text-xs font-black uppercase tracking-[0.12em]', toneClass.label]}>{label}</p>
  <strong class="block max-w-full break-words text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">{value}</strong>
  <p class="mt-3 text-sm font-medium leading-relaxed text-slate-500">{description}</p>
</article>
