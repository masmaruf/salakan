---
interface Props {
  label: string;
  value: string | number;
  description: string;
  tone?: 'blue' | 'emerald' | 'amber' | 'red' | 'orange';
  icon?: string;
}

const {
  label,
  value,
  description,
  tone = 'blue',
  icon,
} = Astro.props;

const toneClasses = {
  blue: { label: 'text-primary', iconBg: 'bg-primary/10', iconText: 'text-primary' },
  emerald: { label: 'text-success', iconBg: 'bg-success/10', iconText: 'text-success' },
  amber: { label: 'text-warning', iconBg: 'bg-warning/10', iconText: 'text-warning' },
  red: { label: 'text-error', iconBg: 'bg-error/10', iconText: 'text-error' },
  orange: { label: 'text-warning', iconBg: 'bg-warning/10', iconText: 'text-warning' },
};

const toneClass = toneClasses[tone];

import Icon from './Icon.tsx';
---

<article class="card border border-base-300/70 bg-base-100 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
  <div class="card-body relative p-6">
    {icon && (
      <div class:list={[
        'absolute right-5 top-5 hidden h-12 w-12 place-items-center rounded-2xl shadow-inner sm:grid',
        toneClass.iconBg,
        toneClass.iconText,
      ]}>
        <Icon name={icon} class="text-[26px]" />
      </div>
    )}
    <p class:list={['mb-2 max-w-[11rem] text-xs font-black uppercase tracking-[0.12em]', toneClass.label]}>{label}</p>
    <strong class="block max-w-full break-words text-3xl font-black tracking-tight text-base-content sm:text-4xl">{value}</strong>
    <p class="mt-3 text-sm font-medium leading-relaxed text-base-content/65">{description}</p>
  </div>
</article>
