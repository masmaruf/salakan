---
interface Props {
  items: {
    label: string;
    href?: string;
    active?: boolean;
  }[];
}

const { items } = Astro.props;
---

<nav class="flex text-sm font-bold text-slate-400 uppercase tracking-[0.2em] mb-8" aria-label="Breadcrumb">
  <ol class="inline-flex items-center gap-3">
    {items.map((item, index) => (
      <li class="flex items-center gap-3">
        {item.active ? (
          <span class="text-blue-700 bg-blue-50 px-3 py-1 rounded-full text-[0.7rem] ring-1 ring-blue-100 whitespace-nowrap">
            {item.label}
          </span>
        ) : (
          <a href={item.href} class="hover:text-blue-600 transition whitespace-nowrap">
            {item.label}
          </a>
        )}
        {index < items.length - 1 && (
          <span class="material-symbols-outlined text-[16px] text-slate-300">chevron_right</span>
        )}
      </li>
    ))}
  </ol>
</nav>
