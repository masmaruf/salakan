---
interface Props {
  items: {
    label: string;
    href?: string;
    active?: boolean;
  }[];
}

const { items } = Astro.props;
---

<nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-6" aria-label="Breadcrumb">
  {items.map((item, index) => (
    <>
      {index > 0 && (
        <span class="material-symbols-outlined text-[16px] text-outline-variant">chevron_right</span>
      )}
      {item.active ? (
        <span class="text-on-surface font-medium truncate max-w-[200px]">{item.label}</span>
      ) : (
        <a href={item.href} class="hover:text-m3-primary transition-colors whitespace-nowrap">{item.label}</a>
      )}
    </>
  ))}
</nav>
