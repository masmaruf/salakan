---
interface Props {
  items: {
    label: string;
    href?: string;
    active?: boolean;
  }[];
}

const { items } = Astro.props;

import { generateBreadcrumbSchema } from '../../lib/seo';
import { siteMeta } from '../../lib/site';

const breadcrumbSchema = generateBreadcrumbSchema(
  items.map((item) => ({
    name: item.label,
    url: new URL(item.href ?? Astro.url.pathname, Astro.site ?? siteMeta.siteUrl).toString(),
  })),
);
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<nav class="breadcrumbs mb-6 text-sm text-base-content/70" aria-label="Breadcrumb">
  <ol>
    {items.map((item) => (
      <li>
        {item.active ? (
          <span class="max-w-full min-w-0 break-words font-semibold text-base-content sm:max-w-[220px] sm:truncate" aria-current="page">{item.label}</span>
        ) : (
          <a href={item.href} class="whitespace-nowrap transition-colors hover:text-primary">{item.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
