---
import Badge from './Badge.astro';
import ContentMeta from './ContentMeta.astro';

interface BadgeItem {
  label: string;
  tone?: 'primary' | 'surface' | 'error' | 'warning' | 'success' | 'info';
  icon?: string;
}

interface MetaItem {
  icon: string;
  text: string;
  datetime?: string;
  accentClass?: string;
}

interface Props {
  href?: string;
  title: string;
  summary?: string;
  badges?: BadgeItem[];
  meta?: MetaItem[];
  image?: string;
  imageAlt?: string;
  class?: string;
}

const {
  href,
  title,
  summary,
  badges = [],
  meta = [],
  image,
  imageAlt,
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'article';
---

<Tag
  href={href}
  class:list={[
    'card group h-full border border-base-300/70 bg-base-100 shadow-sm transition-all',
    href && 'hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40',
    className,
  ]}
>
  {image && (
    <img
      src={image}
      alt={imageAlt || title}
      class="h-52 w-full object-cover"
      loading="lazy"
    />
  )}

  <div class="card-body gap-4 p-5 sm:p-6">
    {badges.length > 0 && (
      <div class="flex flex-wrap items-center gap-2">
        {badges.map((item) => <Badge label={item.label} tone={item.tone} icon={item.icon} />)}
      </div>
    )}

    <div>
      <h3 class="text-xl font-bold tracking-tight text-base-content transition-colors group-hover:text-primary">{title}</h3>
      {summary && <p class="mt-3 text-sm leading-relaxed text-base-content/65">{summary}</p>}
    </div>

  {meta.length > 0 && (
    <ContentMeta
      items={meta}
      class="mt-auto grid gap-2 border-t border-base-300/70 pt-4 text-sm text-base-content/60"
      itemClass="text-sm text-base-content/60"
      iconClass="text-[18px] text-primary"
    />
  )}

    <slot />
  </div>
</Tag>
