---
import Badge from './Badge.astro';
import ContentMeta from './ContentMeta.astro';

interface BadgeItem {
  label: string;
  tone?: 'primary' | 'surface' | 'error' | 'warning' | 'success' | 'info';
  icon?: string;
}

interface MetaItem {
  icon: string;
  text: string;
  datetime?: string;
  accentClass?: string;
}

interface Props {
  href?: string;
  title: string;
  summary?: string;
  badges?: BadgeItem[];
  meta?: MetaItem[];
  image?: string;
  imageAlt?: string;
  class?: string;
}

const {
  href,
  title,
  summary,
  badges = [],
  meta = [],
  image,
  imageAlt,
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'article';
---

<Tag
  href={href}
  class:list={[
    'group section-card flex h-full flex-col gap-4',
    href && 'section-card-hover',
    className,
  ]}
>
  {image && (
    <img
      src={image}
      alt={imageAlt || title}
      class="h-52 w-full rounded-[1.25rem] object-cover"
      loading="lazy"
    />
  )}

  {badges.length > 0 && (
    <div class="flex flex-wrap items-center gap-2">
      {badges.map((item) => <Badge label={item.label} tone={item.tone} icon={item.icon} />)}
    </div>
  )}

  <div>
    <h3 class="text-xl font-bold tracking-tight text-on-surface transition-colors group-hover:text-m3-primary">{title}</h3>
    {summary && <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">{summary}</p>}
  </div>

  {meta.length > 0 && (
    <ContentMeta
      items={meta}
      class="mt-auto grid gap-2 border-t border-outline-variant/50 pt-4 text-sm text-on-surface-variant"
      itemClass="text-sm text-on-surface-variant"
      iconClass="text-[18px] text-m3-primary"
    />
  )}

  <slot />
</Tag>
