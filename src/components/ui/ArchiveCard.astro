---
import Badge from './Badge.astro';
import ContentMeta from './ContentMeta.astro';

interface BadgeItem {
  label: string;
  tone?: 'primary' | 'surface' | 'error' | 'warning' | 'success' | 'info';
  icon?: string;
}

interface MetaItem {
  icon: string;
  text: string;
  datetime?: string;
  accentClass?: string;
}

interface Props {
  href?: string;
  title: string;
  summary?: string;
  badges?: BadgeItem[];
  meta?: MetaItem[];
  image?: string;
  imageAlt?: string;
  class?: string;
}

const {
  href,
  title,
  summary,
  badges = [],
  meta = [],
  image,
  imageAlt,
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'article';
---

<Tag
  href={href}
  class:list={[
    'group flex h-full flex-col overflow-hidden rounded-xl border border-outline-variant bg-surface-container-lowest shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all',
    href && 'hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-m3-primary/40 active:scale-[0.99]',
    className,
  ]}
>
  {image && (
    <img
      src={image}
      alt={imageAlt || title}
      class="h-52 w-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  )}

  <div class="flex flex-1 flex-col gap-4 p-5 sm:p-6">
    {badges.length > 0 && (
      <div class="flex flex-wrap items-center gap-2">
        {badges.map((item) => <Badge label={item.label} tone={item.tone} icon={item.icon} />)}
      </div>
    )}

    <div>
      <h3 class="text-xl font-bold tracking-tight text-on-surface transition-colors group-hover:text-m3-primary">{title}</h3>
      {summary && <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">{summary}</p>}
    </div>

  {meta.length > 0 && (
    <ContentMeta
      items={meta}
      class="mt-auto grid gap-2 border-t border-outline-variant/60 pt-4 text-sm text-on-surface-variant/80"
      itemClass="text-sm text-on-surface-variant/80"
      iconClass="text-[18px] text-m3-primary"
    />
  )}

    <slot />
  </div>
</Tag>
