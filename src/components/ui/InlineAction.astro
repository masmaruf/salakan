---
const {
  href,
  label,
  icon,
  tone = 'primary',
  target,
  rel,
  class: className = '',
  as = href ? 'a' : 'span',
} = Astro.props;

import Icon from './Icon.tsx';

const toneClass =
  tone === 'success'
    ? 'btn btn-success btn-xs rounded-full'
    : tone === 'muted'
      ? 'btn btn-disabled btn-xs rounded-full border-base-300 bg-base-200 text-base-content/60'
      : 'btn btn-outline btn-primary btn-xs rounded-full';

const classes = [toneClass, className].filter(Boolean).join(' ');
---

{as === 'a' ? (
  <a href={href} target={target} rel={rel} class={classes}>
    {icon && <Icon name={icon} class="text-[14px]" />}
    {label}
  </a>
) : (
  <span class={classes}>
    {icon && <Icon name={icon} class="text-[14px]" />}
    {label}
  </span>
)}
