---
interface Props {
  title?: string;
  message: string;
  class?: string;
}

const {
  title,
  message,
  class: className = 'card border border-base-300/70 bg-base-100 text-center text-base-content/70 shadow-sm',
} = Astro.props;
---

<div class={className}>
  <div class="card-body p-8 sm:p-12">
  {title && <p class="mb-2 text-base font-bold text-base-content">{title}</p>}
  <p>{message}</p>
  </div>
</div>
