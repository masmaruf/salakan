---
type TagName = 'article' | 'aside' | 'div' | 'form' | 'section';
type Surface = 'base' | 'muted' | 'plain';
type Shadow = 'none' | 'sm' | 'md';

interface Props {
  as?: TagName;
  action?: string;
  method?: 'get' | 'post';
  class?: string;
  bodyClass?: string;
  surface?: Surface;
  shadow?: Shadow;
  bordered?: boolean;
}

const {
  as = 'div',
  action,
  method,
  class: className = '',
  bodyClass = 'card-body p-5 sm:p-6',
  surface = 'base',
  shadow = 'sm',
  bordered = true,
} = Astro.props as Props;

const Tag = as;
const surfaceClass =
  surface === 'muted'
    ? 'bg-surface-container-low'
    : surface === 'plain'
      ? ''
      : 'bg-surface-container-lowest';
const shadowClass =
  shadow === 'md'
    ? 'shadow-md'
    : shadow === 'sm'
      ? 'shadow-[0_4px_12px_rgba(15,23,42,0.05)]'
      : 'shadow-none';
---

<Tag
  action={action}
  method={method}
  class:list={[
    'card rounded-xl',
    bordered && 'border border-outline-variant',
    surfaceClass,
    shadowClass,
    className,
  ]}
>
  <div class={bodyClass}>
    <slot />
  </div>
</Tag>
