---
import DaisyCard from './DaisyCard.astro';
import SectionHeading from './SectionHeading.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  resultText?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  resultText,
  class: className = '',
} = Astro.props;
---

<DaisyCard class={className} bodyClass="card-body grid gap-4 p-5 sm:p-6">
  <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <SectionHeading
      eyebrow={eyebrow}
      title={title}
      description={description}
      class=""
      contentClass="max-w-2xl"
      titleClass="mt-1 text-2xl font-bold tracking-tight text-base-content"
    />
    {resultText && <p class="max-w-md text-sm font-semibold leading-relaxed text-base-content/70 lg:text-right">{resultText}</p>}
    <slot name="active" />
  </div>

  <slot name="filters" />
</DaisyCard>
