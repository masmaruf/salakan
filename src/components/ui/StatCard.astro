---
interface Props {
  label: string;
  value: string | number;
  icon: string;
  variant?: 'blue' | 'emerald' | 'amber' | 'red' | 'slate';
  description?: string;
}

const { label, value, icon, variant = 'slate', description } = Astro.props;

const iconBgMap = {
  blue: 'bg-primary/10 text-primary',
  emerald: 'bg-emerald-100/50 text-emerald-600',
  amber: 'bg-amber-100/50 text-amber-600',
  red: 'bg-red-100/50 text-red-600',
  slate: 'bg-base-300 text-base-content/70',
};

import Icon from './Icon.tsx';
---

<article class="card border border-base-300/70 bg-base-100 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
  <div class="card-body flex-row items-center gap-4 p-5">
  <div class:list={['grid h-11 w-11 shrink-0 place-items-center rounded-xl', iconBgMap[variant]]}>
    <Icon name={icon} class="text-[22px]" />
  </div>
  <div class="min-w-0">
    <p class="text-[12px] font-semibold uppercase tracking-wider text-base-content/60">{label}</p>
    <p class="text-xl font-bold leading-tight text-base-content">{value}</p>
    {description && <p class="mt-0.5 text-[12px] text-base-content/55">{description}</p>}
  </div>
  </div>
</article>
