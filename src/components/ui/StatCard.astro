---
interface Props {
  label: string;
  value: string | number;
  icon: string;
  variant?: 'blue' | 'emerald' | 'amber' | 'red' | 'slate';
  description?: string;
}

const { label, value, icon, variant = 'slate', description } = Astro.props;

const iconBgMap = {
  blue: 'bg-primary-container/30 text-m3-primary',
  emerald: 'bg-emerald-100/50 text-emerald-600',
  amber: 'bg-amber-100/50 text-amber-600',
  red: 'bg-red-100/50 text-red-600',
  slate: 'bg-surface-container-high text-on-surface-variant',
};
---

<article class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 flex items-center gap-4 transition-all hover:-translate-y-0.5 hover:shadow-md">
  <div class:list={['grid h-11 w-11 shrink-0 place-items-center rounded-xl', iconBgMap[variant]]}>
    <span class="material-symbols-outlined text-[22px]">{icon}</span>
  </div>
  <div class="min-w-0">
    <p class="text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider">{label}</p>
    <p class="text-xl font-bold text-on-surface leading-tight">{value}</p>
    {description && <p class="text-[12px] text-outline mt-0.5">{description}</p>}
  </div>
</article>
