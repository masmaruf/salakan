---
interface Props {
  label: string;
  value: string | number;
  icon: string;
  variant?: 'blue' | 'emerald' | 'amber' | 'red' | 'slate';
  description?: string;
}

const { label, value, icon, variant = 'slate', description } = Astro.props;

const iconBgMap = {
  blue: 'bg-primary-container/40 text-m3-primary',
  emerald: 'bg-success/10 text-success',
  amber: 'bg-warning/10 text-warning',
  red: 'bg-error/10 text-error',
  slate: 'bg-surface-container-low text-on-surface-variant',
};

import Icon from './Icon.tsx';
---

<article class="flex items-center gap-4 rounded-xl border border-outline-variant bg-surface-container-lowest p-5 shadow-[0_4px_12px_rgba(15,23,42,0.05)] transition-all hover:-translate-y-0.5 hover:border-m3-primary/30 hover:shadow-md">
  <div class:list={['grid h-11 w-11 shrink-0 place-items-center rounded-xl', iconBgMap[variant]]}>
    <Icon name={icon} class="text-[22px]" />
  </div>
  <div class="min-w-0">
    <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">{label}</p>
    <p class="text-xl font-bold leading-tight text-on-surface">{value}</p>
    {description && <p class="mt-0.5 text-[12px] text-on-surface-variant/80">{description}</p>}
  </div>
</article>
