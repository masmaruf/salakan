---
interface Props {
  title?: string;
  icon?: string;
  class?: string;
  bodyClass?: string;
}

const {
  title,
  icon,
  class: className = 'card border border-base-300/70 bg-base-100 shadow-sm',
  bodyClass = 'card-body p-5 sm:p-6',
} = Astro.props;

import Icon from './Icon.tsx';
---

<div class={className}>
  <div class={bodyClass}>
    {(title || icon) && (
      <div class="mb-2 flex items-center gap-2 text-[12px] font-semibold uppercase tracking-wider text-primary">
        {icon && <Icon name={icon} class="text-[16px]" />}
        {title && <span>{title}</span>}
      </div>
    )}
    <slot />
  </div>
</div>
