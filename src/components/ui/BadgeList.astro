---
import Badge from './Badge.astro';

interface Item {
  label: string;
  tone?: 'primary' | 'surface' | 'error' | 'warning' | 'success' | 'info';
  variant?: 'outline' | 'soft' | 'ghost';
  icon?: string;
  iconClass?: string;
  href?: string;
  target?: string;
  rel?: string;
  datetime?: string;
  class?: string;
  visible?: boolean;
}

interface Props {
  items: Item[];
  class?: string;
}

const { items, class: className = 'flex flex-wrap items-center gap-2' } = Astro.props;
const visibleItems = items.filter((item) => item.visible !== false);
---

{visibleItems.length > 0 && (
  <div class={className}>
    {visibleItems.map((item) => (
      <Badge
        label={item.label}
        tone={item.tone}
        variant={item.variant}
        icon={item.icon}
        iconClass={item.iconClass}
        href={item.href}
        target={item.target}
        rel={item.rel}
        datetime={item.datetime}
        class={item.class}
      />
    ))}
  </div>
)}
