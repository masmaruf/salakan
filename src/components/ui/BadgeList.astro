---
import Badge from './Badge.astro';

interface Item {
  label: string;
  tone?: 'primary' | 'surface' | 'error' | 'warning' | 'success' | 'info';
  icon?: string;
  class?: string;
  visible?: boolean;
}

interface Props {
  items: Item[];
  class?: string;
}

const { items, class: className = 'flex flex-wrap items-center gap-2' } = Astro.props;
const visibleItems = items.filter((item) => item.visible !== false);
---

{visibleItems.length > 0 && (
  <div class={className}>
    {visibleItems.map((item) => (
      <Badge label={item.label} tone={item.tone} icon={item.icon} class={item.class} />
    ))}
  </div>
)}
