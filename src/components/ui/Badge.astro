---
interface Props {
  label: string;
  tone?: 'primary' | 'surface' | 'error' | 'warning' | 'success' | 'info';
  icon?: string;
  class?: string;
}

const {
  label,
  tone = 'primary',
  icon,
  class: className = '',
} = Astro.props;

const toneClasses = {
  primary: 'badge-primary badge-outline',
  surface: 'badge-ghost border-base-300 text-base-content/70',
  error: 'badge-error badge-outline',
  warning: 'badge-warning badge-outline',
  success: 'badge-success badge-outline',
  info: 'badge-info badge-outline',
};

import Icon from './Icon.tsx';
---

<span class:list={[
  'badge inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-[12px] font-semibold',
  toneClasses[tone],
  className,
]}>
  {icon && <Icon name={icon} class="text-[12px]" />}
  <span>{label}</span>
</span>
