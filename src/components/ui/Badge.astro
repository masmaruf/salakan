---
import Icon from './Icon.tsx';
import type { BadgeTone, BadgeVariant } from '../../lib/ui-badge';
import { getBadgeClasses } from '../../lib/ui-badge';

interface Props {
  label: string;
  tone?: BadgeTone;
  variant?: BadgeVariant;
  icon?: string;
  iconClass?: string;
  href?: string;
  target?: string;
  rel?: string;
  datetime?: string;
  class?: string;
}

const {
  label,
  tone = 'primary',
  variant = 'outline',
  icon,
  iconClass = 'shrink-0 text-[12px]',
  href,
  target,
  rel,
  datetime,
  class: className = '',
} = Astro.props;
---

{href ? (
  <a
    href={href}
    target={target}
    rel={rel}
    class:list={[getBadgeClasses({ tone, variant, className }), 'transition-colors active:scale-[0.99]']}
  >
    {icon && <Icon name={icon} class={iconClass} />}
    <span>{label}</span>
  </a>
) : datetime ? (
  <time
    datetime={datetime}
    class={getBadgeClasses({ tone, variant, className })}
  >
    {icon && <Icon name={icon} class={iconClass} />}
    <span>{label}</span>
  </time>
) : (
  <span class={getBadgeClasses({ tone, variant, className })}>
    {icon && <Icon name={icon} class={iconClass} />}
    <span>{label}</span>
  </span>
)}
