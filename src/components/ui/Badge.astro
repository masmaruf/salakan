---
interface Props {
  label: string;
  tone?: 'primary' | 'surface' | 'error' | 'warning' | 'success' | 'info';
  icon?: string;
  class?: string;
}

const {
  label,
  tone = 'primary',
  icon,
  class: className = '',
} = Astro.props;

const toneClasses = {
  primary: 'bg-primary-container text-on-primary-container',
  surface: 'border border-outline-variant bg-surface-variant text-on-surface-variant',
  error: 'bg-error-container text-on-error-container',
  warning: 'bg-amber-100 text-amber-800',
  success: 'bg-emerald-100 text-emerald-800',
  info: 'bg-blue-100 text-blue-800',
};

import Icon from './Icon.tsx';
---

<span class:list={[
  'inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-[12px] font-semibold',
  toneClasses[tone],
  className,
]}>
  {icon && <Icon name={icon} class="text-[12px]" />}
  <span>{label}</span>
</span>
