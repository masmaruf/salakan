---
interface Props {
  namaLayanan: string;
  ringkasan: string;
  syarat: string[];
  langkah: string[];
  kontak: string;
  jamLayanan: string;
}

const { namaLayanan, ringkasan, syarat, langkah, kontak, jamLayanan } = Astro.props;
---

<article class="group relative rounded-[3rem] bg-white/80 backdrop-blur-md p-8 md:p-10 shadow-sm border border-slate-100 transition-all duration-500 hover:shadow-xl hover:-translate-y-2 overflow-hidden">
  <div class="absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition duration-500">
    <span class="material-symbols-outlined text-9xl">support_agent</span>
  </div>
  
  <div class="relative z-10 flex flex-col h-full">
    <div class="flex items-start justify-between gap-6 mb-8">
      <div class="flex-1 min-w-0">
        <h2 class="text-3xl font-black tracking-tight text-slate-900 group-hover:text-blue-700 transition-colors leading-[1.1]">
          {namaLayanan}
        </h2>
        <p class="mt-4 text-lg font-bold text-slate-400 leading-relaxed group-hover:text-slate-500 transition-colors">
          {ringkasan}
        </p>
      </div>
      <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600 shadow-inner group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
        <span class="material-symbols-outlined text-[32px]">description</span>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 flex-1">
      <div class="rounded-3xl bg-slate-50/50 p-6 md:p-8 border border-slate-100/50 group-hover:bg-white transition-colors duration-500">
        <p class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-widest mb-6">
          <span class="material-symbols-outlined text-[18px] text-blue-500">checklist</span> Syarat Utama
        </p>
        <ul class="space-y-4 text-[0.95rem] font-medium leading-relaxed text-slate-600">
          {syarat.map((item) => (
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined mt-0.5 text-[18px] text-emerald-500">check_circle</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      
      <div class="rounded-3xl bg-blue-50/30 p-6 md:p-8 border border-blue-100/20 group-hover:bg-white transition-colors duration-500">
        <p class="flex items-center gap-2 text-xs font-black text-slate-900 uppercase tracking-widest mb-6">
          <span class="material-symbols-outlined text-[18px] text-amber-500">format_list_numbered</span> Alur Proses
        </p>
        <ol class="space-y-4 text-[0.95rem] font-medium leading-relaxed text-slate-600">
          {langkah.map((item, idx) => (
            <li class="flex items-start gap-4">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-white text-xs font-black text-blue-700 shadow-sm border border-blue-100 ring-2 ring-blue-50">
                {idx + 1}
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap gap-4 pt-8 border-t border-slate-100">
      <div class="flex items-center gap-3 rounded-2xl bg-white px-5 py-3 shadow-sm border border-slate-100 text-sm font-black text-slate-700 transition group-hover:border-blue-100">
        <span class="material-symbols-outlined text-[20px] text-blue-500">call</span> 
        {kontak}
      </div>
      <div class="flex items-center gap-3 rounded-2xl bg-white px-5 py-3 shadow-sm border border-slate-100 text-sm font-black text-slate-700 transition group-hover:border-blue-100">
        <span class="material-symbols-outlined text-[20px] text-emerald-500">schedule</span> 
        {jamLayanan}
      </div>
    </div>
  </div>
</article>
