---
interface Item {
  href: string;
  label: string;
  active?: boolean;
}

interface Props {
  items: Item[];
  class?: string;
}

const {
  items,
  class: className = 'mt-4 flex items-center gap-2 overflow-x-auto pb-2 hide-scrollbar sm:mt-5',
} = Astro.props;
---

<div class={className}>
  {items.map((item) => (
    <a
      href={item.href}
      class:list={[
        'btn btn-sm min-h-[38px] whitespace-nowrap rounded-full px-4 text-sm font-semibold',
        item.active
          ? 'btn-primary shadow-sm'
          : 'btn-outline bg-base-100 text-base-content/70',
      ]}
      aria-current={item.active ? 'page' : undefined}
    >
      {item.label}
    </a>
  ))}
</div>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
