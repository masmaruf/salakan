---
interface LinkItem {
  label: string;
  href: string;
  icon: string;
  copy?: boolean;
}

interface Props {
  title?: string;
  links: LinkItem[];
}

const { title = 'Bagikan halaman ini', links } = Astro.props;

import Icon from './ui/Icon.tsx';
---

<div class="mt-8 border-t border-base-300/70 pt-6">
  <p class="mb-3 text-sm font-semibold text-base-content/70">{title}</p>
  <div class="flex gap-2">
    {links.map((link) => (
      <a
        href={link.href}
        class="grid h-10 w-10 place-items-center rounded-xl border border-base-300 bg-base-100 text-base-content/70 transition-colors hover:border-transparent hover:bg-primary/10 hover:text-base-content"
        target={link.copy ? undefined : '_blank'}
        rel={link.copy ? undefined : 'noreferrer'}
        title={link.label}
        data-copy-link={link.copy ? '' : undefined}
        data-copy-value={link.copy ? link.href : undefined}
      >
        <Icon name={link.icon} class="text-[20px]" />
      </a>
    ))}
  </div>
</div>

<script is:inline>
  document.querySelectorAll('[data-copy-link]').forEach((button) => {
    button.addEventListener('click', async (event) => {
      event.preventDefault();
      const value = button.getAttribute('data-copy-value') || '';
      try {
        await navigator.clipboard.writeText(value);
      } catch {}
    });
  });
</script>
