---
import Icon from './ui/Icon.tsx';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { href: '/berita', label: 'Berita', icon: 'article' },
  { href: '/', label: 'Beranda', icon: 'home' },
  { href: '/data', label: 'Layanan', icon: 'gavel' },
  { href: '/galeri', label: 'Galeri', icon: 'image' },
];

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  return current === href || current.startsWith(href + '/');
}
---

<nav
  class="fixed bottom-0 left-0 z-50 flex w-full items-center justify-around border-t border-outline-variant/70 bg-surface-container-lowest/95 px-1.5 pb-[calc(env(safe-area-inset-bottom,0px)+0.35rem)] pt-1.5 shadow-[0_-2px_16px_rgba(15,23,42,0.08)] backdrop-blur-lg md:hidden"
  aria-label="Navigasi mobile"
>
  {navItems.map((item) => {
    const active = isActive(item.href, currentPath);
    return (
      <a
        href={item.href}
        class:list={[
          'flex min-h-[56px] min-w-[60px] flex-col items-center justify-center gap-0.5 rounded-2xl px-3 py-2 transition-all active:scale-95',
          active
            ? 'bg-m3-primary text-on-primary shadow-sm'
            : 'text-on-surface-variant hover:bg-surface-container-low active:bg-surface-container',
        ]}
        aria-current={active ? 'page' : undefined}
      >
        <Icon name={item.icon} class="text-[22px]" />
        <span
          class:list={[
            'text-[10px] leading-tight',
            active ? 'font-bold' : 'font-medium',
          ]}
        >
          {item.label}
        </span>
      </a>
    );
  })}
</nav>
