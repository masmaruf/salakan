---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { href: '/agenda', label: 'Agenda', icon: 'calendar_month' },
  { href: '/berita', label: 'Berita', icon: 'article' },
  { href: '/', label: 'Beranda', icon: 'home' },
  { href: '/data', label: 'Layanan', icon: 'gavel' },
  { href: '/galeri', label: 'Galeri', icon: 'image' },
];

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  return current === href || current.startsWith(href + '/');
}
---

<nav
  class="fixed bottom-0 left-0 w-full z-50 md:hidden flex justify-around items-center px-1 pb-[env(safe-area-inset-bottom,6px)] pt-1.5 shadow-[0_-2px_16px_rgba(15,23,42,0.08)] bg-white/95 backdrop-blur-lg border-t border-slate-100"
  aria-label="Navigasi mobile"
>
  {navItems.map((item) => {
    const active = isActive(item.href, currentPath);
    return (
      <a
        href={item.href}
        class:list={[
          'flex flex-col items-center justify-center rounded-2xl px-3 py-1.5 min-w-[58px] min-h-[52px] transition-colors',
          active
            ? 'bg-primary-container text-on-primary-container'
            : 'text-on-surface-variant active:bg-surface-container-low',
        ]}
        aria-current={active ? 'page' : undefined}
      >
        <span
          class="material-symbols-outlined text-[22px]"
          style={active ? "font-variation-settings: 'FILL' 1;" : "font-variation-settings: 'FILL' 0;"}
        >
          {item.icon}
        </span>
        <span
          class:list={[
            'text-[10px] leading-tight mt-0.5',
            active ? 'font-bold' : 'font-medium',
          ]}
        >
          {item.label}
        </span>
      </a>
    );
  })}
</nav>
