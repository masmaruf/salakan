---
import DaisyContainer from './ui/DaisyContainer.astro';
import SectionHeading from './ui/SectionHeading.astro';

interface Props {
  title?: string;
  eyebrow?: string;
  actionHref?: string;
  actionLabel?: string;
  sectionClass?: string;
  containerClass?: string;
  headerClass?: string;
}

const {
  title,
  eyebrow,
  actionHref,
  actionLabel,
  sectionClass = 'py-10 sm:py-14',
  containerClass = 'container-premium',
  headerClass = 'mb-6 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center',
} = Astro.props;
---

<DaisyContainer class={sectionClass} containerClass={containerClass}>
    <SectionHeading
      eyebrow={eyebrow}
      title={title}
      actionHref={actionHref}
      actionLabel={actionLabel}
      class={headerClass}
    />
    <slot />
</DaisyContainer>
