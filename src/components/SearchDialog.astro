---
---

<button
  type="button"
  class="js-search-open inline-flex h-9 w-9 items-center justify-center rounded-full text-on-surface-variant transition-colors hover:bg-surface-container-high hover:text-on-surface focus:outline-none focus-visible:ring-2 focus-visible:ring-m3-primary focus-visible:ring-offset-2"
  aria-label="Cari di website"
  aria-haspopup="dialog"
>
  <svg aria-hidden="true" class="h-[22px] w-[22px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="7"></circle>
    <path d="m20 20-3.5-3.5"></path>
  </svg>
</button>

<div class="js-search-modal fixed inset-0 z-50 hidden bg-inverse-surface/40 p-3 backdrop-blur-sm sm:p-4" role="presentation">
  <div
    role="dialog"
    aria-modal="true"
    aria-labelledby="search-dialog-title"
    class="mx-auto mt-6 flex max-h-[88vh] w-full max-w-3xl flex-col overflow-hidden rounded-2xl border border-outline-variant bg-surface-container-lowest shadow-[0_32px_80px_rgba(15,23,42,0.2)] sm:mt-[8vh] sm:max-h-[80vh]"
  >
    <div class="border-b border-outline-variant/40 px-5 py-4">
      <div class="flex items-center gap-3">
        <svg aria-hidden="true" class="h-6 w-6 shrink-0 text-m3-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
        <h2 id="search-dialog-title" class="sr-only">Pencarian</h2>
        <input
          class="js-search-input h-auto min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-semibold text-on-surface outline-none placeholder:text-outline focus-visible:ring-0"
          placeholder="Cari agenda, berita, layanan, atau dokumen"
          autocomplete="off"
        />
        <button
          type="button"
          class="js-search-close rounded-full p-1.5 text-on-surface-variant opacity-80 transition hover:bg-surface-container-high hover:opacity-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-m3-primary"
          aria-label="Tutup pencarian"
        >
          <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>
      <div class="js-search-filters mt-4 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"></div>
    </div>

    <div class="js-search-results min-h-0 flex-1 overflow-y-auto p-4">
      <div class="py-12 text-center">
        <div class="mx-auto grid h-16 w-16 place-items-center rounded-xl bg-surface-container-low text-outline animate-pulse">
          <svg aria-hidden="true" class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2h12"></path>
            <path d="M6 22h12"></path>
            <path d="M7 2c0 6 10 6 10 10s-10 4-10 10"></path>
            <path d="M17 2c0 6-10 6-10 10s10 4 10 10"></path>
          </svg>
        </div>
        <p class="mt-3 text-[12px] font-semibold uppercase tracking-wider text-outline">Memuat data...</p>
      </div>
    </div>
  </div>
</div>

<script>
  // @ts-nocheck
  // Search records are escaped before insertion; innerHTML is only used to render trusted UI templates efficiently.
  const typeOrder = ['semua', 'berita', 'agenda', 'layanan', 'data', 'galeri'];
  const typeMeta = {
    berita: { label: 'Berita', icon: 'news' },
    agenda: { label: 'Agenda', icon: 'calendar' },
    layanan: { label: 'Layanan', icon: 'file' },
    data: { label: 'Data', icon: 'chart' },
    galeri: { label: 'Galeri', icon: 'image' },
  };

  const root = document.currentScript?.parentElement;
  const openButton = root?.querySelector('.js-search-open');
  const modal = root?.querySelector('.js-search-modal');
  const closeButton = root?.querySelector('.js-search-close');
  const input = root?.querySelector('.js-search-input');
  const filters = root?.querySelector('.js-search-filters');
  const resultsEl = root?.querySelector('.js-search-results');

  let records = [];
  let loaded = false;
  let loading = false;
  let activeType = 'semua';
  let previousOverflow = '';

  const normalize = (value) => String(value || '')
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  const haystack = (item) => normalize([
    item.title,
    item.description,
    item.type,
    item.category,
    ...(item.keywords || []),
  ].filter(Boolean).join(' '));

  const iconSvg = (name, className = 'h-5 w-5') => {
    if (name === 'chevron') return `<svg aria-hidden="true" class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>`;
    if (name === 'empty') return `<svg aria-hidden="true" class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path><path d="m7 7 8 8"></path></svg>`;
    return `<svg aria-hidden="true" class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>`;
  };

  const escapeHtml = (value) => String(value || '').replace(/[&<>'"]/g, (char) => ({
    '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
  })[char]);

  const formatDate = (value) => {
    if (!value) return '';
    try {
      return new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(value));
    } catch {
      return '';
    }
  };

  const getCounts = () => typeOrder.reduce((acc, type) => {
    acc[type] = type === 'semua' ? records.length : records.filter((item) => item.type === type).length;
    return acc;
  }, {});

  const renderFilters = () => {
    if (!filters) return;
    const counts = getCounts();
    filters.innerHTML = typeOrder.map((type) => {
      const meta = type === 'semua' ? { label: 'Semua' } : (typeMeta[type] || { label: type });
      const active = activeType === type;
      return `<button type="button" data-search-type="${type}" class="inline-flex min-h-[38px] items-center gap-2 whitespace-nowrap rounded-full px-4 py-2 text-sm font-semibold transition-colors ${active ? 'bg-primary-container text-on-primary-container shadow-sm' : 'border border-outline-variant bg-white text-on-surface-variant hover:bg-surface-container-low'}">${type === 'semua' ? iconSvg('travel', 'h-4 w-4') : iconSvg(meta.icon, 'h-4 w-4')} ${escapeHtml(meta.label)} <span class="text-[11px] opacity-70">${counts[type] ?? 0}</span></button>`;
    }).join('');
  };

  const sortRecords = (items) => [...items].sort((a, b) => {
    const priority = (item) => item.priority === 'high' ? 1 : 0;
    const date = (item) => item.date ? new Date(item.date).getTime() : 0;
    return priority(b) - priority(a) || date(b) - date(a);
  });

  const renderResults = () => {
    if (!resultsEl || !input) return;
    if (loading) return;

    const query = normalize(input.value);
    const quick = sortRecords(records).slice(0, 5);
    const filteredByQuery = query ? records.filter((item) => haystack(item).includes(query)) : quick;
    const results = sortRecords(filteredByQuery)
      .filter((item) => activeType === 'semua' || item.type === activeType)
      .slice(0, 10);

    if (results.length === 0) {
      resultsEl.innerHTML = `<div class="py-16 text-center"><div class="mx-auto grid h-16 w-16 place-items-center rounded-full bg-surface-container-low text-outline">${iconSvg('empty', 'h-8 w-8')}</div><p class="mt-4 text-base font-bold text-on-surface">Tidak ditemukan</p><p class="mt-1 text-sm text-on-surface-variant">Coba kata kunci lain atau ubah tipe pencarian.</p></div>`;
      return;
    }

    const intro = query ? '' : `<div class="mb-4 rounded-2xl border border-outline-variant bg-surface-container-low/60 p-4"><p class="text-[12px] font-semibold uppercase tracking-wider text-outline">Akses cepat warga</p><p class="mt-1 text-sm text-on-surface-variant">Mulai dari agenda penting, informasi terbaru, atau layanan yang paling sering dicari.</p></div>`;

    resultsEl.innerHTML = `${intro}<div class="space-y-1"><p class="mb-2 px-2 text-[12px] font-semibold uppercase tracking-wider text-outline">${query ? `${results.length} hasil ditemukan` : 'Saran cepat'}</p>${results.map((item) => {
      const meta = typeMeta[item.type] || { label: item.type, icon: 'search' };
      const date = formatDate(item.date);
      return `<a href="${escapeHtml(item.url)}" class="group flex items-start gap-4 rounded-xl p-3 transition-colors hover:bg-surface-container-low focus:outline-none focus-visible:ring-2 focus-visible:ring-m3-primary"><div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-primary-container/30 text-m3-primary transition-colors group-hover:bg-m3-primary group-hover:text-on-primary">${iconSvg(meta.icon, 'h-5 w-5')}</div><div class="min-w-0 flex-1"><div class="flex flex-wrap items-center gap-2 text-[11px] font-semibold uppercase tracking-wider text-outline"><span>${escapeHtml(meta.label)}</span>${item.priority === 'high' ? '<span class="rounded-full bg-error-container px-2 py-0.5 text-[10px] text-on-error-container">Penting</span>' : ''}${date ? `<span class="normal-case tracking-normal">${escapeHtml(date)}</span>` : ''}</div><h3 class="truncate text-sm font-bold leading-tight text-on-surface transition-colors group-hover:text-m3-primary">${escapeHtml(item.title)}</h3><p class="mt-0.5 line-clamp-2 text-[12px] text-on-surface-variant">${escapeHtml(item.description)}</p></div>${iconSvg('chevron', 'h-[18px] w-[18px] text-outline transition-transform group-hover:translate-x-0.5 group-hover:text-m3-primary')}</a>`;
    }).join('')}</div>`;
  };

  const loadSearch = async () => {
    if (loaded || loading) return;
    loading = true;
    try {
      const response = await fetch('/api/search.json');
      records = await response.json();
    } catch {
      records = [];
    } finally {
      loaded = true;
      loading = false;
      renderFilters();
      renderResults();
    }
  };

  const openSearch = () => {
    if (!modal || !input) return;
    previousOverflow = document.body.style.overflow;
    document.body.style.overflow = 'hidden';
    modal.classList.remove('hidden');
    input.focus();
    loadSearch();
  };

  const closeSearch = () => {
    if (!modal || !input) return;
    document.body.style.overflow = previousOverflow;
    modal.classList.add('hidden');
    input.value = '';
    activeType = 'semua';
    renderFilters();
  };

  openButton?.addEventListener('click', openSearch);
  closeButton?.addEventListener('click', closeSearch);
  input?.addEventListener('input', renderResults);
  filters?.addEventListener('click', (event) => {
    const button = event.target instanceof Element ? event.target.closest('[data-search-type]') : null;
    if (!button) return;
    activeType = button.getAttribute('data-search-type') || 'semua';
    renderFilters();
    renderResults();
  });
  modal?.addEventListener('mousedown', (event) => {
    if (event.target === modal) closeSearch();
  });
  window.addEventListener('keydown', (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      openSearch();
    }
    if (event.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeSearch();
    }
  });

  renderFilters();
</script>
