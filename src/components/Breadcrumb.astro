---
/**
 * Breadcrumb navigation component for salakan.id
 * Improves SEO and user navigation
 * 
 * Usage:
 * <Breadcrumb items={[
 *   { name: 'Beranda', href: '/' },
 *   { name: 'Berita', href: '/berita' },
 *   { name: 'Judul Berita' },
 * ]} />
 */

interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;

import { generateBreadcrumbSchema } from '../lib/seo';
import { siteMeta } from '../lib/site';

// Generate JSON-LD for breadcrumbs
const breadcrumbJsonLd = generateBreadcrumbSchema(
  items.map((item) => ({
    name: item.name,
    url: new URL(item.href ?? Astro.url.pathname, Astro.site ?? siteMeta.siteUrl).toString(),
  })),
);
---

{/* Breadcrumb JSON-LD */}
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

{/* Visual Breadcrumb */}
<nav aria-label="Breadcrumb" class:list={['text-sm', className]}>
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && (
          <span class="text-base-content/50" aria-hidden="true">/</span>
        )}
        {item.href ? (
          <a
            href={item.href}
            class="text-base-content/70 hover:text-primary transition-colors"
          >
            {item.name}
          </a>
        ) : (
          <span class="font-medium text-base-content" aria-current="page">
            {item.name}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
