---
/**
 * Breadcrumb navigation component for salakan.id
 * Improves SEO and user navigation
 *
 * Usage:
 * <Breadcrumb items={[
 *   { name: 'Beranda', href: '/' },
 *   { name: 'Berita', href: '/berita' },
 *   { name: 'Judul Berita' },
 * ]} />
 */

interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;

import { generateBreadcrumbSchema } from '../lib/seo';
import { siteMeta } from '../lib/site';

const breadcrumbJsonLd = generateBreadcrumbSchema(
  items.map((item) => ({
    name: item.name,
    url: new URL(item.href ?? Astro.url.pathname, Astro.site ?? siteMeta.siteUrl).toString(),
  })),
);
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

<nav aria-label="Breadcrumb" class:list={['breadcrumbs text-sm text-base-content/70', className]}>
  <ol>
    {items.map((item) => (
      <li>
        {item.href ? (
          <a href={item.href} class="transition-colors hover:text-primary">
            {item.name}
          </a>
        ) : (
          <span class="max-w-full min-w-0 break-words font-semibold text-base-content" aria-current="page">
            {item.name}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
