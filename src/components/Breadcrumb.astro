---
/**
 * Breadcrumb navigation component for salakan.id
 * Improves SEO and user navigation
 *
 * Usage:
 * <Breadcrumb items={[
 *   { name: 'Beranda', href: '/' },
 *   { name: 'Berita', href: '/berita' },
 *   { name: 'Judul Berita' },
 * ]} />
 */

interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;

import { generateBreadcrumbSchema } from '../lib/seo';
import { siteMeta } from '../lib/site';
import Icon from './ui/Icon.tsx';

const breadcrumbJsonLd = generateBreadcrumbSchema(
  items.map((item) => ({
    name: item.name,
    url: new URL(item.href ?? Astro.url.pathname, Astro.site ?? siteMeta.siteUrl).toString(),
  })),
);
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

<nav aria-label="Breadcrumb" class:list={['flex flex-wrap items-center gap-1.5 text-sm text-on-surface-variant', className]}>
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {item.href ? (
          <a href={item.href} class="rounded-md px-1 transition-colors hover:text-m3-primary">
            {item.name}
          </a>
        ) : (
          <span class="max-w-full min-w-0 break-words rounded-md px-1 font-semibold text-on-surface" aria-current="page">
            {item.name}
          </span>
        )}
        {index < items.length - 1 && (
          <Icon name="chevron_right" class="text-[14px] text-outline-variant" />
        )}
      </li>
    ))}
  </ol>
</nav>
