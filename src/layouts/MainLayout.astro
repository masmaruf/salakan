---
import MobileNav from '../components/MobileNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import '../styles/global.css';
import { getSeoImage, siteMeta, toAbsoluteUrl } from '../lib/site';
import { SEO } from 'astro-seo';
import { Schema } from 'astro-seo-schema';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  noIndex?: boolean;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  image,
  type = 'website',
  publishedTime,
  noIndex = false,
} = Astro.props;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : new URL(Astro.url.pathname, siteMeta.siteUrl);
const seoImage = getSeoImage(image);
---

<!doctype html>
<html lang="id" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#3b5998" />
    <SEO
      title={title}
      description={description}
      canonical={canonical.toString()}
      noindex={noIndex}
      nofollow={noIndex}
      openGraph={{
        basic: {
          title,
          type,
          image: seoImage,
          url: canonical.toString(),
        },
        optional: {
          description,
          locale: siteMeta.locale,
          siteName: siteMeta.name,
        },
        image: {
          alt: title,
          width: 1200,
          height: 630,
        },
        ...(type === 'article' && publishedTime
          ? { article: { publishedTime: new Date(publishedTime).toISOString() } }
          : {}),
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: seoImage,
      }}
    />
    {type === 'article' && publishedTime ? (
      <Schema
        item={{
          '@context': 'https://schema.org',
          '@type': 'Article',
          headline: title,
          description,
          image: [seoImage],
          datePublished: publishedTime,
          inLanguage: 'id-ID',
          mainEntityOfPage: canonical.toString(),
          publisher: {
            '@type': 'Organization',
            name: siteMeta.name,
            url: siteMeta.siteUrl,
          },
        }}
      />
    ) : (
      <Schema
        item={{
          '@context': 'https://schema.org',
          '@type': 'WebSite',
          name: siteMeta.name,
          description,
          url: siteMeta.siteUrl,
          inLanguage: 'id-ID',
        }}
      />
    )}
    <link rel="icon" type="image/svg+xml" href="/images/og-salakan.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
    <link rel="alternate" type="application/rss+xml" title="RSS Berita Padukuhan Salakan" href={toAbsoluteUrl('/rss/berita.xml')} />
    <link rel="alternate" type="application/rss+xml" title="RSS Pengumuman Padukuhan Salakan" href={toAbsoluteUrl('/rss/pengumuman.xml')} />
  </head>
  <body class="relative min-h-screen bg-slate-50 pb-[calc(4.5rem+env(safe-area-inset-bottom,0px))] md:pb-0">
    {/* Glowing Orbs Background */}
    <div class="orb-blue"></div>
    <div class="orb-emerald"></div>

    <SiteHeader currentPath={Astro.url.pathname} />
    <main id="app-shell" class="relative z-10 min-h-screen">
      <slot />
    </main>
    <SiteFooter />
    <MobileNav currentPath={Astro.url.pathname} />
  </body>
</html>
