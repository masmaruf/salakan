---
import MobileNav from '../components/MobileNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import DevServiceWorkerReset from '../components/DevServiceWorkerReset.astro';
import '../styles/global.css';
import { getSeoImage, siteMeta, toAbsoluteUrl } from '../lib/site';
import { generateLocalBusinessSchema, generateWebSiteSchema, localSeo } from '../lib/seo';
import { SEO } from 'astro-seo';
import { Schema } from 'astro-seo-schema';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  noIndex?: boolean;
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  noIndex = false,
  breadcrumbs,
} = Astro.props;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : new URL(Astro.url.pathname, siteMeta.siteUrl);
const seoImage = getSeoImage(image);

// Generate schemas for all pages
const localBusinessSchema = generateLocalBusinessSchema();
const webSiteSchema = generateWebSiteSchema();
---

<!doctype html>
<html lang="id" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={siteMeta.themeColor} />
    
    {/* Local SEO Geo Meta Tags */}
    <meta name="geo.region" content="ID-YO" />
    <meta name="geo.placename" content="Bangunjiwo, Kasihan, Bantul" />
    <meta name="geo.position" content={`${localSeo.latitude};${localSeo.longitude}`} />
    <meta name="ICBM" content={`${localSeo.latitude}, ${localSeo.longitude}`} />
    
    {/* Additional SEO Meta Tags */}
    <meta name="author" content={siteMeta.name} />
    <meta name="language" content="id" />
    <meta name="revisit-after" content="3 days" />
    <meta name="rating" content="general" />
    <meta name="distribution" content="global" />
    
    {/* Mobile Web App */}
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={siteMeta.name} />
    <SEO
      title={title}
      description={description}
      canonical={canonical.toString()}
      noindex={noIndex}
      nofollow={noIndex}
      openGraph={{
        basic: {
          title,
          type,
          image: seoImage,
          url: canonical.toString(),
        },
        optional: {
          description,
          locale: siteMeta.locale,
          siteName: siteMeta.name,
        },
        image: {
          alt: title,
          width: 1200,
          height: 630,
        },
        ...(type === 'article' && publishedTime
          ? { article: { publishedTime: new Date(publishedTime).toISOString() } }
          : {}),
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: seoImage,
      }}
    />
    
    {/* LocalBusiness Schema - appears on all pages */}
    <Schema item={localBusinessSchema} />
    
    {/* WebSite Schema - appears on all pages */}
    <Schema item={webSiteSchema} />
    
    {type === 'article' && publishedTime ? (
      <Schema
        item={{
          '@context': 'https://schema.org',
          '@type': 'Article',
          headline: title,
          description,
          image: [seoImage],
          datePublished: publishedTime,
          inLanguage: 'id-ID',
          mainEntityOfPage: canonical.toString(),
          publisher: {
            '@type': 'Organization',
            name: siteMeta.name,
            url: siteMeta.siteUrl,
          },
        }}
      />
    ) : (
      <Schema
        item={{
          '@context': 'https://schema.org',
          '@type': 'WebSite',
          name: siteMeta.name,
          description,
          url: siteMeta.siteUrl,
          inLanguage: 'id-ID',
        }}
      />
    )}
    <link rel="icon" type="image/svg+xml" href="/images/og-salakan.svg" />
    <link rel="alternate" type="application/rss+xml" title="RSS Berita Padukuhan Salakan" href={toAbsoluteUrl('/rss/berita.xml')} />
    <link rel="alternate" type="application/rss+xml" title="RSS Agenda Warga Padukuhan Salakan" href={toAbsoluteUrl('/rss/pengumuman.xml')} />

  </head>
  <body class="relative min-h-screen bg-slate-50 pb-[calc(4.5rem+env(safe-area-inset-bottom,0px))] md:pb-0">
    <DevServiceWorkerReset />
    {/* Glowing Orbs Background */}
    <div class="orb-blue"></div>
    <div class="orb-emerald"></div>

    <SiteHeader currentPath={Astro.url.pathname} />
    <main id="app-shell" class="relative z-10 min-h-screen">
      <slot />
    </main>
    <SiteFooter />
    <MobileNav currentPath={Astro.url.pathname} />
  </body>
</html>


