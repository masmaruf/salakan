---
import '../styles/global.css';

interface Props {
  title: string;
  activeMenu?: string;
  description?: string;
}

const { title, activeMenu = 'berkeluarga', description } = Astro.props;

const sidebarMenus = [
  {
    group: "Layanan Primer",
    menus: [
      { id: 'berkeluarga', label: 'E-Surat & Pengantar', icon: 'description', href: '/dasbor' },
      { id: 'kas', label: 'Transparansi Kas RT', icon: 'account_balance_wallet', href: '/dasbor/kas' },
      { id: 'inventaris', label: 'Peminjaman Inventaris', icon: 'inventory_2', href: '/dasbor/inventaris' },
    ]
  },
  {
    group: "Akun Warga",
    menus: [
      { id: 'profil', label: 'Data Keluarga (KK)', icon: 'family_home', href: '/dasbor/profil' },
      { id: 'pengaturan', label: 'Pengaturan Notifikasi', icon: 'settings', href: '/dasbor/pengaturan' },
    ]
  }
];
---

<!doctype html>
<html lang="id" class="bg-slate-50 text-slate-900 antialiased h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Portal Layanan Digital Salakan</title>
    {description && <meta name="description" content={description} />}
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="flex min-h-screen overflow-hidden">
    
    {/* Sidebar Section */}
    <aside class="w-72 shrink-0 border-r border-slate-200 bg-white flex flex-col pt-6 z-20 shadow-[4px_0_24px_rgba(15,23,42,0.02)] hidden lg:flex">
      <div class="px-6 pb-6 border-b border-slate-100">
         <a href="/" class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-lg bg-blue-700 font-['Roboto'] font-extrabold text-white text-sm shadow-md">
              PS
            </span>
            <div>
               <h2 class="font-bold text-[0.95rem] tracking-tight leading-tight text-slate-900">E-Kependudukan</h2>
               <p class="text-[0.65rem] font-bold text-slate-500 uppercase tracking-widest mt-0.5">Padukuhan Salakan</p>
            </div>
         </a>
      </div>

      <div class="flex-1 overflow-y-auto px-4 py-6 space-y-8">
         {sidebarMenus.map((group) => (
            <div>
               <h3 class="px-2 text-[0.68rem] font-bold text-slate-400 uppercase tracking-wider mb-2">{group.group}</h3>
               <nav class="space-y-1">
                  {group.menus.map(menu => {
                     const isActive = activeMenu === menu.id;
                     return (
                        <a 
                          href={menu.href} 
                          class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 ${isActive ? 'bg-blue-50 text-blue-700 font-semibold' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'}`}
                        >
                           <span class={`material-symbols-outlined text-[20px] ${isActive ? 'text-blue-600' : 'text-slate-400'}`}>{menu.icon}</span>
                           {menu.label}
                        </a>
                     )
                  })}
               </nav>
            </div>
         ))}
      </div>

      <div class="p-4 border-t border-slate-100 bg-slate-50/50">
         <div class="flex items-center gap-3 rounded-xl bg-white p-3 border border-slate-200 shadow-sm">
            <div class="h-9 w-9 bg-emerald-100 text-emerald-700 rounded-full flex items-center justify-center font-bold text-sm">
               BW
            </div>
            <div class="flex-1 min-w-0">
               <p class="text-sm font-bold text-slate-900 truncate">Bapak Warga</p>
               <p class="text-[0.65rem] text-slate-500 truncate mt-0.5">Ketua RT 02</p>
            </div>
         </div>
         <a href="/" class="mt-3 flex items-center justify-center gap-2 text-xs font-semibold text-red-600 border border-red-200 bg-red-50 hover:bg-red-100 rounded-lg py-2.5 transition-colors">
            <span class="material-symbols-outlined text-[16px]">logout</span> Keluarkan Sesi
         </a>
      </div>
    </aside>

    {/* Main Content Content */}
    <main class="flex-1 flex flex-col h-screen overflow-hidden bg-[#f8f9fc]">
      <header class="h-16 border-b border-slate-200 bg-white flex items-center justify-between px-6 lg:px-8 shrink-0 z-10 sticky top-0 shadow-sm">
         <div class="flex items-center gap-4">
            <button class="lg:hidden text-slate-500 hover:text-slate-900">
               <span class="material-symbols-outlined">menu</span>
            </button>
            <h1 class="text-lg font-bold text-slate-900 hidden sm:block">{title}</h1>
         </div>
         <div class="flex items-center gap-4">
            <button class="relative rounded-full h-9 w-9 flex items-center justify-center text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-colors">
               <span class="material-symbols-outlined text-[20px]">notifications</span>
               <span class="absolute top-2 right-2 h-2 w-2 rounded-full bg-red-500 ring-2 ring-white"></span>
            </button>
            <a href="/" class="text-[0.75rem] font-bold text-blue-600 border border-blue-200 bg-blue-50 px-3 py-1.5 rounded-full hover:bg-blue-100">
               Ke Portal Publik
            </a>
         </div>
      </header>

      <div class="flex-1 overflow-auto">
         <div class="p-6 lg:p-8 max-w-5xl mx-auto space-y-6">
            <slot />
         </div>
      </div>
    </main>
    
  </body>
</html>
