---
import '../styles/global.css';

interface Props {
  title: string;
  activeMenu?: string;
  description?: string;
}

const { title, activeMenu = 'berkeluarga', description } = Astro.props;

const sidebarMenus = [
  {
    group: "Layanan Primer",
    menus: [
      { id: 'berkeluarga', label: 'E-Surat & Pengantar', icon: 'description', href: '/dasbor' },
      { id: 'kas', label: 'Transparansi Kas RT', icon: 'account_balance_wallet', href: '/dasbor/kas' },
      { id: 'inventaris', label: 'Peminjaman Inventaris', icon: 'inventory_2', href: '/dasbor/inventaris' },
    ]
  },
  {
    group: "Akun Warga",
    menus: [
      { id: 'profil', label: 'Data Keluarga (KK)', icon: 'family_home', href: '/dasbor/profil' },
      { id: 'pengaturan', label: 'Pengaturan Notifikasi', icon: 'settings', href: '/dasbor/pengaturan' },
    ]
  }
];

// Deteksi Admin
import { getAdminSession, getSessionCookieName } from '../lib/admin-auth';
const isAdmin = !!getAdminSession(Astro.cookies.get(getSessionCookieName())?.value);
if (isAdmin) {
  sidebarMenus.push({
    group: "Admin Padukuhan",
    menus: [
      { id: 'admin-surat', label: 'Kelola Pengajuan', icon: 'admin_panel_settings', href: '/admin/surat' },
      { id: 'admin-users', label: 'Manajemen User', icon: 'group_add', href: '/admin/users' },
    ]
  });
}
---

<!doctype html>
<html lang="id" class="bg-slate-50 text-slate-900 antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Portal Layanan Digital Salakan</title>
    {description && <meta name="description" content={description} />}
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 relative overflow-x-clip lg:flex-row">
    
    {/* Glowing Orbs Background */}
    <div class="orb-blue"></div>
    <div class="orb-emerald"></div>

    {/* Sidebar Section */}
    <aside class="relative hidden w-72 shrink-0 bg-white/70 pt-8 shadow-[0_4px_30px_rgba(0,0,0,0.03)] backdrop-blur-3xl z-30 lg:sticky lg:top-0 lg:flex lg:h-screen lg:flex-col lg:self-start">
      <div class="px-8 pb-8">
         <a href="/" class="flex items-center gap-4 group">
            <span class="grid h-11 w-11 place-items-center rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-700 font-bold text-white text-base shadow-[0_8px_20px_rgba(37,99,235,0.3)] group-hover:scale-105 transition-transform">
              PS
            </span>
            <div class="space-y-0.5">
               <h2 class="font-extrabold text-[1rem] tracking-tight leading-tight text-slate-900 group-hover:text-blue-700 transition-colors">E-Mandiri</h2>
               <p class="text-[0.62rem] font-bold text-slate-400 uppercase tracking-[0.1em]">Layanan Warga</p>
            </div>
         </a>
      </div>

      <div class="flex-1 overflow-y-auto px-5 py-2 space-y-9">
         {sidebarMenus.map((group) => (
            <div>
               <h3 class="px-4 text-label mb-4">{group.group}</h3>
               <nav class="space-y-1.5 text-center">
                  {group.menus.map(menu => {
                     const isActive = activeMenu === menu.id;
                     return (
                        <a 
                          href={menu.href} 
                          class={`flex items-center gap-3.5 px-4 py-3 rounded-2xl text-[0.9rem] font-bold transition-all duration-300 group ${isActive ? 'bg-blue-600 text-white shadow-[0_10px_25px_rgba(37,99,235,0.25)] scale-[1.02]' : 'text-slate-500 hover:bg-blue-50 hover:text-blue-700 hover:translate-x-1'}`}
                        >
                           <span class={`material-symbols-outlined text-[22px] transition-colors ${isActive ? 'text-white' : 'text-slate-400 group-hover:text-blue-500'}`}>{menu.icon}</span>
                           {menu.label}
                        </a>
                     )
                   })}
               </nav>
            </div>
         ))}
      </div>

      <div class="p-5 mt-auto">
         <div class="flex items-center gap-3 rounded-3xl bg-white/80 backdrop-blur-xl p-4 shadow-sm border border-white/50">
            <div class="h-10 w-10 bg-indigo-100 text-indigo-700 rounded-2xl flex items-center justify-center font-bold text-base shadow-inner">
               BW
            </div>
            <div class="flex-1 min-w-0">
               <p class="text-[0.85rem] font-extrabold text-slate-900 truncate">Sandi Warga</p>
               <p class="text-[0.68rem] font-bold text-slate-400 truncate mt-0.5">Penduduk Salakan</p>
            </div>
         </div>
         <a href="/admin/logout" class="mt-4 flex items-center justify-center gap-2 text-xs font-bold text-red-500 bg-red-50/50 hover:bg-red-100/50 border border-red-100/30 rounded-2xl py-3.5 transition-all hover:shadow-sm">
            <span class="material-symbols-outlined text-[18px]">logout</span> Keluar Sesi
         </a>
      </div>
    </aside>

    {/* Main Content Area */}
    <main class="relative z-10 flex min-h-screen flex-1 flex-col">
      <header class="sticky top-0 z-20 flex h-20 shrink-0 items-center justify-between border-b border-white/40 bg-white/40 px-6 backdrop-blur-2xl transition-all lg:px-10">
         <div class="flex items-center gap-5">
            <button class="lg:hidden h-10 w-10 flex items-center justify-center rounded-xl bg-white shadow-sm text-slate-600 hover:text-blue-600">
               <span class="material-symbols-outlined">menu</span>
            </button>
            <h1 class="text-xl font-extrabold tracking-tight text-slate-900 hidden sm:block text-gradient">{title}</h1>
         </div>
         <div class="flex items-center gap-5">
            <button class="relative h-11 w-11 flex items-center justify-center rounded-2xl bg-white text-slate-400 hover:bg-blue-50 hover:text-blue-600 transition-all shadow-sm group">
               <span class="material-symbols-outlined text-[24px]">notifications</span>
               <span class="absolute top-3 right-3 h-2.5 w-2.5 rounded-full bg-red-500 ring-4 ring-white group-hover:scale-110 transition-transform"></span>
            </button>
            <a href="/" class="hidden sm:flex items-center gap-2 text-[0.72rem] font-black uppercase tracking-[0.1em] text-blue-700 bg-blue-50 px-5 py-2.5 rounded-full hover:bg-blue-600 hover:text-white transition-all shadow-sm">
               <span class="material-symbols-outlined text-[16px]">public</span> Kembali Ke Portal Utama
            </a>
         </div>
      </header>

      <div class="flex-1 bg-transparent">
         <div class="p-8 lg:p-12 max-w-6xl mx-auto">
            <slot />
         </div>
      </div>
    </main>
    
  </body>
</html>
